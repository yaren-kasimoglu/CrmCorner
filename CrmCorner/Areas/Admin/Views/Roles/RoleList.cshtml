@model List<AdminModel.RoleVM>
@{
    ViewData["Title"] = "RoleList";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutHomePageArea.cshtml";
}




<div class="row">
    <div class="col-md-6 offset-md-2">
        <h2>Roller</h2>
    </div>
    <div class="col-md-2 offset-md-1">
        <a class="btn btn-outline-primary" asp-controller="Roles" asp-action="RoleCreate" asp-area="Admin">Role Ekle</a>
    </div>

</div>
<div class="row">

    <div class="col-md-8 offset-md-2">
        <table id="role_List" class="table center-aligned-table">
            <thead>
                <tr>
                    <th>Rol Id</th>
                    <th>Rol Adı</th>
                    <th>İşlemler</th>
                </tr>

            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>
                            <a asp-area="admin" asp-controller="Roles" asp-action="RoleUpdate" asp-route-id="@item.Id" target="_self">
                                <button type="button" class="btn btn-sm btn-outline-secondary">
                                    <i class="fa fa-edit"></i>
                                </button>
                            </a>

                            <a asp-area="admin" asp-controller="Roles" asp-action="RoleDelete" asp-route-id="@item.Id" target="_self">
                                <button type="button" class="btn btn-sm btn-outline-secondary">
                                    <i class="fa fa-trash-o"></i>
                                </button>
                            </a>
                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>
</div>




<!-- core js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>

<!-- page js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/datatables.bundle.js"></script>

<script>
    $(document).ready(function () {
        $('#role_List')
            .dataTable({
                responsive: true,
                columnDefs: [
                    {
                        orderable: false,
                        targets: [0]
                    }
                ]
            });
    });
</script>
