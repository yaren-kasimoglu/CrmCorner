@model CrmCorner.Areas.Admin.Models.AssignRoleToUserVM
@{
    ViewData["Title"] = "AssignRoleToUserVM";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutHomePageArea.cshtml";
}

<h2>Assign Role to User</h2>

@foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
{
    <div class="alert alert-danger">@error.ErrorMessage</div>
}

<form asp-action="AssignRoleToUserVM" method="post">
    <div class="form-group">
    <label asp-for="UserId" class="control-label">Select User</label>
    <select asp-for="UserId" class="form-control" asp-items="Model.Users">
        <option value="">-- Select User --</option>
    </select>
    <span asp-validation-for="UserId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="RoleId" class="control-label">Select Role</label>
        <select asp-for="RoleId" class="form-control" asp-items="Model.Roles">
            <option value="">-- Select Role --</option>
        </select>
        <span asp-validation-for="RoleId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <button type="submit" class="btn btn-primary">Assign Role</button>
    </div>
</form>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<!-- core js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>

<!-- page js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>