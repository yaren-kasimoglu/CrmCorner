    <style>
        .logo-container {
            max-width: 100px; /* Maksimum genişlik */
            max-height: 50px; /* Maksimum yükseklik */
            display: flex;
            justify-content: center; /* Merkeze hizalama */
            align-items: center; /* Dikey hizalama */
        }

            .logo-container img {
                width: 100%;
                height: auto;
                object-fit: contain; /* Oranı koruma */
            }

        .green-light {
            box-shadow: 0 0 5px 2px #2eacb3; /* Yeşil bir gölge ekler */
            border: 1px solid #2eacb3; /* Yeşil bir kenarlık ekler */
        }

        .pink-light {
            box-shadow: 0 0 5px 2px white; /* Yeşil bir gölge ekler */
            border: 1px solid white; /* Yeşil bir kenarlık ekler */
        }

        .notification-count {
            position: absolute;
            bottom: -5px;
            right: 0;
            color: red;
            font-size: 12px;
            font-weight: bold;
        }

        #messageDropdown {
            display: none;
            position: absolute;
            top: 100%;
            right: 0;
            background-color: white;
            box-shadow: 0 8px 16px rgba(0,0,0,0.2);
            z-index: 1;
            list-style: none;
            padding: 0;
            margin: 0;
            width: 200px; /* Genişlik ayarlanabilir */
        }

            #messageDropdown li {
                padding: 8px 16px;
                border-bottom: 1px solid #ddd;
            }

                #messageDropdown li:hover {
                    background-color: #f1f1f1;
                }


        .always-open > ul {
            display: block !important;
        }

        .always-open > a {
            cursor: default;
            pointer-events: none; /* Tıklanabilirliği tamamen kaldırır */
        }
    </style>
    <link rel="icon" href="~/CRMTema/favicon.ico" type="image/x-icon">
