    @RenderSection("Scripts", required: false)
    <script>
        let unreadMessagesHtml = '';
        function toggleDropdown(event) {
            event.stopPropagation();
            $('#messageDropdown').toggle();

        }

        function hideDropdown() {
            $('#messageDropdown').hide();
        }


        $(document).ready(function () {

            // Her 2 saniyede bir bildirim durumunu kontrol etmek için bir fonksiyon tanımlayalım
            setInterval(function () {
                $.get('/Home/GetNotificationsStatus', function (data) {
                    var hasUnreadMessages = data.message.hasUnreadMessages;
                    var unreadSenderCount = data.message.distinctSenderIdsCount;
                    console.log(data.message.unreadMessages);
                    if (hasUnreadMessages) {

                        // Bildirim varsa yapılacak işlemler
                        // Örneğin, bir div'in arka plan rengini yeşil yapabiliriz
                        showNotificationDot();
                        $('#notificationCount').text(unreadSenderCount);
                        //var unreadMessagesHtml = '';
                        //data.message.unreadMessages.forEach(function (message) {
                        //    unreadMessagesHtml += '<li>' + message.senderId + '</li>';
                        //});
                        console.log("buraya girdi");
                        let newUnreadMessagesHtml = '';
                        data.message.unreadMessages.forEach(function (message) {
                            newUnreadMessagesHtml += `<li><a href="javascript:void(0);" onclick="redirectToUserMessages('${message.senderId}')">${message.senderName}</a></li>`;
                        });
                        if (newUnreadMessagesHtml !== unreadMessagesHtml) {
                            unreadMessagesHtml = newUnreadMessagesHtml;
                            $('#messageDropdown').html(unreadMessagesHtml);
                        }
                    } else {
                        // Bildirim yoksa yapılacak işlemler
                        // Örneğin, bir div'in arka plan rengini varsayılan hale getirebiliriz
                        hideNotificationDot();
                    }
                });
            }, 1000); // 2 saniyede bir çağıralım
        });
        function redirectToUserMessages(userId) {
            window.location.href = '/ChatApp/ChatApp';
        }
        document.addEventListener('DOMContentLoaded', function () {
            var messageIconElement = document.getElementById("messageIcon");
            messageIconElement.classList.add("pink-light");
        });

        function showNotificationDot() {
            var messageIconElement = document.getElementById("messageIcon");
            messageIconElement.classList.remove("pink-light"); // Eğer varsa pink-light sınıfını kaldır
            messageIconElement.classList.add("green-light"); // green-light sınıfını ekle

        }

        function hideNotificationDot() {
            var messageIconElement = document.getElementById("messageIcon");
            messageIconElement.classList.remove("green-light"); // Eğer varsa green-light sınıfını kaldır
            messageIconElement.classList.add("pink-light"); // pink-light sınıfını ekle

        }</script>




    <script src="~/CRMTema/bootstrap5/js/pages/index.js"></script>

</body>
