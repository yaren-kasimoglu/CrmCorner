@model List<Company>
@{
    ViewData["Title"] = "CompanyList";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutHomePageArea.cshtml";
}

<table class="table table-hover" id="company_List">
    <thead>
        <tr>
            <th scope="col">Firma Adı</th>
            <th scope="col">Domain</th>
            <th scope="col">Onay Durumu</th>
            <th scope="col">İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CompanyName</td>
                <td>@item.EmailDomain</td>
                <td>@(item.IsApproved.HasValue && item.IsApproved.Value ? "Onaylı" : "Onaysız")</td>
                <td>
                    @if (!item.IsApproved.HasValue || !item.IsApproved.Value)
                    {
                        <form method="post" asp-action="ApproveCompany" asp-controller="Company">
                            <input type="hidden" name="id" value="@item.CompanyId" />
                            <button type="submit" class="btn btn-sm btn-success">Onayla</button>
                        </form>
                        <form method="post" asp-action="RejectCompany" asp-controller="Company">
                            <input type="hidden" name="id" value="@item.CompanyId" />
                            <button type="submit" class="btn btn-sm btn-danger">Reddet</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
<!-- core js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>

<!-- page js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>


<script src="~/CRMTema/bootstrap5/dist/assets/bundles/datatables.bundle.js"></script>

<script>
    function confirmDelete(button) {
        // Kullanıcıya silme işlemini onaylamasını sor
        if (confirm('Are you sure you want to dele te this company?')) {
            var companyid = button.getAttribute('data-companyid');
            var form = document.createElement('form');
            form.action = '/Company/CompanyDelete/' + companyid;
            form.method = 'post';
            document.body.appendChild(form);
            form.submit();
        }
    }
</script>

<script>
    $(document).ready(function () {
        $('#company_List')
            .dataTable({
                responsive: true,
                columnDefs: [
                    {
                        orderable: false,
                        targets: [0]
                    }
                ]
            });
    });
</script>