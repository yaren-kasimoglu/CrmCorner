@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = "İletişim";
}

<section class="py-5">
    <div class="container py-5">
        <div class="text-center mb-5">
            <h1 class="page-title">İletişim</h1>
            <p class="page-text mx-auto" style="max-width:700px;">
                CRM Corner ile ilgili her türlü soru, destek ve iş birliği talepleriniz için bizimle iletişime geçebilirsiniz.
            </p>
        </div>

        <div class="row g-4">

            <!-- Şirket Bilgileri -->
            <div class="col-md-4">
                <div class="info-card">
                    <h5 class="fw-bold">Şirket Ünvanı</h5>
                    <p class="page-text mb-0">
                        SAAS CORNER DANIŞMANLIK VE EĞİTİM HİZMETLERİ SANAYİ TİCARET
                        LİMİTED ŞİRKETİ
                    </p>
                </div>
            </div>


            <!-- Telefon -->
            <div class="col-md-4">
                <div class="info-card">
                    <h5 class="fw-bold">Telefon</h5>
                    <p class="page-text mb-0">+90 530 027 81 33</p>
                </div>
            </div>

            <!-- E-posta -->
            <div class="col-md-4">
                <div class="info-card">
                    <h5 class="fw-bold">E-posta</h5>
                    <p class="page-text mb-0">info@saascorner.co</p>
                </div>
            </div>


            <!-- Adres -->
            <div class="col-md-4">
                <div class="info-card">
                    <h5 class="fw-bold">Adres</h5>
                    <p class="page-text mb-0">
                        Ayazağa Mah. Kemerburgaz Cad. Vadistanbul Park<br />
                        Sarıyer / İstanbul / Türkiye
                    </p>
                </div>
            </div>

        </div>
    </div>
</section>