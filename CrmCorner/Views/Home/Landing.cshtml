@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = "CRM Corner";
}

<section class="hero-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="hero-badge">
                    <i class="fa-solid fa-layer-group"></i>
                    Tek platform, çoklu modül deneyimi
                </div>

                <h1 class="hero-title">
                    Satış süreçlerini ve sosyal medya operasyonlarını tek merkezden yönetin.
                </h1>

                <p class="hero-text">
                    CRM Corner; CRM yönetimi, sosyal medya operasyonları, kişisel markalaşma ve gelişebilir modül yapısıyla
                    ekiplerinizi tek bir çalışma alanında buluşturur.
                </p>

                <div class="d-flex flex-wrap gap-3 mt-4">
                    <a href="#modules" class="btn btn-main">Ürünleri İncele</a>
                    <a href="/Home/SignIn" class="btn btn-light-custom">Giriş Yap</a>
                </div>

                <div class="row g-3 mt-4">
                    <div class="col-md-4">
                        <div class="stats-card">
                            <div class="stats-number">2+</div>
                            <div class="stats-label">Ana modül</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stats-card">
                            <div class="stats-number">Role-based</div>
                            <div class="stats-label">Erişim yapısı</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stats-card">
                            <div class="stats-number">Company-based</div>
                            <div class="stats-label">Veri görünümü</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="dashboard-card">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h5 class="mb-1 fw-bold">Social Media Dashboard</h5>
                            <small class="text-muted">Company based overview</small>
                        </div>
                        <span class="badge rounded-pill text-bg-light px-3 py-2">Live</span>
                    </div>

                    <div class="row g-3">
                        <div class="col-6">
                            <div class="mini-stat" style="background: var(--warning-soft);">
                                <small class="text-muted">Onay Bekleyen</small>
                                <div class="stats-number mt-2">30</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="mini-stat" style="background: var(--success-soft);">
                                <small class="text-muted">Onaylanan</small>
                                <div class="stats-number mt-2">43</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="mini-stat" style="background: var(--blue-soft);">
                                <small class="text-muted">Bu Hafta</small>
                                <div class="stats-number mt-2">12</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="mini-stat" style="background: #fef2f2;">
                                <small class="text-muted">Revize</small>
                                <div class="stats-number mt-2">4</div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mt-2">
                        <div class="col-md-6">
                            <div class="stats-card h-100">
                                <h6 class="fw-bold mb-2">CRM Workspace</h6>
                                <p class="mb-0 text-muted">
                                    Müşteri yönetimi, pipeline ve görev akışı için tasarlanmış düzenli çalışma alanı.
                                </p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="stats-card h-100">
                                <h6 class="fw-bold mb-2">Personal Branding</h6>
                                <p class="mb-0 text-muted">
                                    Kişisel içerik planlama, onay ve yayın süreçlerini aynı dashboard içinde takip edin.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mt-4">
            <div class="col-md-4">
                <div class="stats-card">
                    <div class="stats-number">2+</div>
                    <div class="stats-label">Ana modül</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stats-card">
                    <div class="stats-number">Role-based</div>
                    <div class="stats-label">Erişim yapısı</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stats-card">
                    <div class="stats-number">Company-based</div>
                    <div class="stats-label">Veri görünümü</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="modules" class="section-space">
    <div class="container">
        <div class="mb-5">
            <div class="text-uppercase fw-bold mb-2" style="color:var(--primary); letter-spacing:2px; font-size:13px;">Ürün Modülleri</div>
            <h2 class="section-title">İhtiyacın olan çalışma alanlarını tek platformda birleştir.</h2>
            <p class="section-text mt-3">
                CRM Corner, tek bir panel içinde farklı operasyon alanlarını yönetebilmen için modüler bir yapı sunar.
            </p>
        </div>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="module-card">
                    <span class="module-tag">Modül</span>
                    <h3>CRM Management</h3>
                    <p>
                        Müşteri takibi, pipeline yönetimi, görev planlama ve ekip koordinasyonunu tek panelden yönetin.
                    </p>

                    <div class="mt-4">
                        <span class="pill">Pipeline Takibi</span>
                        <span class="pill">Müşteri Yönetimi</span>
                        <span class="pill">Görev Kontrolü</span>
                        <span class="pill">Raporlama</span>
                    </div>

                    <a href="/Home/SignIn" class="btn btn-main mt-4">CRM'i Keşfet</a>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="module-card">
                    <span class="module-tag">Modül</span>
                    <h3>Social Media Management</h3>
                    <p>
                        İçerik planlama, onay akışları, yayın takvimi ve kişisel markalaşma süreçlerini kolaylaştırın.
                    </p>

                    <div class="mt-4">
                        <span class="pill">İçerik Planlama</span>
                        <span class="pill">Onay Süreci</span>
                        <span class="pill">Takvim Yönetimi</span>
                        <span class="pill">Personal Branding</span>
                    </div>

                    <a href="/Home/SignIn" class="btn btn-main mt-4">Social Media'yı Keşfet</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="features" class="section-space soft-section">
    <div class="container">
        <div class="mb-5">
            <div class="text-uppercase fw-bold mb-2" style="color:var(--primary); letter-spacing:2px; font-size:13px;">Öne Çıkan Özellikler</div>
            <h2 class="section-title">Büyüyen ekipler için düzenli, güvenli ve esnek altyapı.</h2>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-xl-4">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#fff4d6; color:#ffb71b;">
                        <i class="fa-solid fa-cubes"></i>
                    </div>
                    <h5 class="fw-bold">Çoklu Modül Yapısı</h5>
                    <p class="text-muted mb-0">Kullanıcılar ihtiyaç duydukları modülleri aynı platform içinde görüntüleyebilir.</p>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#eff6ff; color:#2563eb;">
                        <i class="fa-solid fa-user-shield"></i>
                    </div>
                    <h5 class="fw-bold">Rol ve Yetki Yönetimi</h5>
                    <p class="text-muted mb-0">Her kullanıcıya şirketine ve yetkisine göre doğru ekranları gösterin.</p>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#ecfdf3; color:#16a34a;">
                        <i class="fa-solid fa-chart-line"></i>
                    </div>
                    <h5 class="fw-bold">Dashboard Deneyimi</h5>
                    <p class="text-muted mb-0">Şirket bazlı verileri, içerik özetlerini ve satış görünümünü tek bakışta takip edin.</p>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#fff7ed; color:#d97706;">
                        <i class="fa-solid fa-calendar-days"></i>
                    </div>
                    <h5 class="fw-bold">Takvim ve Planlama</h5>
                    <p class="text-muted mb-0">Sosyal medya içerikleri ve operasyonel süreçler için düzenli çalışma alanı oluşturun.</p>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#fef2f2; color:#dc2626;">
                        <i class="fa-solid fa-building"></i>
                    </div>
                    <h5 class="fw-bold">Şirket Bazlı Görünüm</h5>
                    <p class="text-muted mb-0">Her kullanıcı yalnızca kendi şirketine ait verileri görsün, adminler toplam tabloyu izlesin.</p>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#fff4d6; color:#ffb71b;">
                        <i class="fa-solid fa-wand-magic-sparkles"></i>
                    </div>
                    <h5 class="fw-bold">Geliştirilebilir Altyapı</h5>
                    <p class="text-muted mb-0">Finance, automation ve yeni modüller için genişleyebilen bir yapı sunar.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="preview" class="section-space">
    <div class="container">
        <div class="mb-5">
            <div class="text-uppercase fw-bold mb-2" style="color:var(--primary); letter-spacing:2px; font-size:13px;">Ekran Deneyimi</div>
            <h2 class="section-title">Her modül kendi iş akışına göre tasarlanır.</h2>
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="preview-card">
                    <div class="preview-image"></div>
                    <h5 class="fw-bold mt-4">CRM Workspace</h5>
                    <p class="text-muted mb-0">
                        Satış süreçlerini, müşteri listesini ve pipeline akışını yönetmek için tasarlandı.
                    </p>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="preview-card">
                    <div class="preview-image"></div>
                    <h5 class="fw-bold mt-4">Social Media Dashboard</h5>
                    <p class="text-muted mb-0">
                        İçerik sayıları, onay süreçleri, yaklaşan paylaşımlar ve kişisel markalaşma kartlarıyla modern bir görünüm sunar.
                    </p>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="preview-card">
                    <div class="preview-image"></div>
                    <h5 class="fw-bold mt-4">Şirket Bazlı Yönetim</h5>
                    <p class="text-muted mb-0">
                        Her modülde kullanıcı bazlı filtreleme ve role özel erişim ile güvenli kullanım sağlar.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="pb-5">
    <div class="container">
        <div class="cta-box">
            <div class="row align-items-center g-4">
                <div class="col-lg-8">
                    <div class="text-uppercase fw-bold mb-2" style="color:#ffd76a; letter-spacing:2px; font-size:13px;">CRM Corner</div>
                    <h2 class="fw-bold" style="font-size:38px;">
                        İş süreçlerini tek platformda toparlamaya hazır mısın?
                    </h2>
                    <p class="mt-3 mb-0 text-white-50" style="line-height:1.8;">
                        Modüllerini seç, ekibini yönet ve şirket bazlı görünüm ile operasyonlarını daha düzenli hale getir.
                    </p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <a href="/Home/SignIn" class="btn btn-main me-2 mb-2">Giriş Yap</a>
                    <a href="#modules" class="btn btn-light-custom mb-2">Ürünleri İncele</a>
                </div>
            </div>
        </div>
    </div>
</section>