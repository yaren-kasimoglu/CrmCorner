@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = "Hakkımızda";
}

<section class="py-5">
    <div class="container py-5">
        <div class="text-center mb-5">
            <span class="page-hero-badge">
                <i class="fa-solid fa-building"></i>
                CRM Corner Hakkında
            </span>

            <h1 class="page-title">Satış ve operasyon süreçlerini tek merkezden yönetin</h1>

            <p class="page-text mx-auto" style="max-width: 820px;">
                CRM Corner; satış süreçleri, müşteri yönetimi, ekip koordinasyonu ve sosyal medya operasyonlarını
                tek bir platform üzerinden yönetmeyi amaçlayan modern ve modüler bir iş yönetim çözümüdür.
            </p>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="info-card">
                    <h3 class="fw-bold mb-3" style="color:#14274a;">Ne sunuyoruz?</h3>
                    <p class="page-text mb-0">
                        CRM Corner; müşteri takibi, pipeline yönetimi, görev süreçleri, raporlama ve sosyal medya operasyonlarını
                        tek bir çalışma alanında bir araya getirir. Farklı ekiplerin dağınık araçlar yerine tek sistemde
                        çalışmasını kolaylaştırır.
                    </p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="info-card">
                    <h3 class="fw-bold mb-3" style="color:#14274a;">Hedefimiz</h3>
                    <p class="page-text mb-0">
                        Amacımız, işletmelerin süreçlerini daha düzenli, izlenebilir ve verimli hale getirmek;
                        aynı zamanda gelişebilir modüler altyapı ile uzun vadeli bir dijital çalışma alanı sunmaktır.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="info-card">
                    <h5 class="fw-bold mb-2" style="color:#14274a;">Modüler yapı</h5>
                    <p class="page-text mb-0">İhtiyaca göre geliştirilebilir ve büyütülebilir sistem altyapısı.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="info-card">
                    <h5 class="fw-bold mb-2" style="color:#14274a;">Tek merkezden yönetim</h5>
                    <p class="page-text mb-0">Satış, müşteri ve içerik operasyonlarını tek panelde toplar.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="info-card">
                    <h5 class="fw-bold mb-2" style="color:#14274a;">Ekip uyumu</h5>
                    <p class="page-text mb-0">Rol bazlı yapı ile ekiplerin doğru ekranlara güvenli erişimini destekler.</p>
                </div>
            </div>
        </div>

        <div class="text-center mt-5">
            <a href="/Home/Landing" class="btn btn-light-custom me-2">Ana Sayfa</a>
            <a href="/Home/Privacy" class="btn btn-main">Gizlilik Politikası</a>
        </div>
    </div>
</section>