<script type="text/javascript">
    $(document).ready(function () {
        $.ajax({
            type: "GET",
            url: "/Home/UserTaskStatusChart",
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (data) {
            //    console.log(data); // Gelen veriyi kontrol etmek için bu satırı ekleyin
                var ctx = document.getElementById('userTaskStatusChart').getContext('2d');
                //var colors = ['#2eacb3', '#FED049', '#2D6187', '#89BEB3', '#FF9A76', '#8bc3fe'];
                var colors = [
                    '#d0e9f5', // En açık mavi
                    '#a0c4e3', // Açık mavi
                    '#6baed6', // Orta mavi
                    '#3182bd'  // Koyu mavi
                ];


                // Gelen veri yapısına göre haritalama yapalım
                var labels = data.map(item => item.statusName);
                var dataValues = data.map(item => item.count);
                var taskNames = data.map(item => item.taskNames);

                new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: dataValues,
                            backgroundColor: colors,
                            borderWidth: 1
                        }]
                    },
                    options: {
                        layout: {
                            padding: {
                                top: 10, // Grafiğin üstündeki boşluğu ayarlayın
                                bottom: 0
                            }
                        },
                        plugins: {
                            legend: {
                                position: 'right',
                                align: 'center',
                                labels: {
                                    boxWidth: 20,
                                    padding: 8,
                                    font: {
                                        size: 11, // Yazı boyutunu 12px olarak ayarladım
                                        family: "'Helvetica Neue', 'Helvetica', 'Arial', sans-serif",
                                        style: 'normal'
                                    }
                                }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function (context) {
                                        var index = context.dataIndex;
                                        var count = dataValues[index];
                                        var tasks = taskNames[index];
                                        var label = labels[index] + ': ' + count;
                                        var lines = [label].concat(tasks); // Görev isimlerini ekle
                                        return lines;
                                    }
                                }
                            },
                            datalabels: {
                                color: 'rgba(0, 0, 0, 0.6)',
                                formatter: function (value, context) {
                                    var total = context.dataset.data.reduce((acc, val) => acc + val, 0);
                                    var percentage = ((value / total) * 100).toFixed(2);
                                    return percentage > 0 ? percentage + '%' : '';
                                },
                                font: {
                                    weight: 'bold',
                                    size: 8// Yazı boyutunu küçük tut
                                },
                                anchor: 'center', // Konumu merkezde gösterir
                                align: 'center',  // Yazıları merkezde hizalar
                                offset: 10 // Sağ tarafa doğru kaydırma
                            }

                        }
                    },
                    plugins: [ChartDataLabels]
                });

            },
            error: function (error) {
                console.error('Error fetching data:', error);
            }
        });
    });

