            <div class="card top_counter">
                <div class="list-group list-group-custom list-group-flush">
                    <div class="list-group-item d-flex align-items-center py-3">
                        <div class="icon text-center me-3"><a class="nav-link text-dark" asp-area="" asp-controller="Employee" asp-action="EmployeeList"><i class="fa fa-user"></i> </a></div>
                        <div class="content">
                            <div>Çalışan Sayımız</div>
                            <h5 class="mb-0">@Model.CompanyUsers.Count</h5>
                        </div>
                    </div>
                    <div class="list-group-item d-flex align-items-center py-3">
                        <div class="icon text-center me-3"><a class="nav-link text-dark" asp-area="" asp-controller="Customer" asp-action="CustomerList"><i class="fa fa-users"></i></a> </div>
                        <div class="content">
                            <div>Müşterilerim</div>
                            <h5 class="mb-0">@Model.CurrentUser.Customers.Count</h5>
                        </div>
                    </div>
                    <div class="list-group-item d-flex align-items-center py-3">
                        <div class="icon text-center me-3"><a class="nav-link text-dark" asp-area="" asp-controller="Task" asp-action="Index"><i class="fa fa-users"></i></a> </div>
                        <div class="content">
                            <div>Sahip Olduğum Görev Sayısı</div>
                            <h5 class="mb-0">@Model.CurrentUser.TaskComps.Count</h5>
                        </div>
                    </div>
                    <div class="list-group-item d-flex align-items-center py-3">
                        <div class="icon text-center me-3"><i class="fa fa-briefcase"></i></div>
                        <div class="content">
                            <div>Sektör</div>
                            <h5 class="mb-0">@Model.SectorCount</h5>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="col-xl-8 col-lg-6 col-md-6 d-flex align-items-start">
        <div class="card">
            <div class="card-header">
                <h6 class="card-title">Yapılacaklar</h6>
                <small>Yaklaşan Yapılacaklar Listesi</small>
            </div>
            <div class="card-body todo_list">
                @if (ViewBag.ToDoList != null)
                {
                    var todoList = ViewBag.ToDoList as List<Tuple<string, string>>;

                    @for (int i = 0; i < Math.Min(5, todoList.Count); i++)
                    {
                        var task = todoList[i].Item1;
                        var url = todoList[i].Item2;

                        <div class="d-flex justify-content-between mb-3">
                            <div class="form-check">
                                <a href="@url" class="form-check-label" style="color: black;" id="@task"><i class="fa fa-calendar me-2"></i>@task</a>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>





