@model CompanyUsersViewModel

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}
<style>
    .chart-title {
        margin-bottom: 10px; /* Başlık ile grafiği ayırmak için alt boşluk ekler */
        font-size: 20px; /* Başlık font boyutunu ayarlar */
        /* Daha fazla stil özelleştirmesi yapabilirsiniz */
    }

    .custom-card {
        background-color: #fff; /* Gri tonunda bir arka plan rengi */
        border-radius: 3px; /* Hafif yuvarlak köşeler */
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075); /* Hafif bir gölge */
        margin-bottom: 30px;
    }



    /* Responsive grid ayarları */
    .row {
        display: flex;
        flex-wrap: wrap;
    }

    .col-xl-4, .col-lg-6, .col-md-6, .col-xl-8, .col-lg-12, .col-md-12 {
        padding: 15px; /* İç boşluk */
    }

    /* Küçük cihazlar için sütun boyutları */
    @@media (max-width: 768px) {
        .col-xl-4, .col-lg-6, .col-md-6, .col-xl-8, .col-lg-12, .col-md-12 {
            flex: 0 0 100%;
            max-width: 100%;
        }

        .custom-card, .card-body {
            width: 100% !important; /* !important kullanımı genelde kaçınılması gereken bir yöntemdir ama burada özel bir durum için kullanılmıştır. */
        }
    }
</style>

@if (!User.Identity!.IsAuthenticated)
{
    <div class="d-flex h100vh justify-content-center align-items-center">
        <div class="text-center">
            <article>
                <h1>Yakında yüklenecektir...</h1>
                <div>
                    <p>
                        Platformumuz henüz kullanıma hazır değildir. Eğer kullanıcı iseniz;
                    </p>
                    <p>&mdash; Crm Corner</p>
                </div>
            </article>
            <div class="margin-top-30">

                <a asp-action="SignIn" asp-controller="Home" class="btn btn-info"><i class="fa fa-home"></i> <span>Giriş Yapınız</span></a>
            </div>
        </div>
    </div>
}
else
{

    @* <a asp-action="Notifications" asp-controller="Home">Bildirimlerim</a>*@


    <div class="row">


        @if (Model.CurrentUser != null)
        {
            <div class="col-xl-4 col-lg-6 col-md-6">
                <div class="card top_counter">
                    <div class="list-group list-group-custom list-group-flush">
                        <div class="list-group-item d-flex align-items-center py-3">
                            <div class="icon text-center me-3"><a class="nav-link text-dark" asp-area="" asp-controller="Employee" asp-action="EmployeeList"><i class="fa fa-user"></i> </a></div>
                            <div class="content">
                                <div>Çalışan Sayımız</div>
                                <h5 class="mb-0">@Model.CompanyUsers.Count</h5>
                            </div>
                        </div>
                        <div class="list-group-item d-flex align-items-center py-3">
                            <div class="icon text-center me-3"><a class="nav-link text-dark" asp-area="" asp-controller="Customer" asp-action="CustomerList"><i class="fa fa-users"></i></a> </div>
                            <div class="content">
                                <div>Müşterilerim</div>
                                <h5 class="mb-0">@Model.CurrentUser.Customers.Count</h5>
                            </div>
                        </div>
                        <div class="list-group-item d-flex align-items-center py-3">
                            <div class="icon text-center me-3"><a class="nav-link text-dark" asp-area="" asp-controller="Task" asp-action="Index"><i class="fa fa-users"></i></a> </div>
                            <div class="content">
                                <div>Sahip Olduğum Görev Sayısı</div>
                                <h5 class="mb-0">@Model.CurrentUser.TaskComps.Count</h5>
                            </div>
                        </div>
                        <div class="list-group-item d-flex align-items-center py-3">
                            <div class="icon text-center me-3"><i class="fa fa-briefcase"></i></div>
                            <div class="content">
                                <div>Sektör</div>
                                <h5 class="mb-0">@Model.CurrentUser.Sector</h5>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }


        <div class="col-xl-8 col-lg-12 col-md-12">
            <div class="col-12">
                <div class="custom-card" style="width: 50%;">
                    <div class="chart-title">Görevlerim</div>
                    <div class="card-body">
                        <canvas id="userTaskStatusChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

    </div>


    <div class="custom-card">
        <div class="row g-2 clearfix row-deck">
            <div class="col-12">
                <div class="card-body text-center">
                    <div class="col-6">
                        <h6>Görevlerin Durumlarına Göre Dağılımları</h6>
                        <div style="width: 60%;">
                            <canvas id="outcomeStatusChart"></canvas>
                        </div>
                    </div>
                </div>

                <div class="card-body text-center">
                    <div class="col-6">
                        <h6>Son Karar Mercii İle Görüşme Durumları</h6>
                        <div style="width: 60%;">
                            <canvas id="isFinalDesicionMaker"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>



        <div class="col-6">
            <div class="chart-title">Müşterilerin sektörel dağılımları</div>
            <div class="custom-card" style="width: 60%;">
                <canvas id="industuryChart"></canvas>
            </div>
        </div>
 




}
<!-- core js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>

<!-- page js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>

<script src="~/CRMTema/bootstrap5/js/pages/widgets/chart-widgets.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script type="text/javascript">
    $(document).ready(function () {

        $.ajax({
            type: "GET",
            url: "/Home/UserTaskStatusChart",
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (data) {
                var ctx = document.getElementById('userTaskStatusChart').getContext('2d');
                var colors = ['#2eacb3', '#FED049', '#2D6187', '#89BEB3', '#FF9A76', '#8bc3fe'];
                new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: data.labels,
                        datasets: [{
                            data: data.data,
                            backgroundColor: colors,
                            borderWidth: 1
                        }]
                    },

                });
            },
            error: function (error) {
                console.error('Error fetching data:', error);
            }
        });

    });
    $(document).ready(function () {
        $.ajax({
            type: "GET",
            url: "/Home/OutcomeStatusChart",
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (data) {
                var ctx = document.getElementById('outcomeStatusChart').getContext('2d');
                var colors = ['#FED049', '#2D6187', '#89BEB3'];
                new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: data.labels,
                        datasets: [{
                            label: 'Görev Durumu',
                            data: data.data,
                            backgroundColor: colors,
                            borderWidth: 2,
                            barThickness: 30,
                        }]
                    },
                    //options: {
                    //    scales: {
                    //        yAxes: [{
                    //            ticks: {
                    //                beginAtZero: true
                    //            }
                    //        }]
                    //    }
                    //},
                });
            },
            error: function (error) {
                console.error('Error fetching data:', error);
            }
        });
    });

    $(document).ready(function () {
        $.ajax({
            type: "GET",
            url: "/Home/IsFinalDesicionMaker",
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (data) {
                var ctx = document.getElementById('isFinalDesicionMaker').getContext('2d');
                var colors = ['#2eacb3', '#FED049'];
                new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: data.labels,
                        datasets: [{
                            label: '',
                            data: data.data,
                            backgroundColor: colors,
                            borderWidth: 2,
                            barThickness: 30,
                        }]
                    },
                });
            },
            error: function (error) {
                console.error('Error fetching data:', error);
            }
        });
    });


</script>

<script>
    $(document).ready(function () {

        $.ajax({
            type: "GET",
            url: "/Home/IndustryChart",
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (data) {
                var ctx = document.getElementById('industuryChart').getContext('2d');
                // Dinamik olarak renk seçimi
                var colors = generateColors(data.labels.length);
                new Chart(ctx, {
                    type: 'pie',
                    data: {
                        labels: data.labels,
                        datasets: [{
                            data: data.data,
                            backgroundColor: colors,
                            borderWidth: 1
                        }]
                    },
                });
            },
            error: function (error) {
                // Hata durumunda kullanıcıya bildirim
                console.error('Error fetching data:', error);
                alert('Error fetching data. Please try again later.');
            }
        });

        // Dinamik renk üretimi
        function generateColors(count) {
            var colors = [];
            for (var i = 0; i < count; i++) {
                // Rastgele renk üretme (örneğin)
                var color = '#' + Math.floor(Math.random() * 16777215).toString(16);
                colors.push(color);
            }
            return colors;
        }

    });

</script>
