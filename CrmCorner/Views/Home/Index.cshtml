@model CompanyUsersViewModel
@using System.Linq

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}
<style>
    .custom-card {
        background-color: #fff; /* Beyaz arka plan */
        border-radius: 10px; /* Köşe yuvarlama */
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1); /* Hafif gölge */
        padding: 20px; /* İç boşluk */
        margin: 10px; /* Dış boşluk */
        border: 1px solid #ddd; /* İnce border */
    }

    .chart-title {
        font-size: 18px;
        font-weight: bold;
        margin-bottom: 15px; /* Başlık altı boşluk */
    }

    .card-body {
        padding: 10px; /* İç boşluk */
    }


    /* Responsive grid ayarları */
    .row {
        display: flex;
        flex-wrap: wrap;
    }

    .col-xl-4, .col-lg-6, .col-md-6, .col-xl-8, .col-lg-12, .col-md-12 {
        padding: 15px; /* İç boşluk */
    }

    /* Küçük cihazlar için sütun boyutları */
    @@media (max-width: 768px) {
        .col-xl-4, .col-lg-6, .col-md-6, .col-xl-8, .col-lg-12, .col-md-12 {
            flex: 0 0 100%;
            max-width: 100%;
        }

        .custom-card, .card-body {
            width: 100% !important; /* !important kullanımı genelde kaçınılması gereken bir yöntemdir ama burada özel bir durum için kullanılmıştır. */
        }
    }
</style>

