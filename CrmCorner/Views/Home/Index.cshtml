<script>$(document).ready(function () {
        $.ajax({
            type: "GET",
            url: "/Home/IndustryChart",
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (data) {
                console.log(data); // Gelen veriyi kontrol etmek için bu satırı ekleyin
                var ctx = document.getElementById('industuryChart').getContext('2d');
                // Dinamik olarak renk seçimi
                var colors = generateColors(data.labels.length);

                var labels = data.labels;
                var dataValues = data.data;
                var customerNames = data.customerNames;

                new Chart(ctx, {
                    type: 'pie',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: dataValues,
                            backgroundColor: colors,
                            borderWidth: 1
                        }]
                    },
                    options: {
                        layout: {
                            padding: {
                                top: 10, // Grafiğin üstündeki boşluğu ayarlayın
                                bottom: 0
                            }
                        },
                        plugins: {
                            legend: {
                                position: 'right',
                                align: 'center',
                                labels: {
                                    boxWidth: 10,
                                    padding: 5,
                                    font: {
                                        size: 10, // Yazı boyutunu 12px olarak ayarladım
                                        family: "'Helvetica Neue', 'Helvetica', 'Arial', sans-serif",
                                        style: 'normal'
                                    }
                                }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function (context) {
                                        var index = context.dataIndex;
                                        var count = dataValues[index];
                                        var customers = customerNames[index];
                                        var label = labels[index] + ': ' + count;
                                        var lines = [label].concat(customers); // Müşteri isimlerini ekle
                                        return lines;
                                    }
                                }
                            }
                        }
                    }
                });
            },
            error: function (xhr, status, error) {
                // Hata durumunda kullanıcıya bildirim
                var errorMessage = xhr.status + ': ' + xhr.statusText;
                console.error('Error - ' + errorMessage);
                // alert('Failed to fetch data. Error: ' + errorMessage);
            }
        });

        // Dinamik renk üretimi
        function generateColors(count) {
            var predefinedColors = [
                '#A3D9A5',
                '#FFDAC1',
                '#BAFFB3',
                '#C2C2F0', // Pastel lavanta
                '#B3F3D0', 
                '#BAE1FF',
                '#FFB3BA', // Pastel pembe
                '#FFDFBA', // Pastel şeftali
                '#FFFFBA', // Pastel sarı
                '#D5AAFF', // Pastel mor
                '#FFB3E6', // Pastel fuşya
          
            ];

            // Renklerin sayısına göre döndür
            return predefinedColors.slice(0, count);
        }
    });</script>

