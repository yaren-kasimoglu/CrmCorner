<script type="text/javascript">
    $(document).ready(function () {
        $.ajax({
            type: "GET",
            url: "/Home/SourceChannelChart", // Controller metoduna yapılan istek
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (data) {
                console.log(data); // Gelen veriyi kontrol etmek için
                var ctx = document.getElementById('sourceChannelChart').getContext('2d');

                // Renkleri dinamik olarak belirleyelim
                var colors = generateColors(data.labels.length);

                new Chart(ctx, {
                    type: 'pie', // sektörel dağılım grafiğiyle aynı tip
                    data: {
                        labels: data.labels,
                        datasets: [{
                            data: data.data,
                            backgroundColor: colors,
                            borderWidth: 1
                        }]
                    },
                    options: {
                        layout: {
                            padding: { top: 10, bottom: 0 }
                        },
                        plugins: {
                            legend: {
                                position: 'right',
                                align: 'center',
                                labels: {
                                    boxWidth: 12,
                                    padding: 5,
                                    font: { size: 10 }
                                }
                            },
                      tooltip: {
        callbacks: {
          label: function (context) {
            const i = context.dataIndex;
            const label = `${data.labels[i]}: ${data.data[i]}`;
            const tasks = (data.taskNames && data.taskNames[i]) ? data.taskNames[i] : [];
            const max = 8; // tooltip'te en fazla kaç görev adı gösterilsin
            const shown = tasks.slice(0, max).map(t => `• ${t}`);
            if (tasks.length > max) shown.push(`+${tasks.length - max} daha…`);
            // Çok satır için dizi döndür
            return [label, ...shown];
          }
        }
      },
                            datalabels: {
                                color: 'rgba(0,0,0,0.6)',
                                formatter: function (value, context) {
                                    var total = context.dataset.data.reduce((a, b) => a + b, 0);
                                    var percentage = ((value / total) * 100).toFixed(2);
                                    return percentage > 0 ? percentage + '%' : '';
                                },
                                font: { weight: 'bold', size: 8 },
                                anchor: 'center',
                                align: 'center',
                                offset: 10
                            }
                        }
                    },
                    plugins: [ChartDataLabels]
                });

            },
            error: function (xhr, status, error) {
                console.error('SourceChannel chart verisi getirilirken hata oluştu:', error);
            }
        });

        // Dinamik renk üretimi
        function generateColors(count) {
            var predefinedColors = [
                '#A3D9A5', '#FFDAC1', '#BAFFB3', '#C2C2F0',
                '#B3F3D0', '#BAE1FF', '#FFB3BA', '#FFDFBA',
                '#FFFFBA', '#D5AAFF', '#FFB3E6'
            ];
            return predefinedColors.slice(0, count);
        }
    });
</script>


