@model CompanyUsersViewModel
@using System.Linq

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

<style>
    :root {
        --crm-bg: #f6f8fc;
        --crm-card: #ffffff;
        --crm-border: #e8edf5;
        --crm-text: #1f2937;
        --crm-muted: #6b7280;
        --crm-primary: #ffb71b;
        --crm-primary-dark: #e3a20f;
        --crm-primary-soft: #fff5db;
        --crm-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
        --crm-radius-lg: 22px;
        --crm-radius-md: 16px;
        --crm-radius-sm: 12px;
    }

    body {
        background: var(--crm-bg);
    }

    .dashboard-page {
        padding: 18px 8px 30px 8px;
    }

    .dashboard-hero {
        background: linear-gradient(135deg, #ffffff 0%, #fffaf0 100%);
        border: 1px solid var(--crm-border);
        border-radius: 24px;
        box-shadow: var(--crm-shadow);
        padding: 24px 26px;
        margin-bottom: 24px;
        position: relative;
        overflow: hidden;
    }

        .dashboard-hero::after {
            content: "";
            position: absolute;
            right: -40px;
            top: -50px;
            width: 180px;
            height: 180px;
            background: radial-gradient(circle, rgba(255,183,27,.18) 0%, rgba(255,183,27,0) 70%);
            pointer-events: none;
        }

    .dashboard-title-main {
        font-size: 28px;
        font-weight: 800;
        color: var(--crm-text);
        margin-bottom: 6px;
        line-height: 1.2;
    }

    .dashboard-subtitle-main {
        color: var(--crm-muted);
        font-size: 14px;
        margin-bottom: 0;
    }

    .dashboard-welcome-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--crm-primary-soft);
        border: 1px solid #ffe3a2;
        color: #8a5a00;
        padding: 10px 14px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
    }

    .dashboard-card {
        background: var(--crm-card);
        border: 1px solid var(--crm-border);
        border-radius: var(--crm-radius-lg);
        box-shadow: var(--crm-shadow);
        height: 100%;
        overflow: hidden;
    }

    .dashboard-card-header {
        padding: 20px 22px 0 22px;
    }

    .dashboard-card-body {
        padding: 18px 22px 22px 22px;
    }

    .section-title {
        font-size: 18px;
        font-weight: 700;
        color: var(--crm-text);
        margin-bottom: 4px;
    }

    .section-subtitle {
        font-size: 13px;
        color: var(--crm-muted);
        margin-bottom: 0;
    }

    .stats-stack {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .stat-box {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 16px;
        border: 1px solid #eef2f7;
        border-radius: var(--crm-radius-md);
        background: #fbfcfe;
        transition: all .2s ease;
    }

        .stat-box:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(15, 23, 42, 0.05);
            background: #ffffff;
        }

    .stat-icon-box {
        width: 48px;
        height: 48px;
        min-width: 48px;
        border-radius: 14px;
        background: var(--crm-primary-soft);
        color: #cf8c00;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }

        .stat-icon-box a {
            color: inherit !important;
        }

    .stat-meta {
        flex: 1;
        min-width: 0;
    }

    .stat-label {
        font-size: 13px;
        color: var(--crm-muted);
        margin-bottom: 2px;
        font-weight: 600;
    }

    .stat-value {
        font-size: 24px;
        font-weight: 800;
        color: var(--crm-text);
        line-height: 1.1;
    }

    .todo-panel {
        min-height: 330px;
    }

    .todo-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .todo-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding: 14px 16px;
        border: 1px solid #eef2f7;
        border-radius: var(--crm-radius-md);
        background: #fbfcfe;
        text-decoration: none;
        transition: all .2s ease;
    }

        .todo-item:hover {
            transform: translateY(-2px);
            background: #ffffff;
            box-shadow: 0 8px 20px rgba(15, 23, 42, 0.05);
        }

    .todo-left {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
    }

    .todo-icon {
        width: 42px;
        height: 42px;
        min-width: 42px;
        border-radius: 12px;
        background: #fff3d6;
        color: #cf8c00;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .todo-text {
        font-size: 14px;
        font-weight: 600;
        color: var(--crm-text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 360px;
    }

    .todo-date {
        font-size: 12px;
        color: var(--crm-muted);
        white-space: nowrap;
        font-weight: 600;
    }

    .custom-card {
        background: var(--crm-card);
        border: 1px solid var(--crm-border);
        border-radius: var(--crm-radius-lg);
        box-shadow: var(--crm-shadow);
        padding: 0;
        margin: 0;
        height: 100%;
        overflow: hidden;
    }

    .chart-card-header {
        padding: 20px 20px 0 20px;
    }

    .chart-title {
        font-size: 17px;
        font-weight: 700;
        color: var(--crm-text);
        margin-bottom: 4px;
    }

    .chart-subtitle {
        color: var(--crm-muted);
        font-size: 12px;
        margin-bottom: 0;
    }

    .card-body {
        padding: 18px 20px 20px 20px;
    }

    .chart-body {
        min-height: 320px;
        position: relative;
    }

    .fixed-todo-height {
        min-height: 260px;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
    }

    .row.dashboard-row {
        row-gap: 24px;
    }

    .equal-card {
        min-height: 100%;
        border-radius: 16px !important;
        background: transparent;
        padding: 0;
        border: none;
        box-shadow: none;
    }

    .empty-state {
        padding: 16px;
        border: 1px dashed #d8e0ea;
        border-radius: 16px;
        background: #fafbfd;
        color: var(--crm-muted);
        font-size: 14px;
    }

    @@media (max-width: 991px) {
        .dashboard-title-main {
            font-size: 24px;
        }

        .todo-text {
            max-width: 220px;
        }
    }

    @@media (max-width: 768px) {
        .dashboard-page {
            padding: 10px 0 24px 0;
        }

        .dashboard-hero {
            padding: 18px;
        }

        .dashboard-card-header,
        .dashboard-card-body,
        .chart-card-header,
        .card-body {
            padding-left: 16px;
            padding-right: 16px;
        }

        .todo-text {
            max-width: 140px;
        }

        .chart-body {
            min-height: 280px;
        }
    }
</style>

<div class="container-fluid px-3 dashboard-page">

    <div class="dashboard-hero d-flex flex-wrap justify-content-between align-items-center">
        <div>
            <div class="dashboard-title-main">CRM Corner Dashboard</div>
            <p class="dashboard-subtitle-main">
                Görevler, müşteri verileri ve temel performans metriklerini tek ekranda takip edebilirsiniz.
            </p>
        </div>

        @if (Model.CurrentUser != null)
        {
            <div class="dashboard-welcome-badge mt-3 mt-md-0">
                <i class="fa fa-user-circle"></i>
                Hoş geldin, @Model.CurrentUser.UserName
            </div>
        }
    </div>

    <div class="row dashboard-row">
        @if (Model.CurrentUser != null)
        {
            <div class="col-xl-4 col-lg-6 col-md-12 d-flex align-items-stretch">
                <div class="dashboard-card w-100">
                    <div class="dashboard-card-header">
                        <h5 class="section-title">Genel Durum</h5>
                        <p class="section-subtitle">Kullanıcı ve şirket bazlı özet bilgiler</p>
                    </div>

                    <div class="dashboard-card-body">
                        <div class="stats-stack">
                            <div class="stat-box">
                                <div class="stat-icon-box">
                                    <a class="nav-link p-0" asp-area="" asp-controller="Employee" asp-action="EmployeeList">
                                        <i class="fa fa-user"></i>
                                    </a>
                                </div>
                                <div class="stat-meta">
                                    <div class="stat-label">Çalışan Sayımız</div>
                                    <div class="stat-value">@Model.CompanyUsers.Count</div>
                                </div>
                            </div>

                            <div class="stat-box">
                                <div class="stat-icon-box">
                                    <a class="nav-link p-0" asp-area="" asp-controller="Customer" asp-action="CustomerList">
                                        <i class="fa fa-users"></i>
                                    </a>
                                </div>
                                <div class="stat-meta">
                                    <div class="stat-label">Müşterilerim</div>
                                    <div class="stat-value">@Model.CurrentUser.Customers.Count</div>
                                </div>
                            </div>

                            <div class="stat-box">
                                <div class="stat-icon-box">
                                    <a class="nav-link p-0" asp-area="" asp-controller="PipelineTask" asp-action="PipelineIndex">
                                        <i class="fa fa-tasks"></i>
                                    </a>
                                </div>
                                <div class="stat-meta">
                                    <div class="stat-label">Sahip Olduğum Görev Sayısı</div>
                                    <div class="stat-value">@Model.PipelineTaskCount</div>
                                </div>
                            </div>

                            <div class="stat-box">
                                <div class="stat-icon-box">
                                    <i class="fa fa-briefcase"></i>
                                </div>
                                <div class="stat-meta">
                                    <div class="stat-label">Sektör</div>
                                    <div class="stat-value">@Model.SectorCount</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="col-xl-8 col-lg-6 col-md-12 d-flex align-items-stretch">
            <div class="dashboard-card w-100 todo-panel">
                <div class="dashboard-card-header">
                    <h5 class="section-title">Yapılacaklar</h5>
                    <p class="section-subtitle">Son eklenen 5 görev</p>
                </div>

                <div class="dashboard-card-body fixed-todo-height">
                    <div class="todo-list">
                        @if (ViewBag.LatestTasks != null)
                        {
                            var tasks = ViewBag.LatestTasks as List<LatestTaskDto>;

                            if (tasks != null && tasks.Any())
                            {
                                foreach (var item in tasks)
                                {
                                    <a href="/ToDoList/ToDoList/@item.BoardId" class="todo-item">
                                        <div class="todo-left">
                                            <div class="todo-icon">
                                                <i class="fa fa-calendar"></i>
                                            </div>

                                            <div class="todo-text">@item.Text</div>
                                        </div>

                                        <div class="todo-date">
                                            @item.CreatedDate.ToString("dd.MM.yyyy")
                                        </div>
                                    </a>
                                }
                            }
                            else
                            {
                                <div class="empty-state">Henüz eklenmiş görev bulunmuyor.</div>
                            }
                        }
                        else
                        {
                            <div class="empty-state">Henüz eklenmiş görev bulunmuyor.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row dashboard-row mt-1">
        <div class="col-xl-4 col-lg-4 col-md-12 d-flex">
            <div class="custom-card w-100">
                <div class="chart-card-header">
                    <div class="chart-title">Kazanıldı / Kaybedildi</div>
                    <p class="chart-subtitle">Pipeline sonuç dağılımı</p>
                </div>
                <div class="card-body chart-body">
                    <canvas id="outcomeStatusChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-lg-4 col-md-12 d-flex">
            <div class="custom-card w-100">
                <div class="chart-card-header">
                    <div class="chart-title">Karar Verici Dağılımı</div>
                    <p class="chart-subtitle">Final decision maker bilgisi</p>
                </div>
                <div class="card-body chart-body">
                    <canvas id="isFinalDecisionMaker"></canvas>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-lg-4 col-md-12 d-flex">
            <div class="custom-card w-100">
                <div class="chart-card-header">
                    <div class="chart-title">Kaynak Kanalı</div>
                    <p class="chart-subtitle">Lead’lerin geldiği kanal dağılımı</p>
                </div>
                <div class="card-body chart-body">
                    <canvas id="sourceChannelChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>




<script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>
<script src="~/CRMTema/bootstrap5/js/pages/widgets/chart-widgets.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0"></script>

<script type="text/javascript">
    Chart.register(ChartDataLabels);

    function getCommonDoughnutOptions(tooltipCallback) {
        return {
            responsive: true,
            maintainAspectRatio: false,
            layout: {
                padding: {
                    top: 10,
                    bottom: 0
                }
            },
            plugins: {
                legend: {
                    position: 'right',
                    align: 'center',
                    labels: {
                        usePointStyle: true,
                        pointStyle: 'circle',
                        boxWidth: 10,
                        padding: 14,
                        font: {
                            size: 12
                        }
                    }
                },
                tooltip: {
                    callbacks: {
                        label: tooltipCallback
                    }
                },
                datalabels: {
                    color: 'rgba(0, 0, 0, 0.6)',
                    formatter: function (value, context) {
                        var total = context.dataset.data.reduce((acc, val) => acc + val, 0);
                        var percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                        return percentage > 0 ? percentage + '%' : '';
                    },
                    font: {
                        weight: 'bold',
                        size: 9
                    }
                }
            }
        };
    }

    function generateColors(count) {
        var predefinedColors = [
            '#A3D9A5',
            '#FFDAC1',
            '#BAFFB3',
            '#C2C2F0',
            '#B3F3D0',
            '#BAE1FF',
            '#FFB3BA',
            '#FFDFBA',
            '#FFFFBA',
            '#D5AAFF',
            '#FFB3E6'
        ];

        if (count <= predefinedColors.length) {
            return predefinedColors.slice(0, count);
        }

        return predefinedColors;
    }

    $(document).ready(function () {
        $.ajax({
            type: "GET",
            url: "/Home/OutcomeStatusChart",
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (data) {
                var ctx = document.getElementById('outcomeStatusChart').getContext('2d');
                var colors = ['#f3e6f6', '#e1a7e8', '#b76cd0', '#8a2c77'];

                var labels = data.labels;
                var dataValues = data.data;
                var taskNames = data.taskNames;

                new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: dataValues,
                            backgroundColor: colors,
                            borderWidth: 1
                        }]
                    },
                    options: getCommonDoughnutOptions(function (context) {
                        var index = context.dataIndex;
                        var count = dataValues[index];
                        var tasks = taskNames[index];
                        var label = labels[index] + ': ' + count;
                        return [label].concat(tasks);
                    })
                });

            },
            error: function (error) {
                console.error('Error fetching data:', error);
            }
        });
    });

    $(document).ready(function () {
        $.ajax({
            type: "GET",
            url: "/Home/IsFinalDecisionMaker",
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (data) {
                var ctx = document.getElementById('isFinalDecisionMaker').getContext('2d');
                var colors = ['#FFE0B2', '#FF6F00', '#FFD180', '#FFB74D'];

                var labels = data.labels;
                var dataValues = data.data;
                var taskNames = data.taskNames;

                new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: dataValues,
                            backgroundColor: colors,
                            borderWidth: 1
                        }]
                    },
                    options: getCommonDoughnutOptions(function (context) {
                        var index = context.dataIndex;
                        var count = dataValues[index];
                        var tasks = taskNames[index];
                        var label = labels[index] + ': ' + count;
                        return [label].concat(tasks);
                    })
                });
            },
            error: function (error) {
                console.error('Error fetching data:', error);
            }
        });
    });

    $(document).ready(function () {
        $.ajax({
            type: "GET",
            url: "/Home/SourceChannelChart",
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (data) {
                var ctx = document.getElementById('sourceChannelChart').getContext('2d');
                var colors = generateColors(data.labels.length);

                new Chart(ctx, {
                    type: 'pie',
                    data: {
                        labels: data.labels,
                        datasets: [{
                            data: data.data,
                            backgroundColor: colors,
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        layout: {
                            padding: { top: 10, bottom: 0 }
                        },
                        plugins: {
                            legend: {
                                position: 'right',
                                align: 'center',
                                labels: {
                                    usePointStyle: true,
                                    pointStyle: 'circle',
                                    boxWidth: 10,
                                    padding: 12,
                                    font: { size: 11 }
                                }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function (context) {
                                        const i = context.dataIndex;
                                        const label = `${data.labels[i]}: ${data.data[i]}`;
                                        const tasks = (data.taskNames && data.taskNames[i]) ? data.taskNames[i] : [];
                                        const max = 8;
                                        const shown = tasks.slice(0, max).map(t => `• ${t}`);
                                        if (tasks.length > max) shown.push(`+${tasks.length - max} daha...`);
                                        return [label, ...shown];
                                    }
                                }
                            },
                            datalabels: {
                                color: 'rgba(0,0,0,0.6)',
                                formatter: function (value, context) {
                                    var total = context.dataset.data.reduce((a, b) => a + b, 0);
                                    var percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                    return percentage > 0 ? percentage + '%' : '';
                                },
                                font: { weight: 'bold', size: 9 }
                            }
                        }
                    }
                });

            },
            error: function (xhr, status, error) {
                console.error('SourceChannel chart verisi getirilirken hata oluştu:', error);
            }
        });
    });
</script>