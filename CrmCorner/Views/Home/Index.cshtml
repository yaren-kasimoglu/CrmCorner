<script>$(document).ready(function () {
        $.ajax({
            type: "GET",
            url: "/Home/IndustryChart",
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (data) {
                console.log(data); // Gelen veriyi kontrol etmek için bu satırı ekleyin
                var ctx = document.getElementById('industuryChart').getContext('2d');
                // Dinamik olarak renk seçimi
                var colors = generateColors(data.labels.length);

                var labels = data.labels;
                var dataValues = data.data;
                var customerNames = data.customerNames;

                new Chart(ctx, {
                    type: 'pie',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: dataValues,
                            backgroundColor: colors,
                            borderWidth: 1
                        }]
                    },
                    options: {
                        layout: {
                            padding: {
                                top: 10, // Grafiğin üstündeki boşluğu ayarlayın
                                bottom: 0
                            }
                        },
                        plugins: {
                            legend: {
                                position: 'right',
                                align: 'center',
                                labels: {
                                    boxWidth: 10,
                                    padding: 5,
                                    font: {
                                        size: 10, // Yazı boyutunu 12px olarak ayarladım
                                        family: "'Helvetica Neue', 'Helvetica', 'Arial', sans-serif",
                                        style: 'normal'
                                    }
                                }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function (context) {
                                        var index = context.dataIndex;
                                        var count = dataValues[index];
                                        var customers = customerNames[index];
                                        var label = labels[index] + ': ' + count;
                                        var lines = [label].concat(customers); // Müşteri isimlerini ekle
                                        return lines;
                                    }
                                }
                            },
                            datalabels: {
                                color: 'rgba(0, 0, 0, 0.6)',
                                formatter: function (value, context) {
                                    var total = context.dataset.data.reduce((acc, val) => acc + val, 0);
                                    var percentage = ((value / total) * 100).toFixed(2);
                                    return percentage > 0 ? percentage + '%' : '';
                                },
                                font: {
                                    weight: 'bold',
                                    size: 8// Yazı boyutunu küçük tut
                                },
                                anchor: 'center', // Konumu merkezde gösterir
                                align: 'center',  // Yazıları merkezde hizalar
                                offset: 10 // Sağ tarafa doğru kaydırma
                            }

                        }
                    },
                    plugins: [ChartDataLabels] // ChartDataLabels plugin'ini kullanın
                });

            },
            error: function (xhr, status, error) {
                // Hata durumunda kullanıcıya bildirim
                var errorMessage = xhr.status + ': ' + xhr.statusText;
                console.error('Error - ' + errorMessage);
                // alert('Failed to fetch data. Error: ' + errorMessage);
            }
        });

        // Dinamik renk üretimi
        function generateColors(count) {
            var predefinedColors = [
                '#A3D9A5',
                '#FFDAC1',
                '#BAFFB3',
                '#C2C2F0', // Pastel lavanta
                '#B3F3D0',
                '#BAE1FF',
                '#FFB3BA', // Pastel pembe
                '#FFDFBA', // Pastel şeftali
                '#FFFFBA', // Pastel sarı
                '#D5AAFF', // Pastel mor
                '#FFB3E6', // Pastel fuşya

            ];

            // Renklerin sayısına göre döndür
            return predefinedColors.slice(0, count);
        }
    });</script>



<script>
    $(document).ready(function () {
        $.ajax({
            type: "GET",
            url: "/Admin/Home/ValueOfferChart",
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (data) {
                createChart('valueOfferChartTL', data.tlChart, '₺');
                createChart('valueOfferChartEU', data.euChart, '€');
                createChart('valueOfferChart$', data.dollarChart, '$');
            },
            error: function (xhr, status, error) {
                console.error('Veri getirilirken hata oluştu:', error);
            }
        });

        // Grafik oluşturma fonksiyonu
        function createChart(canvasId, chartData, currency) {
            var ctx = document.getElementById(canvasId).getContext('2d');
            var colors = generateColors(chartData.labels.length);

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: chartData.labels,
                    datasets: [{
                        label: 'Değer Teklifi (' + currency + ')',
                        data: chartData.data,
                        backgroundColor: colors,
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    var label = context.dataset.label || '';
                                    if (label) {
                                        label += ': ';
                                    }

                                    var value = context.dataset.data[context.dataIndex]; // Toplam Değer
                                    var index = context.dataIndex;
                                    var taskNames = chartData.taskNames[index];

                                    var lines = [
                                        label + value + ' ' + currency, // Toplam Değer ve Para Birimi
                                        'Görev: ' + taskNames.join(', ') // Görev isimleri
                                    ];

                                    return lines;
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true
                        }
                    }
                }
            });
        }

        // Dinamik renk üretimi
        function generateColors(count) {
            var predefinedColors = [
                '#A3D9A5', '#FFDAC1', '#BAFFB3', '#C2C2F0', '#B3F3D0', '#BAE1FF',
                '#FFB3BA', '#FFDFBA', '#FFFFBA', '#D5AAFF', '#FFB3E6'
            ];
            return predefinedColors.slice(0, count);
        }
    });

</script>

