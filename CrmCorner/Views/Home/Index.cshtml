                <small>Yaklaşan Yapılacaklar Listesi</small>
            </div>
            <div class="card-body todo_list">
                @if (ViewBag.ToDoList != null)
                {
                        var todoList = ViewBag.ToDoList as List<string>;
                    
                    @for (int i = 0; i < Math.Min(5, todoList.Count); i++)
                    {
                        var task = todoList[i];
                        <div class="d-flex justify-content-between mb-3">
                            <div class="form-check">
                                <label class="form-check-label" for="@task"><i class="fa fa-calendar me-2"></i>@task</label>
                            </div>
                        </div>
                    }
                 }
                </div>
        </div>
    </div>

</div>
