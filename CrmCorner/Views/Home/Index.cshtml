@model CompanyUsersViewModel
@using System.Linq

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}
<style>
    .custom-card {
        background-color: #fff; /* Beyaz arka plan */
        border-radius: 10px; /* Köşe yuvarlama */
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1); /* Hafif gölge */
        padding: 20px; /* İç boşluk */
        margin: 10px; /* Dış boşluk */
        border: 1px solid #ddd; /* İnce border */
    }

    .chart-title {
        font-size: 18px;
        font-weight: bold;
        margin-bottom: 15px; /* Başlık altı boşluk */
    }

    .card-body {
        padding: 10px; /* İç boşluk */
    }


    /* Responsive grid ayarları */
    .row {
        display: flex;
        flex-wrap: wrap;
    }

    .col-xl-4, .col-lg-6, .col-md-6, .col-xl-8, .col-lg-12, .col-md-12 {
        padding: 15px; /* İç boşluk */
    }

    /* Küçük cihazlar için sütun boyutları */
    @@media (max-width: 768px) {
        .col-xl-4, .col-lg-6, .col-md-6, .col-xl-8, .col-lg-12, .col-md-12 {
            flex: 0 0 100%;
            max-width: 100%;
        }

        .custom-card, .card-body {
            width: 100% !important; /* !important kullanımı genelde kaçınılması gereken bir yöntemdir ama burada özel bir durum için kullanılmıştır. */
        }
    }

    .task-item:hover {
        background: #f9fafb;
        transform: translateX(3px);
    }

    .fixed-todo-height {
        min-height: 260px; /* Kartın minimum yüksekliği */
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
    }

    .card.top_counter {
        border-radius: 16px !important; /* Köşeleri yuvarlat */
        border: 1px solid #e5e7eb; /* Hafif çerçeve */
        box-shadow: 0 4px 10px rgba(0,0,0,0.07); /* Hafif gölge */
        overflow: hidden; /* Köşe taşmalarını önle */
    }

        .card.top_counter .list-group-item {
            border: none !important; /* İç çizgileri kaldır */
            padding: 18px 20px !important;
        }

        .card.top_counter .icon {
            width: 45px;
            height: 45px;
            background: #f1f5f9;
            border-radius: 10px; /* İkon kutusunu da yumuşat */
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .card.top_counter .content div {
            color: #6b7280; /* Başlık alt ton */
            font-size: 14px;
        }

    .equal-card {
        min-height: 330px; /* Her iki kutu aynı boy */
        border-radius: 16px !important;
        background: #fff;
        padding: 10px;
    }



</style>

