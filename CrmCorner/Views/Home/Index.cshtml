<script>$(document).ready(function () {
        $.ajax({
            type: "GET",
            url: "/Home/IndustryChart",
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (data) {
                console.log(data); // Gelen veriyi kontrol etmek için bu satırı ekleyin
                var ctx = document.getElementById('industuryChart').getContext('2d');
                // Dinamik olarak renk seçimi
                var colors = generateColors(data.labels.length);

                var labels = data.labels;
                var dataValues = data.data;
                var customerNames = data.customerNames;

                new Chart(ctx, {
                    type: 'pie',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: dataValues,
                            backgroundColor: colors,
                            borderWidth: 1
                        }]
                    },
                    options: {
                        plugins: {
                            tooltip: {
                                callbacks: {
                                    label: function (context) {
                                        var index = context.dataIndex;
                                        var count = dataValues[index];
                                        var customers = customerNames[index];
                                        var label = labels[index] + ': ' + count;
                                        var lines = [label].concat(customers); // Müşteri isimlerini ekle
                                        return lines;
                                    }
                                }
                            }
                        }
                    }
                });
            },
            error: function (xhr, status, error) {
                // Hata durumunda kullanıcıya bildirim
                var errorMessage = xhr.status + ': ' + xhr.statusText;
                console.error('Error - ' + errorMessage);
                // alert('Failed to fetch data. Error: ' + errorMessage);
            }
        });

        // Dinamik renk üretimi
        function generateColors(count) {
            var colors = [];
            for (var i = 0; i < count; i++) {
                // Rastgele renk üretme (örneğin)
                var color = '#' + Math.floor(Math.random() * 16777215).toString(16);
                colors.push(color);
            }
            return colors;
        }
    });</script>
