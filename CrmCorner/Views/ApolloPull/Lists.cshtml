@model List<CrmCorner.Services.ApolloListDto>

@{
    ViewData["Title"] = "Kayıtlı Apollo Kişi Listeleri";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

<h2>Apollo Kişi Listeleri</h2>

@if (Model != null && Model.Any())
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Liste Adı</th>
                <th>Kişi Sayısı</th>
                <th>Oluşturulma</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var list in Model)
            {
                <tr>
                    <td>@list.Name</td>
                    <td>@list.ContactCount</td>
                    <td>@list.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-warning">Hiç liste bulunamadı.</div>
}

