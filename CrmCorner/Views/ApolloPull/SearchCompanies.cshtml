@model CrmCorner.Services.ApolloCompanySearchDto
@{
    ViewData["Title"] = "Şirket Arama";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

<h2>Şirket Arama</h2>

<form asp-action="SearchCompanies" method="post" class="form-horizontal">
    <div class="form-group">
        <label>Şirket Adı</label>
        <input asp-for="OrganizationName" class="form-control" />
    </div>
    <div class="form-group">
        <label>Lokasyon</label>
        <input asp-for="Location" class="form-control" />
    </div>
    <div class="form-group">
        <label>Sektör (İsteğe Bağlı)</label>
        <input asp-for="IndustryTagIds" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary mt-2">Ara</button>
</form>
