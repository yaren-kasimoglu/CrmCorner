@model List<CrmCorner.Services.ApolloPersonDto1>
@{
    ViewData["Title"] = "Kişi Arama Sonuçları";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

<h2 class="mb-4">Kişi Arama Sonuçları</h2>

@if (Model != null && Model.Any())
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Ad</th>
                <th>Soyad</th>
                <th>Email</th>
                <th>Görev</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var person in Model)
            {
                <tr>
                    <td>@person.FirstName</td>
                    <td>@person.LastName</td>
                    <td>@person.Email</td>
                    <td>@person.Title</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">Hiç kişi bulunamadı.</div>
}
