<form asp-action="FetchLabels" method="post">
    <div class="mb-2">
        <label class="form-label">API Anahtarınız</label>
        <input asp-for="ApiKey" class="form-control" />
        <span asp-validation-for="ApiKey" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-secondary">Label’ları Getir</button>

</form>
<form asp-action="FetchContactsByLabel" method="post" class="mt-3">
    <input asp-for="ApiKey" type="hidden" />

    <div class="mb-2">
        <label class="form-label">Liste Seçin</label>
        <select asp-for="SelectedLabelId" asp-items="Model.Labels" class="form-control">
            <option value="">-- Liste seçin --</option>
        </select>
    </div>

    <button type="submit" class="btn btn-primary">
        Seçili Listenin Kişilerini Çek
    </button>
</form>



@if (ViewBag.Error != null)
{
    <div class="alert alert-danger mt-3">@ViewBag.Error</div>
}

@if (ViewBag.TotalCount != null)
{
    <div class="alert alert-info mt-4">
        Toplam <strong>@ViewBag.TotalCount</strong> kişi getirildi.
    </div>
}

@if (ViewBag.ContactList != null)
{
    var contacts = ViewBag.ContactList as List<CrmCorner.ViewModels.ApolloContactViewModel>;
    <h4 class="mt-4">📋 Çekilen Kişiler</h4>
    <table id="contactsTable" class="display nowrap table table-bordered" style="width:100%">
        <thead>
            <tr>
                <th>Ad</th>
                <th>Soyad</th>
                <th>Unvan</th>
                <th>Şirket</th>
                <th>Email</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var contact in contacts)
            {
                <tr>
                    <td>@contact.FirstName</td>
                    <td>@contact.LastName</td>
                    <td>@contact.Title</td>
                    <td>@contact.CompanyName</td>
                    <td>@contact.Email</td>
                </tr>
            }
        </tbody>
    </table>
}

