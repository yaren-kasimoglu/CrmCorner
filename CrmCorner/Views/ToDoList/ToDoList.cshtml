    </button>
    <label class="task" style="display: flex; align-items: center;position:releative;">
        <input type="checkbox" name="taskCheckbox" class="taskCheckbox" onclick="clickToDoCheckbox(this); document.getElementById('delbutton').blur();" id="taskCheckbox" @(false ? "checked" : "")>
        <span class="custom-checkbox" style="margin-top: auto;"></span>
