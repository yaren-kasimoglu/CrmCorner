        function selectPerson(person) {
            document.getElementById('peopleDropdown').innerHTML = person;
        }
        function assignPerson(selectedtext) {
            console.log("assssss" + selectedtext);
            try {
                var selectedPerson = document.getElementById('peopleDropdown').innerHTML;

                // POST isteği yap
                $.ajax({
                    type: 'POST',
                    url: '/ToDoList/AssignPerson/',
                    data: { person: selectedPerson, text: selectedtext },
                    success: function (response) {
                        window.location.reload();
                        // Başarılı bir şekilde eklendiğinde yapılacak işlemler buraya gelebilir
