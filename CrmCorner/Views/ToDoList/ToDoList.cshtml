                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button> \
                                        </div> \
                                        <div class="modal-body"> \
                                            <div class="dropdown"> \
                                                <button style="width: auto;" class="btn btn-secondary dropdown-toggle" type="button" id="peopleDropdown" data-bs-toggle="dropdown" aria-expanded="false"> \
                                                    Seçiniz \
                                                </button> \
                                                <ul class="dropdown-menu" aria-labelledby="peopleDropdown">';

                // AJAX ile gelen verilere göre dropdown menüsünü oluştur
                data.message.forEach(function (user) {
                    modalContent += '<li><a class="dropdown-item" href="#" onclick="selectPerson(\'' + user.userName + '\')">' + user.nameSurname + '</a></li>';
                });

                modalContent += '</ul> \
                                    </div> \
                                </div> \
                                <div class="modal-footer"> \
                                    <button style="width: auto;" type="button" class="btn btn-secondary" onclick="assignPerson(\'' + selectedtext + '\')">Kişiye Ata</button> \                                </div> \
                            </div> \
                        </div> \
                    </div>';

                // Modal içeriğini body içine ekle
                document.body.innerHTML += modalContent;

                // Modalı göster
                var modal = new bootstrap.Modal(document.getElementById('peopleModal'));
                modal.show();
            } catch (error) {
                console.error('Fetch error:', error);
                // Hata durumunda kullanıcıya bildirim yapabilirsiniz
            }
        }

