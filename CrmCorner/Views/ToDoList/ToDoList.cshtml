</form>

            }

                    }
            `;



    var toplam = kartIcerik + kartIcerik2;
            $('#kartContainer2').append(toplam);
    var taskData = @Json.Serialize(ViewBag.TaskData);
            var notTaskData = @Json.Serialize(ViewBag.NotTaskData);
            if (taskData == null && notTaskData == null) {
                if (id == 0 || id == null) {
                    var cardDiv = document.getElementById("cardpng");
                    cardDiv.style.display = "block";
