                                        <input type="text" name="textValue" class="textInput2" id="textInput" placeholder="Görev Ekle" style="font-size:14px;text-decoration: none;">
                                    </label>
                            
                                    <button type="submit" id="containerbutton" class="btn btn-primary btn-sm" style="width:auto">Ekle</button>
                             
                            </div>
                         

                            <label id="todoId" style="display:none"></label>
                        </form>


                    </div>

                    <div id="myModal" class="modal">
                        <div class="modal-content">
                            <p>Kaydedildi!</p>
                            <span class="close">Tamam</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>


    <script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>
    <script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>

