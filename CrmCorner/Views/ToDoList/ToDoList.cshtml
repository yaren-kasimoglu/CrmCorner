        }
        var el = document.querySelector("list-group-item")
        document.getElementById("deleteToDoList").style.visibility = "visible";


    $.ajax({
        type: 'GET',
        url: "/ToDoList/GetToDoList/",
        encode: true,
        data: { id: id },
        dataType: "json",
        success: function (data) {
