            margin-bottom: 20px;
        }

            .listelerim h3 {
                font-size: 18px;
                margin-bottom: 10px;
                color: #333;
            }

        .list-group {
            list-style: none;
            padding-left: 0;
        }

        .list-group-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 5px;
            margin-bottom: 5px;
        }


        .btn-secondary {
            background-color: #2eacb3;
            color: #212529; /* Metin rengi */
            border-color: #6c757d; /* Kenarlık rengi */
        }


        .dropdown-menu {
            width: 100%; /* Genişlik yüzde olarak belirlendi */
            max-width: 300px; /* Maksimum genişlik değeri */
            border: none;
        }

            .dropdown-menu .list-group-item:hover {
                background-color: #2eacb3; /* Üzerine gelince arka plan rengini yeşil yap */
            }

            .dropdown-menu .list-group-item a {
                color: black;
                text-decoration: none; /* Alt çizgiyi kaldır */
            }

        #hover-effect:hover {
            background-color: #f0f0f0; /* Hafif gri arka plan rengi */
            border-radius: 5px; /* Köşeleri yuvarlak yapma */
        }

        .containerText {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 93%;
            z-index: 1000;
            padding: 10px;
        }

        #containerbutton {
            position: absolute;
            bottom: 15px;
            left: 99%;
        }

        #progressBarContainer {
            position: relative; /* Pozisyon referansını ayarla */
            width: 100%;
            height: 20px;
            background-color: #f0f0f0;
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 20px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }

        /*            #taskCount {
                position: absolute;
                top: 50%;
                right: -20px;
                transform: translateY(-50%);
                white-space: nowrap;
                color: black;
                font-size: 14px;
            }*/
        .progress-bar {
            height: 100%;
            background-color: #4CAF50; /* Yeşil renk */
            border-radius: 10px;
            transition: width 0.5s ease-in-out;
        }

            .progress-bar.done {
                background-color: #3498db;
            }

            .progress-bar:hover {
                filter: brightness(110%);
            }

        .progress2 {
            padding: 6px;
            border-radius: 30px;
            background: rgba(0, 0, 0, 0.25);
            box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.25), 0 1px rgba(255, 255, 255, 0.08);
        }

        .progress-bar2 {
            height: 10px;
            border-radius: 30px;
            padding-left: 20px;
            padding-bottom: 10px;
            background-color: #2eacb3;
            background-image: linear-gradient(to bottom, rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0.05));
            transition: 0.4s linear;
            transition-property: width, background-color;
        }

        .progress-moved .progress-bar2 {
            background-color: #2eacb3;
            animation: progressAnimation 6s;
        }

        .progress-percentage {
            position: absolute;
            /*top: 20px;*/ /* Yukarıdan 20px uzaklık */
            /*            left:90%;*/
            right: 0;
            font-size: 14px;
            color: #777;
        }
    </style>
</head>
