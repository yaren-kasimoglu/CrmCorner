                    container2.style.backgroundImage = "url('" + yeniArkaPlanURL + "')";
                }
            }

            var btnPrima = document.getElementById('btn-prima');
            var ekleButton = document.getElementById('ekleButton2');

            // Boş bir alana tıklandığında
            document.addEventListener('click', function (event) {
                var isClickedInsideDropdown = document.querySelector('.dropdown-menu').contains(event.target);

                // Eğer tıklanan alan dropdown menü içinde değilse ve btn-prima görünürse
                if (!isClickedInsideDropdown && btnPrima.style.display === 'none') {
