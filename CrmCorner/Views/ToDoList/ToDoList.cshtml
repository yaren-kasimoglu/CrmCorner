@model CrmCorner.ViewModels.ToDoPageViewModel
@inject IJsonHelper JsonHelper

@{
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
    ViewData["Title"] = "ToDoList";
}

<style>
    .todo-page {
        font-family: "Segoe UI", sans-serif;
        background-color: #f3f4f6;
        overflow-x: hidden;
    }

    .todo-sidebar {
        background: #ffffff;
        height: calc(100vh - 80px);
        padding: 20px;
        border-right: 1px solid #e5e7eb;
        transition: all 0.3s ease;
        position: relative;
        z-index: 5;
    }

    .todo-menu-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 15px;
        border-radius: 10px;
        font-size: 16px;
        font-weight: 500;
        color: #374151;
        cursor: pointer;
        transition: all 0.3s ease;
        white-space: nowrap;
    }

        .todo-menu-item:hover {
            background: #e6f4f5;
            color: #2eacb3;
        }

        .todo-menu-item i {
            font-size: 20px;
        }

    hr.todo-menu-divider {
        border: none;
        border-top: 1px solid #e5e7eb;
        margin: 20px 0;
    }

    .todo-dropdown-toggle {
        width: 100%;
        background: #2eacb3;
        color: white;
        border: none;
        border-radius: 10px;
        padding: 10px 15px;
        font-weight: 500;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .todo-dropdown-menu {
        width: 100%;
        border: none;
        box-shadow: 0 5px 10px rgba(0,0,0,0.1);
        border-radius: 8px;
    }

    .todo-dropdown-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 15px;
        color: #333;
        cursor: pointer;
        transition: background 0.3s ease;
    }

        .todo-dropdown-item:hover {
            background: #f3f4f6;
        }

    .todo-addlist-input {
        width: 100%;
        margin-top: 12px;
        display: flex;
        gap: 10px;
    }

        .todo-addlist-input input {
            border: 1px solid #ccc;
            border-radius: 8px;
            padding: 8px;
            flex: 1;
        }

        .todo-addlist-input button {
            background: #4B0082;
            border: none;
            color: white;
            border-radius: 8px;
            padding: 8px 15px;
            transition: background 0.3s ease;
        }

            .todo-addlist-input button:hover {
                background: #350063;
            }

    .todo-container {
        background: url('/icons/todo/todo3.jpeg') no-repeat center center / cover;
        min-height: calc(100vh - 80px);
        position: relative;
        overflow: hidden;
        border-left: 1px solid #e5e7eb;
        transition: all 0.3s ease;
    }

    .todo-overlay {
        background: linear-gradient(to bottom, rgba(255,255,255,0.2), rgba(0,0,0,0.5));
        position: absolute;
        inset: 0;
    }

    .todo-content {
        position: relative;
        z-index: 2;
        padding: 40px;
        color: white;
    }

    .todo-header h1 {
        font-size: 30px;
        font-weight: 600;
        margin-bottom: 5px;
    }

    .todo-header h4 {
        font-size: 16px;
        color: #d1d5db;
    }

    .todo-lists-wrapper {
        margin-top: 30px;
        background: rgba(0,0,0,0.35);
        border-radius: 14px;
        padding: 20px 25px;
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 20px;
        backdrop-filter: blur(6px);
    }

    .todo-section-title {
        font-size: 15px;
        font-weight: 600;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
        color: rgba(255,255,255,0.9);
    }

        .todo-section-title i {
            font-size: 16px;
        }

    .todo-items-list {
        max-height: 380px;
        overflow-y: auto;
        padding-right: 5px;
    }

    .todo-item-card {
        background: rgba(0,0,0,0.25);
        border-radius: 10px;
        padding: 10px 12px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 8px;
        transition: background 0.2s ease, transform 0.1s ease;
    }

        .todo-item-card:hover {
            background: rgba(0,0,0,0.4);
            transform: translateY(-1px);
        }

    .todo-item-left {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .todo-checkbox-button {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        border: 2px solid #9ca3af;
        background: transparent;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        cursor: pointer;
    }

        .todo-checkbox-button.done {
            background: #10b981;
            border-color: #10b981;
        }

        .todo-checkbox-button i {
            font-size: 14px;
            color: white;
        }

    .todo-item-text {
        font-size: 14px;
        color: rgba(255,255,255,0.92);
    }

        .todo-item-text.done {
            text-decoration: line-through;
            color: rgba(209,213,219,0.8);
        }

    .todo-item-meta {
        font-size: 11px;
        color: rgba(209,213,219,0.7);
        margin-top: 2px;
    }

    .todo-item-delete-btn {
        background: transparent;
        border: none;
        color: #fca5a5;
        cursor: pointer;
    }

    .todo-task-input-area {
        position: absolute;
        bottom: 25px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        width: min(90%, 1000px);
        background: rgba(255,255,255,0.9);
        border-radius: 30px;
        padding: 10px 20px;
        align-items: center;
        z-index: 3;
        box-shadow: 0 8px 20px rgba(0,0,0,0.25);
    }

        .todo-task-input-area input[type="date"] {
            border: none;
            background: transparent;
            color: #333;
            width: 130px;
            margin-right: 10px;
            outline: none;
            font-size: 13px;
        }

        .todo-task-input-area input[type="text"] {
            flex: 1;
            border: none;
            background: transparent;
            outline: none;
            font-size: 15px;
            color: #333;
        }

        .todo-task-input-area button {
            background: #2eacb3;
            border: none;
            color: white;
            border-radius: 25px;
            padding: 8px 20px;
            font-weight: 500;
            transition: background 0.3s ease;
        }

            .todo-task-input-area button:hover {
                background: #248b91;
            }

    @@media (max-width: 992px) {
        .todo-sidebar {
            height: auto;
            border-bottom: 1px solid #e5e7eb;
        }

        .todo-content {
            padding: 20px;
        }

        .todo-lists-wrapper {
            grid-template-columns: 1fr;
            max-height: none;
        }

        .todo-task-input-area {
            bottom: 15px;
            width: 95%;
        }
    }
</style>

<div class="todo-page container-fluid px-0">
    <div class="row g-0">

        <!-- SOL MENÜ -->
        <div class="col-lg-3 col-md-4 todo-sidebar">

            <div class="todo-menu-item" onclick="clickToday()">
                <i class="fa-solid fa-sun"></i>
                <span>Günüm</span>
            </div>

            <div class="todo-menu-item" onclick="clickImportant()">
                <i class="fa-solid fa-star"></i>
                <span>Önemli</span>
            </div>

            <div class="todo-menu-item" onclick="clickAssign()">
                <i class="fa-solid fa-user-check"></i>
                <span>Bana Atananlar</span>
            </div>

            <hr class="todo-menu-divider" />

            <div class="dropdown">
                <button class="todo-dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="fa-solid fa-list-ul"></i> Listelerim
                    <i class="fa-solid fa-chevron-down"></i>
                </button>

                <ul class="dropdown-menu todo-dropdown-menu">
                    @foreach (var item in Model.Boards)
                    {
                        <li class="todo-dropdown-item" onclick="handleListItemClick('@item.Id')">
                            <span>@item.Title</span>
                            <span class="badge bg-light text-dark">@item.Count</span>
                        </li>
                    }
                </ul>
            </div>

            <form asp-action="AddBoard" asp-controller="ToDoList" method="post" class="todo-addlist-input">
                <input type="text" name="title" placeholder="Yeni Liste Oluştur" />
                <button type="submit">Ekle</button>
            </form>

        </div>

        <!-- SAĞ PANEL -->
        <div class="col-lg-9 col-md-8 todo-container">
            <div class="todo-overlay"></div>

            <div class="todo-content">
                <div class="todo-header">
                    <h1>@Model.Title</h1>
                    <h4>@DateTime.Now.ToString("dd MMMM yyyy dddd", new System.Globalization.CultureInfo("tr-TR"))</h4>
                </div>

                <div class="todo-lists-wrapper">
                    <!-- Açık görevler -->
                    <div>
                        <div class="todo-section-title">
                            <i class="fa-regular fa-circle"></i>
                            <span>Görevler</span>
                        </div>
                        <div class="todo-items-list">
                            @if (Model.NotDoneItems.Any())
                            {
                                foreach (var item in Model.NotDoneItems)
                                {
                                    <div class="todo-item-card">
                                        <div class="todo-item-left">
                                            <form id="toggleForm-@item.Id" method="post" action="@Url.Action("ToggleEntry", "ToDoList")">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="boardId" value="@Model.CurrentBoardId" />
                                                <button type="button"
                                                        class="todo-checkbox-button"
                                                        onclick="document.getElementById('toggleForm-@item.Id').submit();">
                                                </button>
                                            </form>

                                            <div>
                                                <div class="todo-item-text">@item.Text</div>

                                                <button type="button"
                                                        class="btn btn-sm btn-outline-light"
                                                        onclick="openAssign(@item.Id)">
                                                    <i class="fa-solid fa-user-plus"></i>
                                                </button>


                                                <div class="todo-item-meta">
                                                    @item.CreatedDate.ToString("dd.MM.yyyy HH:mm")
                                                </div>
                                            </div>
                                        </div>

                                        <form method="post" action="@Url.Action("DeleteEntry", "ToDoList")">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="boardId" value="@Model.CurrentBoardId" />
                                            <button type="submit" class="todo-item-delete-btn">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        </form>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-muted" style="font-size:13px;">
                                    Henüz görev eklenmemiş.
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Tamamlananlar -->
                    <div>
                        <div class="todo-section-title">
                            <i class="fa-solid fa-check"></i>
                            <span>Tamamlananlar</span>
                        </div>
                        <div class="todo-items-list">
                            @if (Model.DoneItems.Any())
                            {
                                foreach (var item in Model.DoneItems)
                                {
                                    <div class="todo-item-card">
                                        <div class="todo-item-left">
                                            <form id="toggleForm-@item.Id" method="post" action="@Url.Action("ToggleEntry", "ToDoList")">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="boardId" value="@Model.CurrentBoardId" />
                                                <button type="button"
                                                        class="todo-checkbox-button done"
                                                        onclick="document.getElementById('toggleForm-@item.Id').submit();">
                                                    <i class="fa-solid fa-check"></i>
                                                </button>
                                            </form>

                                            <div>
                                                <div class="todo-item-text done">@item.Text</div>
                                                <div class="todo-item-meta">
                                                    @if (item.CompletedDate.HasValue)
                                                    {
                                                        @:Tamamlandı: @item.CompletedDate.Value.ToString("dd.MM.yyyy HH:mm")
                                                    }
                                                </div>
                                            </div>
                                        </div>

                                        <form method="post" action="@Url.Action("DeleteEntry", "ToDoList")">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="boardId" value="@Model.CurrentBoardId" />
                                            <button type="submit" class="todo-item-delete-btn">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        </form>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-muted" style="font-size:13px;">
                                    Tamamlanan görev yok.
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Görev ekleme barı -->
            <form id="taskForm"
                  method="post"
                  action="@Url.Action("AddEntry", "ToDoList")"
                  class="todo-task-input-area">
                <input type="hidden" name="boardId" value="@Model.CurrentBoardId" />
                <input type="date" name="date" placeholder="GG.AA.YYYY" />
                <input type="text" name="text" placeholder="Görev ekle..." />
                <button type="submit">Ekle</button>
            </form>
        </div>

    </div>
</div>
<!-- Görev Atama Popup -->
<div id="assignPopup"
     style="display:none; position:fixed; top:30%; left:50%; transform:translateX(-50%);
            background:white; padding:20px; border-radius:10px; z-index:9999; width:300px;
            box-shadow:0 4px 10px rgba(0,0,0,0.25);">

    <h4 class="mb-3">Görevi Ata</h4>

    <!-- Atanacak olan task id tutulacak -->
    <input type="hidden" id="assignTaskId" />

    <select id="assignUserSelect" class="form-control mb-3">
        @foreach (var user in ViewBag.Users)
        {
            <option value="@user.Id">@user.NameSurname</option>

        }
    </select>

    <button onclick="assignTask()" class="btn btn-success w-100">Ata</button>
</div>

<script>
    const baseUrl = window.location.origin + "/";

    function clickToday() {
        window.location.href = baseUrl + "ToDoList/ToDoList/0";
    }

    function clickImportant() {
        var id = "@Model.ImportantId";
        window.location.href = baseUrl + "ToDoList/ToDoList/" + id;
    }

    function clickAssign() {
        var id = "@Model.AssignListId";
        window.location.href = baseUrl + "ToDoList/ToDoList/" + id;
    }

    function handleListItemClick(id) {
        window.location.href = baseUrl + "ToDoList/ToDoList/" + id;
    }


        function openAssign(taskId) {
        $("#assignTaskId").val(taskId);
        $("#assignPopup").fadeIn(200);
    }

    function assignTask() {
        let taskId = $("#assignTaskId").val();
        let username = $("#assignUserSelect").val();

        $.post("/ToDoList/AssignTask",
        {
            taskId: taskId,
     assigneeUserId: userId

        },
        function (res) {
            alert(res.message);
            location.reload();
        });
    }

</script>
