        async function openPopupPeople(selectedtext) {
            console.log(selectedtext)
            // AJAX isteği yap
            try {
                // AJAX isteği yap
                const response = await fetch('/ToDoList/GetPerson'); // Controller ve action yolunu doğru şekilde güncelleyin
                if (!response.ok) {
                    throw new Error('Network response was not ok');
                }
                const data = await response.json();

                // Modal içeriğini oluştur
                var modalContent = '<div class="modal fade" id="peopleModal" tabindex="-1" aria-labelledby="peopleModalLabel" aria-hidden="true"> \
                                <div class="modal-dialog"> \
