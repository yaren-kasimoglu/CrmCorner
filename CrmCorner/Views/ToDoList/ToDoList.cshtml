            }
        });


        function getParameterByName(name, url) {
            var pathArray = window.location.pathname.split('/');
            console.log(pathArray);
            var id = pathArray[pathArray.length - 1];
            if (!isNaN(id)) {
                // Rakamsa, sayı değerini döndür
                return parseInt(id);
            } else {
                // Rakam değilse veya sayı yoksa, null döndür
                return null;
            }
        }

        function addTaskImportant(item) {
            var label = item.parentElement.querySelector('input[type="text"]');
            var checkbox = item.parentElement.querySelector('.taskCheckbox');
            var importantId = document.getElementById("ImportantId").innerText;

            $.ajax({
                type: 'POST',
                url: '/ToDoList/AddTaskToImportant/',
                data: { textContent: label.value, id: importantId, check: checkbox.checked },
                success: function (response) {
                    window.location.reload();
                    // Başarılı bir şekilde eklendiğinde yapılacak işlemler buraya gelebilir
                },
                error: function (xhr, status, error) {
                    console.error("Görev eklenirken bir hata oluştu: " + error);
                    // Hata durumunda yapılacak işlemler buraya gelebilir
                }
            });
        }

    </script>
    <script>var today = new Date();
        var options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
        var formattedDate = today.toLocaleDateString('tr-TR', options);
        document.getElementById('currentDate').textContent = formattedDate;
        function toggleAltMenu(item) {
            var altMenu = item.querySelector('.alt-menu');
            altMenu.classList.toggle('goster'); // Alt menünün görünürlüğünü değiştirir
        }

        function openPopup(itemId) {
            var id = itemId;
            $.ajax({
                type: 'GET',
                url: '/ToDoList/GetTitle/',
                data: { id: itemId },
                success: function (data) {
                    // Bilgi metni
                    var title = data.message;
                    var infoText = "Liste adınızı güncellemek için aşağıdaki kutucuğa giriniz.";
                    // Popup içeriğini oluştur
                    var popupContent = '<p>' + infoText + '</p>' +
                        '<form action="/ToDoList/DeleteToDoList/' + id + '" method="post">' +
                        '<input type="text" value="' + title + '" id="editInput" style="outline:none;border-bottom:1px solid #333;box-shadow:0px 0.3px 0.9px rgba(0,0,0,0.1), 0px 1.6px 3.6px rgba(0,0,0,0.1);border:none;font-size:x-large;border: outset;width:-webkit-fill-available">' +
                        '<div style="display: flex; justify-content: flex-end;">' +
                        '<button type="submit" class="btn btn-danger btn-sm" style="margin-left: 5px;">Listeyi Sil</button>' +
                        '<button type="button" class="btn btn-info btn-sm" style="width:auto; margin-left: 5px;" onclick="updateTitle(this)">Düzenle</button>' +
                        '</div>' +
                        '</form>';
                    var popupDiv = document.createElement('div');
                    popupDiv.innerHTML = popupContent;
                    popupDiv.classList.add('popup-containeredit');
                    popupDiv.innerHTML = popupContent;
                    popupDiv.style.backgroundColor = 'white';
                    popupDiv.style.border = '1px solid black';
                    popupDiv.style.padding = '20px';
                    popupDiv.style.position = 'fixed';
                    popupDiv.style.top = '50%';
                    popupDiv.style.left = '50%';
                    popupDiv.style.transform = 'translate(-50%, -50%)';
                    popupDiv.style.zIndex = '9999';

                    // Overlay divini oluştur
                    var overlayDiv = document.createElement('div');
                    overlayDiv.style.backgroundColor = 'rgba(0, 0, 0, 0.5)';
                    overlayDiv.style.position = 'fixed';
                    overlayDiv.style.top = '0';
                    overlayDiv.style.left = '0';
                    overlayDiv.style.width = '100%';
                    overlayDiv.style.height = '100%';
                    overlayDiv.style.zIndex = '9998';

                    // Overlay'e tıklandığında popup'ı kapat
                    overlayDiv.addEventListener('click', function () {
                        document.body.removeChild(popupDiv);
                        document.body.removeChild(overlayDiv);
                    });

                    // Popup ve overlay divlerini sayfaya ekle
                    document.body.appendChild(overlayDiv);
                    document.body.appendChild(popupDiv);

                    // Edit input alanını seç ve odaklan
                    var editInput = document.getElementById('editInput');
                    console.log(editInput.value);
                    editInput.focus();
                }
            });
        }

        function updateTitle(itemId) {
            console.log(itemId);
            var newTitle = document.getElementById('editInput').value;
            var id = document.getElementById("todoIdvalue").value;
            console.log(id);
            $.ajax({
                type: 'POST',
                url: "/ToDoList/UpdateTitle/",
                encode: true,
                data: { itemId: id, newtitle: newTitle },
                dataType: "json",
                success: function () {
                    window.location.reload();
                }

            });
            var editButtons = document.querySelectorAll('.list-group-item button');

            // Tüm düğmelerin tıklanabilirliğini geri yükle
            editButtons.forEach(function (button) {
                button.disabled = false;
            });
        }
        

        function textVisibleshow() {
            var inputElement = document.getElementById("textInput");
            inputElement.style.textDecoration = "none";
        }

        function textVisible() {
            var inputElement = document.getElementById("textInput");
            inputElement.style.textDecoration = "none"; //
        }


        document.querySelector(".close").addEventListener("click", function () {
            // Modalı gizle
            document.getElementById("myModal").style.display = "none";
            location.reload();

        });

        </script>
