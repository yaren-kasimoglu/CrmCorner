    <script>
        document.getElementById('dropdownMenuButton').addEventListener('click', function () {
            var btnPrima = document.getElementById('btn-prima');
            btnPrima.style.display = 'none';
            // Eğer btn-prima gizlenmişse

            // Eğer btn-prima görünürse, herhangi bir işlem yapmamıza gerek yok
        });
// Form submit edildiğinde
        var form = document.getElementById("taskForm"); // Form elementini seçin

        console.log(form);
        // Form submit olduğunda...
        form.addEventListener("submit", function (event) {
            // Checkbox'ın checked durumunu kontrol edin

            var id = getParameterByName('id');
            console.log(id);


            var idinput = document.createElement("input");
            idinput.setAttribute("type", "hidden");
            idinput.setAttribute("name", "id");
            idinput.setAttribute("value", id);
            form.appendChild(idinput);

        });



        var baseUrl = "https://localhost:7145/";
        document.querySelectorAll('.link-item').forEach(item => {
            item.addEventListener('click', event => {
                event.preventDefault(); // Bağlantının varsayılan davranışını önle
                var itemId = item.getAttribute('data-id'); // Tıklanan öğenin id'sini al
                console.log(itemId);

                // TodoId'ye değeri set et
                var todoId = document.getElementById('todoId');
                todoId.value = itemId;

                // Başka bir alanın değerini değiştirme işlemini yap
                var newUrl = baseUrl + "ToDoList/ToDoList/" + itemId;
                // URL'yi değiştir
                window.location.href = newUrl;

            });
        });

        function clickToday() {
            var newUrl = "";
            document.getElementById('todoId').value = 0;
            newUrl = baseUrl + "ToDoList/ToDoList/" + 0;

            // URL'yi değiştir
            window.location.href = newUrl;
        }

        function clickImportant() {
            var newUrl = "";
            var ImportantId = document.getElementById("ImportantId");
            var ImportantIdValue = ImportantId.innerHTML;

            newUrl = baseUrl + "ToDoList/ToDoList/" + ImportantIdValue;
            window.location.href = newUrl;

            // Arka plan resminin URL'sini belirleyin

        }
        document.addEventListener("submit", function (event) {
            var id = getParameterByName('id');
            if (event.target && event.target.classList.contains("delete-task-form")) {

                event.preventDefault();
                var form = event.target; // Form öğesini alın

                var taskLabels = document.querySelectorAll('.task');
                var selectedTaskTexts = [];
                var notselectedTaskTexts = [];


            taskLabels.forEach(function (label) {
                var checkbox = label.querySelector('.taskCheckbox');
                console.log("checkbox deger:" + checkbox);
                var textInput = label.querySelector('input[type="text"]');
                console.log("textınput deger:" + textInput);
                if (textInput.value != null && checkbox!=null) {
                    if (checkbox.checked) {
                        selectedTaskTexts.push(textInput.value.trim());
                    }
                    else {
                        notselectedTaskTexts.push(textInput.value.trim());
                    }
                }
            });
                var selectedTaskTextsString1 = selectedTaskTexts.join(",");
                var notselectedTaskTextsString1 = notselectedTaskTexts.join(",");
                var selectedTaskTextsString = selectedTaskTextsString1.replace(/^,|,$/g, '');
                var notselectedTaskTextsString = notselectedTaskTextsString1.replace(/^,|,$/g, '');
                var textContentInput = document.createElement("input");
                textContentInput.setAttribute("type", "hidden");
                textContentInput.setAttribute("name", "selectedtext");
                textContentInput.setAttribute("value", selectedTaskTextsString);
                form.appendChild(textContentInput);
                var textContentInput2 = document.createElement("input");
                textContentInput2.setAttribute("type", "hidden");
                textContentInput2.setAttribute("name", "notselectedtext");
                textContentInput2.setAttribute("value", notselectedTaskTexts);
                form.appendChild(textContentInput2);
                // Formun varsayılan davranışını engelle
                var taskIdInput = document.createElement("input");
                taskIdInput.setAttribute("type", "hidden");
                taskIdInput.setAttribute("name", "taskId");
                taskIdInput.setAttribute("value", id);
                form.appendChild(taskIdInput);




                // Şimdi formu gönderme işlemini gerçekleştirin
                form.submit();

            }
            else if (event.target.classList.contains("add-task-formlist")) {
                event.preventDefault(); // Formun varsayılan davranışını engelle
                var form = event.target; // Form öğesini alın
                var idInput = document.createElement("input");
                idInput.setAttribute("type", "hidden");
                idInput.setAttribute("name", "id");
                idInput.setAttribute("value", id);
                form.appendChild(idInput);

                // Şimdi formu gönderme işlemini gerçekleştirin
                form.submit();

            }

        });
        function deleteTodo(item) {
            var label = item.parentElement.querySelector('input[type="text"]');
            var checkbox = item.parentElement.querySelector('.taskCheckbox');
            var id = getParameterByName('id');

            $.ajax({
                type: 'POST',
                url: '/ToDoList/DeleteToDo/',
                data: { textContent: label.value, id: id },
                success: function (response) {
                    window.location.reload();
                    // Başarılı bir şekilde eklendiğinde yapılacak işlemler buraya gelebilir
                },
                error: function (xhr, status, error) {
                    console.error("Görev eklenirken bir hata oluştu: " + error);
                    // Hata durumunda yapılacak işlemler buraya gelebilir
                }
            });
        }

        document.querySelectorAll('.delete-task-form').forEach(function (input) {
            input.addEventListener('keypress', function (event) {
                if (event.key === 'Enter') {
                    event.preventDefault();
                }
            });
        });
        function clickToDoCheckbox(checkbox) {
            var label = checkbox.parentElement.querySelector('input[type="text"]');
            if (checkbox.checked) {
                label.style.textDecoration = "line-through";

            } else {
                label.style.textDecoration = "none";
            }

            var id = getParameterByName('id');

            $.ajax({
                type: 'POST',
                url: "/ToDoList/UpdateToDo/",
                encode: true,
                data: { id: id, textContent: label.value, checkbox: checkbox.checked },
                dataType: "json",
                success: function () {
                   window.location.reload();
                }

            });
        }

        function showTooltip() {
            var tooltip = document.getElementById("tooltip");
            tooltip.style.display = "block";
        }

        function hideTooltip() {
            var tooltip = document.getElementById("tooltip");
            tooltip.style.display = "none";
        }
        document.addEventListener("DOMContentLoaded", function () {

            var id = getParameterByName('id');
            var titleElement = document.getElementById('todaymaintitle');
            var titleValue = titleElement.textContent;
            var kartIcerik = `@if (taskData != null) {
  @foreach (var task in taskData)
            {

<form action="/ToDoList/UpdateToDoText/${id}" method="post" id="delete-task-form" class="delete-task-form" style="width:100%;display: flex; align-items: center;overflow-x:hidden;padding-top:7px;">

            <input type="hidden" name="taskId" class="taskId">
    <input type="hidden" name="textContent" id="textContent" value="@task">
    <button type="button" onclick="deleteTodo(this)" id="delete-button" class="delete-button" style="margin-right: 5px;width:4%;background: none; border: none; display: flex; justify-content: center; align-items: center;">
        <img src="/icons/todo/delete3.png" width="30" height="30" style="padding: 0;cursor: pointer;">
    </button>
    <label class="task" style="display: flex; align-items: center;position:releative;">
        <input type="checkbox" name="taskCheckbox" class="taskCheckbox" onclick="clickToDoCheckbox(this); document.getElementById('delbutton').blur();" id="taskCheckbox" @(true ? "checked" : "")>
        <span class="custom-checkbox"  style="margin-top: auto;"></span>
        <input type="text" name="textContentVisible" class="textContent" style="position:absolute;text-decoration: line-through;width:80%;" id="textContentVisible" placeholder="Görev Ekle" value="@task">
        
 </label>
 @if (mainTitle != "Önemli")
    {
        <button type="button" style="margin-left:85%;width:4%;background: none; border: none;" onclick="addTaskImportant(this)" >
            <img src="/icons/todo/staradd.png" width="30" height="30" style="cursor: pointer;" id="logo">
        </button>
    }
 

  

</form>
