@inject IJsonHelper JsonHelper
@{
    ViewData["Title"] = "ToDoList";
    string[] taskData = ViewBag.TaskData;
    string[] notTaskData = ViewBag.NotTaskData;
    string mainTitle = ViewBag.TitleValue;

}
@{
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Pacifico&display=swap" rel="stylesheet">
<link href="~/css/todo.css" rel="stylesheet" />

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Responsive Tasarım</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .card {
            background-color: #f4f4f4;
            box-shadow: 2px 2px 5px rgba(0, 0, 0, 0.3);
            height: 100%;
        }

        .taskcontainer {
            max-height: 70%;
            overflow-y: overlay;
            margin-top: 20px;
        }

        .listelerim {
            margin-bottom: 20px;
        }

            .listelerim h3 {
                font-size: 18px;
                margin-bottom: 10px;
                color: #333;
            }

        .list-group {
            list-style: none;
            padding-left: 0;
        }

        .list-group-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 5px;
            margin-bottom: 5px;
        }


        .btn-secondary {
            background-color: antiquewhite;
            color: #212529; /* Metin rengi */
            border-color: #6c757d; /* Kenarlık rengi */
        }


        .dropdown-menu {
            width: 100%; /* Genişlik yüzde olarak belirlendi */
            max-width: 300px; /* Maksimum genişlik değeri */
            border: none;
        }
            .dropdown-menu .list-group-item:hover {
                background-color: #2eacb3; /* Üzerine gelince arka plan rengini yeşil yap */
            }
            .dropdown-menu .list-group-item a {
                color: black; 
                text-decoration: none; /* Alt çizgiyi kaldır */
            }
        #hover-effect:hover {
            background-color: #f0f0f0; /* Hafif gri arka plan rengi */
            border-radius: 5px; /* Köşeleri yuvarlak yapma */
        }

        .containerText {
            position: absolute; /* Formun konumunu mutlak olarak ayarlar */
            bottom: 0; /* Sayfanın en altına sabitler */
            left: 0; /* Sayfanın soluna sabitler */
            width: 93%; /* Sayfa genişliğini kaplar */
            z-index: 1000; /* Diğer öğelerin üzerinde olmasını sağlar */
            padding: 10px; /* İstenilen boşlukları ayarlar */
            
        }

            #containerbutton {
            position: absolute;
            bottom:20px;
            left: 100%;  
        }

       
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-3">
                <div id="hover-effect" class="d-flex align-items-center">
                    <img src="/icons/todo/sun.png" alt="Logo" class="logo" style="max-width: 50px; max-height: 50px;">
                    <label onclick="clickToday()" class="date">Günüm</label>
                </div>
                <br />
                <div class="d-flex align-items-center" id="hover-effect" style="padding-left: 1%;">
                    <i class="fa fa-star-o" style="font-size:45px;max-width: 50px; max-height: 50px; margin-right: 5px;"></i>
                    <span onclick="clickImportant()" style="font-size: x-large; margin-right: 5px; cursor: pointer;">Önemli</span>
                    <span id="ImportantId" style="display: none;">@ViewBag.ImportantId</span>
                </div>
                <hr class="horizontal-line">
                <div class="btn-group" style="width: -webkit-fill-available;">
                    <button type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false" style="height:50px; font-size: 18px; width: -webkit-fill-available; text-align: left;">
                        <img src="/icons/todo/deneme.png" alt="Logo" style="max-width: 20px; margin-right: 5px;">
                        Listelerim
                        <i class="fa fa-caret-down" style="font-size: 30px; float: right;"></i>
                    </button>

                    <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton" style="min-width: 100%">
                        @foreach (var item in ViewBag.ToDoList)
                        {
                            <li class="list-group-item" onclick="toggleAltMenu(this)">
                                <div class="d-flex align-items-center">
                                    <button type="button" class="btn btn-sm btn-outline-secondary mr-2" onclick="openPopup('@item.Id'); disableOtherButtons(this);">
                                        <img src="/icons/todo/düzenle.png" alt="Düzenle" style="max-width: 20px;">
                                    </button>
                                    <span style="font-size: 14px; margin-right: 10px;">
                                        <a href="#" style="margin-left: 8px;" class="link-item" data-id="@item.Id">@item.Title</a>
                                    </span>
                                </div>
                                <span id="count_@item.Id">@item.Count</span>
                                <input type="text"  value="@item.Id" id="todoIdvalue" style="display:none"></input>
                            </li>
                        }
                    </ul>
                </div>


                <form action="/ToDoList/ToDoListAddList/" method="post" class="add-task-formlist">
                    <div id="Containerlist" style="padding-top: 5%; display: flex; align-items: center;">
                        <input type="text" name="title" id="ekleButton2" class="addlist form-control" placeholder="Yeni Liste Oluştur" style="border: 1px solid grey; border-radius: 5px; padding: 5px; box-shadow: 0px 0px 5px rgba(0, 0, 0, 0.5); padding: 5px; width: 100%; margin-right: 5px; ">
                        <button type="submit" id="btn-prima" class="btn btn-primary" style="width:auto">Ekle</button>
                    </div>
                </form>



            </div>
            <div class="col-md-9">
                <div class="card" id="container2" style="width: 100%; height: 700px; overflow-y: hidden; background-color: #f4f4f4; background-image: url('/icons/todo/todo3.jpeg'); background-size: cover; background-position: center; display: flex; justify-content: center; box-shadow: 2px 2px 5px rgba(0, 0, 0, 0.3);">
                    <div class="card-body" style="position: relative; z-index: 1; width: 90%; height: 90%; margin: auto;">
                        <h1 style="font-size: 28px; font-weight: normal; color: white; margin: 0px; display: block;" id="todaymaintitle">@ViewBag.TitleValue</h1>
                        <h3 style="font-size: 18px; font-weight: normal; color: white; margin: 0px; display: block; margin-bottom: 2%"> <span id="currentDate"></span></h3>
                        <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: -1;">

                            <div class="card" id="cardpng" style="display:none;background-color: rgba(0, 0, 0, 0.2); padding: 20px; border-radius: 10px; text-align: center;">
                                <div style="text-align: center;">
                                    <img src="/icons/todo/calendar.png" alt="Your Image" class="img-fluid" style="max-width: 50%; max-height: 50px; margin-bottom: 10px;">
                                </div>
                                <h2 style="font-size: 20px; font-weight: bold; color: rgba(221, 221, 221, 0.7);">Gününüze odaklanın</h2>
                                <h2 style="font-size: 18px; font-weight: bold; color: rgba(221, 221, 221, 0.7);">Her gün yenilenen Günüm listesiyle işlerinizi tamamlayın.</h2>
                            </div>
                            <div class="card" id="cardpng2" style="display:none;background-color: rgba(0, 0, 0, 0.2); padding: 20px; border-radius: 10px; text-align: center;">
                                <div style="text-align: center;">
                                    <img src="/icons/todo/importantlogo.png" alt="Your Image" class="img-fluid" style="max-width: 50%; max-height: 50px; margin-bottom: 10px;">
                                </div>
                                <h2 style="font-size: 20px; font-weight: bold; color: rgba(221, 221, 221, 0.7);">Önemli listenize odaklanın</h2>
                                <h2 style="font-size: 18px; font-weight: bold; color: rgba(221, 221, 221, 0.7);">Önemli listesiyle işlerinizi tamamlayın.</h2>
                            </div>
                            <div class="card" id="cardpng3" style="display:none;background-color: rgba(0, 0, 0, 0.2); padding: 20px; border-radius: 10px; text-align: center;">
                                <div style="text-align: center;">
                                    <img src="/icons/todo/listlogo.png" alt="Your Image" class="img-fluid" style="max-width: 50%; max-height: 50px; margin-bottom: 10px;">
                                </div>
                                <h2 style="font-size: 20px; font-weight: bold; color: rgba(221, 221, 221, 0.7);">@ViewBag.TitleValue listenize odaklanın</h2>
                                <h2 style="font-size: 18px; font-weight: bold; color: rgba(221, 221, 221, 0.7);">@ViewBag.TitleValue listesiyle işlerinizi tamamlayın.</h2>
                            </div>
                        </div>
                        <div class="taskcontainer" id="kartContainer2">
                        </div>
