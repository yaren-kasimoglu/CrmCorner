}
function addtodo() {
    // Kartın içeriği
    var kartIcerik2 = `
                <div>
            <img src="/icons/todo/delete2.png" id="delbutton" onclick="deleteToDo(this)" width="30" height="30"  style="margin-right:1%;margin-left:-8%;cursor: pointer;float: left;">
          <label class="task" >
             <input type="checkbox" class="taskCheckbox" id="taskCheckbox" onclick="clickToDoCheckbox(this)">
             <span class="custom-checkbox"></span>
             <input type="text" name="textContent" class="textContent"  id="textContent" placeholder="Görev Ekle">
           </label>
           </div>
    `;
    // Kartı kartContainer içine ekle
    $('#kartContainer2').append(kartIcerik2);
}

    $(document).on('keyup', '.textInput2', function (event) {
        console.log("girdi")
        if (event.keyCode === 13) {
            event.preventDefault();
            addtodo();
        }
});

$("#ekleButton2").keyup(function (event) {
    if (event.keyCode === 13) {
        var inputElement = document.getElementById("ekleButton2");
        var toDoTitleList = inputElement.value;
        $.ajax({
            type: 'POST',
            url: "/ToDoList/ToDoListAddList/",
            encode: true,
            data: { title: toDoTitleList },
            dataType: "json",
            success: function () {
                location.reload();
            }
        });
    }

});


function clickToDoCheckbox(checkbox) {
    var label = checkbox.parentElement.querySelector('input[type="text"]');
    if (checkbox.checked) {
        label.style.textDecoration = "line-through";

    } else {
        label.style.textDecoration = "none";
    }
}
function textVisibleshow() {
    var inputElement = document.getElementById("textInput");
    inputElement.style.textDecoration = "none";
}

function textVisible() {
    var inputElement = document.getElementById("textInput");
    inputElement.style.textDecoration = "none"; //
}


 function deleteToDo(item) {
        if (confirm("Gerçekten silmek istiyor musunuz?")) {
            var label = item.parentElement.querySelector('input[type="text"]');
            var checkbox = item.parentElement.querySelector('.taskCheckbox');
            console.log(label.value);
            console.log(checkbox.checked);
            var inputElement = document.getElementById("todoId");
            var todoListId = 0;
            if (inputElement != null && typeof inputElement.value !== "undefined")
                todoListId = inputElement.value;
            $.ajax({
                type: 'POST',
                url: "/ToDoList/DeleteToDo/",
                encode: true,
                data: { selectedItem: label.value, itemId: todoListId },
                dataType: "json",
                success: function () {
                    if (todoListId != 0)
                        showItem(inputElement.value);
                    else
                        show();
                    clear();
                    if (todoListId != 0) {
                        var countElement = document.getElementById("count_" + todoListId);
                        if (countElement && !checkbox.checked) {
                            var currentCount = parseInt(countElement.innerText); // Mevcut count değerini al
                            countElement.innerText = currentCount - 1; // Count değerini 1 artırarak güncelle
                        }
                    }

                }

            });


            return false;
        }


 }

function save() {
    var taskLabels = document.querySelectorAll('.task');
    var selectedTaskTexts = [];
    var notselectedTaskTexts = [];
    var toDoTitle = document.querySelector(".main-title").innerText;

    taskLabels.forEach(function (label) {
        var checkbox = label.querySelector('.taskCheckbox');
        var textInput = label.querySelector('input[type="text"]');
        if (textInput.value !=null) {
            if (checkbox.checked) {
                selectedTaskTexts.push(textInput.value.trim());
            }
            else {
                notselectedTaskTexts.push(textInput.value.trim());
            }
        }

    });

    var temizlenmisDizi = notselectedTaskTexts.filter(function (item) {
        return item.trim() !== ''; // Boş dize olmayanları filtrele
    });

    console.log(temizlenmisDizi.length);
    console.log(notselectedTaskTexts);
    var selectedTaskTextsString1 = selectedTaskTexts.join(",");
    var notselectedTaskTextsString1 = notselectedTaskTexts.join(",");
    var selectedTaskTextsString= selectedTaskTextsString1.replace(/^,|,$/g, '');
    var notselectedTaskTextsString=notselectedTaskTextsString1.replace(/^,|,$/g, '');
    var inputElement = document.getElementById("todoId");
    var todoListId = 0;
    if (inputElement != null && typeof inputElement.value !== "undefined")
        todoListId = inputElement.value;
    $.ajax({
        type: 'POST',
        url: "/ToDoList/ToDoListAdd/",
        encode: true,
        data: { selected: selectedTaskTextsString, unselected: notselectedTaskTextsString, title: toDoTitle, itemId: todoListId },
        success: function (data) {
            if (todoListId != 0) {
                showItem(todoListId);
            }
            else
                show();
            clear();
            if (todoListId != 0) {
                var countElement = document.getElementById("count_" + todoListId);
                if (countElement) {
                    console.log(notselectedTaskTexts.length);
                    var currentCount = temizlenmisDizi.length; // Mevcut count değerini al
                    countElement.innerText = currentCount; // Count değerini 1 artırarak güncelle
                }
            }
        }
    });

}

document.querySelector(".close").addEventListener("click", function () {
    // Modalı gizle
    document.getElementById("myModal").style.display = "none";
    location.reload();

});

    function clear() {
        document.getElementById("textInput").value = "";
        var checkbox = document.getElementById("taskCheckbox");
        if (checkbox.checked) {
            checkbox.checked = false;
        }
        var textInput = document.getElementById("textInput");
        if (textInput.value.trim() !== "") {
            textInput.style.textDecoration = "line-through";
        } else {
            textInput.style.textDecoration = "none";
        }
    }

</script>
<style>
    .popup-containeredit {
        background-color: white;
        border-radius: 10px; /* Yuvarlak kenarlar */
        box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.5); /* Gölgeli efekt */
        padding: 20px;
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 9999;
    }
    .popup-content text {
        font-size: 16px; /* Metin boyutunu ayarla (örneğin 16 piksel) */
    }
    .main-title {
        text-align: center;
        font-size: 32px;
        font-weight: normal; /* Yazı tipi ağırlığı azaltıldı */
        color: #333;
        margin: 0;
    }
    .selected {
        ransform: scale(1.1); /* Seçilen elemanın boyutunu artırır */
        transition: transform 0.2s ease; /* Dönüşümün yumuşak olması için geçiş efekti ekler */
        border: 1px solid #ccc; /* Çizgi stilini belirler */
        border-radius: 10px;
    }
    .dropbtn {
        background-color: #f1f1f1;
        color: black;
        padding: 10px;
        font-size: 16px;
        border: none;
        cursor: pointer;
    }

    /* Açılır menü içeriği stilleri */
        .dropdown-content {
        display: none;
        position: absolute;
        background-color: #f1f1f1;
        min-width: 160px;
        z-index: 1;
    }

        /* Açılır menü içeriğini göstermek için */


        /* Açılır menü içeriği linkleri */
        .dropdown-content a {
            color: black;
            padding: 12px 16px;
            text-decoration: none;
            display: block;
        }

            /* Açılır menü içeriği linklerinin üzerine gelindiğinde */
            .dropdown-content a:hover {
                background-color: #ddd;
            }

    .close {
        border: 1px solid #ccc; /* Kenar çizgisi */
        padding: 5px 10px; /* İç boşluk */
        background-color: #f9f9f9; /* Arka plan rengi */
        cursor: pointer;
        width: fit-content;
        text-align: end;
    }

    .modal {
        display: none;
        position: fixed;
        z-index: 1000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
        background-color: rgba(0,0,0,0.5);
    }

    .modal-content {
        background-color: #fefefe;
        margin: 15% auto;
        padding: 20px;
        border: 1px solid #888;
        width: 50%;
    }

    /* Kapatma düğmesi stilleri */

    #container4 {
        display: flex;
        flex-direction: column; /* Öğeleri dikey olarak hizalar */
    }

    #container3 {
        flex-direction: column;
        margin: 7% 0px 0px -17%;
        padding-top: 10px;
