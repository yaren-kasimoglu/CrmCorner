                    error: function (xhr, status, error) {
                        console.error("Görev eklenirken bir hata oluştu: " + error);
                        // Hata durumunda yapılacak işlemler buraya gelebilir
                    }
                });

                // Modalı kapat (isteğe bağlı)
                var modalElement = document.getElementById('peopleModal');
                var modal = bootstrap.Modal.getInstance(modalElement);
                modal.hide();

            } catch (error) {
                console.error('Fetch error:', error);
                // Hata durumunda kullanıcıya bildirim yapabilirsiniz
            }
        }
