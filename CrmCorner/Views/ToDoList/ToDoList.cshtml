@inject IJsonHelper JsonHelper
@{
    ViewData["Title"] = "ToDoList";
    string[] taskData = ViewBag.TaskData;
    string[] notTaskData = ViewBag.NotTaskData;

}
@{
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Pacifico&display=swap" rel="stylesheet">
<link href="~/css/todo.css" rel="stylesheet" />


<div class="wrapper" style="margin-top:-10%">
    <div class="container">
        <div class="row">
            <div class="col-md-3">
                <div id="container1">
                    <img src="~/icons/todo/sun.png" alt="Logo" class="logo" style="max-width: 50px; max-height: 50px;">
                    <label onclick="show()" class="date">Günüm</label>
                </div>
                <div class="horizontal-line" style="padding-bottom:15px;width: 97%;margin-left: 1%;"></div>
                <ul class="list-group" style="width: 100%;">
                    @foreach (var item in ViewBag.ToDoList)
                    {
                        <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2" onclick="showItem(@item.Id)">
                            <div class="d-flex align-items-center">
                                <button type="button" class="btn btn-sm btn-outline-secondary mr-2" onclick="openPopup('@item.Id'); disableOtherButtons(this);"><img src="~/icons/todo/düzenle.png" alt="Düzenle" style="max-width: 20px;"></button>
                                <img src="~/icons/todo/deneme.png" alt="Logo" style="max-width: 30px; margin-right: 10px;" />
                                <span style="font-size: 14px; margin-right: 5px;">@item.Title</span>
                            </div>
                            <span id="count_@item.Id">@item.Count</span> <!-- id'yi unique hale getir -->
                            <label id="todoId" style="display:none">@item.Id</label> <!-- id değeri gizli bir şekilde burada tutulabilir -->
                        </a>
                    }
                </ul>
                <div id="Containerlist">
                    <input type="text" id="ekleButton2" class="addlist"  style="width: 100%;" placeholder="Liste Ekle..">
                </div>
            </div>
            <div class="col-md-9">
                <div class="container" id="container2">
                    <div class="card" style="background-color: #f4f4f4;box-shadow: 2px 2px 5px rgba(0, 0, 0, 0.3); border: 2px solid #2eacb3;">
                        <div class="card-header" style=" background-color: #f4f4f4; text-align: center; font-size: 32px; font-weight: normal;color: #333; margin: 0;" id="todaymaintitle">Günüm</div>
                        <div class="card-body">
                                <h1 class="main-title"></h1>
                            <div class="todo-list">
                                <table class="table">
                                    <tr>
                                        <td>
                                            <label class="task">
                                                <input type="checkbox" class="taskCheckbox" id="taskCheckbox" onclick="clickToDoCheckbox(this)">
                                                <span class="custom-checkbox"></span>
                                                <input type="text" name="textValue" class="textInput2" id="textInput" placeholder="Görev Ekle">
                                            </label>
                                            <div class="taskcontainer" id="kartContainer2"></div>
                                        </td>

                                    </tr>
                                </table>
                            </div>
                            <div class="text-end mt-3">
                                <button type="submit" id="deleteToDoList" class="btn btn-danger btn-sm" style="width:auto;visibility:hidden" onclick="deleteToDoList(this)">Listeyi Sil</button>
                                <button type="submit" class="btn btn-primary btn-sm" style="width:auto" onclick="save()">Kaydet</button>
                            </div>
                            <div id="myModal" class="modal">
                                <div class="modal-content">
                                    <p>Kaydedildi!</p>
                                    <span class="close">Tamam</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>



<script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>


<script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.1/dist/js/bootstrap.bundle.min.js" integrity="sha384-gtEjrD/SeCtmISkJkNUaaKMoLD0//ElJ19smozuHV6z3Iehds+3Ulb9Bn9Plx0x4" crossorigin="anonymous"></script>



<script>
    function openPopup(itemId) {

        $.ajax({
            type: 'GET',
            url: '/ToDoList/GetTitle/',
            data: { id: itemId },
            success: function (data) {
                // Bilgi metni
                var title = data.message;
                var infoText = "Liste adınızı güncellemek için aşağıdaki kutucuğa giriniz.";
                // Popup içeriğini oluştur
                var popupContent = '<p>' + infoText + '</p>' +
                    '<input type="text" value="' + title + '" onkeypress="handleKeyPress(event, ' + itemId + ')" id="editInput"  style="outline:none;border-bottom:1px solid #333;box-shadow:0px 0.3px 0.9px rgba(0,0,0,0.1), 0px 1.6px 3.6px rgba(0,0,0,0.1);border:none;font-size:x-large;border: outset;width:-webkit-fill-available">';

                var popupDiv = document.createElement('div');
                popupDiv.innerHTML = popupContent;
                popupDiv.classList.add('popup-containeredit');
                popupDiv.innerHTML = popupContent;
                popupDiv.style.backgroundColor = 'white';
                popupDiv.style.border = '1px solid black';
                popupDiv.style.padding = '20px';
                popupDiv.style.position = 'fixed';
                popupDiv.style.top = '50%';
                popupDiv.style.left = '50%';
                popupDiv.style.transform = 'translate(-50%, -50%)';
                popupDiv.style.zIndex = '9999';

                // Overlay divini oluştur
                var overlayDiv = document.createElement('div');
                overlayDiv.style.backgroundColor = 'rgba(0, 0, 0, 0.5)';
                overlayDiv.style.position = 'fixed';
                overlayDiv.style.top = '0';
                overlayDiv.style.left = '0';
                overlayDiv.style.width = '100%';
                overlayDiv.style.height = '100%';
                overlayDiv.style.zIndex = '9998';

                // Overlay'e tıklandığında popup'ı kapat
                overlayDiv.addEventListener('click', function () {
                    document.body.removeChild(popupDiv);
                    document.body.removeChild(overlayDiv);
                });

                // Popup ve overlay divlerini sayfaya ekle
                document.body.appendChild(overlayDiv);
                document.body.appendChild(popupDiv);

                // Edit input alanını seç ve odaklan
                var editInput = document.getElementById('editInput');
                console.log(editInput.value);
                editInput.focus();
            }
         });
    }
    function handleKeyPress(event, itemId) {
        if (event.key === 'Enter') {
            updateTitle(itemId);
        }
    }
    function updateTitle(itemId) {
        var newTitle = document.getElementById('editInput').value;
        console.log(newTitle);
        $.ajax({
            type: 'POST',
            url: "/ToDoList/UpdateTitle/",
            encode: true,
            data: { itemId: itemId, newtitle: newTitle },
            dataType: "json",
            success: function () {
                location.reload();
            }

        });
        var editButtons = document.querySelectorAll('.list-group-item button');

        // Tüm düğmelerin tıklanabilirliğini geri yükle
        editButtons.forEach(function (button) {
            button.disabled = false;
        });
    }
    function disableOtherButtons(clickedButton) {
        // Tüm düzenleme düğmelerini seç
        var editButtons = document.querySelectorAll('.list-group-item button');

        // Tıklanan düğmeyi hariç, diğer düğmelerin tıklanabilirliğini devre dışı bırak
        editButtons.forEach(function (button) {
            if (button !== clickedButton) {
                button.disabled = true;
            }
        });
    }
    document.addEventListener("DOMContentLoaded", function () {
            var kartIcerik = `@if (taskData != null) {
            @foreach (var task in taskData)
            {
                <div>
            <img src="/icons/todo/delete2.png" id="delbutton" onclick="deleteToDo(this)" width="30" height="30" style="margin-right:1%;margin-left:-8%;cursor: pointer;float: left;">
        <label class="task">
             <input type="checkbox" class="taskCheckbox" onclick="clickToDoCheckbox(this)" id="taskCheckbox" @(true ? "checked" : "")>
        <span class="custom-checkbox"></span>
             <input type="text" name="textContent" class="textContent" style="text-decoration:line-through"  id="textContent" placeholder="Görev Ekle" value="@task">
        </label>
            </div>
        }
                }
            `;

      var kartIcerik2 = `@if (notTaskData != null) {
                @foreach (var task2 in notTaskData)
            {
               <div>
            <img src="/icons/todo/delete2.png" id="delbutton" onclick="deleteToDo(this)" width="30" height="30" style="margin-right:1%;margin-left:-8%;cursor: pointer;float: left;">
          <label class="task" >
        <input type="checkbox" class="taskCheckbox" onclick="clickToDoCheckbox(this);document.getElementById('delbutton').blur();" id="taskCheckbox" @(false ? "checked" : "")>
        <span class="custom-checkbox"></span>
        <input type="text" name="textValue" class="textInput2"  id="textInput" placeholder="Görev Ekle"  value="@task2">
            </label>
             </div>
            }
                }
            `;

    var toplam = kartIcerik + kartIcerik2;
    $('#kartContainer2').append(toplam);
    });


    function deleteToDoList(item) {
        if (confirm("Gerçekten silmek istiyor musunuz?")) {
            var inputElement = document.getElementById("todoId");
            console.log(inputElement.value);
            $.ajax({
                type: 'POST',
                url: "/ToDoList/DeleteToDoList/",
                encode: true,
                data: { itemId: inputElement.value },
                dataType: "json",
                success: function () {
                    location.reload();
                }

            });
        }

    }


    function show() {
        console.log("show a girdi");
    document.getElementById("todaymaintitle").style.display = "block";
    var mainTitle = document.querySelector('.main-title');
    mainTitle.style.display = 'none';
    var labelElement = document.getElementById("todoId");
    console.log(labelElement);

    if (labelElement !== null) {
        // labelElement değişkeni bir değer içeriyorsa (null değilse)
        labelElement.value = 0;
    } else {
        // labelElement değişkeni null ise (hiçbir öğe bulunamazsa)
        console.log("todoId elementi bulunamadı.");
        // Değer yoksa, 0 atama
        labelElement = 0;
    }
    document.getElementById("deleteToDoList").style.visibility = "hidden";
    $.ajax({
        type: 'POST',
        url: "/ToDoList/ToDoListDay/",
        encode: true,
        dataType: "json",
        success: function (data) {
            var baslik = data.message.title;
            $(".main-title").text(baslik);
            var kartIcerik = '';
            var kartIcerik2 = '';
            if (data.message.taskData != null) {
                for (var i = 0; i < data.message.taskData.length; i++) {
                    var task = data.message.taskData[i];
                    kartIcerik += `
                       <div>
            <img src="/icons/todo/delete2.png" id="delbutton" onclick="deleteToDo(this)" width="30" height="30" style="margin-right:1%;margin-left:-8%;cursor: pointer;float: left;">
        <label class="task">
             <input type="checkbox" class="taskCheckbox" onclick="clickToDoCheckbox(this)" id="taskCheckbox" @(true ? "checked" : "")>
        <span class="custom-checkbox"></span>
             <input type="text" name="textContent" class="textContent" style="text-decoration:line-through"  id="textContent" placeholder="Görev Ekle" value="${task}">
        </label>
            </div>`;

                }
            }
            if (data.message.notTaskData != null) {
                for (var i = 0; i < data.message.notTaskData.length; i++) {
                    var task2 = data.message.notTaskData[i];
                    kartIcerik2 += `
                      <div>
                        <img src="/icons/todo/delete2.png" id="delbutton" onclick="deleteToDo(this)" width="30" height="30"  style="margin-right:1%;margin-left:-8%;cursor: pointer;float: left;">
              <label class="task">
        <input type="checkbox" class="taskCheckbox"  id="taskCheckbox"  onclick="clickToDoCheckbox(this)" @(false ? "checked" : "")>
        <span class="custom-checkbox"></span>
             <input type="text" name="textContent" class="textContent"  id="textContent" placeholder="Görev Ekle" value="${task2}">
            </label>
             </div>`;
                }
            }
            $('#kartContainer2').empty();
            var toplam = kartIcerik + kartIcerik2;
            $('#kartContainer2').append(toplam);
        }
    });

}
