@model CrmCorner.Models.PipelineTask
@using CrmCorner.Extensions
@using CrmCorner.Models.Enums
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "PipelineEdit";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";

    var stageList = new SelectList(Enum.GetValues(typeof(PipelineStage)).Cast<PipelineStage>(), Model.Stage);
    var outcomeList = new SelectList(Enum.GetValues(typeof(OutcomeType)).Cast<OutcomeType>(), Model.Outcomes);
}

<h3 class="mb-4">Görev Düzenle</h3>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger" role="alert">
        @TempData["ErrorMessage"]
    </div>
}

@if (ViewBag.DebugErrors != null)
{
    <div class="alert alert-warning">
        <ul>
            @foreach (var err in ViewBag.DebugErrors)
            {
                <li>@err.Field : @string.Join(", ", err.Errors)</li>
            }
        </ul>
    </div>
}



<form asp-action="PipelineEdit" asp-controller="PipelineTask" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="row">
        <div class="col-md-6">
            <div class="form-group mb-3">
                <label asp-for="Title">Başlık</label>
                <input asp-for="Title" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Value">Değer</label>
                <div class="input-group">
                    <input asp-for="Value" class="form-control" />
                    <select asp-for="Currency" class="form-select" style="max-width: 100px;">
                        <option value="$">$</option>
                        <option value="€">€</option>
                        <option value="₺">₺</option>
                    </select>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Stage">Aşama</label>
                <select asp-for="Stage" asp-items="ViewBag.StageList" class="form-select" id="Stage">
                    <option value="">Lütfen seçiniz</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ExpectedCloseDate">Beklenen Kapanış Tarihi</label>
                <input asp-for="ExpectedCloseDate" type="date" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Outcomes">Süreç Durumu</label>
                <select asp-for="Outcomes" asp-items="outcomeList" class="form-select"></select>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="control-label">Açıklama</label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="OutcomeStatus">Sonuç</label>
                @Html.DropDownListFor(model => model.OutcomeStatus,
                new SelectList(
                Enum.GetValues(typeof(OutcomeTypeSales)).Cast<OutcomeTypeSales>().Select(e =>
                new SelectListItem { Text = EnumExtensions.GetDisplayName(e), Value = e.ToString() }
                ),
                "Value", "Text"
                ),
                                "Seçiniz",
                                new { @class = "form-control", id = "outcomeStatusDropdown" }
                                )
            </div>

            <div class="form-group" id="negativeReasonGroup" style="display:none;">
                <label for="NegativeReason">Olumsuz Sebep</label>
                @Html.TextBoxFor(model => model.NegativeReason, new { @class = "form-control", placeholder = "Neden kaybedildi?" })
                <span asp-validation-for="NegativeReason" class="text-danger"></span>
            </div>

            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="contactedViaLinkedIn" name="ContactedViaLinkedIn"
                       value="true" @(Model.ContactedViaLinkedIn == true ? "checked" : "") />
                <input type="hidden" name="ContactedViaLinkedIn" value="false" />
                <label class="form-check-label" for="contactedViaLinkedIn">LinkedIn ile iletişim kuruldu</label>
            </div>

            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="contactedViaColdCall" name="ContactedViaColdCall"
                       value="true" @(Model.ContactedViaColdCall == true ? "checked" : "") />
                <input type="hidden" name="ContactedViaColdCall" value="false" />
                <label class="form-check-label" for="contactedViaColdCall">Soğuk arama yapıldı</label>
            </div>
        </div>

        <div class="col-md-6">
            <div class="form-group mb-3">
                <label asp-for="CustomerId">Müşteri</label>
                <select asp-for="CustomerId" asp-items="ViewBag.Customer" class="form-select">
                    <option value="">Lütfen seçiniz</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="AppUserId">Görüşmeyi Alan</label>
                <select asp-for="AppUserId" asp-items="ViewBag.Users" class="form-select">
                    <option value="">Lütfen seçiniz</option>
                </select>
                <span asp-validation-for="AppUserId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ResponsibleUserId">Sorumlu Kullanıcı</label>
                <select asp-for="ResponsibleUserId" asp-items="ViewBag.Users" class="form-select">
                    <option value="">Lütfen seçiniz</option>
                </select>
                <span asp-validation-for="ResponsibleUserId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CustomerName">Ad</label>
                <input asp-for="CustomerName" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="CustomerSurname">Soyad</label>
                <input asp-for="CustomerSurname" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="CompanyName">Şirket</label>
                <input asp-for="CompanyName" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Phone">Telefon</label>
                <input asp-for="Phone" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Email">E-posta</label>
                <input asp-for="Email" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="LinkedinUrl">LinkedIn URL</label>
                <input asp-for="LinkedinUrl" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Source">Kaynak</label>
                <input asp-for="Source" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="SourceChannel">Kanal</label>
                <select asp-for="SourceChannel" asp-items="ViewBag.SourceChannels" class="form-select">
                    <option value="">Lütfen seçiniz</option>
                </select>
                <span asp-validation-for="SourceChannel" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" id="submitBtn" class="btn btn-primary">Güncelle</button>
        <a href="/PipelineTask/PipelineIndex" class="btn btn-secondary">İptal</a>
        <a href="/PipelineTask/PipelineDetails/@Model.Id" class="btn btn-info">Detay Sayfasına Git</a>
    </div>

</form>


<script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>

@section Scripts {
    <script>
        $(document).ready(function () {
            function toggleNegativeReason() {
                var outcome = $('#outcomeStatusDropdown').val();
                if (outcome === 'Lost') {
                    $('#negativeReasonGroup').show();
                } else {
                    $('#negativeReasonGroup').hide();
                    $('#NegativeReason').val('');
                }
            }

            $('#outcomeStatusDropdown').change(toggleNegativeReason);
            toggleNegativeReason();
        });
    </script>


    <script>
        $(function () {
          // Elemanlar
          const $outcomes = $('#Outcomes');                 // asp-for="Outcomes"
          const $status   = $('#outcomeStatusDropdown');    // Sonuç (OutcomeStatus)
          const $negGrp   = $('#negativeReasonGroup');      // Olumsuz Sebep alan grubu (div)
          const $negTxt   = $('#NegativeReason');           // Olumsuz Sebep textbox
          const $submit   = $('#submitBtn');                // Kaydet/Güncelle butonu
          const bannerId  = 'reportBanner';

          // Önceki değer (Tutarlılık kilidi için geri al)
          let prevOutcome = $outcomes.val();

          function ensureBanner() {
            let $b = $('#' + bannerId);
            if ($b.length === 0) {
              $b = $('<div>', { id: bannerId, class: 'alert alert-warning mt-3', style: 'display:none;' });
              // Sonuç dropdown'unun altına ekle
              $status.closest('.form-group').append($b);
            }
            return $b;
          }
          function showBanner(msg) { const $b = ensureBanner(); $b.text(msg).show(); }
          function hideBanner()    { const $b = ensureBanner(); $b.hide().text(''); }

          function applyRules() {
            const o = ($outcomes.val() || '').trim();  // Surecte | Olumlu | Olumsuz
            const s = ($status.val()   || '').trim();  // None | Won | Lost | "" (Seçiniz)

            // 1) Süreçte iken Sonuç kilidi: otomatik None + disable
            if (o === 'Surecte') {
              if (s !== 'None') { $status.val('None').trigger('change'); }
              $status.prop('disabled', true);
            } else {
              $status.prop('disabled', false);
            }

            // 2) Tutarlılık kilidi: Won/Lost seçiliyken Outcomes'u "Süreçte"ye çekemez
            if ((s === 'Won' || s === 'Lost') && o === 'Surecte') {
              alert('Sonuç "Kazanıldı/Kaybedildi" seçiliyken "Süreçte" yapılamaz. Önce sonucu "Hiçbiri" yapın.');
              // Geri al
              $outcomes.val(prevOutcome).trigger('change');
              return;
            }

            // 3) Negatif gerekçe görünürlüğü
            if (o === 'Olumsuz' || s === 'Lost') {
              $negGrp.show();
            } else {
              $negGrp.hide();
              $negTxt.val('');
            }

            // 4) Raporlama standardı banner: Olumlu & None → uyarı
            if (o === 'Olumlu' && s === 'None') {
              showBanner('Uyarı: Sonuç belirlenmedi, raporlarda “Açık” görünecek.');
            } else {
              hideBanner();
            }

            // Submit butonu default açık kalsın (engellemeleri submit’te yapacağız)
          }

          // Submit sırasında son kontroller
          $('form').on('submit', function (e) {
            const o = ($outcomes.val() || '').trim();
            const s = ($status.val()   || '').trim();
            const neg = ($negTxt.val() || '').trim();

            // Süreçte iken Sonuç Won/Lost olamaz
            if (o === 'Surecte' && (s === 'Won' || s === 'Lost')) {
              e.preventDefault();
              alert('Süreçte iken sonuç "Kazanıldı/Kaybedildi" olamaz. Lütfen sonucu "Hiçbiri" yapın.');
              return false;
            }

            // Olumlu iken Kaybedildi olamaz
            if (o === 'Olumlu' && s === 'Lost') {
              e.preventDefault();
              alert('Süreç durumu "Olumlu" iken sonuç "Kaybedildi" olamaz.');
              return false;
            }

            // Olumsuz iken Kazanıldı olamaz
            if (o === 'Olumsuz' && s === 'Won') {
              e.preventDefault();
              alert('Süreç durumu "Olumsuz" iken sonuç "Kazanıldı" olamaz.');
              return false;
            }

            // Negatif gerekçe zorunlu: Outcomes=Olumsuz veya OutcomeStatus=Lost
            if ((o === 'Olumsuz' || s === 'Lost') && !neg) {
              e.preventDefault();
              alert('Olumsuz durumda "Olumsuz Sebep" zorunludur.');
              $negGrp.show(); $negTxt.focus();
              return false;
            }
          });

          // Değişim yakalayıcılar
          $outcomes.on('focus', function(){ prevOutcome = $outcomes.val(); });
          $outcomes.on('change', function(){ applyRules(); prevOutcome = $outcomes.val(); });
          $status.on('change', applyRules);

          // İlk yüklemede uygula
          applyRules();
        });
    </script>
}
