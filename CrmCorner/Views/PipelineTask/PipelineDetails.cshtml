@model CrmCorner.Models.PipelineTask
@using CrmCorner.Models.Enums
@using CrmCorner.Extensions

@{
    ViewData["Title"] = "PipelineDetails";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

@section Styles {
    <style>
        .highlight {
            background-color: #f8f9fa;
            padding: 20px;
        }

        .ellipsis {
            max-width: 160px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            display: block;
        }

        .buyukYazi {
            font-size: 20px;
        }
    </style>
}

<div class="container-fluid">
    <div class="row g-2">
        <div class="col-lg-4 col-md-12">
            <div class="card mb-2">
                <div class="card-body">
                    <h6 class="card-title mb-4">Detaylar/Notlar</h6>
                    <p>@Model.Description</p>
                    <span class="buyukYazi badge badge-light text-danger border border-danger">
                        @EnumExtensions.GetDisplayName(Model.Outcomes)
                    </span>
                </div>
            </div>

            <div class="card mb-2">
                <div class="card-body">
                    <ul class="list-unstyled basic-list mb-0">
                        <li class="d-flex justify-content-between mb-3">Sorumlu:<span class="badge bg-primary">@Model.AppUser?.NameSurname</span></li>
                       @*  <li class="d-flex justify-content-between mb-3">Görev Oluşturma Tarihi:<span class="bg-success badge">@Model.CreatedDate?.ToString("dd.MM.yyyy")</span></li> *@
                       @*  <li class="d-flex justify-content-between mb-3">Güncel Durum:<span class="bg-info badge">@Model.Status?.StatusName</span></li>
                        <li class="d-flex justify-content-between mb-3">Satış Kapatma Tarihi:<span class="bg-danger badge">@Model.SalesDone?.ToString("dd.MM.yyyy")</span></li>
                        <li class="d-flex justify-content-between mb-3">Değer Teklifi:<span class="bg-warning badge">@Model.ValueOrOffer?.ToString("N2")</span></li>
                        <li class="d-flex justify-content-between mb-3">Kayıt Nereden Geldi?<span class="badge bg-primary">@Model.HeardFrom</span></li> *@
                    </ul>
                </div>
            </div>

            <div class="card mb-2">
                <div class="card-header">
                    <h6 class="card-title">Müşteri-Firma Bilgileri</h6>
                </div>
                <div class="card-body">
                    @if (Model.Customer != null)
                    {
                        <div class="w-100 d-flex align-items-start">
                            <img class="rounded-circle" src="~/userprofilepicture/firm.png" alt="user" width="50">
                            <div class="wid-u-info ms-3">
                                <h5 class="mb-0">@Model.Customer.CompanyName</h5>
                                <br />
                                <span>E-Posta: @Model.Customer.CompanyEmail</span>
                                <br />
                                <span>Sektör: @EnumExtensions.GetDisplayName(Model.Customer.Industry)</span>
                                <br />
                                <span class="message">Çalışan Sayısı: @EnumExtensions.GetDisplayName(Model.Customer.EmployeeCount)</span>
                            </div>
                        </div>
                        <hr>
                        <ul class="right_chat list-unstyled mb-0">
                            <li class="offline">
                                <a class="d-flex mb-3" href="/Customer/CustomerList">
                                    <img class="rounded-circle" src="~/userprofilepicture/defaultpp.png" width="35" height="35" alt="" />
                                    <div class="ms-3 w-100 text-muted">
                                        <span class="name d-block">@Model.Customer.Name</span>
                                        <span class="message">@Model.Customer.CustomerEmail</span>
                                        <br />
                                        <span class="message">@Model.Customer.PhoneNumber</span>
                                        <br />
                                        <span class="message">@Model.Customer.CustomerTitle</span>
                                    </div>
                                </a>
                                <br />
                          @*       <span class="badge badge-dark text-dark border border-dark message">
                                    Son Karar Mercii :
                                    @if (Model.IsFinalDecisionMaker)
                                    {
                                        <i class="fa fa-check-circle" style="color: green;"></i>
                                    }
                                    else
                                    {
                                        <i class="fa fa-times-circle" style="color: red;"></i>
                                    }
                                </span> *@
                            </li>
                        </ul>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            Müşteri bilgisi bulunamadı.
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-8 col-md-12">
            <div class="card mb-2">
                <div class="card-body">
                    <a href="@Url.Action("EditPipelineTask", "PipelineTask", new { id = Model.Id })" class="btn btn-primary mb-3">Görevi Düzenle</a>

                    @if (ViewBag.Logs != null && (ViewBag.Logs as List<CrmCorner.Models.PipelineTaskLog>)?.Any() == true)
                    {
                        foreach (var log in ViewBag.Logs as List<CrmCorner.Models.PipelineTaskLog>)
                        {
                            var timelineClass = log.LogId % 2 == 0 ? "timeline-item blue" : "timeline-item green";
                            <div class="@timelineClass">
                                <div class="timeline-badge primary"><i class="glyphicon glyphicon-record"></i></div>
                                <div class="timeline-panel">
                                    <div class="timeline-heading">
                                        <h5><small class="text-muted">@log.UpdatedAt?.ToString("dd.MM.yyyy HH:mm")</small></h5>
                                        <h6 class="timeline-title">@log.UpdatedField</h6>
                                    </div>
                                    <div class="timeline-body">
                                        <p>@log.OldValue <i class="fa fa-long-arrow-right"></i> @log.NewValue</p>
                                        <p>Düzenleyen: @log.UpdatedBy?.NameSurname</p>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p>Henüz bir değişiklik yapılmadı.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>
    <script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>
}
