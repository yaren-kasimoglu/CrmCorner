@section Scripts {

 <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Bootstrap JS -->
    @*      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta1/dist/js/bootstrap.bundle.min.js"></script>*@

    <script>
        var triggerTabList = [].slice.call(document.querySelectorAll('.nav-tabs a'))
        triggerTabList.forEach(function (triggerEl) {
            var tabTrigger = new bootstrap.Tab(triggerEl)

            triggerEl.addEventListener('click', function (event) {
                event.preventDefault()
                tabTrigger.show()
            })
        })

    </script>

@*    AÇILACAK SOSYAL MEDYADAN SONRA     
    <script type="text/javascript">
            $(document).ready(function () {
                $.ajax({
                    type: "GET",
                    url: "/Home/UserTaskStatusChart",
                    contentType: "application/json; charset=utf-8",
                    dataType: "json",
                    success: function (data) {
                        console.log(data); // Gelen veriyi kontrol etmek için bu satırı ekleyin
                        var ctx = document.getElementById('userTaskStatusChart').getContext('2d');
                        var colors = ['#2eacb3', '#FED049', '#2D6187', '#89BEB3', '#FF9A76', '#8bc3fe'];

                        // Gelen veri yapısına göre haritalama yapalım
                        var labels = data.map(item => item.statusName);
                        var dataValues = data.map(item => item.count);
                        var taskNames = data.map(item => item.taskNames);

                        new Chart(ctx, {
                            type: 'doughnut',
                            data: {
                                labels: labels,
                                datasets: [{
                                    data: dataValues,
                                    backgroundColor: colors,
                                    borderWidth: 1
                                }]
                            },
                            options: {
                                plugins: {
                                    tooltip: {
                                        callbacks: {
                                            label: function (context) {
                                                var index = context.dataIndex;
                                                var count = dataValues[index];
                                                var tasks = taskNames[index];
                                                var label = labels[index] + ': ' + count;
                                                var lines = [label].concat(tasks); // Görev isimlerini ekle
                                                return lines;
                                            }
                                        }
                                    }
                                }
                            }
                        });
                    },
                    error: function (error) {
                        console.error('Error fetching data:', error);
                    }
                });
            });
    </script> *@


