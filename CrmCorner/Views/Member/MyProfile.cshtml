@model CrmCorner.ViewModels.UserViewModel

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

<h1>Kullanıcı Bilgileri</h1>



    <div class="row g-3">

        <div class="col-lg-6 col-md-12">
            <div class="card mb-3 profile-header">
                <div class="card-body text-center">
                    <div class="profile-image mb-3"> <user-picture-thumbnail class="rounded" style="width:200px; height:200px" picture-url="@Model.PictureUrl"></user-picture-thumbnail> </div>
                    <div>
                        <h4 class=""><strong>@Model.UserName</strong></h4>
                    </div>
                    @*    <div class="mt-3">
                    <button class="btn btn-outline-secondary">Message</button>
                    </div>*@
                </div>
            </div>
            <div class="card mb-3">
                <div class="card-body">
                    <hr>
                    <small class="text-muted">Email: </small>
                    <p>@Model.Email</p>
                    <hr>
                    <small class="text-muted">Telefon Numarası: </small>
                    <p>@Model.PhoneNumber</p>
                    <hr>
                    @* <small class="text-muted">Social: </small>
                    <p><i class="fa fa-twitter me-2 text-center" style="width: 17px;"></i>twitter.com/example</p>
                    <p><i class="fa fa-facebook me-2 text-center" style="width: 17px;"></i>facebook.com/example</p>
                    <p><i class="fa fa-github me-2 text-center" style="width: 17px;"></i>github.com/example</p>
                    <p><i class="fa fa-instagram me-2 text-center" style="width: 17px;"></i>instagram.com/example</p>*@
                </div>
            </div>
        </div>
        <div class="col-lg-9 col-md-12">
