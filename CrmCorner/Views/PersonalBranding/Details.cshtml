@model CrmCorner.Models.PersonalBrandingContent
@using Microsoft.AspNetCore.Identity
@inject UserManager<AppUser> UserManager

@{
    ViewData["Title"] = "İçerik Detayı";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
    var currentUser = await UserManager.GetUserAsync(User);
    var roles = await UserManager.GetRolesAsync(currentUser);
    bool isAdmin = roles.Contains("SocialMediaAdmin") || roles.Contains("Admin") || roles.Contains("SuperAdmin");
}

<div class="container mt-4">
    <div class="row g-4">
        <!-- Sol Sütun: Yazı ve görsel -->
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h3 class="fw-bold">@Model.Title</h3>
                    <p class="text-muted mb-1">
                        Oluşturulma: @Model.CreatedDate.ToString("dd MMM yyyy")
                    </p>

                    @if (Model.PersonalUser != null)
                    {
                        <p class="text-muted mb-1">
                            <i class="fa fa-user me-1"></i> @Model.PersonalUser.NameSurname
                        </p>
                    }


                    @if (Model.EstimatedPublishDate.HasValue)
                    {
                        <p class="text-muted">Tahmini Paylaşım Tarihi: @Model.EstimatedPublishDate.Value.ToString("dd MMM yyyy")</p>
                    }

                    <hr />

                    <!-- Yazı İçeriği -->
                    <div class="mt-3">
                        @Html.Raw(Model.Description)
                    </div>

                    <!-- Görsel -->
                    @if (Model.MediaFile != null)
                    {
                        <div class="mt-4 text-center">
                            <img src="@Url.Action("GetMedia", "PersonalBranding", new { id = Model.Id })"
                                 class="img-fluid rounded shadow-sm"
                                 alt="İçerik Görseli" />
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Sağ Sütun: Durum + Feedback -->
        <div class="col-lg-4">
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <h5 class="fw-bold">Durum</h5>

                    @if (Model.Status == CrmCorner.Models.Enums.ContentStatus.Onaylandi)
                    {
                        <span class="badge bg-success">Onaylandı</span>
                    }
                    else if (Model.Status == CrmCorner.Models.Enums.ContentStatus.FeedbackVerildi)
                    {
                        <span class="badge bg-warning text-dark">Feedback Verildi</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Onay Bekliyor</span>
                    }

                    @if (isAdmin)
                    {
                        <div class="mt-3">
                            @if (Model.Status != CrmCorner.Models.Enums.ContentStatus.Onaylandi)
                            {
                                <form asp-action="Approve" asp-route-id="@Model.Id" method="post">
                                    <button type="submit" class="btn btn-success btn-sm w-100 mb-2">
                                        <i class="fa fa-check me-1"></i> Onayla
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="CancelApproval" asp-route-id="@Model.Id" method="post">
                                    <button type="submit" class="btn btn-outline-warning btn-sm w-100 mb-2">
                                        <i class="fa fa-undo me-1"></i> Onayı Geri Al
                                    </button>
                                </form>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Feedback Alanı -->
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Geri Bildirimler</h5>

                    @if (Model.Feedbacks != null && Model.Feedbacks.Any())
                    {
                        foreach (var feedback in Model.Feedbacks)
                        {
                            <div class="alert alert-light border mb-2">
                                <div>@feedback.Message</div>
                                <small class="text-muted">
                                    @feedback.CreatedDate.ToString("dd MMM yyyy HH:mm")
                                </small>

                                @if (isAdmin)
                                {
                                    <form asp-action="DeleteFeedback" method="post" class="d-inline float-end ms-2">
                                        <input type="hidden" name="feedbackId" value="@feedback.Id" />
                                        <input type="hidden" name="contentId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger p-0 px-1"
                                                onclick="return confirm('Bu geri bildirimi silmek istiyor musunuz?')">
                                            <i class="fa fa-times"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">Henüz geri bildirim yok.</p>
                    }

                    <hr />

                    <!-- Yeni Feedback Ekleme -->
                    <form asp-action="SendFeedback" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="mb-2">
                            <textarea name="feedbackMessage" class="form-control" rows="3"
                                      placeholder="Geri bildirim yazın..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm w-100">
                            <i class="fa fa-paper-plane me-1"></i> Gönder
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/CRMTema/bootstrap5/dist/assets/plugins/jquery-ui/jquery-ui.min.js"></script>