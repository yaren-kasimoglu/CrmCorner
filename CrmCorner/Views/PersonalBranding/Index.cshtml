@model IEnumerable<CrmCorner.Models.PersonalBrandingContent>
@using Microsoft.AspNetCore.Identity
@inject UserManager<AppUser> UserManager

@{
    ViewData["Title"] = "Personal Branding İçerikleri";
    var currentUser = await UserManager.GetUserAsync(User);
    var roles = await UserManager.GetRolesAsync(currentUser);
    bool isAdmin = roles.Contains("SocialMediaAdmin") || roles.Contains("Admin") || roles.Contains("SuperAdmin");
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
            <h4 class="fw-bold mb-0">Personal Branding İçerikleri</h4>
            @if (isAdmin)
            {
                <a asp-action="Create" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                    <i class="fa fa-plus me-1"></i> Yeni Yazı
                </a>

            }
        </div>

        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:5%">#</th>
                        <th style="width:20%">Başlık</th>
                        <th style="width:35%">Yazı</th>
                        <th style="width:15%">Tahmini Paylaşım Tarihi</th>
                        <th style="width:10%">Durum</th>
                        <th style="width:15%" class="text-center">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                Henüz bir içerik eklenmemiş.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>

                                <!-- Başlık -->
                                <td>
                                    <div class="fw-semibold">@item.Title</div>
                                    <div class="text-muted small">Oluşturulma: @item.CreatedDate.ToString("dd MMM yyyy")</div>
                                </td>

                                <!-- Description (ilk 12 kelime) -->
                                <td>
                                    @{
                                        var desc = item.Description?.Length > 80
                                        ? item.Description.Substring(0, 80) + "..."
                                        : item.Description;
                                    }
                                    <span>@desc</span>
                                </td>

                                <!-- Tahmini paylaşım tarihi -->
                                <td>
                                    @if (item.EstimatedPublishDate.HasValue)
                                    {
                                        @item.EstimatedPublishDate.Value.ToString("dd MMM yyyy")
                                    }
                                    else
                                    {
                                        <span class="text-muted">Belirtilmemiş</span>
                                    }
                                </td>

                                <!-- Durum -->
                                <td>
                                    @if (item.Status == CrmCorner.Models.Enums.ContentStatus.Onaylandi)
                                    {
                                        <span class="badge bg-success">Onaylandı</span>
                                    }
                                    else if (item.Status == CrmCorner.Models.Enums.ContentStatus.FeedbackVerildi)
                                    {
                                        <span class="badge bg-warning text-dark">Feedback Verildi</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Onay Bekliyor</span>
                                    }
                                </td>

                                <!-- İşlem butonları -->
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1" title="Görüntüle">
                                        <i class="fa fa-eye"></i>
                                    </a>

                                    @if (isAdmin)
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success me-1" title="Düzenle">
                                            <i class="fa fa-edit"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil" onclick="return confirm('Bu içeriği silmek istediğine emin misin?')">
                                                <i class="fa fa-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
