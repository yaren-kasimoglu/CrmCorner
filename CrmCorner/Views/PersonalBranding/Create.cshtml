@model CrmCorner.Models.PersonalBrandingContent
@using Microsoft.AspNetCore.Identity
@inject UserManager<AppUser> UserManager

@{
    ViewData["Title"] = "Yeni Personal Branding İçeriği";
    var currentUser = await UserManager.GetUserAsync(User);
    var roles = await UserManager.GetRolesAsync(currentUser);
    bool isAdmin = roles.Contains("SocialMediaAdmin") || roles.Contains("Admin") || roles.Contains("SuperAdmin");
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-white border-0">
            <h4 class="fw-bold mb-0">Yeni Personal Branding İçeriği Oluştur</h4>
        </div>

        <div class="card-body">
            <form asp-action="Create" enctype="multipart/form-data" method="post">
                <div class="row g-3">
                    <!-- Başlık -->
                    <div class="col-md-12">
                        <label asp-for="Title" class="form-label fw-semibold">Başlık *</label>
                        <input asp-for="Title" class="form-control" placeholder="Örneğin: Liderlikte Empati Gücü" required />
                    </div>

                    <!-- LinkedIn Yazısı (Summernote editör) -->
                    <div class="col-md-12">
                        <label asp-for="Description" class="form-label fw-semibold">Yazı *</label>
                        <textarea asp-for="Description" id="summernote" class="form-control" rows="5" required></textarea>
                    </div>

                    <!-- Görsel Yükleme -->
                    <div class="col-md-12">
                        <label class="form-label fw-semibold">Görsel veya Video</label>
                        <div class="border border-2 border-dashed rounded p-3 text-center bg-light">
                            <input type="file" name="mediaFile" accept="image/*,video/*" class="form-control" />
                        </div>
                    </div>

                    <!-- Tahmini Paylaşım Tarihi -->
                    <div class="col-md-6">
                        <label asp-for="EstimatedPublishDate" class="form-label fw-semibold">Tahmini Paylaşım Tarihi</label>
                        <input asp-for="EstimatedPublishDate" type="date" class="form-control" />
                    </div>

                    <!-- Şirket Seçimi (sadece admin görür) -->
                    @if (isAdmin)
                    {
                        <div class="col-md-6">
                            <label asp-for="CompanyId" class="form-label fw-semibold">Şirket</label>
                            <select asp-for="CompanyId" class="form-select" asp-items="ViewBag.CompanyList">
                                <option value="">Şirket Seçiniz</option>
                            </select>
                        </div>


<div class="col-md-6">
    <label asp-for="PersonalUserId" class="form-label fw-semibold">Kişi (opsiyonel)</label>
    <select asp-for="PersonalUserId" class="form-select" asp-items="ViewBag.UserList">
        <option value="">Kişi Seçiniz (isteğe bağlı)</option>
    </select>
</div>

                    }
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-primary px-4">Oluştur</button>
                    <a asp-action="Index" class="btn btn-secondary">İptal</a>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Summernote CSS -->
<link href="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.css" rel="stylesheet">

<!-- Summernote JS -->
<script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.js"></script>

<!-- Summernote başlatma -->
<script>
    $(document).ready(function () {
        $('#summernote').summernote({
            placeholder: 'LinkedIn gönderi metnini buraya yazın...',
            tabsize: 2,
            height: 250,
            toolbar: [
                ['style', ['bold', 'italic', 'underline', 'clear']],
                ['font', ['fontname', 'fontsize', 'color']],
                ['para', ['ul', 'ol', 'paragraph']],
                ['insert', ['link', 'picture', 'video']],
                ['view', ['codeview']]
            ]
        });
    });
</script>
