@model CrmCorner.Models.PersonalBrandingContent
@using Microsoft.AspNetCore.Identity
@inject UserManager<AppUser> UserManager

@{
    ViewData["Title"] = "İçeriği Düzenle";
    var currentUser = await UserManager.GetUserAsync(User);
    var roles = await UserManager.GetRolesAsync(currentUser);
    bool isAdmin = roles.Contains("SocialMediaAdmin") || roles.Contains("Admin") || roles.Contains("SuperAdmin");
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-white border-0">
            <h4 class="fw-bold mb-0">Personal Branding İçeriğini Düzenle</h4>
        </div>

        <div class="card-body">
            <form asp-action="Edit" enctype="multipart/form-data" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="row g-3">
                    <!-- Başlık -->
                    <div class="col-md-12">
                        <label asp-for="Title" class="form-label fw-semibold">Başlık *</label>
                        <input asp-for="Title" class="form-control" required />
                    </div>

                    <!-- LinkedIn Yazısı (Summernote) -->
                    <div class="col-md-12">
                        <label asp-for="Description" class="form-label fw-semibold">Yazı *</label>
                        <textarea asp-for="Description" id="summernote" class="form-control" rows="5" required></textarea>
                    </div>

                    <!-- Mevcut Görsel Önizleme -->
                    @if (Model.MediaFile != null)
                    {
                        <div class="col-md-12 text-center">
                            <label class="form-label fw-semibold">Mevcut Görsel</label>
                            <div class="border p-3 rounded">
                                <img src="@Url.Action("GetMedia", "PersonalBranding", new { id = Model.Id })"
                                     class="img-fluid rounded shadow-sm mb-2"
                                     style="max-height: 250px;" />
                                <p class="text-muted small mb-0">Yeni bir dosya seçersen, bu görselin yerini alır.</p>
                            </div>
                        </div>
                    }

                    <!-- Yeni Görsel Yükleme -->
                    <div class="col-md-12">
                        <label class="form-label fw-semibold">Yeni Görsel veya Video</label>
                        <input type="file" name="mediaFile" accept="image/*,video/*" class="form-control" />
                    </div>

                    <!-- Tahmini Paylaşım Tarihi -->
                    <div class="col-md-6">
                        <label asp-for="EstimatedPublishDate" class="form-label fw-semibold">Tahmini Paylaşım Tarihi</label>
                        <input asp-for="EstimatedPublishDate" type="date" class="form-control" />
                    </div>

                    <!-- Durum (sadece admin görür) -->
                    @if (isAdmin)
                    {
                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label fw-semibold">Durum</label>
                            <select asp-for="Status" class="form-select">
                                <option value="0" selected="@((int)Model.Status == 0)">Onay Bekliyor</option>
                                <option value="1" selected="@((int)Model.Status == 1)">Onaylandı</option>
                                <option value="2" selected="@((int)Model.Status == 2)">Feedback Verildi</option>
                            </select>
                        </div>
                    }
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-success px-4">Kaydet</button>
                    <a asp-action="Index" class="btn btn-secondary">İptal</a>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Summernote CSS -->
<link href="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.css" rel="stylesheet">
<!-- Summernote JS -->
<script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.js"></script>

<!-- Summernote başlat -->
<script>
    $(document).ready(function () {
        $('#summernote').summernote({
            placeholder: 'LinkedIn gönderi metnini düzenleyin...',
            tabsize: 2,
            height: 250,
            toolbar: [
                ['style', ['bold', 'italic', 'underline', 'clear']],
                ['font', ['fontname', 'fontsize', 'color']],
                ['para', ['ul', 'ol', 'paragraph']],
                ['insert', ['link', 'picture', 'video']],
                ['view', ['codeview']]
            ]
        });
    });
</script>
