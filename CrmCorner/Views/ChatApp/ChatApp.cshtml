    <input type="hidden" id="useronlyId" value="@useronlyId" />

    <script>


        document.addEventListener("DOMContentLoaded", function () {
            var userId = document.getElementById("selectedUserId").value;
            var userName = document.getElementById("selectedUser").innerHTML;
            
            if (userId && userName) {
                document.getElementById("searchDiv").style.display = "block";
            }
        });


        document.getElementById("searchIcon").addEventListener("click", function () {
            var searchText = document.getElementById("searchInput").value;

            // Controller'a git
            window.location.href = "/ChatApp/ChatApp?search=" + searchText;
        });
        const selectedUserElement = document.getElementById("selectedUser");
        console.log(selectedUserElement.value);
        // selectedUser elementi null ise "Hello" mesajını ekleyelim
        if (selectedUserElement.value === undefined) {
            const messageElement = document.querySelector('.message.other-message');
            messageElement.textContent = 'Yeni bir sohbet başlatın..';
        }
        function formatDateTime(dateTimeString) {
            const date = new Date(dateTimeString);
            const options = {
                year: 'numeric',
                month: '2-digit',
                day: '2-digit',
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit',
                hour12: false
            };
            return date.toLocaleString('tr-TR', options).replace(',', '');
        }
        function selectUser(userName, userId) {
            document.getElementById("searchDiv").style.display = "block";
            document.getElementById("selectedUserId").value = userId;
            document.getElementById("selectedUser").innerHTML = userName;
            var test = document.getElementById("selectedUserId").value;
            var useronlyId = document.getElementById("useronlyId").value;
            var useronlyId2 = $("#useronlyId").val();

            //const messageElement = document.querySelector('.message.other-message');
            //messageElement.textContent = '';
            // Seçilen kullanıcının kimliğini controller action'a iletmek için form submit işlemi gerçekleştiriyoruz
            $.ajax({
                type: "GET",
                url: "/ChatApp/GetUserMessages",
                data: { userId: userId },
                success: function (response) {
                    var $MessageBox = $("#MessageBox");
                    $MessageBox.empty();
                    // Başarılı bir şekilde veri alındığında yapılacak işlemler
                    console.log("Veri alındı:", response.message);
                    console.log(useronlyId);
                    response.message.forEach(function (item) {
                        const formattedMessageTime = formatDateTime(item.messageTime);
                        if (item.senderId != useronlyId) {
                            console.log(item.senderId);
                            $MessageBox.append(`<li class="clearfix">
                                            <div class="message-data mb-3">
                                                <span class="small text-muted me-3">${formattedMessageTime}</span>
                                            </div>
                                            <div class="message my-message d-inline-block" style="line-height: normal;">
                                                ${item.message}
                                            </div>
                                        </li>`);
                        }
                        else {
                            $MessageBox.append(`<li class="clearfix">
                                            <div class="message-data text-end mb-3 me-3">
                                                <span class="small text-muted me-2"> ${formattedMessageTime}</span>
                                                </div>
                                             <div class="message other-message d-inline-block float-end" style="line-height: normal;">
                                            ${item.message}
                                            </div>
                                    </li>`);
                        }
                    });
                    scrollToBottom2();

                },
                error: function (xhr, status, error) {
                    // Hata durumunda yapılacak işlemler
                    console.error("Hata:", error);
                }
            });

        }
        function scrollToBottom2() {
            var messageBox = document.getElementById("chat-history");
            var scrooltop = messageBox.scrollHeight;
            messageBox.scrollTop = messageBox.scrollHeight;
        }

        function getMessages() {
            document.getElementById("selectedUserId").value = userId;
            document.getElementById("selectedUser").innerHTML = userName;
            var selectedUserId = document.getElementById("selectedUserId").value;

            // Sunucuya istek gönder ve mesajları al
            fetch("/getMessage?userId=" + selectedUserId)
                .then(response => response.json())
                .then(data => {
                    // Mesajları ekrana ekle
                    var messageContainer = document.getElementById("messageContainer");
                    messageContainer.innerHTML = ""; // Önceki mesajları temizle
                    data.forEach(message => {
                        messageContainer.innerHTML += `<div>${message}</div>`;
                    });
                })
                .catch(error => console.error("Error:", error));
        }
        


    </script>
