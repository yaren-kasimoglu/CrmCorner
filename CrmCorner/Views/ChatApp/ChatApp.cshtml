@inject IJsonHelper JsonHelper
@{
    ViewData["Title"] = "ChatApp";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
    string useronlyId = ViewBag.GetUserId;
}

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/3.1.3/signalr.min.js"></script>
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>

<div class="row"></div>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>:: Lucid HR BS5 :: Chat App</title>
    <meta http-equiv="X-UA-Compatible" content="IE=Edge">

    <style>
        .container {
            display: flex;
            justify-content: center;
            align-items: flex-start;
            height: 100vh;
        }

        .message.other-message,
        .message.my-message {
            font-size: 16px;
        }

        ul.chat-list {
            overflow-y: auto;
            max-height: 400px;
        }

        #MessageBox li::marker {
            content: none;
        }

        .notification {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background-color: #444;
            color: white;
            padding: 10px;
            border-radius: 5px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
            display: none;
            z-index: 1000;
        }

        #notification {
            cursor: pointer;
        }

        .file-upload-label {
            cursor: pointer;
            padding: 0.5rem 0.75rem;
            border: 1px solid #ced4da;
            border-radius: 0.25rem;
            background-color: #f8f9fa;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

            .file-upload-label i {
                font-size: 1.5rem;
            }

            .file-upload-label:hover {
                background-color: #e2e6ea;
            }

        .ai-suggestion-btn {
            border: 1px solid #6f42c1;
            background-color: #f8f5ff;
            color: #6f42c1;
            border-radius: 20px;
            padding: 6px 12px;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

            .ai-suggestion-btn:hover {
                background-color: #6f42c1;
                color: white;
            }

        #aiSuggestionsContainer {
            display: none;
        }

        .ai-loading {
            font-size: 12px;
            color: #6c757d;
            margin-bottom: 8px;
        }
    </style>
</head>

<body>
    <div class="row clearfix">
        <div class="col-lg-12">
            <div class="card">
                <div class="chat_app d-flex">
                    <div class="people_list">
                        <div class="input-group p-3">
                            <span id="searchIcon" class="input-group-text"><i class="fa fa-search"></i></span>
                            <input id="searchInput" type="text" class="form-control" placeholder="Search..." aria-label="Search..." />
                        </div>

                        <ul class="list-unstyled chat-list mb-0">
                            @if (ViewBag.UserNames != null)
                            {
                                @foreach (var userName in ViewBag.UserNames)
                                {
                                    <li class="d-flex align-items-center py-2 px-3"
                                        onclick="selectUser('@userName.NameSurname','@userName.UserId')">
                                        <div style="position: relative; display: flex; align-items: center;">
                                            @if (userName.HasUnreadMessages)
                                            {
                                                <div class="unread-dot"
                                                     style="position: absolute; left: -15px; top: 50%; transform: translateY(-50%); width: 10px; height: 10px; background-color: #2eacb3; border-radius: 50%;"></div>
                                            }
                                            <img class="avatar rounded user-avatar"
                                                 src="@userName.PictureUrl"
                                                 alt="avatar"
                                                 onerror="this.onerror=null; this.src='@Url.Content("~/userprofilepicture/defaultpp.png")';" />
                                        </div>
                                        <div class="about ps-3">
                                            <div class="fs-6">@userName.NameSurname</div>
                                        </div>
                                    </li>
                                }
                            }
                        </ul>
                    </div>

                    <div id="notification" class="notification" onclick="hideNotification()"></div>

                    <div class="chat">
                        <div class="chat-header d-flex justify-content-between align-items-center p-3 border-bottom">
                            <div class="left d-flex" id="selectedUser">
                                <button type="button" class="btn p-0" data-bs-toggle="modal" data-bs-target="#exampleModal">
                                </button>
                                <div class="chat-about ps-2">
                                    <h6 class="mb-0" id="selectedUserName">Yeni bir sohbet başlatın..</h6>
                                </div>
                            </div>

                            <input type="hidden" id="selectedUserId" />
                        </div>

                        <div class="chat-history p-3" id="chat-history">
                            <div id="MessageBox">
                                <ul class="list-unstyled mb-0"></ul>
                            </div>
                        </div>

                        <div class="chat-message p-3 border-top" id="searchDiv" style="display: none;">
                            <div id="aiSuggestionsContainer" class="mb-2">
                                <div id="aiLoadingText" class="ai-loading" style="display:none;">AI önerileri hazırlanıyor...</div>
                                <div class="d-flex flex-wrap gap-2" id="aiSuggestions"></div>
                            </div>

                            <div class="input-group">
                                <button id="SendMessageBtn" type="button">
                                    <span class="input-group-text"><i class="fa fa-paper-plane"></i></span>
                                </button>

                                <input type="text"
                                       id="SendMessageTextArea"
                                       class="form-control"
                                       placeholder="Enter text here..."
                                       aria-label="Enter text here..." />

                                <input type="hidden" id="userIdHiddenInput" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModal" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">User Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex align-items-start">
                        <img src="../dist/assets/images/xs/avatar2.jpg" class="rounded-circle" alt="">
                        <div class="content ms-2">
                            <div>Team Leader</div>
                            <h6>Aiden Chavez</h6>
                        </div>
                    </div>
                    <hr>
                    <small class="text-muted">Address: </small>
                    <p>795 Folsom Ave, Suite 600 San Francisco, 94107</p>
                    <small class="text-muted">Email address: </small>
                    <p>michael@gmail.com</p>
                    <small class="text-muted">Mobile: </small>
                    <p>+ 202-555-2828</p>
                    <small class="text-muted">Birth Date: </small>
                    <p>October 22th, 1990</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <input type="hidden" id="useronlyId" value="@useronlyId" />

    <script>
        let aiTypingTimer = null;

        document.addEventListener("DOMContentLoaded", function () {
            var userIsd = localStorage.getItem('selectedUserId');
            var userNames = localStorage.getItem('selectedUserName');

            if (userIsd && userNames) {
                selectUser(userNames, userIsd);
                localStorage.removeItem('selectedUserId');
                localStorage.removeItem('selectedUserName');
            } else {
                var userId = document.getElementById("selectedUserId").value;
                var userName = document.getElementById("selectedUserName").textContent;

                if (userId && userName && userName.trim() !== "") {
                    document.getElementById("searchDiv").style.display = "block";
                }
            }
        });

        document.getElementById("searchIcon").addEventListener("click", function () {
            var searchText = document.getElementById("searchInput").value;
            window.location.href = "/ChatApp/ChatApp?search=" + encodeURIComponent(searchText);
        });

        document.getElementById("searchInput").addEventListener("keypress", function (event) {
            if (event.key === "Enter") {
                var searchText = this.value;
                window.location.href = "/ChatApp/ChatApp?search=" + encodeURIComponent(searchText);
            }
        });

        function formatDateTime(dateTimeString) {
            const date = new Date(dateTimeString);
            const options = {
                year: 'numeric',
                month: '2-digit',
                day: '2-digit',
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit',
                hour12: false
            };
            return date.toLocaleString('tr-TR', options).replace(',', '');
        }

        function renderAiSuggestions(response) {
            if (response.success && response.suggestions && response.suggestions.length > 0) {
                $("#aiSuggestions").html("");

                response.suggestions.forEach(function (item) {
                    const btn = $("<button>")
                        .attr("type", "button")
                        .addClass("ai-suggestion-btn")
                        .text(item)
                        .on("click", function () {
                            useAiSuggestion(item);
                        });

                    $("#aiSuggestions").append(btn);
                });

                $("#aiSuggestionsContainer").show();
            } else {
                $("#aiSuggestions").html("");
                $("#aiSuggestionsContainer").hide();
            }
        }

        function setAiLoading(isLoading) {
            if (isLoading) {
                $("#aiSuggestionsContainer").show();
                $("#aiLoadingText").show();
            } else {
                $("#aiLoadingText").hide();
            }
        }

        function useAiSuggestion(text) {
            $("#SendMessageTextArea").val(text);
            $("#SendMessageTextArea").focus();
        }

        function selectUser(userName, userId) {
            document.getElementById("searchDiv").style.display = "block";
            document.getElementById("selectedUserId").value = userId;

            if (userName !== "1") {
                document.getElementById("selectedUserName").textContent = userName;
            }

            var useronlyId = document.getElementById("useronlyId").value;
            var userItems = document.querySelectorAll("ul.chat-list li");

            userItems.forEach(function (item) {
                if (item.getAttribute("onclick")?.includes(userId)) {
                    var dot = item.querySelector(".unread-dot");
                    if (dot) {
                        dot.remove();
                        console.log("✅ Mavi nokta kendi ekranında kaldırıldı:", userId);
                    }
                }
            });

            signalRConnection.invoke("MarkMessagesAsRead", userId)
                .then(() => console.log("📨 MarkMessagesAsRead tetiklendi:", userId))
                .catch(err => console.error("MarkMessagesAsRead hatası:", err.toString()));

            $.ajax({
                type: "GET",
                url: "/ChatApp/GetUserMessages",
                data: { userId: userId },
                success: function (response) {
                    var $MessageBox = $("#MessageBox");
                    $MessageBox.empty();

                    response.message.forEach(function (item) {
                        const formattedMessageTime = formatDateTime(item.messageTime);

                        if (item.senderId != useronlyId) {
                            $MessageBox.append(`
                                <li class="clearfix">
                                    <div class="message-data mb-3">
                                        <span class="small text-muted me-3">${formattedMessageTime}</span>
                                    </div>
                                    <div class="message my-message d-inline-block" style="line-height: normal;">
                                        ${item.message}
                                    </div>
                                </li>
                            `);
                        } else {
                            $MessageBox.append(`
                                <li class="clearfix">
                                    <div class="message-data text-end mb-3 me-3">
                                        <span class="small text-muted me-2">${formattedMessageTime}</span>
                                    </div>
                                    <div class="message other-message d-inline-block float-end" style="line-height: normal;">
                                        ${item.message}
                                    </div>
                                </li>
                            `);
                        }
                    });

                    scrollToBottom2();
                    loadAiSuggestions(userId);
                },
                error: function (xhr, status, error) {
                    console.error("Hata:", error);
                }
            });
        }

        function scrollToBottom2() {
            var messageBox = document.getElementById("chat-history");
            messageBox.scrollTop = messageBox.scrollHeight;
        }

        function showNotification(userId, message) {
            document.getElementById("userIdHiddenInput").value = userId;
            var notificationElement = document.getElementById("notification");

            if (!notificationElement) {
                console.error("Notification element not found!");
                return;
            }

            $.ajax({
                type: 'POST',
                url: "/ChatApp/GetUserName/",
                data: { userId: userId },
                dataType: "json",
                success: function (data) {
                    if (data.message) {
                        notificationElement.textContent = data.message + " Kişisinden Mesajınız var";
                        document.body.appendChild(notificationElement);
                        notificationElement.style.display = 'block';
                    } else {
                        alert("Error: No message received.");
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Error occurred: " + status + " " + error);
                    alert("Error occurred while fetching user name.");
                }
            });
        }

        function hideNotification() {
            var notificationElement = document.getElementById("notification");
            notificationElement.style.display = "none";

            var userId = document.getElementById("userIdHiddenInput").value;
            selectUser("1", userId);
        }

        function loadAiSuggestions(userId) {
            if (!userId) {
                $("#aiSuggestionsContainer").hide();
                $("#aiSuggestions").html("");
                return;
            }

            setAiLoading(true);

            $.ajax({
                url: '/ChatApp/GetAiReplySuggestions',
                type: 'GET',
                data: { userId: userId },
                success: function (response) {
                    setAiLoading(false);
                    renderAiSuggestions(response);
                },
                error: function () {
                    setAiLoading(false);
                    $("#aiSuggestions").html("");
                    $("#aiSuggestionsContainer").hide();
                }
            });
        }

        function loadAiSuggestionsLive(userId, draftMessage) {
            if (!userId) {
                $("#aiSuggestionsContainer").hide();
                $("#aiSuggestions").html("");
                return;
            }

            if (!draftMessage || !draftMessage.trim()) {
                loadAiSuggestions(userId);
                return;
            }

            setAiLoading(true);

            $.ajax({
                url: '/ChatApp/GetAiReplySuggestionsLive',
                type: 'POST',
                data: {
                    userId: userId,
                    draftMessage: draftMessage
                },
                success: function (response) {
                    setAiLoading(false);
                    renderAiSuggestions(response);
                },
                error: function () {
                    setAiLoading(false);
                    $("#aiSuggestions").html("");
                    $("#aiSuggestionsContainer").hide();
                }
            });
        }
    </script>

    <script>
        var signalRConnection;

        $(function () {
            var $SendMessageTextArea = $("#SendMessageTextArea");
            var $SendMessageBtn = $("#SendMessageBtn");
            var $MessageBox = $("#MessageBox");

            signalRConnection = new signalR.HubConnectionBuilder().withUrl("/chatHub").build();

            signalRConnection.on("ReceiveNotification", function (senderId) {
                console.log("📩 Yeni mesaj bildirimi geldi! Gönderen ID:", senderId);

                var userItems = document.querySelectorAll(".chat-list li");
                userItems.forEach(function (item) {
                    if (item.getAttribute("onclick")?.includes(senderId)) {
                        if (!item.querySelector(".unread-dot")) {
                            var dot = document.createElement("div");
                            dot.className = "unread-dot";
                            dot.style.cssText =
                                "position:absolute;left:-15px;top:50%;transform:translateY(-50%);width:10px;height:10px;background-color:#2eacb3;border-radius:50%;";
                            item.querySelector("div").appendChild(dot);
                        }
                    }
                });
            });

            signalRConnection.on("MessagesMarkedAsRead", function (senderId) {
                console.log("📩 MessagesMarkedAsRead sinyali geldi, gönderen:", senderId);

                var userItems = document.querySelectorAll(".chat-list li");
                userItems.forEach(function (item) {
                    if (item.getAttribute("onclick")?.includes(senderId)) {
                        var dot = item.querySelector(".unread-dot");
                        if (dot) {
                            dot.remove();
                            console.log("✅ Mavi nokta kaldırıldı:", senderId);
                        }
                    }
                });
            });

            signalRConnection.on("ChatChannel", function (message, dateTime, senderId) {
                var currentUserId = document.getElementById("useronlyId").value;
                var selectedUserId = document.getElementById("selectedUserId").value;

                if (senderId === selectedUserId) {
                    $MessageBox.append(`
                        <li class="clearfix">
                            <div class="message-data mb-3">
                                <span class="small text-muted me-3">${dateTime}</span>
                            </div>
                            <div class="message my-message d-inline-block">${message}</div>
                        </li>
                    `);
                    scrollToBottom();
                    loadAiSuggestions(selectedUserId);
                } else if (senderId !== currentUserId) {
                    showNotification(senderId, message);
                }
            });

            async function startConnection() {
                try {
                    await signalRConnection.start();
                    console.log("✅ SignalR bağlantısı kuruldu.");
                } catch (err) {
                    console.error("❌ SignalR bağlantısı başarısız:", err.toString());
                    setTimeout(startConnection, 5000);
                }
            }

            startConnection();

            $SendMessageBtn.click(function () {
                sendMessage();
            });

            $SendMessageTextArea.on("input", function () {
                var userId = document.getElementById("selectedUserId").value;
                var draftMessage = $(this).val();

                clearTimeout(aiTypingTimer);

                if (!userId) return;

                if (!draftMessage || !draftMessage.trim() || draftMessage.trim().length < 2) {
                    loadAiSuggestions(userId);
                    return;
                }

                aiTypingTimer = setTimeout(function () {
                    loadAiSuggestionsLive(userId, draftMessage);
                }, 700);
            });

            document.getElementById("SendMessageTextArea").addEventListener("keypress", function (e) {
                if (e.key === "Enter") {
                    e.preventDefault();
                    sendMessage();
                }
            });

            async function sendMessage() {
                var userId = document.getElementById("selectedUserId").value;
                var message = $SendMessageTextArea.val();

                clearTimeout(aiTypingTimer);

                if (!userId) {
                    alert("Lütfen önce bir kullanıcı seçin.");
                    return;
                }

                if (!message || !message.trim()) return;

                var now = new Date();
                var dateTime = now.toLocaleString('tr-TR', {
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit',
                    hour: '2-digit',
                    minute: '2-digit'
                });

                $MessageBox.append(`
                    <li class="clearfix">
                        <div class="message-data text-end mb-3 me-3">
                            <span class="small text-muted me-2">${dateTime}</span>
                        </div>
                        <div class="message other-message d-inline-block float-end">${message}</div>
                    </li>
                `);

                try {
                    await signalRConnection.invoke("SendMessage", message, userId, dateTime);
                } catch (err) {
                    console.error("Gönderim hatası:", err.toString());
                }

                $SendMessageTextArea.val("");
                scrollToBottom();

                setTimeout(function () {
                    loadAiSuggestions(userId);
                }, 400);

                signalRConnection.invoke("MarkMessagesAsRead", userId)
                    .then(() => console.log("✅ Mesajlar okundu olarak işaretlendi:", userId))
                    .catch(err => console.error("MarkMessagesAsRead hatası:", err.toString()));
            }

            function scrollToBottom() {
                var messageBox = document.getElementById("chat-history");
                messageBox.scrollTop = messageBox.scrollHeight;
            }

            signalRConnection.onclose(async () => {
                console.warn("⚠️ SignalR bağlantısı koptu, yeniden bağlanılıyor...");
                await startConnection();
            });

            setInterval(async function () {
                if (signalRConnection.state === signalR.HubConnectionState.Disconnected) {
                    console.warn("🔄 Bağlantı durumu: disconnected. Yeniden bağlanılıyor...");
                    await startConnection();
                }
            }, 10000);
        });
    </script>

</body>
</html>