<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>:: Lucid HR BS5 :: Chat App</title>
    <meta http-equiv="X-UA-Compatible" content="IE=Edge">
    <style>
        .container {
            display: flex;
            justify-content: center; /* Yatayda ortala */
            align-items: flex-start; /* Dikeyde yukarıda hizala */
            height: 100vh; /* Sayfa yüksekliği kadar genişlet */
        }

        /* Mesaj divi */
        .message.other-message {
            font-size: 16px; /* Örnek bir font boyutu */
            /* Diğer stiller buraya eklenebilir */
        }

        ul.chat-list {
            overflow-y: auto; /* Yükseklik aşıldığında dikey kaydırma çubuğunu göster */
            max-height: 400px; /* Maksimum yükseklik belirleyin */
        }

        #MessageBox li::marker {
            content: none;
        }
        .notification {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background-color: #444;
            color: white;
            padding: 10px;
            border-radius: 5px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
            display: none;
            z-index: 1000;
        }
        #notification {
            cursor: pointer; /* Kullanıcıya tıklamaya hazır olduğunu göstermek için fare işaretçisini değiştirir */
        }
        .file-upload-label {
            cursor: pointer;
            padding: 0.5rem 0.75rem; /* Yatay ve dikey padding değerlerini artırdım */
            border: 1px solid #ced4da;
            border-radius: 0.25rem;
            background-color: #f8f9fa;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

            .file-upload-label i {
                font-size: 1.5rem; /* Simge boyutunu artırdım */
            }

            .file-upload-label:hover {
                background-color: #e2e6ea;
            }
      
    </style>
</head>

<body>
    <div class="row clearfix">
        <div class="col-lg-12">
            <div class="card">
                <div class="chat_app d-flex">
                    <div class="people_list">
                        <div class="input-group p-3">
                            <span id="searchIcon" class="input-group-text"><i class="fa fa-search"></i></span>
                            <input id="searchInput" type="text" class="form-control" placeholder="Search..." aria-label="Search...">
                        </div>
                        <ul class="list-unstyled chat-list mb-0">
                            @if (ViewBag.UserNames != null)
                            {
                                @foreach (var userName in ViewBag.UserNames)
                                {
                                    <li class="d-flex align-items-center py-2 px-3" onclick="selectUser('@userName.NameSurname','@userName.UserId')">
                                        <div style="position: relative; display: flex; align-items: center;">
                                            @if (@userName.HasUnreadMessages)
                                            {
                                                <div style="position: absolute; left: -15px; top: 50%; transform: translateY(-50%); width: 10px; height: 10px; background-color: #2eacb3; border-radius: 50%;"></div>
                                            }
                                            <img class="avatar rounded" src="@userName.PictureUrl" alt="avatar" />
                                        </div>
                                        <div class="about ps-3">
                                            <div class="fs-6">@userName.NameSurname</div>
                                        </div>
                                    </li>
                                }

                            }
                        </ul>
                    </div>
                    <div id="notification" class="notification"  onclick="hideNotification()"></div>
                    <div class="chat">
                        <div class="chat-header d-flex justify-content-between align-items-center p-3 border-bottom">
                            <div class="left d-flex" id="selectedUser">
                                <button type="button" class="btn p-0" data-bs-toggle="modal" data-bs-target="#exampleModal">
                                    @*<img class="avatar rounded" src="../dist/assets/images/xs/avatar2.jpg" alt="avatar" />*@
                                </button>
                                <div class="chat-about ps-2">
                                    <h6 class="mb-0"></h6>
                                    @*<small class="text-muted">Last seen: 2 hours ago</small>*@
                                </div>
                            </div>
                            <div id="selectedUserId" class="hidden"></div>

                            @*<div class="right d-md-block d-none text-end">
                    <a href="javascript:void(0);" class="btn btn-sm btn-outline-secondary"><i class="fa fa-camera"></i></a>
                    <a href="javascript:void(0);" class="btn btn-sm btn-outline-secondary"><i class="fa fa-video-camera"></i></a>
                    <a href="javascript:void(0);" class="btn btn-sm btn-outline-secondary"><i class="fa fa-cog"></i></a>
                    <a href="javascript:void(0);" class="btn btn-sm btn-outline-secondary"><i class="fa fa-question"></i></a>
                </div>*@
                        </div>
                        <div class="chat-history p-3" id="chat-history">
                            <div id="MessageBox">
                                <ul class="list-unstyled mb-0">
                                </ul>
                            </div>
                        </div>
                        <div class="chat-message p-3 border-top" id="searchDiv" style="display: none;">
                            <div class="input-group">
                                <button id="SendMessageBtn">
                                    <span class="input-group-text"><i class="fa fa-paper-plane"></i></span>
                                </button>
                                <input type="text" id="SendMessageTextArea" class="form-control" placeholder="Enter text here..." aria-label="Enter text here...">
                                <input type="hidden" id="userIdHiddenInput">
                                @*< <form id="uploadForm" class="d-inline">
                                    <label for="fileInput" class="file-upload-label">
                                        <i class="fa fa-paperclip"></i>
                                    </label>
                                    input type="file" id="fileInput" style="display: none;" />
        <button type="button" onclick="uploadFile()" style="display: none;">Upload</button>
                                </form>
                                *@
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>



    <!-- Modal -->
    <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModal" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">User Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex align-items-start">
                        <img src="../dist/assets/images/xs/avatar2.jpg" class="rounded-circle" alt="">
                        <div class="content ms-2">
                            <div>Team Leader</div>
                            <h6>Aiden Chavez</h6>
                        </div>
                    </div>
                    <hr>
                    <small class="text-muted">Address: </small>
                    <p>795 Folsom Ave, Suite 600 San Francisco, 94107</p>
                    <small class="text-muted">Email address: </small>
                    <p>michael@gmail.com</p>
                    <small class="text-muted">Mobile: </small>
                    <p>+ 202-555-2828</p>
                    <small class="text-muted">Birth Date: </small>
                    <p class="">October 22th, 1990</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
    <input type="hidden" id="useronlyId" value="@useronlyId" />

    <script>


        document.addEventListener("DOMContentLoaded", function () {
            var userIsd = localStorage.getItem('selectedUserId');
            var userNames = localStorage.getItem('selectedUserName');
            console.log("userNames" + userNames);
            if (userIsd) {
                selectUser(userNames, userIsd);
                localStorage.removeItem('selectedUserId');
                localStorage.removeItem('selectedUserName');
            }
            else {
                var userId = document.getElementById("selectedUserId").value;
                var userName = document.getElementById("selectedUser").innerHTML;

                if (userId && userName) {
                    document.getElementById("searchDiv").style.display = "block";
                }
            }

        });


        document.getElementById("searchIcon").addEventListener("click", function () {
            var searchText = document.getElementById("searchInput").value;

            // Controller'a git
            window.location.href = "/ChatApp/ChatApp?search=" + searchText;
        });

        document.getElementById("searchInput").addEventListener("keypress", function (event) {
            // Enter tuşuna basıldığında işlem yap
            if (event.key === "Enter") {
                var searchText = document.getElementById("searchInput").value;
                var searchText = this.value; // Input alanından arama metnini al

                // Aynı URL yönlendirme işlemi
                window.location.href = "/ChatApp/ChatApp?search=" + encodeURIComponent(searchText);
            }
        });
        const selectedUserElement = document.getElementById("selectedUser");
        // selectedUser elementi null ise "Hello" mesajını ekleyelim
        if (selectedUserElement.value === undefined) {
            const messageElement = document.querySelector('.message.other-message');
            messageElement.textContent = 'Yeni bir sohbet başlatın..';
        }
        function formatDateTime(dateTimeString) {
            const date = new Date(dateTimeString);
            const options = {
                year: 'numeric',
                month: '2-digit',
                day: '2-digit',
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit',
                hour12: false
            };
            return date.toLocaleString('tr-TR', options).replace(',', '');
        }
     

        function selectUser(userName, userId) {
            document.getElementById("searchDiv").style.display = "block";
            document.getElementById("selectedUserId").value = userId;
            if (userName != "1") {
                document.getElementById("selectedUser").innerHTML = userName;
            }
            var test = document.getElementById("selectedUserId").value;
            var useronlyId = document.getElementById("useronlyId").value;
            var useronlyId2 = $("#useronlyId").val();
            //const messageElement = document.querySelector('.message.other-message');
            //messageElement.textContent = '';
            // Seçilen kullanıcının kimliğini controller action'a iletmek için form submit işlemi gerçekleştiriyoruz
            $.ajax({
                type: "GET",
                url: "/ChatApp/GetUserMessages",
                data: { userId: userId },
                success: function (response) {
                    var $MessageBox = $("#MessageBox");
                    $MessageBox.empty();
                    // Başarılı bir şekilde veri alındığında yapılacak işlemler
                    response.message.forEach(function (item) {
                        const formattedMessageTime = formatDateTime(item.messageTime);
                        if (item.senderId != useronlyId) {
                            $MessageBox.append(`<li class="clearfix">
                                            <div class="message-data mb-3">
                                                <span class="small text-muted me-3">${formattedMessageTime}</span>
                                            </div>
                                            <div class="message my-message d-inline-block" style="line-height: normal;">
                                                ${item.message}
                                            </div>
                                        </li>`);
                        }
                        else {
                            $MessageBox.append(`<li class="clearfix">
                                            <div class="message-data text-end mb-3 me-3">
                                                <span class="small text-muted me-2"> ${formattedMessageTime}</span>
                                                </div>
                                             <div class="message other-message d-inline-block float-end" style="line-height: normal;">
                                            ${item.message}
                                            </div>
                                    </li>`);
                        }
                    });
                    scrollToBottom2();

                },
                error: function (xhr, status, error) {
                    // Hata durumunda yapılacak işlemler
                    console.error("Hata:", error);
                }
            });

        }
        function scrollToBottom2() {
            var messageBox = document.getElementById("chat-history");
            var scrooltop = messageBox.scrollHeight;
            messageBox.scrollTop = messageBox.scrollHeight;
        }
        function showNotification(userId,message) {
            document.getElementById("userIdHiddenInput").value = userId;
            var notificationElement = document.getElementById("notification");
            if (!notificationElement) {
                console.error("Notification element not found!");
                return;
            }
            var name = "";
            var id = userId;  // userId değişkeninin doğru atandığından emin olun
            $.ajax({
                type: 'POST',
                url: "/ChatApp/GetUserName/",  // URL'nin doğru olduğundan emin olun
                data: { userId: id },  // userId'nin doğru gönderildiğinden emin olun
                dataType: "json",
                success: function (data) {
                    if (data.message) {
                        name = data.message;
                        notificationElement.textContent = name + " " + "Kişisinden Mesajınız var";
                        document.body.appendChild(notificationElement);
                        notificationElement.style.display = 'block';

                    } else {
                        alert("Error: No message received.");
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Error occurred: " + status + " " + error);
                    alert("Error occurred while fetching user name.");
                }
            });
            // Bildirimi belirli bir süre sonra gizle
          
        }

        // Notification elementine tıklandığında kaybolmasını sağlayan bir event listener ekleyin
        function hideNotification() {
            var notificationElement = document.getElementById("notification");
            notificationElement.style.display = "none";
            var userId = document.getElementById("userIdHiddenInput").value;
            selectUser("1", userId);
        }
        
        function getMessages() {
            document.getElementById("selectedUserId").value = userId;
            document.getElementById("selectedUser").innerHTML = userName;
            var selectedUserId = document.getElementById("selectedUserId").value;

            // Sunucuya istek gönder ve mesajları al
            fetch("/getMessage?userId=" + selectedUserId)
                .then(response => response.json())
                .then(data => {
                    // Mesajları ekrana ekle
                    var messageContainer = document.getElementById("messageContainer");
                    messageContainer.innerHTML = ""; // Önceki mesajları temizle
                    data.forEach(message => {
                        messageContainer.innerHTML += `<div>${message}</div>`;
                    });
                })
                .catch(error => console.error("Error:", error));
        }
        


    </script>
    <script>
 
        $(function () {

            var $SendMessageTextArea = $("#SendMessageTextArea");
            var $UserListSelectBox = $("#UserList");
            var $SendMessageBtn = $("#SendMessageBtn");
            var $MessageBox = $("#MessageBox");
            var isMyMessage = false;

            var signalRConnection = new signalR.HubConnectionBuilder().withUrl("/chatHub").build();
            signalRConnection.on("ChatChannel", function (message, dateTime) {
                var userId = document.getElementById("selectedUserId").value;

                if (userId !== null && userId !== undefined) {

                    $MessageBox.append(`<li class="clearfix">
                                <div class="message-data mb-3">
                                    <span class="small text-muted me-3">${dateTime}</span>
                                </div>
                                <div class="message my-message d-inline-block">
                                    ${message}
                                </div>
                            </li>`);
                
                
                }
                scrollToBottom();
                showNotification( userId,message);

            });
   
            function uploadFile() {
                const fileInput = document.getElementById('fileInput');
                const file = fileInput.files[0];

                if (!file) {
                    alert("Please select a file.");
                    return;
                }

                const formData = new FormData();
                formData.append("file", file);

                $.ajax({
                    url: '/api/fileupload',
                    type: 'POST',
                    data: formData,
                    contentType: false,
                    processData: false,
                    success: function (data) {
                        console.log("File uploaded successfully:", data);
                        // SignalR üzerinden dosya bilgilerini gönderme
                        signalRConnection.invoke("SendFile", "User", data.fileName, new Uint8Array(file));
                    },
                    error: function (error) {
                        console.error("Error uploading file:", error);
                        console.log("formdataerror" + error);

                    }
                    });
                 }
            $SendMessageBtn.click(function () {
                signalRConnection.start().then(function () {

                }).catch(function (err) {
                    return console.error(err.toString());
                });
                var userId = document.getElementById("selectedUserId").value;
                var message = $SendMessageTextArea.val();
                var now = new Date();
                var day = ("0" + now.getDate()).slice(-2);
                var month = ("0" + (now.getMonth() + 1)).slice(-2);
                var year = now.getFullYear(); // Yılı al
                var hour = ("0" + now.getHours()).slice(-2);
                var minute = ("0" + now.getMinutes()).slice(-2);
                var dateTime = day + "." + month + "." + year + " " + hour + ":" + minute;


                $MessageBox.append(`<li class="clearfix">
                                <div class="message-data text-end mb-3 me-3">
                                    <span class="small text-muted me-2"> ${dateTime}</span>
                                    </div>
                                 <div class="message other-message d-inline-block float-end">
                                ${message}
                                </div>
                        </li>`);
                signalRConnection.invoke("SendMessage", message, userId, dateTime);
                $SendMessageTextArea.val("");
                scrollToBottom();

            });
            document.getElementById('SendMessageTextArea').addEventListener('keypress', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault(); // Formun gönderilmesini engelle
                    sendMessage();
                }
            });
            function sendMessage() {
                signalRConnection.start().then(function () {

                }).catch(function (err) {
                    return console.error(err.toString());
                });
                var userId = document.getElementById("selectedUserId").value;
                var message = $SendMessageTextArea.val();
                var now = new Date();
                var day = ("0" + now.getDate()).slice(-2);
                var month = ("0" + (now.getMonth() + 1)).slice(-2);
                var year = now.getFullYear(); // Yılı al
                var hour = ("0" + now.getHours()).slice(-2);
                var minute = ("0" + now.getMinutes()).slice(-2);
                var dateTime = day + "." + month + "." + year + " " + hour + ":" + minute;

                console.log(dateTime);
                $MessageBox.append(`<li class="clearfix">
                                <div class="message-data text-end mb-3 me-3">
                                    <span class="small text-muted me-2"> ${dateTime}</span>
                                    </div>
                                 <div class="message other-message d-inline-block float-end">
                                ${message}
                                </div>
                        </li>`);
                signalRConnection.invoke("SendMessage", message, userId, dateTime);
                $SendMessageTextArea.val("");
                scrollToBottom();
            }
            function scrollToBottom() {
                var messageBox = document.getElementById("chat-history");
                var scrooltop = messageBox.scrollHeight;
                messageBox.scrollTop = messageBox.scrollHeight;
            }

            signalRConnection.start().then(function () {

            }).catch(function (err) {
                return console.error(err.toString());
            });

            signalRConnection.onclose(async () => {
                console.log("SignalR bağlantısı kapandı. Yeniden bağlanılıyor...");
                await tryReconnect();
            });
            setInterval(async function () {
                if (signalRConnection.state === signalR.HubConnectionState.Disconnected) {
                    console.log("SignalR bağlantısı kapandıss. Yeniden bağlanılıyor...");
                    await tryReconnect();
                }
            }, 10000); 
            async function tryReconnect() {
                try {
                    await signalRConnection.start();
                    console.log("SignalR bağlantısı başarıyla yeniden kuruldu.");
                } catch (err) {
                    console.error("SignalR bağlantısı yeniden kurulamadı: " + err.toString());
                    // Hata durumunda tekrar deneme mekanizmasını başlat
                    setTimeout(tryReconnect, 5000); // 5 saniye sonra tekrar dene
                }
            }
            //setInterval(function () {
            //    console.log("SignalR bağlantısı yenileniyor...");
            //        .then(function () {
            //            return connection.start();
            //        })
            //        .then(function () {
            //            console.log("SignalR bağlantısı başarıyla yenilendi.");
            //        })
            //        .catch(function (err) {
            //            console.error("SignalR bağlantısı yenilenemedi: " + err);
            //        });
            //}, 120000);
           
        })
     

      
      
    </script>
