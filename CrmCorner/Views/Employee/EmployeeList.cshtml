@model List<CrmCorner.Models.AppUser>
@{
    ViewData["Title"] = "Çalışan Listesi";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

<style>
    .table-spacing {
        margin-bottom: 40px !important;
    }

    .profile-img {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid #ddd;
    }
</style>

<h4 class="mb-4">👥 Şirket Çalışanları</h4>

<table id="employeeTable" class="table table-striped table-bordered table-spacing align-middle">
    <thead class="table-primary">
        <tr>
            <th>Profil</th>
            <th>Ad Soyad</th>
            <th>Email</th>
            <th>Telefon Numarası</th>
            <th>Pozisyon</th>
            <th>Şirket Adı</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>
                    <img src="/userprofilepicture/@(user.Picture ?? "defaultpp.png")" class="profile-img" />
                </td>
                <td>@user.NameSurname</td>
                <td>@user.Email</td>
                <td>@(string.IsNullOrEmpty(user.PhoneNumber) ? "-" : user.PhoneNumber)</td>
                <td>@(string.IsNullOrEmpty(user.PositionName) ? "-" : user.PositionName)</td>
                <td><span class="badge bg-info">@user.CompanyName</span></td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <!-- core js file -->
    <script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>
    <script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>
    <script src="~/CRMTema/bootstrap5/dist/assets/bundles/datatables.bundle.js"></script>

    <script>
        $(document).ready(function () {
            $('#employeeTable').DataTable({
                responsive: true,
                order: [[1, "asc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.1/i18n/tr.json"
                },
                columnDefs: [
                    { orderable: false, targets: [0] }
                ]
            });
        });
    </script>
}
