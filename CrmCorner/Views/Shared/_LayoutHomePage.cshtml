    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        let unreadMessagesHtml = '';

        const notificationsUrl = '@Url.Action("GetNotificationsStatus", "Home", new { area = currentArea })';
        const chatAppUrl = '@Url.Action("ChatApp", "ChatApp", new { area = currentArea })';

        function escapeHtml(text) {
            if (!text) return '';
            return text
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        function toggleDropdown(event) {
            event.stopPropagation();

            const dropdown = document.getElementById("messageDropdown");
            if (!dropdown) return;

            if (dropdown.style.display === "block") {
                dropdown.style.display = "none";
            } else {
                dropdown.style.display = "block";
            }
        }

        function hideDropdown() {
            const dropdown = document.getElementById("messageDropdown");
            if (dropdown) {
                dropdown.style.display = "none";
            }
        }

        function redirectToUserMessages(userId, name) {
            localStorage.setItem('selectedUserId', userId);
            localStorage.setItem('selectedUserName', name);
            window.location.href = chatAppUrl;
        }

        function showNotificationDot() {
            const messageIconElement = document.getElementById("messageIcon");
            if (messageIconElement) {
                messageIconElement.classList.add("has-unread");
            }
        }

        function hideNotificationDot() {
            const messageIconElement = document.getElementById("messageIcon");
            if (messageIconElement) {
                messageIconElement.classList.remove("has-unread");
            }
        }

        function updateNotificationCount(count) {
            const countElement = document.getElementById("notificationCount");
            if (!countElement) return;

            if (count && count > 0) {
                countElement.textContent = count > 99 ? "99+" : count;
                countElement.classList.remove("d-none");
            } else {
                countElement.textContent = "";
                countElement.classList.add("d-none");
            }
        }

        function renderEmptyDropdown() {
            const emptyHtml = `
                <li>
                    <a href="${chatAppUrl}">
                        <div class="message-empty">Yeni okunmamış mesaj yok.</div>
                    </a>
                </li>
            `;

            if (emptyHtml !== unreadMessagesHtml) {
                unreadMessagesHtml = emptyHtml;
                $('#messageDropdown').html(emptyHtml);
            }
        }

        function loadNotifications() {
            $.get(notificationsUrl, function (data) {
                const payload = data.message || data.Message;

                if (!payload) {
                    hideNotificationDot();
                    updateNotificationCount(0);
                    renderEmptyDropdown();
                    return;
                }

                const hasUnreadMessages = payload.hasUnreadMessages ?? payload.HasUnreadMessages ?? false;
                const unreadSenderCount = payload.distinctSenderIdsCount ?? payload.DistinctSenderIdsCount ?? 0;
                const unreadMessages = payload.unreadMessages ?? payload.UnreadMessages ?? [];

                if (hasUnreadMessages && unreadMessages.length > 0) {
                    showNotificationDot();
                    updateNotificationCount(unreadSenderCount);

                    let newUnreadMessagesHtml = '';

                    unreadMessages.forEach(function (message) {
                        const senderId = message.senderId || message.SenderId;
                        const senderName = escapeHtml(message.senderName || message.SenderName || "Kullanıcı");
                        const name = escapeHtml(message.name || message.Name || senderName);

                        newUnreadMessagesHtml += `
                            <li>
                                <a href="javascript:void(0);" onclick="redirectToUserMessages('${senderId}','${name}')">
                                    <div class="message-sender">${senderName}</div>
                                    <div class="message-preview">Okunmamış mesaj var</div>
                                </a>
                            </li>`;
                    });

                    if (newUnreadMessagesHtml !== unreadMessagesHtml) {
                        unreadMessagesHtml = newUnreadMessagesHtml;
                        $('#messageDropdown').html(unreadMessagesHtml);
                    }
                } else {
                    hideNotificationDot();
                    updateNotificationCount(0);
                    renderEmptyDropdown();
                }
            }).fail(function (xhr, status, error) {
                console.error("Bildirimler alınırken hata oluştu:", error);
                hideNotificationDot();
                updateNotificationCount(0);

                const errorHtml = `
                    <li>
                        <div class="message-empty">Mesajlar yüklenemedi.</div>
                    </li>
                `;

                if (errorHtml !== unreadMessagesHtml) {
                    unreadMessagesHtml = errorHtml;
                    $('#messageDropdown').html(errorHtml);
                }
            });
        }

        $(document).ready(function () {
            $(".btn-toggle-offcanvas").on("click", function () {
                $("#left-sidebar").toggleClass("sidebar-closed");
                $("#main-content").toggleClass("expanded-content");
            });

            loadNotifications();
            loadBellNotifications();

            setInterval(loadNotifications, 5000);
            setInterval(loadBellNotifications, 60000);
        });

    document.addEventListener('click', function (event) {
    const messageDropdown = document.getElementById("messageDropdown");
    const messageIcon = document.getElementById("messageIcon");

    const bellDropdown = document.getElementById("notificationBellDropdown");
    const bellIcon = document.getElementById("notificationBell");

    if (messageDropdown && messageIcon && !messageIcon.contains(event.target)) {
        hideDropdown();
    }

    if (bellDropdown && bellIcon && !bellIcon.contains(event.target)) {
        hideBellDropdown();
    }
});

    </script>

    <script src="~/CRMTema/bootstrap5/js/pages/index.js"></script>

    @RenderSection("Scripts", required: false)

    <div id="chatCornerWidget">
        <button id="chatCornerToggle" type="button" onclick="toggleChatCorner()">
            <span>💬</span>
            <span>ChatCorner</span>
        </button>

        <div id="chatCornerPanel" class="chatcorner-panel d-none">
            <div class="chatcorner-header">
                <div>
                    <div class="chatcorner-title">ChatCorner</div>
                    <div class="chatcorner-subtitle">CRM asistanınız</div>
                </div>
                <button type="button" class="chatcorner-close" onclick="toggleChatCorner()">×</button>
            </div>

            <div id="chatCornerMessages" class="chatcorner-messages">
                <div class="chat-msg bot">
                    <div class="chat-bubble">
                        Merhaba, ben ChatCorner. CRM verilerinizi analiz edebilirim.
                    </div>
                </div>
            </div>

            <div class="chatcorner-suggestions">
                <button type="button" onclick="setChatQuestion('Bu ayki tasklarım ne durumda?')">Bu ayki tasklarım</button>
                <button type="button" onclick="setChatQuestion('Geçen ay durumum nasıldı?')">Geçen ay durumum</button>
                <button type="button" onclick="setChatQuestion('Bu yıl performansım nasıl?')">Bu yıl performansım</button>
            </div>

            <div class="chatcorner-input-area-wrapper">
                <div id="chatUserSuggestions" class="chat-user-suggestions d-none"></div>

                <div class="chatcorner-input-area">
                    <input type="text"
                           id="chatCornerQuestion"
                           placeholder="Örn: @@yaren bu ay nasıldı?"
                           onkeydown="handleChatCornerKey(event)"
                           oninput="handleMentionSearch()"
                           autocomplete="off" />
                    <button type="button" class="chatcorner-send-btn" onclick="askChatCorner()">Gönder</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        let selectedMentionUser = null;
        let mentionSearchTimeout = null;

        function toggleChatCorner() {
            const panel = document.getElementById("chatCornerPanel");
            panel.classList.toggle("d-none");

            setTimeout(function () {
                const input = document.getElementById("chatCornerQuestion");
                if (input && !panel.classList.contains("d-none")) {
                    input.focus();
                }
            }, 150);
        }

        function setChatQuestion(text) {
            const input = document.getElementById("chatCornerQuestion");
            input.value = text;
            input.focus();
            handleMentionSearch();
        }

        function handleChatCornerKey(event) {
            if (event.key === "Enter") {
                event.preventDefault();
                askChatCorner();
            }
        }

        function appendMessage(sender, text, isHtml, elementId) {
            const messages = document.getElementById("chatCornerMessages");

            const wrapper = document.createElement("div");
            wrapper.className = "chat-msg " + sender;

            const bubble = document.createElement("div");
            bubble.className = "chat-bubble";

            if (elementId) {
                bubble.id = elementId;
            }

            if (isHtml) {
                bubble.innerHTML = text;
            } else {
                bubble.textContent = text;
            }

            wrapper.appendChild(bubble);
            messages.appendChild(wrapper);
            messages.scrollTop = messages.scrollHeight;
        }

        async function searchChatUsers(query) {
            const suggestionsBox = document.getElementById("chatUserSuggestions");

            if (!query || query.trim().length < 1) {
                suggestionsBox.classList.add("d-none");
                suggestionsBox.innerHTML = "";
                return;
            }

            try {
                const response = await fetch("/ChatCorner/SearchUsers?q=" + encodeURIComponent(query));
                const users = await response.json();

                if (!users || users.length === 0) {
                    suggestionsBox.classList.add("d-none");
                    suggestionsBox.innerHTML = "";
                    return;
                }

                suggestionsBox.innerHTML = "";

                users.forEach(function (user) {
                    const item = document.createElement("div");
                    item.className = "chat-user-suggestion-item";
                    item.onclick = function () {
                        selectMentionUser(user.id, user.name || "", user.email || "");
                    };

                    const nameDiv = document.createElement("div");
                    nameDiv.className = "chat-user-suggestion-name";
                    nameDiv.textContent = user.name || "";

                    const emailDiv = document.createElement("div");
                    emailDiv.className = "chat-user-suggestion-email";
                    emailDiv.textContent = user.email || "";

                    item.appendChild(nameDiv);
                    item.appendChild(emailDiv);
                    suggestionsBox.appendChild(item);
                });

                suggestionsBox.classList.remove("d-none");
            } catch (error) {
                suggestionsBox.classList.add("d-none");
                suggestionsBox.innerHTML = "";
            }
        }

        function selectMentionUser(userId, userName, userEmail) {
            const input = document.getElementById("chatCornerQuestion");
            const suggestionsBox = document.getElementById("chatUserSuggestions");

            selectedMentionUser = {
                id: userId,
                name: userName,
                email: userEmail
            };

            const currentText = input.value;
            const atIndex = currentText.lastIndexOf("@@");

            if (atIndex >= 0) {
                const beforeAt = currentText.substring(0, atIndex);
                input.value = beforeAt + "@@" + userEmail + " ";
            } else {
                input.value = "@@" + userEmail + " ";
            }

            suggestionsBox.classList.add("d-none");
            suggestionsBox.innerHTML = "";
            input.focus();
        }

        function handleMentionSearch() {
            const input = document.getElementById("chatCornerQuestion");
            const suggestionsBox = document.getElementById("chatUserSuggestions");
            const text = input.value;

            const atIndex = text.lastIndexOf("@@");
            if (atIndex < 0) {
                suggestionsBox.classList.add("d-none");
                suggestionsBox.innerHTML = "";
                return;
            }

            const afterAt = text.substring(atIndex + 2).trim();

            if (afterAt.indexOf(" ") >= 0) {
                suggestionsBox.classList.add("d-none");
                suggestionsBox.innerHTML = "";
                return;
            }

            clearTimeout(mentionSearchTimeout);
            mentionSearchTimeout = setTimeout(function () {
                searchChatUsers(afterAt);
            }, 250);
        }

        async function askChatCorner() {
            const input = document.getElementById("chatCornerQuestion");
            const suggestionsBox = document.getElementById("chatUserSuggestions");
            const question = input.value.trim();

            if (!question) return;

            suggestionsBox.classList.add("d-none");
            suggestionsBox.innerHTML = "";

            appendMessage("user", question, false, null);
            input.value = "";
            input.focus();

            appendMessage("bot", "Yazıyor...", false, "chatcorner-typing");

            try {
                const response = await fetch("/ChatCorner/Ask", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({ question: question })
                });

                const data = await response.json();

                const typing = document.getElementById("chatcorner-typing");
                if (typing) {
                    typing.parentElement.remove();
                }

                if (data.success) {
                    appendMessage("bot", data.answer, false, null);
                } else {
                    appendMessage("bot", "Hata: " + (data.errorMessage || "Bilinmeyen hata oluştu."), false, null);
                }
            } catch (error) {
                const typing = document.getElementById("chatcorner-typing");
                if (typing) {
                    typing.parentElement.remove();
                }

                appendMessage("bot", "Hata: İstek sırasında bir sorun oluştu.", false, null);
            }
        }
    </script>

    <script>
    let bellNotificationsHtml = '';

    const bellNotificationsUrl = '@Url.Action("GetTopbarNotifications", "Home", new { area = currentArea })';
    const todoListBaseUrl = '@Url.Action("ToDoList", "ToDoList", new { area = currentArea })';

    function toggleBellDropdown(event) {
        event.stopPropagation();

        const dropdown = document.getElementById("notificationBellDropdown");
        const messageDropdown = document.getElementById("messageDropdown");

        if (messageDropdown) {
            messageDropdown.style.display = "none";
        }

        if (!dropdown) return;

        if (dropdown.style.display === "block") {
            dropdown.style.display = "none";
        } else {
            dropdown.style.display = "block";
        }
    }

    function hideBellDropdown() {
        const dropdown = document.getElementById("notificationBellDropdown");
        if (dropdown) {
            dropdown.style.display = "none";
        }
    }

    function updateBellCount(count) {
        const bell = document.getElementById("notificationBell");
        const badge = document.getElementById("notificationBellCount");

        if (!bell || !badge) return;

        if (count && count > 0) {
            badge.textContent = count > 99 ? "99+" : count;
            badge.classList.remove("d-none");
            bell.classList.add("has-unread");
        } else {
            badge.textContent = "";
            badge.classList.add("d-none");
            bell.classList.remove("has-unread");
        }
    }

    function getTypeBadge(type) {
        if (type === "assigned") {
            return '<span class="topbar-type-badge assigned">Atanan Görev</span>';
        }
        if (type === "overdue") {
            return '<span class="topbar-type-badge overdue">Süresi Geçti</span>';
        }
        return '<span class="topbar-type-badge deadline">Yaklaşan Son Tarih</span>';
    }

    function loadBellNotifications() {
        $.get(bellNotificationsUrl, function (data) {
            const notifications = data.notifications || [];
            const unreadCount = data.unreadCount || 0;

            updateBellCount(unreadCount);

            if (!notifications.length) {
                const emptyHtml = `
                    <li>
                        <div class="topbar-empty">Şu anda todo tarafında yeni bildirim yok.</div>
                    </li>
                `;

                if (emptyHtml !== bellNotificationsHtml) {
                    bellNotificationsHtml = emptyHtml;
                    $('#notificationBellDropdown').html(emptyHtml);
                }

                return;
            }

            let html = '';

            notifications.forEach(function (item) {
                const targetUrl = `${todoListBaseUrl}/${item.boardId}`;

                html += `
                    <li>
                        <a href="${targetUrl}">
                            ${getTypeBadge(item.type)}
                            <div class="topbar-title">${item.title}</div>
                            <div class="topbar-meta">${item.meta}${item.deadline ? ' • Son tarih: ' + item.deadline : ''}</div>
                        </a>
                    </li>
                `;
            });

            if (html !== bellNotificationsHtml) {
                bellNotificationsHtml = html;
                $('#notificationBellDropdown').html(html);
            }
        }).fail(function () {
            updateBellCount(0);

            const errorHtml = `
                <li>
                    <div class="topbar-empty">Bildirimler yüklenemedi.</div>
                </li>
            `;

            if (errorHtml !== bellNotificationsHtml) {
                bellNotificationsHtml = errorHtml;
                $('#notificationBellDropdown').html(errorHtml);
            }
        });
    }
</script>

</body>
</html>