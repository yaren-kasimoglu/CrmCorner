                            <ul class="choose-skin list-unstyled">
                                <li data-theme="purple" class="mb-2"><div class="purple"></div><span>Purple</span></li>
                                <li data-theme="blue" class="mb-2"><div class="blue"></div><span>Blue</span></li>
