#chatCornerWidget {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 9999;
    font-family: inherit;
}

#chatCornerToggle {
    border: none;
    border-radius: 999px;
    padding: 14px 18px;
    background: #ffb71b;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 10px 30px rgba(255,183,27,.28);
    cursor: pointer;
    font-weight: 600;
}

.chatcorner-panel {
    width: 380px;
    height: 560px;
    background: #fff;
    border-radius: 24px;
    box-shadow: 0 20px 60px rgba(255,183,27,.18);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    margin-bottom: 14px;
    border: 1px solid #ffe3a3;
}

.chatcorner-header {
    background: linear-gradient(135deg, #ffb71b, #ff9800);
    color: #fff;
    padding: 18px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.chatcorner-title {
    font-size: 18px;
    font-weight: 700;
}

.chatcorner-subtitle {
    font-size: 12px;
    opacity: .85;
    margin-top: 2px;
}

.chatcorner-close {
    border: none;
    background: transparent;
    color: #fff;
    font-size: 26px;
    cursor: pointer;
    line-height: 1;
}

.chatcorner-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    background: #fffaf0;
}

.chat-msg {
    display: flex;
    margin-bottom: 12px;
}

.chat-msg.user {
    justify-content: flex-end;
}

.chat-msg.bot {
    justify-content: flex-start;
}

..chat-bubble {
    max-width: 90%;
    padding: 13px 15px;
    border-radius: 18px;
    font-size: 14px;
    line-height: 1.6;
    white-space: pre-line;
    word-break: break-word;
}

.chat-msg.user .chat-bubble {
    background: #ffb71b;
    color: #fff;
    border-bottom-right-radius: 6px;
}

.chat-msg.bot .chat-bubble {
    background: #fff;
    color: #333;
    border: 1px solid #ececf3;
    border-bottom-left-radius: 6px;
    box-shadow: 0 4px 14px rgba(0,0,0,.04);
}

.chatcorner-suggestions {
    padding: 10px 14px 0 14px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    background: #fff;
}

.chatcorner-suggestions button {
    border: 1px solid #ddd;
    background: #fafafa;
    border-radius: 999px;
    padding: 8px 12px;
    font-size: 12px;
    cursor: pointer;
    transition: all .2s ease;
}

.chatcorner-suggestions button:hover {
    background: #f3ebfb;
    border-color: #caa7eb;
    color: #4b1d73;
}

.chatcorner-input-area-wrapper {
    position: relative;
    padding: 14px;
    background: #fff;
    border-top: 1px solid #eee;
}

.chatcorner-input-area {
    display: flex;
    gap: 10px;
}

.chat-user-suggestions {
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 68px;
    background: #fff;
    border: 1px solid #e6d6f5;
    border-radius: 14px;
    box-shadow: 0 10px 24px rgba(0,0,0,.08);
    max-height: 220px;
    overflow-y: auto;
    z-index: 20;
}

.chat-user-suggestion-item {
    padding: 10px 12px;
    cursor: pointer;
    border-bottom: 1px solid #f3ecfa;
}

.chat-user-suggestion-item:last-child {
    border-bottom: none;
}

.chat-user-suggestion-item:hover {
    background: #faf5ff;
}

.chat-user-suggestion-name {
    font-weight: 600;
    color: #4b1d73;
    font-size: 13px;
}

.chat-user-suggestion-email {
    font-size: 12px;
    color: #666;
    margin-top: 2px;
}

.chatcorner-send-btn {
    background: #ffb71b;
    border: none;
    color: #ffffff;
    padding: 0 18px;
    height: 44px;
    border-radius: 12px;
    font-size: 14px;
