        </div>

<div class="chatcorner-suggestions">
    <button type="button" onclick="setChatQuestion('Bu ayki tasklarım ne durumda?')">Bu ayki tasklarım</button>
    <button type="button" onclick="setChatQuestion('Geçen ay durumum nasıldı?')">Geçen ay durumum</button>
    <button type="button" onclick="setChatQuestion('Bu yıl performansım nasıl?')">Bu yıl performansım</button>
</div>

        <div class="chatcorner-input-area-wrapper">
    <div id="chatUserSuggestions" class="chat-user-suggestions d-none"></div>

<div class="chatcorner-input-area-wrapper">
    <div id="chatUserSuggestions" class="chat-user-suggestions d-none"></div>

    <div class="chatcorner-input-area">
        <input type="text"
               id="chatCornerQuestion"
               placeholder="Örn: @@yaren bu ay nasıldı?"
               onkeydown="handleChatCornerKey(event)"
               oninput="handleMentionSearch()"
               autocomplete="off" />
        <button type="button" class="chatcorner-send-btn"  onclick="askChatCorner()">Gönder</button>
    </div>
</div>
</div>
    </div>
</div>



<script>
    let selectedMentionUser = null;
    let mentionSearchTimeout = null;

    function toggleChatCorner() {
        const panel = document.getElementById("chatCornerPanel");
        panel.classList.toggle("d-none");

        setTimeout(function () {
            const input = document.getElementById("chatCornerQuestion");
            if (input && !panel.classList.contains("d-none")) {
                input.focus();
            }
        }, 150);
    }
     function setChatQuestion(text) {
        const input = document.getElementById("chatCornerQuestion");
        input.value = text;
        input.focus();
        handleMentionSearch();
    }

 function handleChatCornerKey(event) {
        if (event.key === "Enter") {
            event.preventDefault();
            askChatCorner();
        }
    }

    function appendMessage(sender, text, isHtml, elementId) {
        const messages = document.getElementById("chatCornerMessages");

        const wrapper = document.createElement("div");
        wrapper.className = "chat-msg " + sender;

        const bubble = document.createElement("div");
        bubble.className = "chat-bubble";

        if (elementId) {
            bubble.id = elementId;
        }

        if (isHtml) {
            bubble.innerHTML = text;
        } else {
            bubble.textContent = text;
        }

        wrapper.appendChild(bubble);
        messages.appendChild(wrapper);
        messages.scrollTop = messages.scrollHeight;
    }


     async function searchChatUsers(query) {
        const suggestionsBox = document.getElementById("chatUserSuggestions");

        if (!query || query.trim().length < 1) {
            suggestionsBox.classList.add("d-none");
            suggestionsBox.innerHTML = "";
            return;
        }
         try {
            const response = await fetch("/ChatCorner/SearchUsers?q=" + encodeURIComponent(query));
            const users = await response.json();

            if (!users || users.length === 0) {
                suggestionsBox.classList.add("d-none");
                suggestionsBox.innerHTML = "";
                return;
            }

            suggestionsBox.innerHTML = "";

            users.forEach(function (user) {
                const item = document.createElement("div");
                item.className = "chat-user-suggestion-item";
                item.onclick = function () {
                    selectMentionUser(user.id, user.name || "", user.email || "");
                };

                const nameDiv = document.createElement("div");
                nameDiv.className = "chat-user-suggestion-name";
                nameDiv.textContent = user.name || "";

                const emailDiv = document.createElement("div");
                emailDiv.className = "chat-user-suggestion-email";
                emailDiv.textContent = user.email || "";

                item.appendChild(nameDiv);
                item.appendChild(emailDiv);
                suggestionsBox.appendChild(item);
            });

            suggestionsBox.classList.remove("d-none");
        } catch (error) {
            suggestionsBox.classList.add("d-none");
            suggestionsBox.innerHTML = "";
        }
    }


    function selectMentionUser(userId, userName, userEmail) {
        const input = document.getElementById("chatCornerQuestion");
        const suggestionsBox = document.getElementById("chatUserSuggestions");

        selectedMentionUser = {
            id: userId,
            name: userName,
            email: userEmail
        };

        const currentText = input.value;
        const atIndex = currentText.lastIndexOf("@@");

        if (atIndex >= 0) {
            const beforeAt = currentText.substring(0, atIndex);
            input.value = beforeAt + "@@" + userEmail + " ";
        } else {
            input.value = "@@" + userEmail + " ";
        }

        suggestionsBox.classList.add("d-none");
        suggestionsBox.innerHTML = "";
        input.focus();
    }


     function handleMentionSearch() {
        const input = document.getElementById("chatCornerQuestion");
        const suggestionsBox = document.getElementById("chatUserSuggestions");
        const text = input.value;

        const atIndex = text.lastIndexOf("@@");
        if (atIndex < 0) {
            suggestionsBox.classList.add("d-none");
            suggestionsBox.innerHTML = "";
            return;
        }
        const afterAt = text.substring(atIndex + 1).trim();

        if (afterAt.indexOf(" ") >= 0) {
            suggestionsBox.classList.add("d-none");
            suggestionsBox.innerHTML = "";
            return;
        }

        clearTimeout(mentionSearchTimeout);
        mentionSearchTimeout = setTimeout(function () {
            searchChatUsers(afterAt);
        }, 250);
    }

    async function askChatCorner() {
        const input = document.getElementById("chatCornerQuestion");
        const suggestionsBox = document.getElementById("chatUserSuggestions");
        const question = input.value.trim();

        if (!question) return;

        suggestionsBox.classList.add("d-none");
        suggestionsBox.innerHTML = "";

        appendMessage("user", question, false, null);
        input.value = "";
        input.focus();

        appendMessage("bot", "Yazıyor...", false, "chatcorner-typing");

        try {
            const response = await fetch("/ChatCorner/Ask", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({ question: question })
            });

            const data = await response.json();

            const typing = document.getElementById("chatcorner-typing");
            if (typing) {
                typing.parentElement.remove();
            }

            if (data.success) {
                appendMessage("bot", data.answer, false, null);
            } else {
                appendMessage("bot", "Hata: " + (data.errorMessage || "Bilinmeyen hata oluştu."), false, null);
            }
        } catch (error) {
            const typing = document.getElementById("chatcorner-typing");
            if (typing) {
                typing.parentElement.remove();
            }

            appendMessage("bot", "Hata: İstek sırasında bir sorun oluştu.", false, null);
        }
    }

</script>




</body>
</html>