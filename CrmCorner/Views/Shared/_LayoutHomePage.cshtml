        }

        #messageDropdown {
        display: none;
        position: absolute;
        top: 100%;
        right: 0;
        background-color: white;
        box-shadow: 0 8px 16px rgba(0,0,0,0.2);
        z-index: 1;
        list-style: none;
        padding: 0;
        margin: 0;
        width: 200px; /* Genişlik ayarlanabilir */
        }

        #messageDropdown li {
        padding: 8px 16px;
        border-bottom: 1px solid #ddd;
        }

        #messageDropdown li:hover {
        background-color: #f1f1f1;
        }


        .always-open > ul {
        display: block !important;
        }

        .always-open > a {
        cursor: default;
        pointer-events: none; /* Tıklanabilirliği tamamen kaldırır */
        }

