@using Microsoft.AspNetCore.Identity
@using CrmCorner.Models
@using CrmCorner.Models.Enums
@using Microsoft.EntityFrameworkCore
@inject CrmCornerContext _context
@inject Microsoft.AspNetCore.Identity.UserManager<CrmCorner.Models.AppUser> UserManager
@inject UserManager<AppUser> UserManager

@{
    var currentUser = UserManager.GetUserAsync(User).Result;
    string userRole = "";
    string userEmail = "";

    if (currentUser != null)
    {
        var roles = UserManager.GetRolesAsync(currentUser).Result;
        if (roles.Contains("SuperAdmin")) userRole = "SuperAdmin";
        else if (roles.Contains("Admin")) userRole = "Admin";
        else if (roles.Contains("SocialMediaAdmin")) userRole = "SocialMediaAdmin";
        else if (roles.Contains("TeamMember")) userRole = "TeamMember";
        else if (roles.Contains("TeamLeader")) userRole = "TeamLeader";
        else userRole = "User";

        userEmail = currentUser.Email;
    }

    var user = await UserManager.GetUserAsync(User);

    List<ModuleType> userModules = new List<ModuleType>();

    if (user != null)
    {
        userModules = await _context.UserModules
            .Where(x => x.UserId == user.Id)
            .Select(x => x.Module)
            .ToListAsync();
    }

    string layoutTheme =
        (userRole == "SuperAdmin" || userRole == "Admin")
            ? "theme-purple"
            : "theme-cyan";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>CRM CORNER</title>
    <meta http-equiv="X-UA-Compatible" content="IE=Edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="CRMCorner HR & Project Admin Dashboard Template with Bootstrap 5x" />
    <meta name="author" content="WrapTheme, design by: ThemeMakker.com" />

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <link rel="icon" href="~/CRMTema/favicon.ico" type="image/x-icon" />
    <link href="~/CRMTema/bootstrap5/dist/assets/css/main.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    @RenderSection("Styles", required: false)

    <style>
        .logo-container {
            max-width: 100px;
            max-height: 50px;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .logo-container img {
            width: 100%;
            height: auto;
            object-fit: contain;
        }

        .green-light {
            box-shadow: 0 0 5px 2px #2eacb3;
            border: 1px solid #2eacb3;
        }

        .pink-light {
            box-shadow: 0 0 5px 2px white;
            border: 1px solid white;
        }

        .notification-count {
            position: absolute;
            bottom: -5px;
            right: 0;
            color: #2eacb3;
            font-size: 12px;
            font-weight: bold;
        }

        #messageDropdown {
            display: none;
            position: absolute;
            top: 100%;
            right: 0;
            background-color: white;
            box-shadow: 0 8px 16px rgba(0,0,0,0.2);
            z-index: 1;
            list-style: none;
            padding: 0;
            margin: 0;
            width: 200px;
        }

        #messageDropdown li {
            padding: 8px 16px;
            border-bottom: 1px solid #ddd;
        }

        #messageDropdown li:hover {
            background-color: #f1f1f1;
        }

        .always-open > ul {
            display: block !important;
        }

        .always-open > a {
            cursor: default;
            pointer-events: none;
        }

        .sidebar-closed {
            transform: translateX(-250px);
            transition: transform 0.3s ease;
        }

        .expanded-content {
            margin-left: 0 !important;
            transition: margin-left 0.3s ease;
        }

        body {
            padding-top: 60px;
        }

        html, body {
            height: 100%;
            overflow-x: hidden;
        }

        #wrapper {
            display: flex;
        }

        #main-content {
            flex: 1;
            padding: 20px;
            transition: margin-left 0.3s ease;
            margin-left: 250px;
            width: calc(100% - 250px);
        }

        #main-content.expanded-content {
            margin-left: 0 !important;
            width: 100%;
        }

        #left-sidebar {
            position: fixed;
            width: 250px;
            height: 100%;
            background: #fff;
            top: 0;
            left: 0;
            z-index: 1000;
            transition: transform 0.3s ease;
        }

        #left-sidebar.sidebar-closed {
            transform: translateX(-250px);
        }

        @@media (max-width: 768px) {
            #left-sidebar {
                transform: translateX(-250px);
            }

            #left-sidebar.sidebar-open {
                transform: translateX(0);
            }

            #main-content {
                margin-left: 0 !important;
                width: 100%;
            }

            .user-avatar {
                width: 48px;
                height: 48px;
                object-fit: cover;
                border-radius: 50%;
                display: block;
                flex-shrink: 0;
            }
        }
    </style>
</head>

<body>
    <div id="layout" class="@layoutTheme">
        <div id="wrapper">
            <nav class="navbar navbar-fixed-top">
                <div class="container-fluid">
                    <div class="logo-container">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <img src="/CRMTema/bootstrap5/dist/assets/images/CRMCornerLogo.png" alt="Logo">
                        </a>
                    </div>

                    <button type="button" class="btn-toggle-offcanvas btn btn-outline-secondary ms-2">
                        <i class="fa fa-bars"></i>
                    </button>

                    <div id="notificationDiv" class="flex-grow-1">
                        <ul class="nav navbar-nav flex-row justify-content-end align-items-center">
                            <li id="messageIcon" class="d-none d-sm-block" style="position: relative;">
                                <a href="/ChatApp/ChatApp" class="text-decoration-none position-relative me-3" title="Mesajlar">
                                    <i class="fa fa-comments fa-lg text-primary"></i>
                                </a>
                                <span id="notificationCount" class="notification-count"></span>
                                <ul id="messageDropdown" class="dropdown-menu"></ul>
                            </li>

                            <li>
                                <a class="icon-menu" asp-route-returnurl="/Home/Index" asp-controller="Member" asp-action="Logout">
                                    <i class="fa fa-sign-out"></i>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>

            @if (User.Identity!.IsAuthenticated)
            {
                <div id="left-sidebar" class="sidebar">
                    <partial name="_NavbarLogin" />

                    <ul class="nav nav-tabs text-center mb-2" role="tablist">
                        <li class="nav-item flex-fill">
                            <a class="nav-link active" id="hr_menu_nav_link" data-bs-toggle="tab" href="#hr_menu" role="tab">Menü</a>
                        </li>
                    </ul>

                    <div class="tab-content px-0">
                        <div class="tab-pane fade show active" id="hr_menu" role="tabpanel">
                            <nav class="sidebar-nav">
                                <ul class="metismenu list-unstyled">

                                    <li class="nav-item">
                                        <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">
                                            <i class="fa fa-home"></i>Ana Sayfam
                                        </a>
                                    </li>

                                    @if (userModules.Contains(ModuleType.SocialMedia))
                                    {
                                        <li class="nav-item">
                                            <a asp-area="" asp-controller="SocialMedia" asp-action="Index">
                                                <i class="fa fa-globe"></i><span>Sosyal Medya</span>
                                            </a>
                                        </li>

                                        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin") || User.IsInRole("SocialMediaAdmin"))
                                        {
                                            <li class="nav-item">
                                                <a asp-area="" asp-controller="SocialMedia" asp-action="Create">
                                                    <i class="fa fa-pencil-square-o"></i><span>Sosyal Medya İçerik Oluştur</span>
                                                </a>
                                            </li>
                                        }

                                        <li class="nav-item">
                                            <a asp-area="" asp-controller="SocialMedia" asp-action="Calendar">
                                                <i class="fa fa-calendar"></i><span>Sosyal Medya Takvim</span>
                                            </a>
                                        </li>

                                        <li class="nav-item">
                                            <a asp-area="" asp-controller="PersonalBranding" asp-action="Index">
                                                <i class="fa fa-calendar"></i><span>Kişisel Markalaşma</span>
                                            </a>
                                        </li>
                                    }

                                    @if (userModules.Contains(ModuleType.CRM))
                                    {
                                        <li class="always-open">
                                            <a href="javascript:void(0);"><i class="fa fa-users"></i><span>Satış</span></a>
                                            <ul class="list-unstyled">
                                                <li class="nav-item">
                                                    <a class="nav-link text-dark" asp-area="" asp-controller="PipelineTask" asp-action="PipelineIndex">
                                                        <i class="fa fa-tag"></i>Tümü
                                                    </a>
                                                </li>
                                                <li class="nav-item">
                                                    <a class="nav-link text-dark" asp-area="" asp-controller="PipelineStatus" asp-action="PositivePipelineTasks">
                                                        <i class="fa fa-tag"></i>Kazanılan
                                                    </a>
                                                </li>
                                                <li class="nav-item">
                                                    <a class="nav-link text-dark" asp-area="" asp-controller="PipelineStatus" asp-action="NegativePipelineTasks">
                                                        <i class="fa fa-tag"></i>Kaybedilen
                                                    </a>
                                                </li>
                                            </ul>
                                        </li>

                                        @if (userRole == "SuperAdmin" || userRole == "Admin")
                                        {
                                            <li class="nav-item">
                                                <a class="nav-link text-dark" asp-area="" asp-controller="Company" asp-action="CompanyList">
                                                    <i class="fa fa-briefcase"></i>Sistemde Kayıtlı Firmalar
                                                </a>
                                            </li>
                                        }

                                        <li class="nav-item">
                                            <a class="nav-link text-dark" asp-area="" asp-controller="AfterTask" asp-action="ListPositiveSales">
                                                <i class="fa fa-tag"></i>Satış Sonrası Takibasyon
                                            </a>
                                        </li>

                                        <li class="nav-item">
                                            <a class="nav-link text-dark" asp-area="" asp-controller="ToDoList" asp-action="ToDoList">
                                                <i class="fa fa-calendar"></i>Yapılacaklar
                                            </a>
                                        </li>

                                        <li class="nav-item">
                                            <a class="nav-link text-dark" asp-area="" asp-controller="Customer" asp-action="CustomerList">
                                                <i class="fa fa-users"></i>Müşterilerim
                                            </a>
                                        </li>

                                        <li class="nav-item">
                                            <a class="nav-link text-dark" asp-area="" asp-controller="Employee" asp-action="EmployeeList">
                                                <i class="fa fa-users"></i>Çalışanlarımız
                                            </a>
                                        </li>

                                        @if (userRole == "SuperAdmin" || userRole == "Admin" || userRole == "TeamLeader")
                                        {
                                            <li class="nav-item">
                                                <a class="nav-link d-flex align-items-center"
                                                   data-bs-toggle="collapse"
                                                   href="#reportSubmenu"
                                                   role="button"
                                                   aria-expanded="false"
                                                   aria-controls="reportSubmenu">
                                                    <i class="fa fa-chart-bar me-2"></i><span>Rapor</span>
                                                    <i class="fa fa-chevron-down ms-auto"></i>
                                                </a>
                                                <ul class="collapse list-unstyled ps-4" id="reportSubmenu">
                                                    <li class="nav-item">
                                                        <a class="nav-link text-dark" asp-controller="Reports" asp-action="ResponsibleUserTasks">
                                                            <i class="fa fa-tasks me-2"></i>Süreç Durumu
                                                        </a>
                                                    </li>
                                                    <li class="nav-item">
                                                        <a class="nav-link text-dark" asp-controller="Reports" asp-action="StageByUserReports">
                                                            <i class="fa fa-layer-group me-2"></i>Görev Sayısı
                                                        </a>
                                                    </li>
                                                    <li class="nav-item">
                                                        <a class="nav-link text-dark" asp-controller="PipelineAnalysis" asp-action="Index">
                                                            <i class="fa fa-layer-group me-2"></i>Kişi / Görev Analiz
                                                        </a>
                                                    </li>
                                                </ul>
                                            </li>
                                        }

                                        @if (userRole == "SuperAdmin")
                                        {
                                            <li class="nav-item">
                                                <a class="nav-link d-flex align-items-center"
                                                   data-bs-toggle="collapse"
                                                   href="#roleSubmenu"
                                                   role="button"
                                                   aria-expanded="false"
                                                   aria-controls="roleSubmenu">
                                                    <i class="fa fa-chart-bar me-2"></i><span>Rol Yetki</span>
                                                    <i class="fa fa-chevron-down ms-auto"></i>
                                                </a>
                                                <ul class="collapse list-unstyled ps-4" id="roleSubmenu">
                                                    <li class="nav-item">
                                                        <a class="nav-link text-dark" asp-area="" asp-controller="Roles" asp-action="Index">
                                                            <i class="fa fa-briefcase"></i>Rol Oluşturma
                                                        </a>
                                                    </li>
                                                    <li class="nav-item">
                                                        <a class="nav-link text-dark" asp-area="" asp-controller="UserRoles" asp-action="Index">
                                                            <i class="fa fa-briefcase"></i>Yetki Atama
                                                        </a>
                                                    </li>
                                                </ul>
                                            </li>
                                        }

                                        <li class="nav-item">
                                            <a asp-area="" asp-controller="ChatApp" asp-action="ChatApp">
                                                <i class="fa fa-comments"></i><span>Mesajlarım</span>
                                            </a>
                                        </li>

                                        <li class="nav-item">
                                            <a asp-area="" asp-controller="ApolloSettings" asp-action="Index">
                                                <i class="fa fa-link"></i><span>Apollo API Tanımla</span>
                                            </a>
                                        </li>

                                        <li class="nav-item">
                                            <a asp-area="" asp-controller="ApolloPull" asp-action="FetchContacts">
                                                <i class="fa fa-plug"></i><span>Apollo.io Kontak Çekme</span>
                                            </a>
                                        </li>

                                        <li class="nav-item">
                                            <a asp-area="" asp-controller="ApolloPull" asp-action="ContactsList">
                                                <i class="fa fa-id-card"></i><span>Apollo.io Kontak Listesi</span>
                                            </a>
                                        </li>

                                        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin") || User.IsInRole("Finance"))
                                        {
                                            <li class="nav-item">
                                                <a asp-area="" asp-controller="Finance" asp-action="Invoices">
                                                    <i class="fa fa-file-invoice-dollar"></i><span>Finans</span>
                                                </a>
                                            </li>

                                            <li class="nav-item">
                                                <a asp-area="" asp-controller="Finance" asp-action="Dashboard">
                                                    <i class="fa fa-file-invoice-dollar"></i><span>Finans Analiz</span>
                                                </a>
                                            </li>
                                        }
                                    }
                                </ul>
                            </nav>
                        </div>
                    </div>
                </div>
            }

            <div id="main-content">
                @RenderSection("BodyContent", required: false)
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        let unreadMessagesHtml = '';

        function toggleDropdown(event) {
            event.stopPropagation();
            $('#messageDropdown').toggle();
        }

        function hideDropdown() {
            $('#messageDropdown').hide();
        }

        $(document).ready(function () {
            $(".btn-toggle-offcanvas").on("click", function () {
                $("#left-sidebar").toggleClass("sidebar-closed");
                $("#main-content").toggleClass("expanded-content");
            });
        });

        $(document).ready(function () {
            setInterval(function () {
                $.get('/Home/GetNotificationsStatus', function (data) {
                    var hasUnreadMessages = data.message.hasUnreadMessages;
                    var unreadSenderCount = data.message.distinctSenderIdsCount;

                    if (hasUnreadMessages) {
                        showNotificationDot();
                        $('#notificationCount').text(unreadSenderCount);

                        let newUnreadMessagesHtml = '';
                        data.message.unreadMessages.forEach(function (message) {
                            newUnreadMessagesHtml += `<li><a href="javascript:void(0);" onclick="redirectToUserMessages('${message.senderId}','${message.name}')">${message.senderName}</a></li>`;
                        });

                        if (newUnreadMessagesHtml !== unreadMessagesHtml) {
                            unreadMessagesHtml = newUnreadMessagesHtml;
                            $('#messageDropdown').html(unreadMessagesHtml);
                        }
                    } else {
                        hideNotificationDot();
                    }
                });
            }, 1000);
        });

        function redirectToUserMessages(userId, name) {
            localStorage.setItem('selectedUserId', userId);
            localStorage.setItem('selectedUserName', name);
            window.location.href = "/ChatApp/ChatApp";
        }

        document.addEventListener('DOMContentLoaded', function () {
            var messageIconElement = document.getElementById("messageIcon");
            if (messageIconElement) {
                messageIconElement.classList.add("pink-light");
            }
        });

        function showNotificationDot() {
            var messageIconElement = document.getElementById("messageIcon");
            if (messageIconElement) {
                messageIconElement.classList.remove("pink-light");
                messageIconElement.classList.add("green-light");
            }
        }

        function hideNotificationDot() {
            var messageIconElement = document.getElementById("messageIcon");
            if (messageIconElement) {
                messageIconElement.classList.remove("green-light");
                messageIconElement.classList.add("pink-light");
            }
        }
    </script>

     <script src="~/CRMTema/bootstrap5/js/pages/index.js"></script>

     <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/CRMTema/bootstrap5/dist/assets/plugins/jquery-ui/jquery-ui.min.js"></script>


    @RenderSection("Scripts", required: false)
</body>
</html>