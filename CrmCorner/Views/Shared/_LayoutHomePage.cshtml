        }

        .notification-count {
            position: absolute;
            top: -6px;
            right: -6px;
            min-width: 20px;
            height: 20px;
            padding: 0 6px;
            border-radius: 999px;
            background: #dc2626;
            color: #fff;
            font-size: 11px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 2px solid #fff;
            line-height: 1;
        }

        .message-dropdown {
            display: none;
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            width: 300px;
            min-height: 56px;
            background: #fff;
            border: 1px solid #eee;
            border-radius: 14px;
            box-shadow: 0 18px 40px rgba(0, 0, 0, .10);
            z-index: 9999;
            padding: 8px 0;
            margin: 0;
            list-style: none;
            overflow: hidden;
        }

        .message-dropdown li {
            border-bottom: 1px solid #f3f4f6;
        }

        .message-dropdown li:last-child {
            border-bottom: none;
        }

        .message-dropdown li a {
            display: block;
            padding: 12px 14px;
            color: #1f2937;
            text-decoration: none;
            font-size: 14px;
            line-height: 1.4;
        }

        .message-dropdown li a:hover {
            background: #fff8e8;
            color: #b77900;
        }

        .message-sender {
            font-weight: 700;
            font-size: 13px;
            color: #1f2937;
            margin-bottom: 2px;
        }

        .message-preview {
            font-size: 12px;
            color: #6b7280;
        }

        .message-empty {
            padding: 14px;
            font-size: 13px;
            color: #6b7280;
        }

        .message-nav-item.has-unread .message-nav-link {
            animation: pulseMessageIcon 1.8s infinite;
        }

        @@keyframes pulseMessageIcon {
            0% {
                box-shadow: 0 0 0 0 rgba(255, 183, 27, 0.35);
            }

            70% {
                box-shadow: 0 0 0 12px rgba(255, 183, 27, 0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(255, 183, 27, 0);
            }
        }

        .always-open > ul {
            display: block !important;
        }

        .always-open > a {
            cursor: default;
            pointer-events: none;
        }

        .sidebar-closed {
            transform: translateX(-250px);
            transition: transform 0.3s ease;
        }

        .expanded-content {
            margin-left: 0 !important;
            transition: margin-left 0.3s ease;
        }

        body {
            padding-top: 60px;
        }

        html, body {
            height: 100%;
            overflow-x: hidden;
        }

        #wrapper {
            display: flex;
        }

        #main-content {
            flex: 1;
            padding: 20px;
            transition: margin-left 0.3s ease;
            margin-left: 250px;
            width: calc(100% - 250px);
        }

        #main-content.expanded-content {
            margin-left: 0 !important;
            width: 100%;
        }

        #left-sidebar {
            position: fixed;
            width: 250px;
            height: 100%;
            background: #fff;
            top: 0;
            left: 0;
            z-index: 1000;
            transition: transform 0.3s ease;
        }

        #left-sidebar.sidebar-closed {
            transform: translateX(-250px);
        }

        @@media (max-width: 768px) {
            #left-sidebar {
                transform: translateX(-250px);
            }

            #left-sidebar.sidebar-open {
                transform: translateX(0);
            }

            #main-content {
                margin-left: 0 !important;
                width: 100%;
            }

            .user-avatar {
                width: 48px;
                height: 48px;
                object-fit: cover;
                border-radius: 50%;
                display: block;
                flex-shrink: 0;
            }

            .message-dropdown {
                right: -10px;
                width: 240px;
            }
        }

        #chatCornerWidget {
            position: fixed;
            right: 24px;
            bottom: 24px;
            z-index: 9999;
            font-family: inherit;
        }

        #chatCornerToggle {
            border: none;
            border-radius: 999px;
            padding: 14px 18px;
            background: #ffb71b;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 10px 30px rgba(255,183,27,.28);
            cursor: pointer;
            font-weight: 600;
        }

        .chatcorner-panel {
            width: 380px;
            height: 560px;
            background: #fff;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(255,183,27,.18);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            margin-bottom: 14px;
            border: 1px solid #ffe3a3;
        }

        .chatcorner-header {
            background: linear-gradient(135deg, #ffb71b, #ff9800);
            color: #fff;
            padding: 18px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .chatcorner-title {
            font-size: 18px;
            font-weight: 700;
        }

        .chatcorner-subtitle {
            font-size: 12px;
            opacity: .85;
            margin-top: 2px;
        }

        .chatcorner-close {
            border: none;
            background: transparent;
            color: #fff;
            font-size: 26px;
            cursor: pointer;
            line-height: 1;
        }

        .chatcorner-messages {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
            background: #fffaf0;
        }

        .chat-msg {
            display: flex;
            margin-bottom: 12px;
        }

        .chat-msg.user {
            justify-content: flex-end;
        }

        .chat-msg.bot {
            justify-content: flex-start;
        }

        .chat-bubble {
            max-width: 90%;
            padding: 13px 15px;
            border-radius: 18px;
            font-size: 14px;
            line-height: 1.6;
            white-space: pre-line;
            word-break: break-word;
        }

        .chat-msg.user .chat-bubble {
            background: #ffb71b;
            color: #fff;
            border-bottom-right-radius: 6px;
        }

        .chat-msg.bot .chat-bubble {
            background: #fff;
            color: #333;
            border: 1px solid #ececf3;
            border-bottom-left-radius: 6px;
            box-shadow: 0 4px 14px rgba(0,0,0,.04);
        }

        .chatcorner-suggestions {
            padding: 10px 14px 0 14px;
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            background: #fff;
        }

        .chatcorner-suggestions button {
            border: 1px solid #ddd;
            background: #fafafa;
            border-radius: 999px;
            padding: 8px 12px;
            font-size: 12px;
            cursor: pointer;
            transition: all .2s ease;
        }

        .chatcorner-suggestions button:hover {
            background: #f3ebfb;
            border-color: #caa7eb;
            color: #4b1d73;
        }

        .chatcorner-input-area-wrapper {
            position: relative;
            padding: 14px;
            background: #fff;
            border-top: 1px solid #eee;
        }

        .chatcorner-input-area {
            display: flex;
            gap: 10px;
        }

        .chatcorner-input-area input {
            flex: 1;
            min-width: 0;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 0 14px;
            height: 44px;
            outline: none;
        }

        .chatcorner-input-area input:focus {
            border-color: #ffb71b;
            box-shadow: 0 0 0 3px rgba(255, 183, 27, 0.12);
        }

        .chat-user-suggestions {
            position: absolute;
            left: 14px;
            right: 14px;
            bottom: 68px;
            background: #fff;
            border: 1px solid #e6d6f5;
            border-radius: 14px;
            box-shadow: 0 10px 24px rgba(0,0,0,.08);
            max-height: 220px;
            overflow-y: auto;
            z-index: 20;
        }

        .chat-user-suggestion-item {
            padding: 10px 12px;
            cursor: pointer;
            border-bottom: 1px solid #f3ecfa;
        }

        .chat-user-suggestion-item:last-child {
            border-bottom: none;
        }

        .chat-user-suggestion-item:hover {
            background: #faf5ff;
        }

        .chat-user-suggestion-name {
            font-weight: 600;
            color: #4b1d73;
            font-size: 13px;
        }

        .chat-user-suggestion-email {
            font-size: 12px;
            color: #666;
            margin-top: 2px;
        }

        .chatcorner-send-btn {
            background: #ffb71b;
            border: none;
            color: #ffffff;
            padding: 0 18px;
            height: 44px;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            min-width: 92px;
            transition: all .2s ease;
            box-shadow: 0 4px 12px rgba(255, 183, 27, 0.28);
        }

        .chatcorner-send-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(255, 183, 27, 0.38);
            filter: brightness(1.03);
        }

        .chatcorner-send-btn:active {
            transform: translateY(0);
            box-shadow: 0 3px 8px rgba(255, 183, 27, 0.25);
        }

        .chatcorner-send-btn:disabled {
            opacity: .65;
            cursor: not-allowed;
            box-shadow: none;
        }

        .d-none {
            display: none !important;
        }

        @@media (max-width: 576px) {
            #chatCornerWidget {
                right: 12px;
                left: 12px;
                bottom: 12px;
            }

            .chatcorner-panel {
                width: 100%;
                height: 70vh;
            }

            #chatCornerToggle {
                margin-left: auto;
            }
        }


