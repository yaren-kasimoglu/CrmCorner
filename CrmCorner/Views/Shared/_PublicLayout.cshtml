@{
    var pageTitle = ViewData["Title"]?.ToString() ?? "CRM Corner";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@pageTitle - CRM Corner</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />

    <style>
        :root {
            --primary: #ffb71b;
            --primary-dark: #e6a514;
            --secondary: #ffd76a;
            --soft-bg: #f7f7fb;
            --card-bg: #ffffff;
            --text-dark: #1f2937;
            --text-muted: #6b7280;
            --border: #e5e7eb;
            --success-soft: #ecfdf3;
            --warning-soft: #fff7ed;
            --blue-soft: #eff6ff;
            --purple-soft: #fff4d6;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #ffffff;
            color: var(--text-dark);
            margin: 0;
            padding: 0;
        }

        .navbar-custom {
            background: rgba(255,255,255,.92);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(229,231,235,.8);
        }

        .brand-box {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 700;
            font-size: 20px;
            box-shadow: 0 10px 25px rgba(255,183,27,.25);
        }

        .hero-section {
            padding: 90px 0 70px 0;
            background: radial-gradient(circle at top left, rgba(255,183,27,.15), transparent 30%), radial-gradient(circle at bottom right, rgba(255,215,106,.15), transparent 28%), #fff;
        }

        .hero-badge,
        .page-hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #fff4d6;
            border: 1px solid #ffe19a;
            color: var(--primary);
            padding: 8px 16px;
            border-radius: 999px;
            font-weight: 600;
            font-size: 14px;
        }

        .hero-title,
        .page-title {
            font-size: 52px;
            line-height: 1.1;
            font-weight: 800;
            letter-spacing: -1px;
            margin-top: 22px;
            color: #14274a;
        }

        .hero-text,
        .page-text {
            font-size: 18px;
            color: var(--text-muted);
            max-width: 620px;
            line-height: 1.75;
            margin-top: 22px;
        }

        .btn-main {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border: none;
            color: white;
            padding: 14px 26px;
            border-radius: 14px;
            font-weight: 600;
            box-shadow: 0 12px 26px rgba(255,183,27,.25);
            transition: all .2s ease;
            text-decoration: none;
        }

            .btn-main:hover {
                transform: translateY(-2px);
                color: white;
                background: linear-gradient(135deg, var(--primary-dark), var(--secondary));
            }

        .btn-light-custom {
            background: #fff;
            border: 1px solid var(--border);
            color: var(--text-dark);
            padding: 14px 26px;
            border-radius: 14px;
            font-weight: 600;
            transition: all .2s ease;
            text-decoration: none;
        }

            .btn-light-custom:hover {
                background: #f9fafb;
                transform: translateY(-2px);
                color: var(--text-dark);
            }

        .stats-card,
        .module-card,
        .feature-card,
        .preview-card,
        .dashboard-card,
        .cta-box,
        .info-card,
        .legal-card {
            border-radius: 24px;
            border: 1px solid var(--border);
            background: var(--card-bg);
            box-shadow: 0 10px 35px rgba(15,23,42,.05);
        }

        .stats-card {
            padding: 22px;
            height: 100%;
        }

        .stats-number {
            font-size: 28px;
            font-weight: 800;
        }

        .stats-label {
            color: var(--text-muted);
            font-size: 14px;
        }

        .dashboard-card {
            padding: 28px;
        }

        .mini-stat {
            border-radius: 18px;
            padding: 18px;
            height: 100%;
        }

        .section-space {
            padding: 90px 0;
        }

        .section-title {
            font-size: 38px;
            font-weight: 800;
            letter-spacing: -.6px;
            color: #14274a;
        }

        .section-text {
            color: var(--text-muted);
            font-size: 17px;
            line-height: 1.8;
            max-width: 720px;
        }

        .module-card {
            padding: 34px;
            transition: all .25s ease;
            height: 100%;
        }

            .module-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 20px 45px rgba(15,23,42,.08);
            }

        .module-tag {
            display: inline-block;
            padding: 7px 14px;
            border-radius: 999px;
            background: var(--purple-soft);
            color: var(--primary);
            font-size: 12px;
            font-weight: 700;
        }

        .module-card h3 {
            font-size: 28px;
            font-weight: 800;
            margin-top: 22px;
            color: #14274a;
        }

        .module-card p {
            color: var(--text-muted);
            line-height: 1.8;
            margin-top: 14px;
        }

        .pill {
            display: inline-block;
            padding: 8px 14px;
            background: #f9fafb;
            border: 1px solid var(--border);
            color: #4b5563;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 600;
            margin: 6px 6px 0 0;
        }

        .feature-card {
            padding: 28px;
            height: 100%;
        }

        .feature-icon {
            width: 52px;
            height: 52px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            margin-bottom: 18px;
        }

        .preview-card {
            padding: 24px;
            height: 100%;
        }

        .preview-image {
            height: 180px;
            border-radius: 18px;
            background: linear-gradient(135deg, #fff4d6, #ffffff 55%, #fff8e8);
            border: 1px solid #ffe7a8;
        }

        .cta-box {
            padding: 50px;
            background: linear-gradient(135deg, #111827, #1f2937);
            color: white;
            border: none;
        }

        .soft-section {
            background: #fafafe;
        }

        .footer-custom {
            border-top: 1px solid var(--border);
            color: var(--text-muted);
            background: #fff;
        }

        .info-card {
            padding: 28px;
            height: 100%;
        }

        .legal-card {
            padding: 32px;
        }

        .public-page {
            min-height: calc(100vh - 160px);
            background: radial-gradient(circle at top left, rgba(255,183,27,.10), transparent 30%), #fff;
        }

        @@media (max-width: 992px) {
            .hero-title,
            .page-title {
                font-size: 40px;
            }
        }

        @@media (max-width: 768px) {
            .hero-title,
            .page-title {
                font-size: 34px;
            }

            .section-title {
                font-size: 30px;
            }

            .cta-box {
                padding: 28px;
            }
        }


        .payment-badges img {
            height: 44px;
            object-fit: contain;
            transition: .2s ease;
            opacity: .95;
        }

            .payment-badges img:hover {
                transform: translateY(-1px);
                opacity: 1;
            }


    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-light navbar-custom sticky-top">
        <div class="container py-2">
            <a class="navbar-brand d-flex align-items-center gap-3 fw-bold" href="/Home/Landing">
                <div class="brand-box">C</div>
                <div>
                    <div style="font-size:18px; line-height:1;">CRM Corner</div>
                    <small class="text-muted fw-normal">Multi-module workspace</small>
                </div>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#landingNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="landingNav">
                <ul class="navbar-nav ms-auto me-3 gap-lg-3">
                    <li class="nav-item"><a class="nav-link fw-semibold" href="/Home/Landing#modules">Ürünler</a></li>
                    <li class="nav-item"><a class="nav-link fw-semibold" href="/Home/Landing#features">Özellikler</a></li>
                    <li class="nav-item"><a class="nav-link fw-semibold" href="/Home/Landing#preview">Ekranlar</a></li>
                    <li class="nav-item"><a class="nav-link fw-semibold" href="/Home/About">Hakkımızda</a></li>
                    <li class="nav-item"><a class="nav-link fw-semibold" href="/Home/Privacy">Gizlilik Politikası</a></li>
                    <li class="nav-item"><a class="nav-link fw-semibold" href="/Home/Contact">İletişim</a></li>
                    <li class="nav-item"><a class="nav-link fw-semibold" href="/Home/Terms">Kullanım Şartları</a></li>
                </ul>

                <div class="d-flex gap-2">
                    <a href="/Home/SignIn" class="btn btn-light-custom">Giriş Yap</a>
                    <a href="/Home/SignUp" class="btn btn-main">Başla</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="public-page">
        @RenderBody()
    </main>

    <footer class="footer-custom py-4 border-top bg-white mt-5">
        <div class="container">

            <div class="row align-items-center gy-3">

                <!-- Sol -->
                <div class="col-lg-3 text-center text-lg-start">
                    <div class="text-muted small">
                        © 2026 CRM Corner. Tüm hakları saklıdır.
                    </div>
                </div>

                <!-- Orta -->
                <div class="col-lg-6 text-center">
                    <div class="d-flex flex-wrap justify-content-center gap-3 small">
                        <a href="/Home/Landing#modules" class="text-decoration-none text-muted">Ürünler</a>
                        <a href="/Home/Pricing" class="text-decoration-none text-muted">Abonelik</a>
                        <a href="/Home/About" class="text-decoration-none text-muted">Hakkımızda</a>
                        <a href="/Home/Privacy" class="text-decoration-none text-muted">Gizlilik Politikası</a>
                        <a href="/Home/Refund" class="text-decoration-none text-muted">Teslimat ve İade</a>
                        <a href="/Home/SignIn" class="text-decoration-none text-muted">Giriş Yap</a>
                    </div>
                </div>

                <!-- Sağ -->
                <div class="col-lg-3 text-center text-lg-end">
                    <div class="payment-badges d-inline-flex align-items-center gap-2 flex-wrap justify-content-center">
                        <img src="~/images/payment/iyzico.jpeg" />
                    </div>
                </div>

            </div>

        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>