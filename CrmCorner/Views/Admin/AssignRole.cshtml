@model CrmCorner.ViewModels.AssignRoleViewModel

@{
    ViewData["Title"] = "Assign Role";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

<h2>Assign Roles to @Model.UserName</h2>

<form asp-action="AssignRole" method="post">
    <div class="form-group">
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="UserName" />
        <label>Roles</label>
        <select asp-for="SelectedRoles" class="form-control" asp-items="@(new MultiSelectList(Model.Roles))" multiple="multiple">
        </select>
    </div>
    <div class="form-group">
        <input type="submit" value="Save" class="btn btn-primary" />
    </div>
</form>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
