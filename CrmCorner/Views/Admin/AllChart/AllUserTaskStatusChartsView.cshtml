@{
    ViewData["Title"] = "Şirket Görev Analizi";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

<h2 style="text-align: center; margin-bottom: 20px;">Şirket Görev Analizi</h2>

<div id="chartsContainer" style="display: flex; flex-wrap: wrap; justify-content: center; gap: 20px;"></div>

<!-- Grafik ve AJAX için gerekli scriptler -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $(document).ready(function () {
        $.ajax({
            type: "GET",
            url: "/Admin/AllChart/AllUserTaskStatusCharts",
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (data) {
                console.log("Gelen JSON:", data); // Konsolda JSON verisini görmek için

                var container = $('#chartsContainer');
                container.empty(); // Önceki içeriği temizle

                if (data.length === 0) {
                    container.append('<p style="text-align:center; font-weight:bold; color:gray;">Henüz gösterilecek görev verisi bulunmamaktadır.</p>');
                    return;
                }

                data.forEach(function (userChart, index) {
                    if (userChart.chartData.length > 0) {
                        var userDiv = $(`
                            <div style="width: 300px; margin: 10px; border: 1px solid #ddd; border-radius: 8px; padding: 15px; box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);">
                                <h4 style="text-align: center;">${userChart.userName}</h4>
                                <canvas id="chart-${index}" width="300" height="300"></canvas>
                            </div>
                        `);
                        container.append(userDiv);

                        var ctx = document.getElementById(`chart-${index}`).getContext('2d');
                        var labels = userChart.chartData.map(item => item.statusName);
                        var dataValues = userChart.chartData.map(item => item.count);
                        var colors = ['#d0e9f5', '#a0c4e3', '#6baed6', '#3182bd', '#ffcccb', '#98fb98'];

                        new Chart(ctx, {
                            type: 'doughnut',
                            data: {
                                labels: labels,
                                datasets: [{
                                    data: dataValues,
                                    backgroundColor: colors
                                }]
                            },
                            options: {
                                plugins: {
                                    legend: {
                                        position: 'bottom'
                                    }
                                }
                            }
                        });
                    }
                });
            },
            error: function (error) {
                console.error("Veri çekme hatası:", error);
            }
        });
    });
</script>
