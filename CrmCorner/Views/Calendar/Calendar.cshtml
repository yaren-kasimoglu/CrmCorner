@model CrmCorner.Models.Calendar
@{
    ViewData["Title"] = "Calendar";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
    var events = ViewBag.Calendar;
    var eventsfilter = ViewBag.CalendarFilter;


}

<body>
    <table id="todoTable" style="display: none; visibility:collapse">
        @foreach (var item in events)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Title</td>
                <td>@item.Date</td>
            </tr>
        }
    </table>

    <div id="layout" class="theme-cyan">

        <!-- Page Loader -->


        <div id="wrapper">


            <div id="main-content-left" class="page-calendar">

                <div class="row g-3 clearfix">
                    <div class="col-lg-8">
                        <div class="card">
                            <div class="card-body" id='my_calendar'></div>

                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="card mb-3">
                            <div class="card-body">
                                <button type="button" class="btn btn-primary w-100" data-bs-toggle="modal"
                                        data-bs-target="#exampleModal">
                                    Yeni takvim ekle
                                </button>
                            </div>
                        </div>
                        <div class="card mb-3">
                            <div class="card-body">

                                @foreach (var item in eventsfilter)
                                {
                                    <div class="event-name row g-2">
                                        <div class="col-2 text-center">
                                            <h6>@item.Date</h6>
                                        </div>
                                        <div class="col-10">
                                            <h6 class="mb-0">@item.Title</h6>
                                            <p class="mb-0">@item.Description</p>

                                        </div>
                                    </div>
                                }

                                <hr>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>



    <!-- Default Size -->
    @using (Html.BeginForm("CalendarAdd", "Calendar", FormMethod.Post))
    {
        <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModal" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="defaultModalLabel">Add Event</h5>
                    </div>

                    <div class="modal-body">
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <div class="form-group">
                            @Html.LabelFor(model => model.Date, htmlAttributes: new { @class = "control-label col-md-2" })
                            <div class="col-md-10">
                                @Html.EditorFor(model => model.Date, "Date", new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.Date, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="form-group">
                            @Html.LabelFor(model => model.Title, htmlAttributes: new { @class = "control-label col-md-2" })
                            <div class="col-md-10">
                                @Html.EditorFor(model => model.Title, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.Title, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="form-group">
                            @Html.LabelFor(model => model.Description, htmlAttributes: new { @class = "control-label col-md-2" })
                            <div class="col-md-10">
                                @Html.EditorFor(model => model.Description, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.Description, "", new { @class = "text-danger" })
                            </div>
                        </div>



                        <div class="form-group">
                            <div class="col-md-offset-2 col-md-10">
                                <input type="submit" value="Add" id="Submit" class="btn btn-default" onclick="location.href='@Url.Action("CalendarAdd", "Calendar")'" />
                            </div>
                        </div>
                    </div>


                </div>

            </div>
        </div>

    }

    <!-- Modal -->
    @using (Html.BeginForm("CalendarUpdate", "Calendar", FormMethod.Post))
    {

        <div class="modal fade" id="myModal" tabindex="-1" aria-labelledby="myModal" aria-hidden="true">

            <div class="modal-dialog">

                <div class="modal-content">

                    <div class="modal-header">

                        <h5 class="modal-title" id="myModalLabel">Edit Event</h5>

                    </div>

                 <h5 id="Id" value="@ViewBag.Id"></h5>
                    <div class="modal-body">

                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })



                        <div class="form-group">

                            <h5 id="eventStart"></h5>

                            @Html.LabelFor(model => model.Date, htmlAttributes: new { @class = "control-label col-md-2" })

                            <div class="col-md-10">

                                @Html.EditorFor(model => model.Date, "Date", new { htmlAttributes = new { @class = "form-control" } })

                                @Html.ValidationMessageFor(model => model.Date, "", new { @class = "text-danger" })

                            </div>

                        </div>



                        <div class="form-group">

                            <h5 id="modalTitle"></h5>



                            @Html.LabelFor(model => model.Title, htmlAttributes: new { @class = "control-label col-md-2" })

                            <div class="col-md-10">

                                @Html.EditorFor(model => model.Title, new { htmlAttributes = new { @class = "form-control" } })

                                @Html.ValidationMessageFor(model => model.Title, "", new { @class = "text-danger" })

                            </div>

                        </div>



                        <div class="form-group">

                            @Html.LabelFor(model => model.Description, htmlAttributes: new { @class = "control-label col-md-2" })

                            <div class="col-md-10">

                                @Html.EditorFor(model => model.Description, new { htmlAttributes = new { @class = "form-control" } })

                                @Html.ValidationMessageFor(model => model.Description, "", new { @class = "text-danger" })

                            </div>

                        </div>







                        <div class="form-group">

                            <div class="col-md-offset-2 col-md-10">

                                <button type="submit" class="btn btn-rounded btn-success" onclick="location.href='@Url.Action("CalendarUpdate", "Calendar")'"><i class="fas fa-check-square"></i>EDİT</button>
                                <button type="submit" class="btn btn-rounded btn-success" onclick="DeleteItem();"><i class="fas fa-check-square"></i> DELETE </button>

                            </div>

                        </div>


                    </div>






                </div>



            </div>


        </div>
    }





    <script>let eventsArr = loadData();

        function loadData() {

            let eventsArr = [];

            let todoTable = document.getElementById("todoTable");
            let trElem = todoTable.getElementsByTagName("tr");
            console.log(trElem);
            for (let tr of trElem) {
                console.log(tr);
                let tdElems = tr.getElementsByTagName("td");
                let eventObj = {
                    id: tdElems[0].innerText,
                    title: tdElems[1].innerText,
                    start: tdElems[2].innerText,
                }

                eventsArr.push(eventObj);
            }

            return eventsArr;
        }

        document.addEventListener('DOMContentLoaded', function () {
            var calendarEl = document.getElementById('my_calendar');

            var calendar = new FullCalendar.Calendar(calendarEl, {
                timeZone: 'UTC',
                initialView: 'dayGridMonth',
                events: eventsArr,
                editable: true,
                selectable: true,
                eventClick: function (info) {
                    document.getElementById("Id").innerHTML = info.event.id;
                    document.getElementById("Title").innerHTML = info.event.title;
                    selectedEvent = info.event;
                    console.log(selectedEvent);
                    $('#myModal').modal('show');
                },
            });
            calendar.render();
        });
        function DeleteItem() {
            if (confirm('Are you sure you want to dele te this calendar event?')) {
                var event = document.getElementById("Id").innerHTML;
                alert(event);
                $.ajax({
                    type: 'POST',
                    url: "/Calendar/CalendarDelete/",
                    encode: true,
                    data: { ID: event },
                    dataType: "json",
                    success: function (data) {
                        if (data['success']) {
                            //previous version
                            //$('#calendar').fullCalendar('removeEvents',eventDelete)
                        }
                    },
                })
            }
        }
    </script>
    <!-- core js file -->
    <script src="/themeforest-IV5IQlTa-lucid-hr-and-project-management-admin-template/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>
    <script src="/themeforest-IV5IQlTa-lucid-hr-and-project-management-admin-template/bootstrap5/dist/assets/bundles/fullcalendar.bundle.js"></script>

    <!-- page js file -->
    <script src="/themeforest-IV5IQlTa-lucid-hr-and-project-management-admin-template/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>
</body>




