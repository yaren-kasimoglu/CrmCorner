@model CrmCorner.Models.Calendar

@{
    ViewData["Title"] = "Calendar";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
    var events = ViewBag.Calendar;
    var eventsfilter = ViewBag.CalendarFilter;
}
<a asp-action="ConnectGoogleCalendar" asp-controller="Calendar" class="btn btn-danger">
    Google Takvimi Bağla
</a>
<table id="todoTable" style="display: none; visibility:collapse">
    @foreach (var item in events)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Title</td>
            <td>@item.Date</td>
            <td>@item.Description</td>
        </tr>
    }
</table>
<style>
    .hidden-section {
        display: none;
    }

    .fc-event {
        background-color: #2eacb3; /* Arka plan rengini maviye değiştir */
        color: #2eacb3; /* Metin rengini beyaza değiştir */
    }

    .custom-padding {
        padding-left: 20px; /* İstediğiniz miktarda boşluk ekleyebilirsiniz */
    }

    #Submit {
        float: right; /* Sağa yaslanması için */
        background-color: #2eacb3; /* Arka plan rengi */
        color: white; /* Yazı rengi */
        font-size: 16px; /* Yazı boyutu */
        padding: 10px 20px; /* Boşluk ayarı */
        margin-top: 20px;
        margin-bottom: 10px;
        border-radius: 5px; /* Köşe yuvarlatma */
    }
</style>
<input type="checkbox" id="myCheckbox" name="myCheckbox" value="true">Sadece benimkileri göster
<div class="row g-3 clearfix">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body" id='my_calendar'></div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-body">
                <button type="button" class="btn btn-primary w-100" data-bs-toggle="modal"
                        data-bs-target="#exampleModal">
                    Yeni takvim ekle
                </button>
            </div>
        </div>
        <div class="card mb-3">
            <div class="card-body">

                @foreach (var item in eventsfilter)
                {
                    <div class="event-name row g-2">
                        <div class="col-2 text-center">
                            <h6>@item.Date</h6>
                        </div>
                        <div class="col-10">
                            <h6 class="mb-0">@item.Title</h6>
                            <p class="mb-0">@item.Description</p>

                        </div>
                    </div>
                }

                <hr>

            </div>
        </div>
    </div>
</div>



<script>
    document.getElementById("Submit").addEventListener("click", function () {
        disableButton(this);
        document.querySelector("form").submit();
    });

    function disableButton(button) {
        button.disabled = true;
        button.value = "Ekleniyor..."; // Optional: Change the button text to indicate the process is ongoing
    }



    $(document).ready(function () {
        $('#searchInput').on('input', function () {
            $('#timeSelection').slideDown();
        });
      
    });

    //$('#my_calendar').on('click', function () {
    //    var selectedDate = $(this).data('date');
    //    var modal = new bootstrap.Modal(document.getElementById('exampleModal'));
    //    modal.show();
    //});

    function toggleManualEmail() {
        var manualEmailInput = document.getElementById("manualEmailInput");
        var manualEmailInput2 = document.getElementById("manualEmailInput2");
        var manualEmailCheckbox = document.getElementById("manualEmailCheckbox"); 
        var manualEmailCheckbox2 = document.getElementById("manualEmailCheckbox2"); 

        if (manualEmailCheckbox.checked || manualEmailCheckbox2.checked) {
            manualEmailInput.style.display = "block";
            manualEmailInput2.style.display = "block";
            manualEmailInput3.style.display = "block";
            manualEmailInput4.style.display = "block";    
        } else {
            manualEmailInput.style.display = "none";
            manualEmailInput2.style.display = "none";
            manualEmailInput3.style.display = "none";
            manualEmailInput4.style.display = "block";    

        }
    }
    function toggleTimeSelection() {
        var timeSelection = document.getElementById('timeSelection');
        timeSelection.classList.remove('hidden-section');

    }
    function updateSelectedEmails() {
        var selectedEmails = [];
        // Seçili e-posta adreslerini listeye ekle
        var selectedCheckboxes = document.querySelectorAll('input[name="SelectedEmails"]:checked');
        selectedCheckboxes.forEach(function (checkbox) {
            selectedEmails.push(checkbox.value);
        });
        // Manuel olarak girilen e-posta adresini de listeye ekle
        var manualEmailInput = document.getElementById('manualEmailInput');
        if (manualEmailInput.value.trim() !== '') {
            selectedEmails.push(manualEmailInput.value.trim());
        }
        // Listeyi gizli alanın değeri olarak ayarla
        document.getElementById('selectedEmails').value = selectedEmails.join(',');
        console.log(selectedEmails);
    }</script>

<script>let eventsArr = loadData();

    function loadData() {

        let eventsArr = [];

        let todoTable = document.getElementById("todoTable");
        let trElem = todoTable.getElementsByTagName("tr");
        for (let tr of trElem) {
            let tdElems = tr.getElementsByTagName("td");
            let eventObj = {
                id: tdElems[0].innerText,
                title: tdElems[1].innerText,
                start: tdElems[2].innerText,
                description: tdElems[3].innerText,
            }
            eventsArr.push(eventObj);
        }
        return eventsArr;
    }


    document.addEventListener('DOMContentLoaded', function () {
        const startTimePicker = document.getElementById('StartDate');
        const endTimePicker = document.getElementById('EndDate');
        const startTimePickers = document.getElementById('StartDates');
        const endTimePickers = document.getElementById('EndDates');

        function populateTimePickers() {
            for (let hour = 0; hour < 24; hour++) {
                for (let minute = 0; minute < 60; minute += 15) {
                    const timeValue = `${String(hour).padStart(2, '0')}:${String(minute).padStart(2, '0')}`;

                    // Create and append options
                    [startTimePicker, endTimePicker, startTimePickers, endTimePickers].forEach(picker => {
                        const option = document.createElement('option');
                        option.value = timeValue;
                        option.textContent = timeValue;
                        picker.appendChild(option);
                    });
                }
            }
        }

        function updateEndTimeOptions() {
            const startValue = startTimePicker.value;
            const [startHour, startMinute] = startValue.split(':').map(Number);

            const options = Array.from(endTimePicker.options);
            endTimePicker.innerHTML = ''; // Clear existing options

            options.forEach(option => {
                const [hour, minute] = option.value.split(':').map(Number);
                if (hour > startHour || (hour === startHour && minute > startMinute)) {
                    endTimePicker.appendChild(option);
                }
            });
        }

        startTimePicker.addEventListener('change', updateEndTimeOptions);

        populateTimePickers();
        updateEndTimeOptions();

        const calendarEl = document.getElementById('my_calendar');
        const calendar = new FullCalendar.Calendar(calendarEl, {
            timeZone: 'UTC',
            initialView: 'dayGridMonth',
            events: eventsArr,
            editable: true,
            selectable: true,
            eventClick: function (info) {
                $.ajax({
                    type: 'POST',
                    url: "/Calendar/GetDescription/",
                    encode: true,
                    data: { ID: info.event.id },
                    dataType: "json",
                    success: function (data) {
                        someFunction(data); // Define someFunction as needed
                    }
                });

                document.getElementById("modalTitle").innerHTML = info.event.title;
                document.getElementById("modalTitle2").value = info.event.title;
                //document.getElementById("modalStart").value = info.event.date;
                //document.getElementById("modalStart").textContent = info.event.date.toJSON().slice(0, 10);
                document.getElementById("Id").textContent = info.event.id;
                document.getElementById("calendarId").value = info.event.id; // Hidden input for ID
                $('#calendarModal').modal('show');
            },
            dateClick: function (info) {
                const clickedDate = info.dateStr;
                document.getElementById('modelDate').value = clickedDate;
                const modal = new bootstrap.Modal(document.getElementById('exampleModal'));
                modal.show();
            }
        });
        calendar.render();
    });
    function someFunction(data) {
        document.getElementById("modalDescription").value = data.message.description;
        document.getElementById("modalDescription").innerHTML = data.message.description;
        document.getElementById("modalDescription").innerHTML = data.message.email;
        console.log("info.event.date" + data.message.date);

        const dateInput = document.getElementById('modalStart');

        // Tarih alanını JSON'dan alınan değerle ayarla
        dateInput.value = data.message.date;

        if (data.message.startDate != null && data.message.endDate!=null) {
            const startDateTime = new Date(data.message.startDate);
            const hours = startDateTime.getHours().toString().padStart(2, '0');
            const minutes = startDateTime.getMinutes().toString().padStart(2, '0');
            const timeString = `${hours}:${minutes}`;
            const selectElement = document.getElementById("StartDates");
            selectElement.value = timeString;

            const endDateTime = new Date(data.message.endDate);
            const hourss = endDateTime.getHours().toString().padStart(2, '0');
            const minutess = endDateTime.getMinutes().toString().padStart(2, '0');
            const timeStrings = `${hourss}:${minutess}`;
            const selectElemenst = document.getElementById("EndDates");
            selectElemenst.value = timeStrings;
        }
        else {
            const selectElement = document.getElementById("StartDates");
            selectElement.value = "00:00";
            const selectElemenst = document.getElementById("EndDates");
            selectElemenst.value = "00:00";

        }
        var manualEmailCheckbox2 = document.getElementById("manualEmailCheckbox2");
        var manualEmailInput = document.getElementById("manualEmailInput3");
        var manualEmailInput2 = document.getElementById("manualEmailInput4");
        manualEmailCheckbox2.checked = false;
        manualEmailInput.style.display = "none";
        manualEmailInput2.style.display = "none";
        document.getElementById("manualEmailInput3").value = null;
        document.getElementById("manualEmailInput3").innerHTML = null;

        if (data.message.notEmail != null && data.message.notEmail != "") {
            manualEmailCheckbox2.checked = true;
            manualEmailInput.style.display = "block";
            manualEmailInput2.style.display = "block";
            document.getElementById("manualEmailInput3").value = data.message.notEmail;
            document.getElementById("manualEmailInput3").innerHTML = data.message.notEmail;
        }



        const selectElemensta = document.getElementById("SelectedEmails2");
        var checkboxes = document.querySelectorAll('#selectedMailDropdown2 input[type="checkbox"]');
        var emailString = data.message.email;
        var emailArray = emailString.split(',').map(email => email.trim());

        // Seçili e-posta adresleri dizisini döngüye al
        emailArray.forEach(function (email) {
            checkboxes.forEach(function (checkbox) {
                // Eğer checkbox'ın değeri seçili e-posta ile eşleşiyorsa, checkbox'ı işaretle
                if (checkbox.value === email) {
                    checkbox.checked = true;
                }
            });
        });

        
    }


    document.getElementById('searchInput').addEventListener('keyup', function (event) {
        // Eğer tuş Enter (keyCode 13) ise veya input boş değilse aramayı gerçekleştir
        console.log("aslında girdi");
        var email = $('#searchInput').val();
        if (email !== '') {
            $.ajax({
                url: "/Calendar/CalendarSearch/",
                type: 'POST',
                data: { email: email },
                dataType: "json",
                success: function (data) {
                    $.each(data.message, function (index, item) {
                        $('#searchInput').val(item);
                    });
                },
                error: function () {
                    $('#result').html('An error occurred while searching.');
                }
            });
        }
    });

    document.getElementById('myCheckbox').addEventListener('change', function (event) {
        // Eğer tuş Enter (keyCode 13) ise veya input boş değilse aramayı gerçekleştir
        console.log("aslında girdi3");
        var isChecked = document.getElementById("myCheckbox").checked;
        $.ajax({
            url: "/Calendar/GetFilterCalendar/",
            type: 'POST',
            data: { ischecked: isChecked },
            dataType: "json",
            success: function (data) {
                $.each(data.message, function (index, item) {
                });
            },
            error: function () {
            }
        });

    });</script>


