@model List<CrmCorner.ViewModels.ResponsibleUserTaskReportVm>

@{
    ViewData["Title"] = "Responsible User Task Reports";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

<h3 class="mb-4">Görev Raporları (ResponsibleUser Bazlı)</h3>

<!-- Tarih filtresi -->
<form method="get" asp-action="ResponsibleUserTasks" class="row g-3 mb-4">
    <div class="col-md-3">
        <label for="startDate" class="form-label">Başlangıç Tarihi</label>
        <input type="date" class="form-control" id="startDate" name="startDate"
               value="@Context.Request.Query["startDate"]" />
    </div>
    <div class="col-md-3">
        <label for="endDate" class="form-label">Bitiş Tarihi</label>
        <input type="date" class="form-control" id="endDate" name="endDate"
               value="@Context.Request.Query["endDate"]" />
    </div>
    <div class="col-md-3 align-self-end">
        <button type="submit" class="btn btn-primary">Filtrele</button>
    </div>
</form>

<!-- Toggle Butonları -->
<div class="btn-group mb-3">
    <button type="button" class="btn btn-primary" id="showChart">Grafik Görünümü</button>
    <button type="button" class="btn btn-secondary" id="showTable">Tablo Görünümü</button>
</div>

<!-- Grafik Alanı -->
<div id="chartView">
    <canvas id="tasksChart" height="100"></canvas>
</div>

<!-- Tablo Alanı -->
<div id="tableView" style="display:none;">
    <table id="tasksTable" class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Kullanıcı</th>
                <th>Toplam</th>
                <th>Süreçte</th>
                <th>Kazanılan</th>
                <th>Kaybedilen</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ResponsibleUserName</td>
                    <td>@item.TotalTasks</td>
                    <td>@item.OngoingTasks</td>
                    <td>@item.SuccessfulTasks</td>
                    <td>@item.FailedTasks</td>
                </tr>
            }
        </tbody>
    </table>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
    <link href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" rel="stylesheet" />

    <script>
        // Toggle görünüm
        $("#showChart").click(function () {
            $("#chartView").show();
            $("#tableView").hide();
        });
        $("#showTable").click(function () {
            $("#tableView").show();
            $("#chartView").hide();
        });

        // Chart.js için veriler
        var labels = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Select(x => x.ResponsibleUserName)));
        var totals = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Select(x => x.TotalTasks)));
        var ongoing = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Select(x => x.OngoingTasks)));
        var success = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Select(x => x.SuccessfulTasks)));
        var failed = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Select(x => x.FailedTasks)));

        var ctx = document.getElementById('tasksChart').getContext('2d');
        var chart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Toplam',
                        data: totals,
                        backgroundColor: 'rgba(54, 162, 235, 0.7)'
                    },
                    {
                        label: 'Süreçte',
                        data: ongoing,
                        backgroundColor: 'rgba(255, 206, 86, 0.7)'
                    },
                    {
                        label: 'Kazanılan',
                        data: success,
                        backgroundColor: 'rgba(75, 192, 192, 0.7)'
                    },
                    {
                        label: 'Kaybedilen',
                        data: failed,
                        backgroundColor: 'rgba(255, 99, 132, 0.7)'
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });

        // DataTable başlat
        $('#tasksTable').DataTable();
    </script>
}
