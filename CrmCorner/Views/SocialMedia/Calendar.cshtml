@model CrmCorner.ViewModels.CalendarViewModel

@{
    ViewData["Title"] = "Calendar";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

<!-- Bootstrap 4 ve FullCalendar CSS -->
<link rel="stylesheet" href="~/CRMTema/bootstrap4/documentation/assets/vendor/bootstrap/css/bootstrap.min.css" />
<link rel="stylesheet" href="~/CRMTema/js/fullcalendar/main.min.css" />

<div class="container py-4">
    <div class="card">
        <div class="card-body">
            <div id="calendar"></div>
        </div>
    </div>
</div>

<!-- Gerekli Scriptler -->
<script src="~/crmtema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>
<script src="~/crmtema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>
<script src="~/CRMTema/bootstrap4/documentation/assets/vendor/jquery/jquery.min.js"></script>
<script src="~/CRMTema/js/fullcalendar/main.min.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var calendarEl = document.getElementById('calendar');

        var calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: ''
            },
            events: [
    @foreach (var item in Model.Contents)
    {
        <text>
                        {
                                  id: '@item.Id',
                title: @Html.Raw(Json.Serialize(item.Title)),
                start: '@item.ScheduledPublishDate?.ToString("yyyy-MM-dd")',
                description: @Html.Raw(Json.Serialize(item.Description))
                        },
        </text>
    }
            ],
            eventClick: function (info) {
                window.location.href = '/SocialMedia/Details/' + info.event.id;
            },
            eventDisplay: 'block',
            eventColor: '#A3D9A5',
        });

        calendar.render();
    });
</script>
