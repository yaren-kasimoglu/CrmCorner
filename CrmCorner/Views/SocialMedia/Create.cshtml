@model CrmCorner.Models.SocialMediaContent

@{
    ViewData["Title"] = "Yeni İçerik Ekle";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

@if (ViewBag.CompanyList == null)
{
    throw new Exception("CompanyList ViewBag'e atanamadı.");
}

<div class="container mt-5">
    <div class="card p-4 shadow rounded">
        <h2 class="mb-4">📥 Yeni Sosyal Medya İçeriği Ekle</h2>

        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" placeholder="Örn: Yeni kampanya duyurusu" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Açıklama giriniz..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Medya Yükle</label>
                <div class="dropzone border rounded text-center p-4" id="dropzone">
                    <p id="dropzoneText">Dosyanızı buraya sürükleyin veya tıklayarak seçin</p>
                    <input type="file" name="mediaFile" class="form-control d-none" id="mediaFileInput" required />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="ScheduledPublishDate" class="form-label">📅 Paylaşım Tarihi ve Saati</label>
                <input asp-for="ScheduledPublishDate" class="form-control" type="datetime-local" />
                <span asp-validation-for="ScheduledPublishDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ContentType" class="form-label">İçerik Türü</label>
                @Html.DropDownListFor(
                         model => model.ContentType,
                         new SelectList(Enum.GetValues(typeof(CrmCorner.Models.Enums.ContentType))),
                         "Tür Seçin",
                         new { @class = "form-select" })
                <span asp-validation-for="ContentType" class="text-danger"></span>
            </div>

      
                <div class="mb-3">
                    <label asp-for="CompanyId" class="form-label">Şirket Seçin</label>
                    @Html.DropDownListFor(
                             model => model.CompanyId,
                             ViewBag.CompanyList as SelectList,
                             "Şirket Seçin",
                             new { @class = "form-select" }
                             )
                    <span asp-validation-for="CompanyId" class="text-danger"></span>
                </div>
            

            <button type="submit" class="btn btn-success w-100">💾 Oluştur</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const dropzone = document.getElementById('dropzone');
        const input = document.getElementById('mediaFileInput');
        const dropzoneText = document.getElementById('dropzoneText');

        dropzone.addEventListener('click', () => input.click());

        dropzone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropzone.classList.add('bg-light');
        });

        dropzone.addEventListener('dragleave', () => {
            dropzone.classList.remove('bg-light');
        });

        dropzone.addEventListener('drop', (e) => {
            e.preventDefault();
            const file = e.dataTransfer.files[0];
            if (file && isValidFile(file)) {
                input.files = e.dataTransfer.files;
                dropzone.classList.remove('bg-light');
                dropzoneText.innerText = file.name;
            } else {
                alert('Sadece JPG, JPEG, PNG ve MP4 dosyaları yükleyebilirsiniz.');
                dropzone.classList.remove('bg-light');
            }
        });

        input.addEventListener('change', () => {
            if (input.files.length > 0) {
                const file = input.files[0];
                if (isValidFile(file)) {
                    dropzoneText.innerText = file.name;
                } else {
                    alert('Sadece JPG, JPEG, PNG ve MP4 dosyaları yükleyebilirsiniz.');
                    input.value = '';
                    dropzoneText.innerText = 'Dosyanızı buraya sürükleyin veya tıklayarak seçin';
                }
            }
        });

        function isValidFile(file) {
            const allowedExtensions = ['jpg', 'jpeg', 'png', 'mp4'];
            const fileExtension = file.name.split('.').pop().toLowerCase();
            return allowedExtensions.includes(fileExtension);
        }
    </script>
}
