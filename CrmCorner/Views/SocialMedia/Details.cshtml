@model CrmCorner.Models.SocialMediaContent

@{
    ViewData["Title"] = "İçerik Detayı";
    var isVideo = Model.MediaPath?.ToLower().EndsWith(".mp4") == true
               || Model.MediaPath?.ToLower().EndsWith(".mov") == true
               || Model.MediaPath?.ToLower().EndsWith(".webm") == true;
}
<!-- Bootstrap Icons CDN -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">


<div class="container mt-5">
    <div class="card shadow p-4">
        <h2 class="mb-4 text-primary">📄 İçerik Detayı</h2>

        @if (!string.IsNullOrEmpty(Model.MediaPath))
        {
            if (isVideo)
            {
                <video class="rounded mb-3 d-block mx-auto" width="300" height="533" controls style="object-fit: cover;">
                    <source src="@Model.MediaPath" type="video/mp4">
                    Tarayıcınız video öğesini desteklemiyor.
                </video>
            }
            else
            {
                <img src="@Model.MediaPath" class="img-fluid rounded mb-3 d-block mx-auto"
                     style="width: 300px; height: 300px; object-fit: cover;" />
            }
        }

        <h4>@Model.Title</h4>
        <p class="text-muted">
            <strong>📅 Yayın Tarihi:</strong>
            @Model.ScheduledPublishDate?.ToString("dd.MM.yyyy HH:mm") ?? "-"
        </p>
        <p><strong>📌 Tür:</strong> @Model.ContentType.ToString()</p>
        <p><strong>📃 Açıklama:</strong> @Html.Raw(Model.Description)</p>

        <p>
            <strong>🔁 Statü:</strong>
            @switch (Model.Status)
            {
                case CrmCorner.Models.Enums.ContentStatus.OnayBekliyor:
                    <span class="badge bg-warning text-dark">Onay Bekliyor</span>
                    break;
                case CrmCorner.Models.Enums.ContentStatus.Onaylandi:
                    <span class="badge bg-success">Onaylandı</span>
                    break;
                case CrmCorner.Models.Enums.ContentStatus.FeedbackVerildi:
                    <span class="badge bg-danger">Feedback Verildi</span>
                    break;
            }
        </p>

        <!-- Onaylama ve Geri Alma -->
        @if (Model.Status == CrmCorner.Models.Enums.ContentStatus.OnayBekliyor)
        {
            <form asp-action="Approve" asp-route-id="@Model.Id" method="post" class="d-inline">
                <button type="submit" class="btn btn-success me-2">✅ Onayla</button>
            </form>
        }
        else if (Model.Status == CrmCorner.Models.Enums.ContentStatus.Onaylandi)
        {
            <!-- Onayı Geri Alma -->
            <form asp-action="CancelApproval" asp-route-id="@Model.Id" method="post" class="d-inline">
                <button type="submit" class="btn btn-warning me-2">🔄 Onayı Geri Al</button>
            </form>
        }

        <!-- Geri Bildirim Gönderme -->
        @if (Model.Status == CrmCorner.Models.Enums.ContentStatus.OnayBekliyor)
        {
            <form asp-action="SendFeedback" asp-route-id="@Model.Id" method="post">
                <div class="mb-3 mt-3">
                    <label for="FeedbackMessage" class="form-label">📝 Geri Bildirim</label>
                    <textarea name="feedbackMessage" class="form-control" rows="3" placeholder="Geri bildiriminizi yazın..."></textarea>
                </div>
                <button type="submit" class="btn btn-danger">📤 Feedback Gönder</button>
            </form>
        }

        <!-- Geri Bildirimlerin Listelenmesi -->
        <h5 class="mt-4">📬 Verilen Geri Bildirimler:</h5>
        @if (Model.Feedbacks != null && Model.Feedbacks.Any())
        {
            <ul class="list-group">
                @foreach (var feedback in Model.Feedbacks.OrderByDescending(f => f.CreatedDate))
                {
                    <li class="list-group-item">
                        <strong>@feedback.Message</strong><br />
                        <small class="text-muted">Gönderilme Tarihi: @feedback.CreatedDate.ToString("dd.MM.yyyy HH:mm")</small>
                        <!-- Silme butonu ekliyoruz -->
                        <form asp-action="DeleteFeedback" asp-route-feedbackId="@feedback.Id" asp-route-contentId="@Model.Id" method="post" class="d-inline float-end ms-2">
                            <button type="submit" class="btn btn-sm btn-danger" title="Sil">
                                <i class="bi bi-trash"></i> <!-- Çöp kutusu simgesi -->
                            </button>
                        </form>
                    </li>
                }
            </ul>
        }
        else
        {
            <p>Henüz geri bildirim yapılmamış.</p>
        }


    </div>
</div>
<!-- core js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>

<!-- page js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>

<script src="~/CRMTema/bootstrap5/dist/assets/bundles/datatables.bundle.js"></script>