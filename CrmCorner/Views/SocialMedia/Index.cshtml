@model CrmCorner.Models.PaginatedList<CrmCorner.Models.SocialMediaContent>
@using CrmCorner.Models.Enums

@{
    ViewData["Title"] = "İçerik Listesi";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

<style>
    .card.bg-warning, .card.bg-success, .card.bg-danger {
        width: 200px;
        font-size: 12px;
        margin: 0 auto;
    }

    .card.bg-warning {
        background-color: #f8d57e !important;
        border-color: #f1c40f;
    }

    .card.bg-success {
        background-color: #81c784 !important;
        border-color: #388e3c;
    }

    .card.bg-danger {
        background-color: #e57373 !important;
        border-color: #d32f2f;
    }

    .card-body {
        padding: 8px;
    }

    .card-text.display-6 {
        font-size: 15px;
        color: black;
    }

    .card-title {
        font-size: 14px;
        color: black;
    }

    .page-header-wrap {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 24px;
    }

        .page-header-wrap h2 {
            margin: 0;
        }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 14px;
        font-weight: 500;
        color: #6c757d;
        text-decoration: none;
        transition: all 0.2s ease;
    }

        .back-link:hover {
            color: #4b2673;
            text-decoration: none;
        }

        .back-link i {
            font-size: 18px;
            line-height: 1;
        }
</style>



<div class="mb-2">
    <a asp-controller="SocialMedia" asp-action="Dashboard" class="back-link">
        <i class="bi bi-arrow-left-short"></i> Dashboard’a Dön
    </a>
</div>

<div class="container mt-5">
    <div class="page-header-wrap">
        <h2>📋 Planlanan Sosyal Medya İçerikleri</h2>
    </div>

    <!-- Özet Kartlar -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card text-white bg-warning mb-3">
                <div class="card-body text-center">
                    <h5 class="card-title">Onay Bekliyor</h5>
                    <p class="card-text display-6">@ViewBag.PendingCount</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card text-white bg-success mb-3">
                <div class="card-body text-center">
                    <h5 class="card-title">Onaylandı</h5>
                    <p class="card-text display-6">@ViewBag.ApprovedCount</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtreleme -->
    <form method="get" class="mb-4">
        <div class="row">
            <div class="col-md-4">
                <input name="search" value="@ViewBag.Search" class="form-control" placeholder="🔍 Başlık veya açıklama" />
            </div>
            <div class="col-md-4">
                <select name="type" class="form-select">
                    <option value="">Tüm Türler</option>
                    @foreach (var type in Enum.GetValues(typeof(ContentType)))
                    {
                        if (ViewBag.Type?.ToString() == type.ToString())
                        {
                            <option value="@type" selected>@type</option>
                        }
                        else
                        {
                            <option value="@type">@type</option>
                        }
                    }
                </select>
            </div>
            @if (ViewBag.IsAdmin != null && ViewBag.IsAdmin)
            {
                <div class="col-md-3">
                    <select name="selectedCompanyId" class="form-select">
                        <option value="">🔍 Tüm Şirketler</option>
                        @foreach (var company in (SelectList)ViewBag.CompanyList)
                        {
                            <option value="@company.Value" selected="@(ViewBag.SelectedCompanyId?.ToString() == company.Value)">
                                @company.Text
                            </option>
                        }
                    </select>
                </div>
            }
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100">Filtrele</button>
            </div>
        </div>
    </form>

    <!-- Kartlar -->
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">

                    @if (item.MediaFile != null)
                    {
                        var isVideo = item.ContentType == ContentType.Reels;

                        if (isVideo)
                        {
                            <div style="width:100%; height:350px; overflow:hidden;">
                                <video class="w-100 h-100 rounded" style="object-fit: cover;" controls preload="metadata">
                                    <source src="@Url.Action("GetMedia", "SocialMedia", new { id = item.Id, t = DateTime.Now.Ticks })" type="video/mp4" />
                                </video>
                            </div>
                        }
                        else
                        {
                            <div style="width:100%; height:350px; overflow:hidden;">
                                <img src="@Url.Action("GetMedia", "SocialMedia", new { id = item.Id, t = DateTime.Now.Ticks })"
                                     class="w-100 h-100 rounded"
                                     style="object-fit: cover;" />
                            </div>
                        }
                    }

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@item.Title</h5>
                        <p class="card-text text-muted mb-1">
                            <strong>📅 Yayın Tarihi:</strong> @(item.ScheduledPublishDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                        </p>
                        <p class="card-text text-muted mb-1">
                            <strong>📌 Tür:</strong> @item.ContentType.ToString()
                        </p>
                        <p class="card-text">
                            <strong>🔁 Durum:</strong>
                            @switch (item.Status)
                            {
                                case ContentStatus.OnayBekliyor:
                                    <span class="badge bg-warning text-dark">Onay Bekliyor</span>
                                    break;
                                case ContentStatus.Onaylandi:
                                    <span class="badge bg-success">Onaylandı</span>
                                    break;
                            }
                        </p>
                        <div class="mt-auto">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary w-100 mb-2">📄 Detay</a>

                            @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin") || User.IsInRole("SocialMediaAdmin"))
                            {
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-danger w-100" title="Sil">
                                        <i class="bi bi-trash"></i> Sil
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Sayfalama -->
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @if (Model.HasPreviousPage)
            {
                <li class="page-item">
                    <a class="page-link" href="?page=@(Model.PageIndex - 1)&search=@ViewBag.Search&type=@ViewBag.Type">⏮ Önceki</a>
                </li>
            }
            else
            {
                <li class="page-item disabled"><span class="page-link">⏮ Önceki</span></li>
            }

            <li class="page-item active"><span class="page-link">@Model.PageIndex</span></li>

            @if (Model.HasNextPage)
            {
                <li class="page-item">
                    <a class="page-link" href="?page=@(Model.PageIndex + 1)&search=@ViewBag.Search&type=@ViewBag.Type">Sonraki ⏭</a>
                </li>
            }
            else
            {
                <li class="page-item disabled"><span class="page-link">Sonraki ⏭</span></li>
            }
        </ul>
    </nav>
</div>

<!-- JS Files -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/datatables.bundle.js"></script>