@model CrmCorner.Models.User
@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>:: Lucid HR BS5 :: Sign Up</title>
    <meta http-equiv="X-UA-Compatible" content="IE=Edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="Lucid HR & Project Admin Dashboard Template with Bootstrap 5x">
    <meta name="author" content="WrapTheme, design by: ThemeMakker.com">

    <link rel="icon" href="/themeforest-IV5IQlTa-lucid-hr-and-project-management-admin-template/bootstrap5/dist/horizontal/favicon.ico" type="image/x-icon">
    <!-- VENDOR CSS -->
    <!-- MAIN CSS -->
    <link rel="stylesheet" href="/themeforest-IV5IQlTa-lucid-hr-and-project-management-admin-template/bootstrap5/dist/assets/css/main.css">
</head>

<body>

    <div id="layout" class="theme-cyan">

<div id="wrapper">
    <div class="d-flex h-100vh align-items-center auth-main w-100">
        <div class="auth-box">
            <div class="card shadow p-lg-4">
                <div class="card-header">
                    <p class="fs-5 mb-0">Create an account</p>
                </div>
                <div class="card-body">
                    <form asp-action="Register" asp-controller="Login" method="post" enctype="multipart/form-data" class="needs-validation" novalidate>
                        <div class="form-floating mb-1">
                            <label for="classdefinition">Kullanıcı Adı</label>
                            <input class="form-control" id="FirstName" name="FirstName" type="text" placeholder="Kullanıcı Adı" required />
                            <span class="invalid-feedback" style="color:darkred">
                                *Lütfen Kullanıcı Adı Giriniz..
                            </span>
                        </div>
                        <br />
                        <div class="form-floating">
                            <label for="classdefinition">Kullanıcı Soyadı</label>
                            <input class="form-control" id="LastName" name="LastName" type="text" placeholder="Kullanıcı Soyadı" required />
                            <span class="invalid-feedback" style="color:darkred">
                                *Lütfen Kullanıcı Soyadı Giriniz..
                            </span>
                        </div>
                        <br />
                        <div class="form-floating">
                            <label for="classdefinition">Sistem Kullanıcı Adı</label>
                            <input class="form-control" id="Username" name="Username" type="text" placeholder="Sistem Kullanıcı Adı" required />
                            <span class="invalid-feedback" style="color:darkred">
                                *Lütfen Kullanıcı Adı Giriniz..
                            </span>
                        </div>
                        <br />
                        <div class="form-floating">
                            <label for="classdefinition">Doğum Günü</label>
                            <input class="form-control" id="DateOfBirth" name="DateOfBirth" type="date" placeholder="Doğum Günü" required />
                                    <span class="invalid-feedback" style="color:darkred">
                        </div>
                        <div class="form-floating">
                            <label for="classdefinition">Kullanıcı Telefon</label>
                            <input class="form-control" id="PhoneNumber" name="PhoneNumber" type="number" placeholder="Kullanıcı Telefon" required />
                            <span class="invalid-feedback" style="color:darkred">
                                *Lütfen Kullanıcı Telefon Giriniz..
                            </span>
                        </div>
                        <br />
                        <div class="form-floating">
                            <label for="classdefinition">Kullanıcı Email</label>
                            <input class="form-control" id="Email" name="Email" type="text" placeholder="Kullanıcı Email" required />
                            <span class="invalid-feedback" style="color:darkred">
                                *Lütfen Kullanıcı Email Giriniz..
                            </span>
                            <input class="form-control" id="UserPasswordsalt" name="UserPasswordsalt" type="hidden" placeholder="" />
                            <input class="form-control" id="UserPasswordhash" name="UserPasswordhash" type="hidden" placeholder="" />
                        </div>
                        <br />
                        <div class="form-floating">
                            <label for="classdefinition">Kullanıcı Şifresi</label>
                            <input class="form-control" id="" name="Password1" type="password" pattern="(?=.*[#$%*?^:;+-._,!=])(?=.*\d)(?=.*[a-z])(?=.*[A-Z]).{8,20}" placeholder="Kullanıcı Şifresi" required />
                            <span class="invalid-feedback" style="color:darkred">
                                *Lütfen Kullanıcı Şifresi Giriniz..(En az 8 karakter,büyük harf ve küçük harf zorunlu,[#$%*?^:;+-._,!=] özel karakter olmalı)
                            </span>
                        </div>
                        <br />
                        <div class="form-floating">
                            <label for="classdefinition">Kullanıcı Şifre Tekrarı</label>
                            <input class="form-control" id="" name="Password2" type="password" placeholder="Kullanıcı Şifre Tekrarı" required />
                            <span class="invalid-feedback" style="color:darkred">
                                *Lütfen Kullanıcı Şifresi Tekrarı Giriniz..
                            </span>
                            <h6 style="color:#f60909"> @ViewBag.Message</h6>
                        </div>
                        <br />
                        <div class="col-md-12">
                            <label for="classdefinition">Kullanıcı Görsel</label>
                            <input class="form-control" id="UserImage" type="file" multiple name="files" placeholder="Kullanıcı Görsel" />
                            <span class="invalid-feedback" style="color:darkred">
                                *Lütfen Kullanıcı Görsel Seçiniz..
                            </span>
                        </div>
                        <br />
                        @*        <div class="d-grid gap-2 mt-3 pt-3">
                        <div class="text-center"><span>OR</span></div>
                        <button class="btn btn-light"><i class="fa fa-facebook-official"></i> Sign in with Facebook</button>
                        <button class="btn btn-light"><i class="fa fa-twitter"></i> Sign in with Twitter</button>
                        </div>*@
                        <div class="my-3">
                            <button type="submit" class="btn btn-primary w-100 px-3 py-2 mb-2">REGISTER</button>
                            <span>Already have an account? @Html.ActionLink("Login", "Login", "Login")</span>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


    </div>
</body>
</html>