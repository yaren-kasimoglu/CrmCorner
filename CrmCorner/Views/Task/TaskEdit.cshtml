@model CrmCorner.Models.TaskComp
@{
    ViewData["Title"] = "TaskEdit";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

<style>
    /* Radio butonunu gizle */
    .radio-button {
        display: none;
    }

        /* Özel radio buton görünümü */
        .radio-button + label {
            position: relative;
            padding-left: 30px;
            cursor: pointer;
            display: inline-block;
            color: #333;
            margin-right: 15px; /* Sağdaki butonlardan boşluk */
        }

            /* Özel görünüm için bir daire */
            .radio-button + label::before {
                content: '';
                position: absolute;
                left: 0;
                top: 50%;
                transform: translateY(-50%);
                width: 20px;
                height: 20px;
                border: 2px solid #9e9e9e;
                border-radius: 50%;
                background-color: #fff;
            }

        /* Seçili radio buton için iç daire */
        .radio-button:checked + label::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 4px;
            transform: translateY(-50%);
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background-color: #007bff;
        }

        /* Radio butonu odaklanma durumu */
        .radio-button:focus + label::before {
            box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.25);
        }

        /* Label metni üzerine gelindiğinde veya odaklanıldığında */
        .radio-button + label:hover::before,
        .radio-button + label:focus::before {
            border-color: #007bff;
        }
</style>

<form asp-action="TaskEdit" asp-controller="Task" method="post">
    <input type="hidden" asp-for="TaskId" />
    <div class="row">
        <!-- Başlık, Değer Teklifi, Açıklama için ayrı bir row -->
        <div class="col-lg-6">
            <div class="form-group">
                <label asp-for="Title" class="control-label">Başlık</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ValueOrOffer" class="control-label">Değer Teklifi</label>
                <input asp-for="ValueOrOffer" class="form-control" />
                <span asp-validation-for="ValueOrOffer" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description" class="control-label">Açıklama</label>
                <textarea asp-for="Description" class="form-control" rows="5" cols="30" required></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            </br>
            <div class="form-group">
                <label class="control-label">Sonuç Durumu</label>
                @foreach (var status in ViewBag.OutcomeStatus as List<SelectListItem>)
                {
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Outcome" type="radio" value="@status.Value" id="@status.Text" />
                        <label class="form-check-label" for="@status.Text">@status.Text</label>
                    </div>
                }
                <span asp-validation-for="Outcome" class="text-danger"></span>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="col-lg-12 col-md-6">
                <label class="form-label">Müşteri</label>
                <select asp-for="CustomerId" asp-items="ViewBag.Customer" class="form-select select2" aria-label="Default select example"> <option value="">Lütfen seçiniz</option></select>
                <span asp-validation-for="CustomerId" class="text-danger"></span>
            </div>
            <div class="col-lg-12 col-md-6">
                <label class="form-label">Görüşmeyi Alan</label>
                <select asp-for="UserId" asp-items="ViewBag.Users" class="form-control">
                    <option value="">Lütfen seçiniz</option>
                </select>
                <span asp-validation-for="UserId" class="text-danger"></span>
            </div>
            <div class="col-lg-12 col-md-6">
                <label class="form-label">Görüşmeyi Gerçekleştiren</label>
                <select asp-for="AssignedUserId" asp-items="ViewBag.Users" class="form-control">
                    <option value="">Lütfen seçiniz</option>
                </select>
                <span asp-validation-for="AssignedUserId" class="text-danger"></span>
            </div>
            <div class="col-lg-12 col-md-6">
                <label class="form-label">Güncel Durum</label>
                <select asp-for="StatusId" asp-items="ViewBag.Status" class="form-select select2" aria-label="Default select example"> <option value="">Lütfen seçiniz</option></select>
                <span asp-validation-for="StatusId" class="text-danger"></span>
            </div>
            <div class="col-lg-12 col-md-6">
                <div class="form-group">
                    <label asp-for="SalesDone" class="control-label">Planlanan Satış Kapatma Tarihi</label>
                    <input asp-for="SalesDone" type="date" class="form-control" />
                    <span asp-validation-for="SalesDone" class="text-danger"></span>
                </div>
            </div>
            </br>
            <div class="form-group">
                <input asp-for="IsFinalDecisionMaker" class="form-check-input" />
                <label asp-for="IsFinalDecisionMaker" class="control-label">Son Karar Mercii İle Görüşüldü</label>
                <span asp-validation-for="IsFinalDecisionMaker" class="text-danger"></span>
            </div>


        </div>
    </div>
    <br />
    <div class="form-group">
        <input type="submit" value="GÜNCELLE" class="btn btn-primary" />
    </div>
</form>

<!-- core js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>
<!-- page js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>