    <script>
        function confirmDelete(button) {
            // Kullanıcıya silme işlemini onaylamasını sor
            if (confirm('Are you sure you want to delete this Task?')) {
                var taskId = button.getAttribute('data-taskId');
                var form = document.createElement('form');
                form.action = '/Task/TaskDelete/' + taskId;
                form.method = 'post';
                document.body.appendChild(form);
                form.submit();
            }
        }


    </script>
    <script>
        // Durum sırasını belirlemek için fonksiyon
        function GetStatusOrder(status) {
            switch (status) {
                case "Değerlendirilen":
                    return 1;
                case "İletişim":
                    return 2;
                case "Teklif":
                    return 3;
                case "Demo":
                    return 4;
                case "Görüşmeler":
                    return 5;
                default:
                    return 6;
            }
        }
    </script>

