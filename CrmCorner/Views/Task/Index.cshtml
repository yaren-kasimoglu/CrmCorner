@model List<TaskComp>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}
@functions {

    int GetStatusOrder(string status)
    {
        switch (status)
        {
            case "Değerlendirilen":
                return 1;
            case "İletişim":
                return 2;
            case "Teklif":
                return 3;
            case "Demo":
                return 4;
            case "Görüşmeler":
                return 5;
            default:
                return 6;
        }
    }
}
<div class="row g-3">
    @{
        // Null olmayan ve istenen alanda null olmayan verileri filtreleme
        var validTasks = Model.Where(task => task.Status != null && task.Status.StatusName != null);

        // GroupBy işlemi için verilerin kontrol edilmiş hali
        var statusGroups = validTasks.GroupBy(task => task.Status.StatusName)
        .OrderBy(group => GetStatusOrder(group.Key))
        .ToArray();
    }
    @*@{
    // var statusGroups = Model.GroupBy(task => task.Status.StatusName);

    var tasksWithNonNullStatus = Model.Where(task => task.Status != null && !string.IsNullOrEmpty(task.Status.StatusName));
    var statusGroups = tasksWithNonNullStatus.GroupBy(task => task.Status.StatusName);
    }*@
  

    @foreach (var statusGroup in statusGroups)
            {
                <div class="col-lg-3 col-md-4 col-sm-6" data-statusid="@GetStatusOrder(statusGroup.Key)" @* style="width:500px"*@>
                    @{
                        string statusClass = "";
                        string borderColor = "";
                        switch (statusGroup.Key)
                        {
                            case "Değerlendirilen":
                                statusClass = "planned_task";
                                borderColor = "#fd7e14";
                                break;
                            case "İletişim":
                                statusClass = "progress_task";
                                borderColor = "#198754";
                                break;
                            case "Teklif":
                                statusClass = "completed_task";
                                borderColor = "#0d6efd";
                                break;
                            case "Demo":
                                statusClass = "planned_task";
                                borderColor = "#FED049";
                                break;
                            case "Görüşmeler":
                                statusClass = "progress_task";
                                borderColor = "#2D6187";
                                break;
                            default:
                                statusClass = "";
                                break;
                        }
                    }
                    <div class="card mb-4 @statusClass" @*style="border-color:@borderColor"*@>
                        <div class="card-header">
                            <h6 class="card-title">@statusGroup.Key</h6>
                            <ul class="header-dropdown">
                                <li>
                                    @if (statusGroup.Key == "Değerlendirilen")
                                    {
                                        <a href="/Task/TaskAdd"><i class="fa fa-plus-circle"></i></a>
                                    }
                                </li>
                            </ul>
                        </div>
                        <div class="card-body">
                            <div class="dd" data-plugin="nestable">
                                <ol class="dd-list">
                                    @foreach (var task in statusGroup)
                                    {
                                        <li class="dd-item" data-taskid="@task.TaskId" data-newstatusid="@task.StatusId">
                                            <div class="dd-handle" style="border-color:@borderColor">
                                                <h6>@task.Title</h6>
                                                <p>
                                                    @if (task.CustomerId != null)
                                                    {
                                                        <span>@task.Customer.Name @task.Customer.Surname</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-danger">No Customer</span>
                                                    }
                                                </p>
                                                <p>
                                                    @if (task.EmployeeId != null)
                                                    {
                                                        <span>@task.Employee.EmployeeName @task.Employee.EmployeeSurname</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-danger">No Employee</span>
                                                    }
                                                </p>
                                                <a href="/Task/TaskEdit/@task.TaskId" target="_blank">
                                                    <button type="button" class="btn btn-sm btn-outline">
                                                        <div class="col-md-3 col-sm-4"><i class="fa fa-file-text-o"></i></div>
                                                    </button>
                                                </a>
                                                <button type="button" class="btn btn-sm btn-outline" data-taskId="@task.TaskId" onclick="confirmDelete(this)">
                                                    <div class="col-md-3 col-sm-4"> <i class="fa fa-trash-o"></i></div>
                                                </button>
                                                <a href="/Task/TaskDetail/@task.TaskId" target="_blank">
                                                    <button type="button" class="btn btn-sm btn-outline">
                                                        <div class="col-md-3 col-sm-4"> <i class="fa fa-align-left"></i></div>
                                                    </button>
                                                </a>
                                            </div>
                                        </li>
                                    }
                                </ol>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>


@section Scripts {
    @* Burada Index sayfasına özgü JavaScript dosyalarınız ve scriptler yer alacak *@
    <script src="~/CCTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>
    <script src="~/CCTema/bootstrap5/dist/assets/plugin/nestable/jquery.nestable.min.js"></script>
    <script src="~/jquery/jquery-ui/dist/jquery-ui.min.js"></script>
 
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            $(".choose-skin li").on("click", function () {
                var t = $("#layout")
                    , e = $(this)
                    , i = $(".choose-skin li.active").data("theme");
                $(".choose-skin li").removeClass("active"),
                    t.removeClass("theme-" + i),
                    e.addClass("active"),
                    t.addClass("theme-" + e.data("theme"))
            })
        });
        function confirmDelete(button) {
            // Kullanıcıya silme işlemini onaylamasını sor
            if (confirm('Are you sure you want to delete this Task?')) {
                var taskId = button.getAttribute('data-taskId');
                var form = document.createElement('form');
                form.action = '/Task/TaskDelete/' + taskId;
                form.method = 'post';
                document.body.appendChild(form);
                form.submit();
            }
        }
        // Durum sırasını belirlemek için fonksiyon
        function GetStatusOrder(status) {
            switch (status) {
                case "Değerlendirilen":
                    return 1;
                case "İletişim":
                    return 2;
                case "Teklif":
                    return 3;
                case "Demo":
                    return 4;
                case "Görüşmeler":
                    return 5;
                default:
                    return 6;
            }
        }

        $('.dd-list').droppable({
            accept: '.dd-item',
            drop: function (event, ui) {
                var newStatusId = $(this).data('statusid'); // Bu kolonun statusId'sini alın.
                var taskId = ui.draggable.data('taskid');

                ui.draggable.detach().appendTo($(this)); // Görevi yeni listeye ekleyin.
                updateTaskStatus(taskId, newStatusId); // Durumu güncelleyin.
            }
        });


    </script>
}

@section Styles {

    <link href="~/CCTema/bootstrap5/dist/assets/plugin/nestable/jquery-nestable.css" rel="stylesheet" />
    <link href="~/jquery/jquery-ui/dist/themes/base/jquery-ui.min.css" rel="stylesheet" />
}
  


