@model List<TaskComp>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}
<style>
    .dd-item-title {
        display: block; /* Bağlantıyı blok seviyesinde bir element yapar, bu da tüm satırı tıklanabilir yapar */
        padding: 8px 16px; /* Bağlantıya iç boşluk ekler */
        margin: -8px -16px; /* Etrafta boşluk bırakmadan bağlantıyı genişletir */
        color: #333; /* Metin rengi */
        background-color: transparent; /* Arkaplan rengi */
        text-decoration: none; /* Alt çizgiyi kaldırır */
        font-weight: bold; /* Metni kalın yapar */
        border-radius: 4px; /* Kenarlara hafif yuvarlaklık ekler */
    }

        .dd-item-title:hover, .dd-item-title:focus {
            text-decoration: none; /* Üzerine gelindiğinde veya odaklandığında alt çizgi ekler */
            background-color: #f5f5f5; /* Üzerine gelindiğinde arkaplan rengini değiştirir */
            color: #006400; /* Üzerine gelindiğinde metin rengini değiştirir */
        }

    .dd-list {
        min-height: 50px; /* Boş listelerde görünürlük sağlamak için */
        padding: 10px; /* Boş listelerde iç boşluk sağlamak için */
        background-color: #f9f9f9; /* Görsel olarak ayırt edilebilir olması için */
    }

    .drop-hover {
        background-color: #e0e0e0; /* Sürüklenen öğenin üzerinde olduğu alanı belirtmek için */
    }

    .card {
        /* Kartlara bir minimum yükseklik verin */
        min-height: 100px; /* Kartın içindeki liste boşsa bile görsel bir alan sağlar */
    }
</style>


@functions {

    int GetStatusOrder(int statusId)
    {
        switch (statusId)
        {
            case 1:
                return 1;
            case 2:
                return 2;
            case 3:
                return 3;
            case 4:
                return 4;
            case 5:
                return 5;
            case 6:
                return 6;
            default:
                return 7;
        }
    }
}
<div class="filter-search-container">
    <input type="text" id="taskSearch" placeholder="Görev ara..." onkeyup="filterTasks()">
    <select id="statusFilter" onchange="filterTasks()">
        <option value="">Tüm Durumlar</option>
        <option value="1">İlk Temas</option>
        <option value="2">Görüşme Ayarlandı</option>
        <option value="3">Görüşme Gerçekleşti</option>
        <option value="4">Teklif Gönderildi</option>
        <option value="5">Sözleşme Aşamasında</option>
        <option value="6">Satış Tamamlandı</option>
        <!-- Diğer durumlar -->
    </select>
</div>

<div class="row g-3">
    @{
        // ViewBag'dan durum isimlerini ve durumların listesini al
        var statusNames = ViewBag.StatusNames as Dictionary<int, string>;
        var statusList = ViewBag.StatusList as Dictionary<int, string>; // Controller'dan gönderilen durum listesi

        // Her durumu temsil edecek kartlar için döngü oluştur
        foreach (var status in statusList)
        {
            // Her durum için bir kart oluştur
            <div class="col-lg-3 col-md-4 col-sm-6" data-statusid="@status.Key">
                @{
                    string statusClass = "";
                    string borderColor = "";
                    switch (status.Key) // Burada status.Key, durumun ID'sidir
                    {
                        case 1:
                            statusClass = "planned_task";
                            borderColor = "#fd7e14";
                            break;
                        case 2:
                            statusClass = "progress_task";
                            borderColor = "#198754";
                            break;
                        case 3:
                            statusClass = "completed_task";
                            borderColor = "#0d6efd";
                            break;
                        case 4:
                            statusClass = "planned_task";
                            borderColor = "#FED049";
                            break;
                        case 5:
                            statusClass = "progress_task";
                            borderColor = "#2D6187";
                            break;
                        case 6:
                            statusClass = "completed_task";
                            borderColor = "#006400";
                            break;
                        default:
                            statusClass = "";
                            break;
                    }
                }
                @{
                    var tasksInThisStatus = Model.Where(task => task.Status != null && task.Status.StatusId == status.Key).ToList();
                }
                <div class="card mb-4 @statusClass" style="border-color:@borderColor; min-height:400px;" data-statusid="@status.Key">
                    <div class="card-header">
                        <h6 class="card-title">@status.Value       <span id="taskCount_@status.Key">@(tasksInThisStatus.Count())</span></h6> 

                        <ul class="header-dropdown">
                            <li>
                                @if (status.Key == 1)
                                {
                                    <a href="/Task/TaskAdd"><i class="fa fa-plus-circle"></i></a>
                                }
                            </li>
                        </ul>
                    </div>
                    <div class="card-body">
                    
                   

                        @if (tasksInThisStatus.Any())
                        {
                        // Görevleri listele
                        <div class="dd" data-plugin="nestable">
                                <ol class="dd-list" data-statusid="@status.Key">
                                @foreach (var task in tasksInThisStatus)
                                {
                                        <li class="dd-item" data-taskid="@task.TaskId" data-statusid="@task.Status.StatusId">

                                        <div class="dd-handle">
                                                <a href="/Task/TaskDetail/@task.TaskId" class="dd-item-title">
                                                    <h6>@task.Title</h6>
                                                </a>
                                                <div class="task-actions">
                                                    <a href="/Task/TaskEdit/@task.TaskId" target="_self">
                                                        <button type="button" class="btn btn-sm btn-outline">
                                                            <i class="fa fa-edit"></i>
                                                        </button>
                                                    </a>
                                                    <button type="button" class="btn btn-sm btn-outline" data-taskId="@task.TaskId" onclick="confirmDelete(this)">
                                                        <i class="fa fa-trash-o"></i>
                                                    </button>
                                                    <a href="/Task/TaskDetail/@task.TaskId" target="_self">
                                                        <button type="button" class="btn btn-sm btn-outline">
                                                            <i class="fa fa-file-text-o"></i>
                                                        </button>
                                                    </a>
                                                </div>
                                        </div>
                                    </li>
                                }
                            </ol>
                        </div>
                        }
                        else
                        {
                        // Eğer bu duruma ait görev yoksa
                        <p>Görev Yok.</p>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>



<!-- core js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>

<link href="~/CRMTema/bootstrap5/dist/assets/plugin/nestable/jquery-nestable.css" rel="stylesheet" />
<link href="~/jquery/jquery-ui/dist/themes/base/jquery-ui.min.css" rel="stylesheet" />


@* Burada Index sayfasına özgü JavaScript dosyaları ve scriptler yer alacak *@
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>
<script src="~/CRMTema/bootstrap5/dist/assets/plugin/nestable/jquery.nestable.min.js"></script>
<script src="~/jquery/jquery-ui/dist/jquery-ui.min.js"></script>


<script>
    $(document).ready(function () {
        $(".choose-skin li").on("click", function () {
            var t = $("#layout")
                , e = $(this)
                , i = $(".choose-skin li.active").data("theme");
            $(".choose-skin li").removeClass("active"),
                t.removeClass("theme-" + i),
                e.addClass("active"),
                t.addClass("theme-" + e.data("theme"))
        })
    });
    function confirmDelete(button) {
        // Kullanıcıya silme işlemini onaylamasını sor
        if (confirm('Are you sure you want to delete this Task?')) {
            var taskId = button.getAttribute('data-taskId');
            var form = document.createElement('form');
            form.action = '/Task/TaskDelete/' + taskId;
            form.method = 'post';
            document.body.appendChild(form);
            form.submit();
        }
    }
    // Durum sırasını belirlemek için fonksiyon
    function GetStatusOrder(status) {
        switch (status) {
            case "İlk Temas":
                return 1;
            case "Görüşme Ayarlandı":
                return 2;
            case "Görüşme Gerçekleşti":
                return 3;
            case "Teklif Gönderildi":
                return 4;
            case "Sözleşme Aşamasında":
                return 5;
            case "Satış Tamamlandı":
                return 6;
            default:
                return 7;
        }
    }

    // Görevleri sürüklenebilir yapın
    $('.dd-item').draggable({
        cursor: 'move',
        helper: 'clone', // Bu, sürüklenirken bir klon oluşturacak
        revert: 'invalid', // Geçerli bir bırakma noktası bulunamazsa, öğe orijinal konumuna geri döner
        start: function (event, ui) {
            $(this).css('opacity', 0.5); // Sürüklenirken orijinal öğeyi soluk yap
        },
        stop: function (event, ui) {
            $(this).css('opacity', 1); // Sürükleme durduğunda orijinal öğeyi normale döndür
        }
    });

    // Durum listelerini bırakılabilir yapın
    // Kartları bırakılabilir yapın, böylece boş kartlar da görevleri kabul edebilir
    // Kartları ve listeleri bırakılabilir yapın

    $('.card, .dd-list').droppable({
         accept: '.dd-item',
        hoverClass: 'drop-hover', // Sürüklerken görsel ipucu sağlamak için
        tolerance: 'pointer', // İşaretçi droppable alanın üzerine geldiğinde bırakmayı kabul eder
        drop: function (event, ui) {

            var $card = $(this);
            var newStatusId = $card.data('statusid');
            var taskId = ui.draggable.data('taskid');

            if (newStatusId !== undefined) {
                // Yeni durum id alındıysa ve farklıysa
                ui.draggable.fadeOut(function () {
                    // Sürüklenen öğeyi yeni listeye ekleyin
                    $(this).appendTo($('.dd-list[data-statusid="' + newStatusId + '"]')).fadeIn();
                    // Durumu server'da güncelleyin
                    updateTaskStatus(taskId, newStatusId);
                });
            } else {
                // Durum aynıysa veya tanımlanmamışsa
                ui.draggable.css('top', '0').css('left', '0').fadeIn();
            }
        }
    });

    function updateTaskStatus(taskId, newStatusId) {
        // AJAX isteğini gönder
        $.ajax({
            url: '/Task/UpdateStatus',
            type: 'POST',
            data: { taskId: taskId, statusId: newStatusId },
            success: function (response) {
                if (response.success) {
                    console.log('Task status updated!');
                    // İsteğin başarılı olduğunu ve görevin durumunun güncellendiğini bildir
                } else {
                    console.error('Failed to update task status.');
                    // Güncelleme başarısız olursa, bir hata mesajı göster
                }
            },
            error: function () {
                console.error('Failed to update task status.');
                // AJAX isteği başarısız olursa, bir hata mesajı göster
            }
        });
    }


    function filterTasks() {
        var searchText = document.getElementById('taskSearch').value.toLowerCase();
        var statusFilter = document.getElementById('statusFilter').value;

        var tasks = document.querySelectorAll('.dd-item');

        tasks.forEach(function (task) {
            var title = task.querySelector('.dd-item-title h6').textContent.toLowerCase();
            var status = task.getAttribute('data-statusid');

            var titleMatch = title.indexOf(searchText) > -1;
            var statusMatch = statusFilter === "" || status === statusFilter;

            if (titleMatch && statusMatch) {
                task.style.display = '';
            } else {
                task.style.display = 'none';
            }
        });
    }


</script>


