    <!-- core js file -->*@
    <script src="/themeforest-IV5IQlTa-lucid-hr-and-project-management-admin-template/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>
    <script src="/themeforest-IV5IQlTa-lucid-hr-and-project-management-admin-template/bootstrap5/dist/assets/plugin/nestable/jquery.nestable.min.js"></script>

    <!-- page js file -->
    <script src="/themeforest-IV5IQlTa-lucid-hr-and-project-management-admin-template/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>

    <script>
        function confirmDelete(button) {
            // Kullanıcıya silme işlemini onaylamasını sor
            if (confirm('Are you sure you want to dele te this Task?')) {
                var taskId = button.getAttribute('data-taskId');
                var form = document.createElement('form');
                form.action = '/Task/TaskDelete/' + taskId;
                form.method = 'post';
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>


    <script>
        $(function () {
            $('.dd').nestable();

            $('.dd').on('change', function () {
                var $this = $(this);
                var serializedData = window.JSON.stringify($this.nestable('serialize'));

                $this.parents('.body').find('textarea').val(serializedData);
            });
        });
    </script>

</body>
</html>
