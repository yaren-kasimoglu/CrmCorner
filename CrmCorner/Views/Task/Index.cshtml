<script>

    function scrollTasks(element) {
        var cardBody = $(element).prev('.card-body');
        var scrollStep = cardBody.find('.dd-item').first().outerHeight();
        cardBody.animate({
            scrollTop: cardBody.scrollTop() + scrollStep
        }, 300);
    }

    function checkTaskCount() {
        $('.card-body').each(function () {
            var taskCount = $(this).find('.dd-item').length;
            if (taskCount > 3) {
                $(this).next('.scroll-arrow').show(); // 3'ten fazla görev varsa oku göster
            } else {
                $(this).next('.scroll-arrow').hide(); // 3 veya daha az görev varsa oku gizle
            }
        });
    }

    // Sayfa yüklendiğinde ve görev listesi değiştiğinde görev sayısını kontrol et
    $(document).ready(function () {
        checkTaskCount();
    });



    function performSearch() {

        var searchTerm = document.getElementById('searchTasks').value.toLowerCase();


        var tasks = document.querySelectorAll('.dd-item');

        tasks.forEach(function (task) {

            var title = task.getAttribute('data-title').toString().toLowerCase();
            var description = task.getAttribute('data-description').toString().toLowerCase();
            var valueOrOffer = task.getAttribute('data-value-or-offer') ? task.getAttribute('data-value-or-offer').toLowerCase() : '';
            var salesDone = task.getAttribute('data-sales-done') ? task.getAttribute('data-sales-done').toLowerCase() : '';
            var createdDate = task.getAttribute('data-created-date') ? task.getAttribute('data-created-date').toLowerCase() : '';
            var modifiedDate = task.getAttribute('data-modified-date') ? task.getAttribute('data-modified-date').toLowerCase() : '';
            var isFinalDecisionMaker = task.getAttribute('data-is-final-decision-maker') ? task.getAttribute('data-is-final-decision-maker').toLowerCase() : '';
            var outcomeType = task.getAttribute('data-outcome-type') ? task.getAttribute('data-outcome-type').toLowerCase() : '';
            var negativeReason = task.getAttribute('data-negative-reason') ? task.getAttribute('data-negative-reason').toLowerCase() : '';


            var userName = task.getAttribute('data-user-name') ? task.getAttribute('data-user-name').toLowerCase() : '';
            var assignedUserName = task.getAttribute('data-assigned-user-name') ? task.getAttribute('data-assigned-user-name').toLowerCase() : '';
            var customerName = task.getAttribute('data-customer-name') ? task.getAttribute('data-customer-name').toLowerCase() : '';


            isFinalDecisionMaker = isFinalDecisionMaker === 'true' ? 'evet' : (isFinalDecisionMaker === 'false' ? 'hayır' : '');


            if (title.includes(searchTerm)
                || description.includes(searchTerm)
                || valueOrOffer.includes(searchTerm)
                || salesDone.includes(searchTerm)
                || createdDate.includes(searchTerm)
                || modifiedDate.includes(searchTerm)
                || isFinalDecisionMaker.includes(searchTerm)
                || negativeReason.includes(searchTerm)
                || userName.includes(searchTerm)
                || outcomeType.includes(searchTerm)
                || assignedUserName.includes(searchTerm)
                || customerName.includes(searchTerm)) {
                task.style.display = ''; // Eşleşen görevleri göster
            }


            else {
                task.style.display = 'none'; // Eşleşmeyen görevleri gizle
            }
        });
    }

    // Arama kutusuna girilen her karakterde performSearch fonksiyonunu çağır
    document.getElementById('searchTasks').addEventListener('keyup', performSearch);


    function filterByStatus() {
        var selectedStatus = document.getElementById('statusFilter').value;

        if (selectedStatus === "") {
            // Tüm Durumlar seçildiyse sayfayı yenile
            location.reload();
        } else {
            var cards = document.querySelectorAll('.card');

            // Tüm kartlardan selected-status sınıfını kaldır
            cards.forEach(function (card) {
                card.classList.remove('selected-status');
            });

            var container = document.querySelector('.row.g-3');

            // Belirli bir durum seçildiyse, sadece ilgili kartları göster
            cards.forEach(function (card) {
                var cardStatus = card.getAttribute('data-statusid');
                if (cardStatus === selectedStatus) {
                    card.style.display = '';
                    card.classList.add('selected-status');
                } else {
                    card.style.display = 'none';
                }
            });

            // Seçilen kartı ilk pozisyona taşı
            var selectedCard = document.querySelector('.card.selected-status');
            if (selectedCard) {
                container.prepend(selectedCard);
            }
        }
    }

    // Dropdown'da bir seçim yapıldığında filterByStatus fonksiyonunu çağır
    document.getElementById('statusFilter').addEventListener('change', filterByStatus);




    // Filtreleme fonksiyonu for isFinalDecisionMaker
    function filterFinalDecision() {

        // Dropdown'dan seçilen değeri al
        var filterValue = document.getElementById('isFinalDecisionMaker').value.toLowerCase(); // Küçük harfle yazılmasını sağla

        // Tüm görevleri al
        var tasksArray = Array.from(document.querySelectorAll('.dd-item'));


        if (tasksArray.length === 0) {
            console.log('Hiç görev öğesi bulunamadı.');
        }

        else {
            // Her görev için döngü
            tasksArray.forEach(function (task) {

                var isFinalAttribute = task.getAttribute('data-is-final-decision-maker');
                var isFinal = isFinalAttribute === 'True' ? 'true' : (isFinalAttribute === 'False' ? 'false' : '');


                // Görevi göster veya gizle
                if (filterValue === "" || filterValue === isFinal) {
                    task.style.display = '';
                } else {
                    task.style.display = 'none';
                }
            });

        }
    }


    document.getElementById('isFinalDecisionMaker').addEventListener('change', filterFinalDecision);


    filterFinalDecision();

</script>



<script>
    $(document).ready(function () {
        $(".choose-skin li").on("click", function () {
            var t = $("#layout")
                , e = $(this)
                , i = $(".choose-skin li.active").data("theme");
            $(".choose-skin li").removeClass("active"),
                t.removeClass("theme-" + i),
                e.addClass("active"),
                t.addClass("theme-" + e.data("theme"))
        })
    });
    function confirmDelete(button) {
        // Kullanıcıya silme işlemini onaylamasını sor
        if (confirm('Are you sure you want to delete this Task?')) {
            var taskId = button.getAttribute('data-taskId');
            var form = document.createElement('form');
            form.action = '/Task/TaskDelete/' + taskId;
            form.method = 'post';
            document.body.appendChild(form);
            form.submit();
        }
    }
    // Durum sırasını belirlemek için fonksiyon
    function GetStatusOrder(status) {
        switch (status) {
            case "İlk Temas":
                return 1;
            case "Görüşme Ayarlandı":
                return 2;
            case "Görüşme Gerçekleşti":
                return 3;
            case "Teklif Gönderildi":
                return 4;
            case "Sözleşme Aşamasında":
                return 5;
            //case "Satış Tamamlandı":
            //    return 6;
            default:
                return 7;
        }
    }

    // Görevleri sürüklenebilir yapın
    $('.dd-item').draggable({
        cursor: 'move',
        helper: 'clone', // Bu, sürüklenirken bir klon oluşturacak
        revert: 'invalid', // Geçerli bir bırakma noktası bulunamazsa, öğe orijinal konumuna geri döner
        start: function (event, ui) {
            $(this).css('opacity', 0.5); // Sürüklenirken orijinal öğeyi soluk yap
        },
        stop: function (event, ui) {
            $(this).css('opacity', 1); // Sürükleme durduğunda orijinal öğeyi normale döndür
        }
    });



    var statusOrder = [1, 2, 3, 4, 5]; // Durumların sıralı ID'leri

    function canChangeStatus(currentStatusId, newStatusId) {
        var currentIndex = statusOrder.indexOf(currentStatusId);
        var newIndex = statusOrder.indexOf(newStatusId);

        // Yeni durum, mevcut durumdan hemen sonraki durumsa veya mevcut durum yeni durumdan büyükse (geriye izin veriliyorsa) true döner
        return newIndex === currentIndex + 1 || currentIndex > newIndex;
    }
    // Durum listelerini bırakılabilir yapın
    // Kartları bırakılabilir yapın, böylece boş kartlar da görevleri kabul edebilir
    // Kartları ve listeleri bırakılabilir yapın

    var statusOrder = [1, 2, 3, 4, 5]; // Örnek olarak belirlediğim durum ID'leri

    function canChangeStatus(currentStatusId, newStatusId) {
        var currentIndex = statusOrder.indexOf(currentStatusId);
        var newIndex = statusOrder.indexOf(newStatusId);

        // Yeni durum, mevcut durumdan hemen sonraki durumsa veya mevcut durum yeni durumdan büyükse (geriye izin veriliyorsa) true döner
        return newIndex === currentIndex + 1 || currentIndex > newIndex;
    }

    $('.card, .dd-list').droppable({
        accept: '.dd-item',
        hoverClass: 'drop-hover',
        tolerance: 'pointer',
        drop: function (event, ui) {
            var $card = $(this);
            var newStatusId = $card.data('statusid');
            var taskId = ui.draggable.data('taskid');
            var currentStatusId = ui.draggable.closest('.dd-list').data('statusid'); // Mevcut durum ID'sini al

            if (newStatusId !== undefined && canChangeStatus(currentStatusId, newStatusId)) {
                // Gerekli alanların kontrolü için AJAX isteği gönder
                $.ajax({
                    url: '/Task/CheckRequiredFieldsBeforeStatusChange',
                    type: 'POST',
                    data: { taskId: taskId, newStatusId: newStatusId },
                    success: function (response) {
                        if (response.isValid) {
                            // Alanlar geçerliyse, görevin durumunu güncelleyin
                            updateTaskStatus(taskId, newStatusId);
                            ui.draggable.fadeOut(function () {
                                $(this).appendTo($('.dd-list[data-statusid="' + newStatusId + '"]')).fadeIn();
                            });

                        } else {
                            // Alanlar geçerli değilse, modal ile uyarı mesajı göster
                            $('#requiredFieldModal .modal-body').text(response.message);
                            $('#requiredFieldModal').modal('show');
                        }
                    },
                    error: function () {
                        console.error('Failed to check required fields.');
                    }
                });
            } else {
                // Durum değişikliği sıraya uygun değilse, kullanıcıya bir uyarı göster
                $('#requiredFieldModal .modal-body').text("Bu durum değişikliği izin verilen bir sırayı takip etmiyor. Süreç sırasını takip ediniz.");
                $('#requiredFieldModal').modal('show');
                ui.draggable.css('top', '0').css('left', '0').fadeIn(); // Öğeyi eski konumuna geri getir
            }
        }
    });



    function updateTaskStatus(taskId, newStatusId) {
        // AJAX isteğini gönder
        $.ajax({
            url: '/Task/UpdateStatus',
            type: 'POST',
            data: { taskId: taskId, statusId: newStatusId },
            success: function (response) {
                if (response.success) {
                    console.log('Task status updated!');
                    location.reload();
                    paginateTasks();
                } else {
                    console.error('Failed to update task status.');
                }
            },
            error: function () {
                console.error('Failed to update task status.');
                // AJAX isteği başarısız olursa, bir hata mesajı göster
            }
        });
    }

    var maxTasksPerCard = 10;

    // Görevleri sayfalandırma işlevi
    function paginateTasks() {
        $('.dd-list').each(function () {
            var tasks = $(this).find('.dd-item').slice(maxTasksPerCard); // 10'dan fazla olan görevleri seç
            tasks.hide(); // Fazladan olanları gizle
            // Daha fazla görev varsa, 'Daha fazla göster' bağlantısını ekleyebilirsiniz
            if (tasks.length > 0) {
                var moreLink = $('<a href="#" class="show-more-tasks">Daha fazla göster...</a>');
                $(this).after(moreLink);
                moreLink.on('click', function (e) {
                    e.preventDefault();
                    tasks.slice(0, maxTasksPerCard).fadeIn(); // Sonraki 10 görevi göster
                    $(this).remove(); // 'Daha fazla göster' bağlantısını kaldır
                });
            }
        });
    }

    // Sayfa yüklendiğinde ve görev listesi değiştiğinde sayfalandırmayı çağır
    $(document).ready(function () {
        paginateTasks();
    });

    function showHiddenTasks(statusKey) {
        $('ol.hidden-tasks[data-statusid="' + statusKey + '"]').toggle();
    }

</script>
