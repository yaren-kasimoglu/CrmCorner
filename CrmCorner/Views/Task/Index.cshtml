@model List<TaskComp>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}
<style>
    .dd-item-title {
        display: block; /* Bağlantıyı blok seviyesinde bir element yapar, bu da tüm satırı tıklanabilir yapar */
        padding: 8px 16px; /* Bağlantıya iç boşluk ekler */
        margin: -8px -16px; /* Etrafta boşluk bırakmadan bağlantıyı genişletir */
        color: #333; /* Metin rengi */
        background-color: transparent; /* Arkaplan rengi */
        text-decoration: none; /* Alt çizgiyi kaldırır */
        font-weight: bold; /* Metni kalın yapar */
        border-radius: 4px; /* Kenarlara hafif yuvarlaklık ekler */
    }

        .dd-item-title:hover, .dd-item-title:focus {
            text-decoration: none; /* Üzerine gelindiğinde veya odaklandığında alt çizgi ekler */
            background-color: #f5f5f5; /* Üzerine gelindiğinde arkaplan rengini değiştirir */
            color: #006400; /* Üzerine gelindiğinde metin rengini değiştirir */
        }

    .dd-list {
        min-height: 50px; /* Boş listelerde görünürlük sağlamak için */
        padding: 10px; /* Boş listelerde iç boşluk sağlamak için */
        background-color: #f9f9f9; /* Görsel olarak ayırt edilebilir olması için */
    }

    .drop-hover {
        background-color: #e0e0e0; /* Sürüklenen öğenin üzerinde olduğu alanı belirtmek için */
    }

    .card {
        position: relative;
        padding-bottom: 40px; /* Scroll arrow için yer açmak için */
    }

    .card-body {
        max-height: 300px; /* Kartın maksimum yüksekliği */
        overflow-y: auto; /* Dikey kaydırma çubuğu ekle */
    }

    .search-filter-container {
        display: flex;
        justify-content: start;
        align-items: stretch; /* İçerikleri aynı yükseklikte hizalar */
        gap: 10px;
        margin-bottom: 20px;
        padding: 0;
    }

    .search-box {
        display: flex;
        align-items: center;
        padding: 8px;
        border: 1px solid #2D6187;
        border-radius: 4px;
        background-color: #fff;
    }

    .status-filter {
        display: flex;
        align-items: center;
        padding: 1px;
        margin-right: 8px;
        border: 1px solid #2D6187;
        border-radius: 4px;
        background-color: #fff;
    }

    .search-box input[type="text"] {
        flex-grow: 1; /* Arama kutusunu esnet ve mevcut alana doldur */
        border: 1px solid #d3d3d3;
        margin-right: 8px;
        padding: 10px;
        font-size: 14px;
        color: #333;
    }

    .status-filter select {
        padding: 10px;
        border: none;
        background-color: #fff;
        cursor: pointer;
        -webkit-appearance: none; /* Özelleştirilmiş dropdown için */
        -moz-appearance: none;
        appearance: none;
        font-size: 14px;
        color: #333;
        background-image: url('dropdown-arrow.svg'); /* Sizin sağladığınız ok ikonu */
        background-repeat: no-repeat;
        background-position: right 10px center;
        background-size: 16px;
        position: relative;
    }

    /* Dropdown menünün altındaki ok işaretini eklemek için kullanılan SVG */
    .status-filter select {
        background-image: url('data:image/svg+xml;charset=US-ASCII,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 4 5"><path fill="%23000" d="M2 0L0 2h4L2 0z"/></svg>');
        background-position: right 15px center;
        background-size: 12px 6px;
        -webkit-appearance: none;
        -moz-appearance: none;
        appearance: none;
    }

    .selected-status {
        order: -1; /* Bu, seçilen statü kutusunun öncelikli olarak sola hizalanmasını sağlar */
    }
    .final-decision-filter {
        display: flex;
        align-items: center;
        padding: 1px;
        margin-right: 8px;
        border: 1px solid #2D6187;
        border-radius: 4px;
        background-color: #fff;
    }

        .final-decision-filter select {
            padding: 10px;
            border: none;
            background-color: #fff;
            cursor: pointer;
            -webkit-appearance: none; /* Özelleştirilmiş dropdown için */
            -moz-appearance: none;
            appearance: none;
            font-size: 14px;
            color: #333;
            background-image: url('dropdown-arrow.svg'); /* Sizin sağladığınız ok ikonu */
            background-repeat: no-repeat;
            background-position: right 10px center;
            background-size: 16px;
            position: relative;
            padding-right: 30px;
        }

        .final-decision-filter select {
            background-image: url('data:image/svg+xml;charset=US-ASCII,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 4 5"><path fill="%23000" d="M2 0L0 2h4L2 0z"/></svg>');
            background-position: right 15px center;
            background-size: 12px 6px;
            -webkit-appearance: none;
            -moz-appearance: none;
            appearance: none;
            padding-right: 30px;
        }

    .selected-status {
        /* Burada seçilen karta özel stil tanımlayabilirsiniz */
        border: 2px solid #000; /* Örnek: kalın siyah kenarlık */
    }

            /* Hover efektleri */
            .search-box input[type="text"]:hover,
            .search-box input[type="text"]:focus,
            .status-filter select:hover,
            .status-filter select:focus,
            .final-decision-filter select:hover,
            .final-decision-filter select:focus {
                background-color: #e6e6e6;
            }

    @@media (max-width: 768px) {
        .search-filter-container {
            flex-direction: column;
        }

        .search-box,
        .status-filter {
            width: 100%;
            margin-right: 0;
            margin-bottom: 10px;
            border: 3px solid #2D6187; /* Gri tonlu 1 piksel kalınlığında çerçeve */
            border-radius: 4px; /* Hafif yuvarlatılmış köşeler için */
        }
    }


    .scroll-arrow {
        text-align: center;
        padding: 10px;
        cursor: pointer;
        font-size: 18px;
        color: #333;
        position: absolute;
        bottom: 0;
        width: 100%;
        background-color: #f9f9f9;
        display: none; /* Başlangıçta gizli */
    }

        .scroll-arrow:hover {
            color: #006400;
        }
</style>


