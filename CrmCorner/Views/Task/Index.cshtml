<div class="row g-3">
    @{
        // ViewBag'dan durum isimlerini ve durumların listesini al
        var statusNames = ViewBag.StatusNames as Dictionary<int, string>;
        var statusList = ViewBag.StatusList as Dictionary<int, string>; // Controller'dan gönderilen durum listesi

        // Her durumu temsil edecek kartlar için döngü oluştur
        foreach (var status in statusList)
        {
            // Her durum için bir kart oluştur
            <div class="col-lg-3 col-md-4 col-sm-6" data-statusid="@status.Key">
                @{
                    string statusClass = "";
                    string borderColor = "";
                    switch (status.Key) // Burada status.Key, durumun ID'sidir
                    {
                        case 1:
                            statusClass = "planned_task";
                            borderColor = "#fd7e14";
                            break;
                        case 2:
                            statusClass = "progress_task";
                            borderColor = "#198754";
                            break;
                        case 3:
                            statusClass = "completed_task";
                            borderColor = "#0d6efd";
                            break;
                        case 4:
                            statusClass = "planned_task";
                            borderColor = "#FED049";
                            break;
                        case 5:
                            statusClass = "progress_task";
                            borderColor = "#2D6187";
                            break;
                        case 6:
                            statusClass = "completed_task";
                            borderColor = "#006400";
                            break;
                        default:
                            statusClass = "";
                            break;
                    }
                }
                @{
                    var tasksInThisStatus = Model.Where(task => task.Status != null && task.Status.StatusId == status.Key).ToList();
                }

                <div class="card mb-4 @statusClass" style="border-color:@borderColor; min-height:400px;" data-statusid="@status.Key">
                    <div class="card-header">
                        <h6 class="card-title">@status.Value </h6>
                        <span id="taskCount_@status.Key">Görev Sayısı:@(tasksInThisStatus.Count())</span>

                        <ul class="header-dropdown">
                            <li>
                                @if (status.Key == 1)
                                {
                                    <a href="/Task/TaskAdd"><i class="fa fa-plus-circle"></i></a>
                                }
                            </li>
                        </ul>
                    </div>


                    <div class="card-body">
                        @if (tasksInThisStatus.Any())
                        {
                            // Görevleri listele
                            <div class="dd" data-plugin="nestable">
                                <ol class="dd-list" data-statusid="@status.Key">
                                    @foreach (var task in tasksInThisStatus)
                                    {
                                        <li class="dd-item" data-taskid="@task.TaskId" data-statusid="@task.Status.StatusId" data-title="@task.Title"
                                            data-value-or-offer="@task.ValueOrOffer?.ToString("0.##")"
                                            data-description="@task.Description"
                                            data-sales-done="@task.SalesDone?.ToString("dd-MM-yyyyTHH:mm:ss")"
                                            data-created-date="@task.CreatedDate.ToString("dd-MM-yyyyTHH:mm:ss")"
                                            data-modified-date="@task.ModifiedDate?.ToString("dd-MM-yyyyTHH:mm:ss")"
                                            data-is-final-decision-maker="@task.IsFinalDecisionMaker"
                                            data-negative-reason="@task.NegativeReason"
                                            data-user-name="@task.AppUser?.UserName"
                                            data-user-id="@task.AppUser?.Id"
                                            data-assigned-user-name="@task.AssignedUser?.UserName"
                                            data-customer-name="@task.Customer?.Name @task.Customer?.Surname"
                                            data-outcome-type="@task.Outcomes.ToString()">
                                            <div class="dd-handle">
                                                <a href="/Task/TaskDetail/@task.TaskId" class="dd-item-title">
                                                    <h6>@task.Title</h6>
                                                </a>
                                                <div class="task-actions">
                                                    <a href="/Task/TaskEdit/@task.TaskId" target="_self">
                                                        <button type="button" class="btn btn-sm btn-outline">
                                                            <i class="fa fa-edit"></i>
                                                        </button>
                                                    </a>
                                                    <button type="button" class="btn btn-sm btn-outline" data-taskId="@task.TaskId" onclick="confirmDelete(this)">
                                                        <i class="fa fa-trash-o"></i>
                                                    </button>
                                                    <a href="/Task/TaskDetail/@task.TaskId" target="_self">
                                                        <button type="button" class="btn btn-sm btn-outline">
                                                            <i class="fa fa-file-text-o"></i>
                                                        </button>
                                                    </a>
                                                </div>
                                            </div>
                                        </li>
                                    }
                                </ol>
                            </div>
                        }
                        else
                        {
                            <p>Görev Yok.</p>
                        }
                    </div>
                    <div class="scroll-arrow" onclick="scrollTasks(this)">
                        <i class="fa  fa-caret-down"></i>
                    </div>

                </div>
            </div>
        }
    }

</div>

