<script src="~/CRMTema/bootstrap5/dist/assets/js/pages/forms/dropify.js"></script>*@

<script>
    $(document).ready(function () {
        $('#file_list')
            .dataTable({
                responsive: true,
                columnDefs: [
                    {
                        orderable: false,
                        targets: [0]
                    }
                ]
            });
    });
</script>