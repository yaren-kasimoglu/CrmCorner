@model CrmCorner.Models.TaskComp
@{
    ViewData["Title"] = "TaskDetail";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}
@section Styles{
    <style>
        /*        <link rel="stylesheet" href="~/CCThema/bootstrap5/dist/assets/vendor/dropify/css/dropify.min.css" >*/
        .highlight {
            background-color: #f8f9fa;
            padding: 20px;
        }

            .highlight pre code {
                font-size: inherit;
                color: #212529;
            }

        .nt {
            color: #2f6f9f;
        }

        .na {
            color: #4f9fcf;
        }

        .s {
            color: #d44950;
        }

        pre.prettyprint {
            background-color: #eee;
            border: 0px;
            margin: 0;
            padding: 20px;
            text-align: left;
        }

        .atv,
        .str {
            color: #05AE0E;
        }

        .tag,
        .pln,
        .kwd {
            color: #3472F7;
        }

        .atn {
            color: #2C93FF;
        }

        .pln {
            color: #333;
        }

        .com {
            color: #999;
        }
    </style>

    }
<div class="container-fluid">
    <div class="row g-2">
        <div class="col-lg-4 col-md-12">
            <div class="card mb-2">
                <div class="card-body">
                    <h6 class="card-title mb-4">Detaylar/Notlar</h6>
                    <p>@Model.Description</p>
                    <div class="progress-container progress-info">
                        @*           <div class="progress">
                        <div class="progress-bar" role="progressbar" aria-valuenow="60" aria-valuemin="0" aria-valuemax="100" style="width: 78%;">
                        <span class="progress-value">78%</span>
                        </div>
                        </div>*@
                    </div>
                </div>
            </div>
            <div class="card mb-2">
                <div class="card-body">
                    <ul class="list-unstyled basic-list mb-0">
                        <li class="d-flex justify-content-between mb-3">Sorumlu:<span class="badge bg-primary">@Model.AppUser.NameSurname</span></li>
                        <li class="d-flex justify-content-between mb-3">Görev Oluşturma Tarihi:<span class="bg-success badge">@Model.CreatedDate</span></li>
                        <li class="d-flex justify-content-between mb-3">Güncel Durum:<span class="bg-info badge">@Model.Status.StatusName</span></li>
                        <li class="d-flex justify-content-between mb-3">Planlanan Kapatma Tarihi:<span class="bg-danger badge">22 Aug, 2021</span></li>
                        <li class="d-flex justify-content-between mb-3">Değer Teklifi:<span class="bg-warning badge">@Model.ValueOrOffer</span></li>

                    </ul>
                </div>
            </div>
            <div class="card mb-2">
                <div class="card-header">
                    <h6 class="card-title">Müşteri-Firma Bilgileri</h6>
                </div>
                <div class="card-body">
                    <div class="w_user d-flex align-items-start">
                        <img class="rounded-circle" src="~/userprofilepicture/defaultpp.png" width="72" alt="" />
                        <div class="wid-u-info ms-3">
                            <h5 class="mb-0">@Model.Customer.CompanyName</h5>
                            <span>@Model.Customer.CompanyEmail</span>
                        </div>
                    </div>
                    <hr>
                    <ul class="right_chat list-unstyled mb-0">
                        <li class="offline">
                            <a class="d-flex mb-3" href="javascript:void(0);">
                                <img class="rounded-circle" src="~/userprofilepicture/defaultpp.png" width="45" height="45" alt="" />
                                <div class="ms-3 w-100 text-muted">
                                    <span class="name d-block">@Model.Customer.Name</span>
                                    <span class="message">@Model.Customer.CustomerEmail</span>
                                    <span class="message">@Model.Customer.PhoneNumber</span>
                                    <span class="status"></span>
                                </div>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>



            <div class="card mb-2">
                <div class="card-header">

                    <form method="post" enctype="multipart/form-data" asp-controller="Task" asp-action="UploadFile">
                        <input type="number" name="taskId" value="@Model.TaskId" />
                        <input type="file" name="uploadedFile" />
                        <button type="submit">Yükle</button>
                    </form>



                </div>
            </div>




            <div class="card mb-2">
                <div class="card-header">
                    <h6 class="card-title">Dosyalar & Belgeler</h6>
                </div>
                <div class="card-body">
                    <div class="w_user d-flex align-items-start">
                        <div class="wid-u-info ms-3">
                            <h5 class="mb-0">@Model.Customer.CompanyName</h5>
                            <span>@Model.Customer.CompanyEmail</span>
                        </div>
                    </div>
                    <hr>
                    <ul class="right_chat list-unstyled mb-0">
                        <li class="offline">
                            <a class="d-flex mb-3" href="javascript:void(0);">
                                <img class="rounded-circle" src="~/userprofilepicture/defaultpp.png" width="45" height="45" alt="" />
                                <div class="ms-3 w-100 text-muted">
                                    <span class="name d-block">@Model.Customer.Name</span>
                                    <span class="message">@Model.Customer.CustomerEmail</span>
                                    <span class="message">@Model.Customer.PhoneNumber</span>
                                    <span class="status"></span>
                                </div>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="card mb-2">
                <div class="card-header">
                    <h6 class="card-title">Kullanıcı Bilgisi</h6>
                </div>
                <div class="card-body text-center">
                    <div class="profile-image mb-3"> <img src="~/userprofilepicture/defaultpp.png" width="65" height="65" class="rounded-circle" alt=""> </div>
                    <div>
                        <h4><strong>@Model.AppUser.NameSurname</strong></h4>
                    </div>
                    <div class="mt-3">
                        <a asp-action="MyProfile" asp-controller="Member">
                            <button class="btn btn-primary">Profilim</button>
                        </a>
                        <a asp-action="ChatApp" asp-controller="ChatApp">
                            <button class="btn btn-outline-secondary">Message</button>
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-8 col-md-12">
            <div class="card mb-2">
                <div class="card-body">
                    <div class="timeline-item green">
                        <span class="date">Just now</span>
                        <h6>iNext - One Page Responsive Template</h6>
                        <span>Project Lead: <a href="javascript:void(0);" title="Fidel Tonn">Fidel Tonn</a></span>
                    </div>
                    <div class="timeline-item warning">
                        <span class="date">02 Jun 2021</span>
                        <h6>Add Team Members</h6>
                        <span>By: <a href="javascript:void(0);" title="Fidel Tonn">Fidel Tonn</a></span>
                        <div class="msg">
                            <p>web by far While that's mock-ups and this is politics, are they really so different? I think the only card she has is the Lorem card.</p>
                            <ul class="list-unstyled team-info d-flex">
                                <li><img src="~/CRMTema/bootstrap5/dist/assets/images/xs/avatar4.jpg" data-toggle="tooltip" data-placement="top" title="Chris Fox" alt="Avatar"></li>
                                <li><img src="~/CRMTema/bootstrap5/dist/assets/images/xs/avatar5.jpg" data-toggle="tooltip" data-placement="top" title="Joge Lucky" alt="Avatar"></li>
                                <li><img src="~/CRMTema/bootstrap5/dist/assets/images/xs/avatar2.jpg" data-toggle="tooltip" data-placement="top" title="Folisise Chosielie" alt="Avatar"></li>
                                <li><img src="~/CRMTema/bootstrap5/dist/assets/images/xs/avatar1.jpg" data-toggle="tooltip" data-placement="top" title="Joge Lucky" alt="Avatar"></li>
                            </ul>
                            <div class="top_counter d-flex">
                                <div class="icon text-center"><i class="fa fa-file-word-o"></i> </div>
                                <div class="content ms-3">
                                    <p class="mb-1">iNext project documentation.doc</p>
                                    <span>Size: 2.3Mb</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="timeline-item warning">
                        <span class="date">02 Jun 2021</span>
                        <h6>Task Assigned</h6>
                        <span>By: <a href="javascript:void(0);" title="Fidel Tonn">Fidel Tonn</a></span>
                        <div class="msg">
                            <p>It is a long established fact that a reader will be distracted by the readable content of a page when looking at its layout. The point of using Lorem Ipsum is that it has a more-or-less normal</p>
                            <div class="d-flex mb-3">
                                <img class="media-object rounded width40 mr-3" src="~/CRMTema/bootstrap5/dist/assets/images/xs/avatar1.jpg" alt="" />
                                <div class="media-body ms-2">
                                    <h6 class="mb-0">Folisise Chosielie</h6>
                                    <p class="mb-0"><strong>Detail:</strong> Ipsum is simply dummy text of the printing and typesetting industry. </p>
                                </div>
                            </div>
                            <div class="d-flex">
                                <img class="media-object rounded width40 mr-3" src="~/CRMTema/bootstrap5/dist/assets/images/xs/avatar5.jpg" alt="" />
                                <div class="media-body ms-2">
                                    <h6 class="mb-0">Joge Lucky</h6>
                                    <p class="mb-0"><strong>Detail:</strong> Ipsum is simply dummy text of the printing and typesetting industry. </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="timeline-item warning">
                        <span class="date">02 Jun 2021</span>

                        <div class="timeline-item danger">
                            <span class="date">04 Jun 2021</span>
                            <h6>Project Reports</h6>
                            <span>By: <a href="javascript:void(0);" title="Fidel Tonn">Fidel Tonn</a></span>
                            <div class="msg">
                                <ul class="list-unstyled">
                                    <li class="mb-3">
                                        <span>Design Bug</span>
                                        <div class="progress" style="height: 5px;">
                                            <div class="progress-bar bg-danger" role="progressbar" aria-valuenow="17" aria-valuemin="0" aria-valuemax="100" style="width: 17%;"></div>
                                        </div>
                                    </li>
                                    <li class="mb-3">
                                        <span>UI UX Design Task</span>
                                        <div class="progress" style="height: 5px;">
                                            <div class="progress-bar" role="progressbar" aria-valuenow="83" aria-valuemin="0" aria-valuemax="100" style="width: 83%;"> </div>
                                        </div>
                                    </li>
                                    <li class="mb-3">
                                        <span>Developer Task</span>
                                        <div class="progress" style="height: 5px;">
                                            <div class="progress-bar bg-success" role="progressbar" aria-valuenow="49" aria-valuemin="0" aria-valuemax="100" style="width: 49%;"></div>
                                        </div>
                                    </li>
                                    <li>
                                        <span>QA (Quality Assurance)</span>
                                        <div class="progress" style="height: 5px;">
                                            <div class="progress-bar bg-warning" role="progressbar" aria-valuenow="33" aria-valuemin="0" aria-valuemax="100" style="width: 33%;"></div>
                                        </div>
                                    </li>
                                </ul>
                            </div>
                        </div>
                        <div class="timeline-item dark">
                            <span class="date">05 Jun 2021</span>
                            <h6>Project on Goinng</h6>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- core js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>

