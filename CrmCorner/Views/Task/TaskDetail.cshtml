@model CrmCorner.Models.TaskComp
@{
    ViewData["Title"] = "TaskDetail";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}


<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>:: Lucid HR BS5 :: Timeline</title>
    <meta http-equiv="X-UA-Compatible" content="IE=Edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <link rel="icon" href="/CRMTema/bootstrap5/dist/horizontal/favicon.ico" type="image/x-icon">
    <!-- VENDOR CSS -->
    <link rel="stylesheet" href="/CRMTema/bootstrap5/dist/assets/vendor/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="/CRMTema/bootstrap5/dist/assets/vendor/font-awesome/css/font-awesome.min.css">
    <link rel="stylesheet" href="/CRMTema/bootstrap5/dist/assets/vendor/dropify/css/dropify.min.css">


    <!-- MAIN CSS -->
    <link rel="stylesheet" href="/CRMTema/bootstrap5/dist/assets/css/main.css">
    <link rel="stylesheet" href="/CRMTema/bootstrap5/dist/assets/css/color_skins.css">
</head>

<body>
@*
    <div class="block-header py-lg-4 py-3">
        <div class="row g-3">
            <div class="col-md-6 col-sm-12">
                <h2 class="m-0 fs-5"><a href="javascript:void(0);" class="btn btn-sm btn-link ps-0 btn-toggle-fullwidth"><i class="fa fa-arrow-left"></i></a> Timeline</h2>
                <ul class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/CRMTema/bootstrap5/dist/index.html">Lucid</a></li>
                    <li class="breadcrumb-item">Pages</li>
                    <li class="breadcrumb-item active">Timeline</li>
                </ul>
            </div>
        </div>
    </div>*@

    <div class="row g-3">
        <div class="col-lg-3 col-md-12 col-sm-12">
            <div class="card">
                <div class="card-header">
                    <h6 class="card-title">Summary</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th class="table-light text-dark" scope="col"><i class="fa fa-money"></i></th>
                                    <th class="table-light text-dark" scope="col"><i class="fa fa-user"></i></th>
                                    <th class="table-light text-dark" scope="col">  <i class="fa fa-users"></i></th>
                               @*     <th class="table-light text-dark" scope="col"><i class="fa fa-calendar"></i></th>*@
                                </tr>
                            </thead>
                            <tbody>
                                <input type="hidden" id="taskId" name="taskId" value="@Model.TaskId" />
                                <tr>
                                    <td>@Model.ValueOrOffer</td>
                                    <td>@Model.Employee.EmployeeName</td>
                                    <td>@Model.Customer.Name</td>
                             @*       <td>x</td>*@
                                </tr>
                                <tr>
                                    <td>Task Name: @Model.Title</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-9 col-md-12 col-sm-12">
            <div class="card">
                <div class="card-header">
                    <h6 class="card-title">Actions</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th class="table-light text-dark" scope="col"><i class="fa fa-folder"></i></th>
                                    <th class="table-light text-dark" scope="col"><i class="fa fa-folder"></i></th>
                                    <th class="table-light text-dark" scope="col"><i class="fa fa-send"></i></th>
                                    <th class="table-light text-dark" scope="col"><i class="fa fa-calendar"></i></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>
                                        <form method="post" enctype="multipart/form-data" asp-controller="Task" asp-action="UploadFile">
                                            <input type="hidden" name="taskId" value="@(Model.TaskId)" />
                                            <div class="col-lg-6 col-md-12">
                                                <div class="card">
                                                    <div class="header">
                                                        <h6>Dosya Yükle</h6>
                                                    </div>
                                                    <div class="body">
                                                        <input type="file" name="uploadedFile" class="dropify" data-allowed-file-extensions="pdf png">
                                                    </div>
                                                    <br />
                                                    <div class="body">
                                                        <button type="submit" class="btn btn-primary">Yükle</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </form>

                                    </td>
                                    <td>
                                        <div class="card">
                                            <h6>Yüklenen Dosyalar</h6>
                                            <ul>
                                                @if (!string.IsNullOrEmpty(Model.UploadedFileName))
                                                {
                                                    string[] fileNames = Model.UploadedFileName.Split(',');

                                                    for (int i = 0; i < fileNames.Length; i++)
                                                    {
                                                        string fileName = fileNames[i];
                                                        <li>
                                                            @fileName
                                                            <div class="row g-3">
                                                                <br />
                                                                <div class="col-lg-6">
                                                                    <a href="@Url.Action("DownloadFile", "Task", new { taskId = Model.TaskId, fileName = fileName })" class="btn btn-primary">İndir</a>
                                                                </div>
                                                                <div class="col-lg-6">
                                                                    <form method="post" asp-controller="Task" asp-action="DeleteFile">
                                                                        <input type="hidden" name="taskId" value="@Model.TaskId" />
                                                                        <input type="hidden" name="fileName" value="@fileName" />
                                                                        <button type="submit" class="btn btn-danger">Sil</button>
                                                                    </form>
                                                                </div>
                                                            </div>
                                                        </li>
                                                    }
                                                }
                                            </ul>
                                        </div>

                                    </td>
                                    <td>@Model.Employee.EmployeeName--send email butonu EKLENECEK</td>
                                    <td>@Model.Customer.Name -- takvim EKLENECEK</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <div class="row clearfix">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-body">

                    @if (Model.TaskCompLogs != null && Model.TaskCompLogs.Any())
                    {
                        
                    @foreach (var log in Model.TaskCompLogs)
                    {
                            var count = Model.TaskCompLogs.Count();
                            var remainder = log.LogId % 3;
                            var timelineClass = "";

                            switch (remainder)
                            {
                                case 0:
                                    timelineClass = "timeline-item warning";
                                    break;
                                case 1:
                                    timelineClass = "timeline-item faster green";
                                    break;
                                case 2:
                                    timelineClass = "timeline-item blue";
                                    break;
                                default:
                                    break;
                            }

                        if (log.UpdatedField != "TaskCompLogs" && log.UpdatedField != "ModifiedDate")
                        {
                                <div class="@timelineClass">
                                <div class="timeline-badge primary"><i class="glyphicon glyphicon-record" rel="tooltip"></i></div>
                                <div class="timeline-panel">
                                    <div class="timeline-heading">
                                            <h5>
                                                <p><small class="text-muted"><i class="glyphicon glyphicon-time"></i> @log.UpdatedAt?.ToString("dd-MM-yyyy HH:mm:ss")</small></p>@* Renk kontrolü eklenebilir KONTROL*@
                                            </h5>
                                        <h6 class="timeline-title">@log.UpdatedField</h6>    
                                    </div>
                                    <div class="timeline-body">
                                        <p>@log.OldValue <i class="fa fa-long-arrow-right"></i> @log.NewValue</p>
                                        <p>Edited By: @log.UpdatedByNavigation?.EmployeeName</p>
                                    </div>
                            </div>
                            </div>
                        }
                    }
                    }
                    else
                    {
                        <p>TaskCompLogs içinde veri bulunamadı veya döngüye giriş yapılmadı.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- core js file -->
    <script src="/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>

    <!-- page js file -->
    <script src="/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>
    <script src="/CRMTema/bootstrap5/dist/assets/bundles/vendorscripts.bundle.js"></script>
    <script src="/CRMTema/bootstrap5/dist/assets/vendor/dropify/js/dropify.min.js"></script>
    <script src="/CRMTema/bootstrap5/dist/assets/js/pages/forms/dropify.js"></script>

</body>
</html>