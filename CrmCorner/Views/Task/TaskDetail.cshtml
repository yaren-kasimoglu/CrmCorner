@using CrmCorner.Models.Enums;
@model CrmCorner.Models.TaskComp
@{
    ViewData["Title"] = "TaskDetail";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}
@functions {
    private string GetOutcomeClass(bool? isPositiveOutcome)
    {
        if (isPositiveOutcome == true)
        {
            return "badge badge-light text-success border border-success"; // Yeşil arka plan
        }
        else if (isPositiveOutcome == false)
        {
            return "badge badge-light text-danger border border-danger"; // Kırmızı arka plan
        }
        else
        {
            return "badge badge-light text-secondary border border-secondary"; // Gri arka plan, eğer null ise
        }
    }
}

@section Styles{
    <style>
        /*        <link rel="stylesheet" href="~/CCThema/bootstrap5/dist/assets/vendor/dropify/css/dropify.min.css" >*/
        .highlight {
            background-color: #f8f9fa;
            padding: 20px;
        }

            .highlight pre code {
                font-size: inherit;
                color: #212529;
            }

        .nt {
            color: #2f6f9f;
        }

        .na {
            color: #4f9fcf;
        }

        .s {
            color: #d44950;
        }

        pre.prettyprint {
            background-color: #eee;
            border: 0px;
            margin: 0;
            padding: 20px;
            text-align: left;
        }

        .atv,
        .str {
            color: #05AE0E;
        }

        .tag,
        .pln,
        .kwd {
            color: #3472F7;
        }

        .atn {
            color: #2C93FF;
        }

        .pln {
            color: #333;
        }

        .com {
            color: #999;
        }



        .ellipsis {
            max-width: 160px; /* Maksimum genişliği ayarlayın */
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            display: block;
        }

        .buyukYazi {
            font-size: 20px; /* Yazı boyutunu istediğiniz piksel değeri olarak ayarlayabilirsiniz */
        }
    </style>

    }
<div class="container-fluid">
    <div class="row g-2">
        <div class="col-lg-4 col-md-12">
            <div class="card mb-2">
                <div class="card-body">
                    <h6 class="card-title mb-4">Detaylar/Notlar</h6>
                    <p>@Model.Description</p>
               @*     <span class="buyukYazi @GetOutcomeClass(Model.IsPositiveOutcome)">
                        @(Model.IsPositiveOutcome ? "Olumlu" : "Olumsuz")
                    </span>*@

                    <div class="progress-container progress-info">
                        @*           <div class="progress">
                        <div class="progress-bar" role="progressbar" aria-valuenow="60" aria-valuemin="0" aria-valuemax="100" style="width: 78%;">
                        <span class="progress-value">78%</span>
                        </div>
                        </div>*@
                    </div>
                </div>
            </div>
            <div class="card mb-2">
                <div class="card-body">
                    <ul class="list-unstyled basic-list mb-0">
                        <li class="d-flex justify-content-between mb-3">Sorumlu:<span class="badge bg-primary">@Model.AppUser.NameSurname</span></li>
                        <li class="d-flex justify-content-between mb-3">Görev Oluşturma Tarihi:<span class="bg-success badge">@Model.CreatedDate</span></li>
                        <li class="d-flex justify-content-between mb-3">Güncel Durum:<span class="bg-info badge">@Model.Status.StatusName</span></li>
                        <li class="d-flex justify-content-between mb-3">Satış Kapatma Tarihi:<span class="bg-danger badge">@Model.SalesDone?.ToString("d")</span></li>
                        <li class="d-flex justify-content-between mb-3">Değer Teklifi:<span class="bg-warning badge">@Model.ValueOrOffer?.ToString("N2")</span></li>
                    </ul>
                </div>
            </div>
            <div class="card mb-2">
                <div class="card-header">
                    <h6 class="card-title">Müşteri-Firma Bilgileri</h6>
                </div>
                <div class="card-body">
                    <div class="w_user d-flex align-items-start">
                        <img class="rounded-circle" src="~/userprofilepicture/firm.png" width="72" alt="" />
                        <div class="wid-u-info ms-3">
                            <h5 class="mb-0">@Model.Customer.CompanyName</h5>
                            <br />
                            <span>E-Posta: @Model.Customer.CompanyEmail</span>
                            <br />
                            <span>Sektör: @Model.Customer.Industry</span>
                            <br />
                            <span class="message"> Çalışan Sayısı: @Model.Customer.EmployeeCount</span>
                        </div>
                    </div>
                    <hr>
                    <ul class="right_chat list-unstyled mb-0">
                        <li class="offline">
                            <a class="d-flex mb-3" href="/Customer/CustomerList">
                                <img class="rounded-circle" src="~/userprofilepicture/defaultpp.png" width="35" height="35" alt="" />
                                <div class="ms-3 w-100 text-muted">
                                    <span class="name d-block">@Model.Customer.Name</span>
                                    <span class="message">@Model.Customer.CustomerEmail</span>
                                    <br />
                                    <span class="message">@Model.Customer.PhoneNumber</span>
                                    <br />
                                    <span class="message">@Model.Customer.CustomerTitle</span>  
                                </div>
                            </a>
                            <br />
                            <span class="badge badge-dark text-dark border border-dark message">
                                Son Karar Mercii : 
                                @if (Model.IsFinalDecisionMaker)
                                {
                                    <i class="fa fa-check-circle" style="color: green;"></i> <!-- Evet durumu için tik işareti -->
                                }
                                else
                                {
                                    <i class="fa fa-times-circle" style="color: red;"></i> <!-- Hayır durumu için çarpı işareti -->
                                }
                            </span>

                        </li>
                    </ul>
                </div>
            </div>
            <div class="card mb-2">
                <div class="card-header">
                    <h6 class="card-title">Dosyalar & Belgeler & Sözleşmeler</h6>
                    <br />
                    @using (Html.BeginForm("UploadFile", "Task", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        <div class="form-group">
                            <input type="file" name="file" required />
                            <input type="hidden" name="taskId" value="@Model.TaskId" />
                        </div>
                        <hr>
                        <div class="form-group">
                            <input type="submit" value="Yükle" class="btn btn-primary" />
                        </div>
                    }

                </div>
                <div class="card-body">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Dosya Adı</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var file in Model.FileAttachments)
                            {
                                <tr>
                                    <td><div class="ellipsis" title="@file.FileName">@file.FileName</div></td>
                                    <td>
                                        <a href="@Url.Action("DownloadFile", "Task", new { fileAttachmentId = file.FileAttachmentId })"><span class="badge bg-success">İndir</span></a>
                                        <a href="@Url.Action("DeleteFile", "Task", new { fileAttachmentId = file.FileAttachmentId })"><span class="badge bg-danger">Sil</span></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>


            <div class="card mb-2">
                <div class="card-header">
                    <h6 class="card-title">Görevi Oluşturan</h6>
                </div>
                <div class="card-body text-center">
                    <div class="profile-image mb-3"> <img src="~/userprofilepicture/defaultpp.png" width="65" height="65" class="rounded-circle" alt=""> </div>
                    <div>
                        <h4><strong>@Model.AppUser.NameSurname</strong></h4>
                    </div>
                    <div class="mt-3">
                        @*         <a asp-action="MyProfile" asp-controller="Member">
                        <button class="btn btn-primary">Profilim</button>
                        </a>*@
                        <a asp-action="ChatApp" asp-controller="ChatApp">
                            <button class="btn btn-outline-secondary">Message</button>
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-8 col-md-12">
            <div class="card mb-2">
                <div class="card-body">

                    @if (Model.TaskCompLogs != null && Model.TaskCompLogs.Any())
                    {

                        foreach (var log in ViewBag.TaskCompLogs as List<CrmCorner.Models.TaskCompLog>)
                        {

                            var count = Model.TaskCompLogs.Count();
                            var remainder = log.LogId % 5;
                            var timelineClass = "";

                            switch (remainder)
                            {
                                case 0:
                                    timelineClass = "timeline-item warning";
                                    break;
                                case 1:
                                    timelineClass = "timeline-item faster green";
                                    break;
                                case 2:
                                    timelineClass = "timeline-item blue";
                                    break;
                                case 3:
                                    timelineClass = "timeline-item danger";
                                    break;
                                case 4:
                                    timelineClass = "timeline-item dark";
                                    break;
                                default:
                                    break;
                            }

                            if (log.UpdatedField != "TaskCompLogs" && log.UpdatedField != "ModifiedDate")
                            {
                                <div class="@timelineClass">
                                    <div class="timeline-badge primary"><i class="glyphicon glyphicon-record" rel="tooltip"></i></div>
                                    <div class="timeline-panel">
                                        <div class="timeline-heading">
                                            <h5>
                                                <p><small class="text-muted"><i class="glyphicon glyphicon-time"></i> @log.UpdatedAt?.ToString("dd-MM-yyyy HH:mm")</small></p>
                                                @* Renk kontrolü eklenebilir KONTROL*@
                                            </h5>
                                            <h6 class="timeline-title">@log.UpdatedField</h6>
                                        </div>
                                        <div class="timeline-body">
                                            <p>@log.OldValue <i class="fa fa-long-arrow-right"></i> @log.NewValue</p>
                                            <p>Düzenleyen: @log.UpdatedBy?.NameSurname</p>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    }
                    else
                    {
                        <p>Henüz bir değişiklik yapılmadı.</p>
                    }
                </div>
            </div>
        </div>
    </div>


</div>


<!-- core js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>

<!-- page js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>


