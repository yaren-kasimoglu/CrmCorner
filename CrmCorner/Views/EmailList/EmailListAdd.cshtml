@model CrmCorner.Models.EmailList

@{
    ViewData["Title"] = "EmailListAdd";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";

}


<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="stylesheet" href="assets/css/summernote.min.css" />

    <!-- MAIN CSS -->
    <link rel="stylesheet" href="assets/css/main.css">
</head>

<body>

    <div id="layout" class="theme-cyan">
        <div class="row">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-body">
                        <form asp-action="EmailListAdd" method="post">
                            <div class="mb-3">
                                <input asp-for="To" type="email" class="form-control" placeholder="To" required
                                       oninvalid="this.setCustomValidity('Lütfen geçerli bir mail adresi girin')"
                                       oninput="this.setCustomValidity('')">
                                <div class="invalid-feedback">
                                    Lütfen geçerli bir mail adresi girin.
                                </div>
                            </div>
                            <div class="mb-3">
                                <input asp-for="Subject" type="text" class="form-control" placeholder="Konu">
                            </div>
                            <div class="mb-3">
                                <input asp-for="CC" type="text" class="form-control" placeholder="CC">
                            </div>
                            <hr>
                            <div class="summernote">
                                <textarea asp-for="Body" class="form-control" rows="10" placeholder="Mail içeriğinizi buraya yazın..."></textarea>
                            </div>
                            <div class="mt-5">
                                <button type="submit" class="btn btn-success">Mail Gönder</button>
                                @*<button type="button" class="btn btn-secondary">Draft</button>
            <a href="app-inbox.html" class="btn btn-outline-secondary">Cancel</a>*@
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- core js file -->
    <script src="assets/bundles/libscripts.bundle.js"></script>

    <!-- page js file -->
    <script src="assets/bundles/mainscripts.bundle.js"></script>
</body>
</html>