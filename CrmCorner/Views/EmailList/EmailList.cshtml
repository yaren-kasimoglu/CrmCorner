
@inject IJsonHelper JsonHelper
@model IEnumerable<CrmCorner.Models.EmailList>

@{
    ViewData["Title"] = "EmailList";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";

}


<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=Edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

</head>

<body>
    <div class="row clearfix">
        <div class="col-lg-12">
            <div class="card">
                <div class="mobile-left">
                    <a class="btn btn-primary toggle-email-nav collapsed" data-bs-toggle="collapse" href="#email-nav" role="button"><span class="btn-label"><i class="la la-bars"></i></span>Menu</a>
                </div>
                <div class="mail-inbox d-flex">
                    <div class="mail-left collapse p-3" id="email-nav">
                        <div class="mail-compose mb-3">
                            <a href="/EmailList/EmailListAdd" class="btn btn-danger d-block" target="_self">
                                Mail Gönder
                            </a>
                        </div>
                        <div class="mail-side flex-column">
                            <ul class="nav flex-column">
                                <li class="active">
                                    <a href="@Url.Action("EmailList", "EmailList")">
                                        <i class="fa fa-envelope"></i> Gelen Kutusu
                                        <span class="badge bg-primary float-end"> @ViewBag.GetCount</span>
                                    </a>
                                </li>
                                <li class="active">
                                    <a href="@Url.Action("EmailListSend", "EmailList")">
                                        <i class="fa fa-envelope"></i> Gönderilen Kutusu
                                        <span class="badge bg-primary float-end">@ViewBag.SendCount</span>
                                    </a>
                                </li>
                            </ul>
                        </div>

                    </div>
                    <div class="mail-right">
                        <div class="p-2 p-sm-3 d-flex justify-content-between align-items-center">
                            <h6 class="card-title">
                                @(ViewBag.CheckedSend != null && (bool)ViewBag.CheckedSend ? "Gönderilen Kutusu" : "Gelen Kutusu")
                            </h6>
                            <form id="searchForm" method="get" action="@Url.Action("EmailList")" class="ms-auto">
                                <div class="input-group">
                                    <input type="text" class="form-control" name="searchTerm" placeholder="Search Mail" aria-label="Search Mail" aria-describedby="search-mail">
                                    <button class="btn btn-outline-secondary" type="submit">
                                        <i class="fa fa-search"></i>
                                    </button>
                                </div>
                            </form>
                        </div>

                        <div class="mail-action clearfix">
                            <div class="float-start mb-2">
                                <div class="form-check d-inline-block me-0 me-sm-3">
                                    <input class="form-check-input" type="checkbox" value="" id="flexCheckDefault6">
                                    <label class="form-check-label" for="flexCheckDefault6"></label>
                                </div>
                                <div class="btn-group" role="group" aria-label="Basic outlined example">
                                    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="location.reload();">
                                        <i class="fa fa-refresh"></i> Refresh
                                    </button>
                                </div>
                            </div>
                            @*<div class="float-end ms-auto">1-50/295
                                    <div class="pagination-email d-flex">
                                        <p>1-50/295</p>
                                        <div class="btn-group ms-2" role="group" aria-label="Basic outlined example">
                                            <button type="button" class="btn btn-outline-secondary btn-sm"><i class="fa fa-angle-left"></i></button>
                                            <button type="button" class="btn btn-outline-secondary btn-sm"><i class="fa fa-angle-right"></i></button>
                                        </div>
                                    </div>
                                </div>*@
                        </div>
                        <div class="mail-list">
                            <ul class="list-unstyled mb-0">
                                @if (Model != null)
                                {
                                    @foreach (var email in Model)
                                    {
                                        <li class="clearfix">
                                            <div class="mail-detail-left float-start">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" value="" id="flexCheckDefault @email.Id">
                                                    <label class="form-check-label" for="flexCheckDefault @email.Id"></label>
                                                </div>
                                                @*<a href="javascript:void(0);" class="mail-star active"><i class="fa fa-star"></i></a>*@
                                            </div>
                                            <div class="mail-detail-right float-start">
                                                <h6 class="sub">
                                                    <a href="javascript:void(0);" class="mail-detail-expand" data-id="@email.Id">
                                                        @(ViewBag.CheckedSend != null && (bool)ViewBag.CheckedSend ? email.To : email.From)
                                                    </a>
                                                    <span class="badge bg-secondary mb-0"></span>
                                                </h6>
                                                <p class="dep">
                                                    <span class="">@email.Subject</span>
                                                    @email.Body
                                                </p>
                                                <span class="time">@email.CreatedDate</span>
                                            </div>
                                            <div class="hover-action">
                                                @*<a class="btn btn-warning mr-2" href="javascript:void(0);"><i class="fa fa-archive"></i></a>*@
                                                <button type="button" class="btn btn-danger" title="Delete" onclick="deleteFunction('@email.Id')">
                                                    <i class="fa fa-trash-o"></i>
                                                </button>
                                            </div>
                                        </li>
                                    }
                                }
                            </ul>
                        </div>
                        <div class="mail-detail-full" id="mail-detail-open" style="display: none;">
                            <div class="mail-action clearfix">
                                <div class="float-start">
                                    <div class="d-inline-block">
                                        <a href="javascript:void(0);" class="mail-back btn btn-primary btn-sm"><i class="fa fa-arrow-left"></i>Back</a>
                                    </div>
                                    <div class="btn-group" role="group" aria-label="Basic outlined example">
                                        @*<button type="button" class="btn btn-outline-secondary btn-sm"><i class="fa fa-refresh"></i> Refresh </button>
                                            <button type="button" class="btn btn-outline-secondary btn-sm"><i class="fa fa-archive"></i> Archive </button>
                                            <button type="button" class="btn btn-outline-secondary btn-sm"><i class="fa fa-trash"></i> Trash </button>
                                            <div class="btn-group d-none d-md-inline-block" role="group">
                                                <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">Tags</button>
                                                <ul class="dropdown-menu dropdown-menu-end">
                                                    <li><a class="dropdown-item" href="#">Tags 1</a></li>
                                                    <li><a class="dropdown-item" href="#">Tags 2</a></li>
                                                    <li><a class="dropdown-item" href="#">Tags 3</a></li>
                                                </ul>
                                            </div>*@
                                        @*<div class="btn-group d-none d-md-inline-block" role="group">
                                                <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">More</button>
                                                <ul class="dropdown-menu dropdown-menu-end">
                                                    <li><a class="dropdown-item" href="#">Mark as read</a></li>
                                                    <li><a class="dropdown-item" href="#">Mark as unread</a></li>
                                                    <li><a class="dropdown-item" href="#">Spam</a></li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li><a class="dropdown-item" href="#">Delete</a></li>
                                                </ul>
                                            </div>*@
                                    </div>
                                </div>
                                @*<div class="float-end ms-auto">
                                        <a href="javascript:void(0);" class="btn btn-secondary btn-sm"><i class="fa fa-mail-forward"></i></a>
                                    </div>*@
                            </div>
                            <div class="detail-header"></div>
                            <div class="mail-cnt"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>



    @*<div class="modal fade" id="ModalDelete" tabindex="-1" aria-labelledby="ModalDelete" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-body text-center pt-4">
                        <i class="fa fa-warning fa-4x text-warning"></i>
                        <p class="fs-3 my-3">Are you sure?</p>
                        <p class="mb-4">You will not be able to recover this imaginary file!</p>
                        <div class="mb-3">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancle</button>
                            <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Yes, delete it!</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>*@

    <!-- core js file -->
    <!-- page js file -->
    <script>
        $(document).ready(function () {
            $(".mail-detail-expand").click(function () {
                $("#mail-detail-open").toggle();
            });
            $(".mail-back").click(function () {
                $("#mail-detail-open").toggle();
            });
         });
        function deleteFunction(emailId) {
            if (confirm('Mailinizi silmek istiyor musunuz?')) {
                $.ajax({
                    url: '/EmailList/EmailListDelete', // Controller adını değiştir
                    type: 'POST',
                    data: { id: emailId },
                    success: function (response) {
                        // Başarılı ise sayfayı güncelle veya mesaj göster
                        window.location.reload(); // Sayfayı yeniden yükle
                    },
                    error: function (xhr, status, error) {
                        // Hata durumunda kullanıcıya bilgi ver
                        alert("Silme işlemi sırasında bir hata oluştu.");
                    }
                });
            }
        }
         document.getElementById('searchForm').addEventListener('submit', function (event) {
        var searchTerm = this.elements['searchTerm'].value;
        // Eğer URL'de 'EmailListSend' varsa, action'ı güncelle
        if (window.location.href.includes('EmailListSend')) {
            this.action = '@Url.Action("EmailListSend")';
        } else {
            this.action = '@Url.Action("EmailList")';
        }
    });

    </script>
    <script>
$(document).ready(function () {
    $(".mail-detail-expand").click(function () {
        var emailId = $(this).data("id");
        $.ajax({
            url: '@Url.Action("GetEmailDetails", "EmailList")',
            type: 'GET',
            data: { id: emailId },
            success: function (data) {
                var from = data.message.from;
                var body = data.message.body;
                var createdDate = data.message.createdDate;
                var to = data.message.to;
                var cc = data.message.cc;
                const toOrFrom = @Html.Raw(Json.Serialize(ViewBag.CheckedSend));
                var toorfrom = toOrFrom ? to : "Ben";
                $("#mail-detail-open .detail-header").html(`
                    <div class="media d-flex mb-3">
                        <div class="float-start me-3">
                            <img class="rounded-3" src="../dist/assets/images/sm/avatar1.jpg" width="65" alt="">
                        </div>
                        <div class="media-body w-100">
                            <p class="mb-0">
                                <strong class="text-muted me-1">From:</strong>
                                <a class="text-default" href="javascript:void(0);">${from}</a>
                                <span class="text-muted text-sm float-end">${createdDate}</span>
                            </p>
                            <p class="mb-0">
                                    <strong class="text-muted me-1">To:</strong> ${toorfrom}
                            </p>
                            <p class="mb-0">
                                <strong class="text-muted me-1">CC:</strong>
                                <a class="text-default" href="javascript:void(0);">${cc}</a>
                            </p>
                        </div>
                    </div>
                `);

                $("#mail-detail-open .mail-cnt").html(`
                    <p>${body}</p>
                    <hr>
                `);

                $("#mail-detail-open").show();
            },
            error: function () {
                alert("Error loading email details.");
            }
        });
    });

    $(".mail-back").click(function () {
        $("#mail-detail-open").hide();
    });
 });
    </script>

</body>
</html>

<script src="/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>
