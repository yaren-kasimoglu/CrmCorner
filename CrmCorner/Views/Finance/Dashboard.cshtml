@model FinanceDashboardVm
@using System.Text.Json
@using System.Globalization

@{
    ViewData["Title"] = "Finans Dashboard";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
    var tr = CultureInfo.GetCultureInfo("tr-TR");

    string MonthName(int m) => new DateTime(2000, m, 1).ToString("MMMM", tr);
}

<style>
    /* Donutlar soldaki grafik yüksekliğini aşmasın */
    .donut-wrap {
        height: 210px; /* burada oynayabilirsin: 180-230 arası ideal */
        position: relative;
    }

        .donut-wrap canvas {
            width: 100% !important;
            height: 100% !important;
        }
</style>

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h3 class="mb-0">Finans Dashboard (@Model.Year)</h3>
        <small class="text-muted">Yıl ve ay seçerek özetleri görüntüleyebilirsin.</small>
    </div>

    <form method="get" asp-action="Dashboard" class="d-flex gap-2 align-items-center">
        <label class="mb-0 fw-semibold">Yıl:</label>
        <select name="year" class="form-select" style="max-width:140px;" onchange="this.form.submit()">
            @foreach (var y in Model.AvailableYears)
            {
                <option value="@y" selected="@(y == Model.Year ? "selected" : null)">@y</option>
            }
        </select>

        <label class="mb-0 fw-semibold">Ay:</label>
        <select name="month" class="form-select" style="max-width:170px;" onchange="this.form.submit()">
            @foreach (var m in Model.AvailableMonths)
            {
                <option value="@m" selected="@(m == Model.SelectedMonth ? "selected" : null)">
                    @MonthName(m)
                </option>
            }
        </select>
    </form>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted fw-semibold">Beklenen Net</div>

                <div class="d-flex justify-content-between mt-2">
                    <span class="text-muted">Yıl:</span>
                    <span class="fw-bold">@Model.TotalExpectedNet.ToString("N2", tr)</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted">@MonthName(Model.SelectedMonth):</span>
                    <span class="fw-bold">@Model.MonthExpectedNet.ToString("N2", tr)</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted fw-semibold">Ödenen</div>

                <div class="d-flex justify-content-between mt-2">
                    <span class="text-muted">Yıl:</span>
                    <span class="fw-bold">@Model.TotalPaid.ToString("N2", tr)</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted">@MonthName(Model.SelectedMonth):</span>
                    <span class="fw-bold">@Model.MonthPaid.ToString("N2", tr)</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted fw-semibold">Kalan</div>

                <div class="d-flex justify-content-between mt-2">
                    <span class="text-muted">Yıl:</span>
                    <span class="fw-bold">@Model.TotalRemaining.ToString("N2", tr)</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted">@MonthName(Model.SelectedMonth):</span>
                    <span class="fw-bold">@Model.MonthRemaining.ToString("N2", tr)</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="mb-3">Aylık Beklenen Net vs Ödenen (@Model.Year)</h5>
                <canvas id="monthlyBar" height="120"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h5 class="mb-3">Durum Dağılımı (Ay) (@MonthName(Model.SelectedMonth) - @Model.Year)</h5>
                <div class="donut-wrap">
                    <canvas id="statusDonutMonth"></canvas>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="mb-3">Durum Dağılımı (Yıl) (@Model.Year)</h5>
                <div class="donut-wrap">
                    <canvas id="statusDonutYear"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // BAR
    const labels = @Html.Raw(JsonSerializer.Serialize(Model.MonthLabels));
    const expected = @Html.Raw(JsonSerializer.Serialize(Model.MonthlyExpectedNet));
    const paid = @Html.Raw(JsonSerializer.Serialize(Model.MonthlyPaid));

    new Chart(document.getElementById('monthlyBar'), {
        type: 'bar',
        data: {
            labels,
            datasets: [
                { label: 'Beklenen Net', data: expected },
                { label: 'Ödenen', data: paid }
            ]
        },
        options: {
            responsive: true,
            plugins: { legend: { position: 'top' } },
            scales: { y: { beginAtZero: true } }
        }
    });

    // ✅ AY DONUT
    const statusLabelsMonth = @Html.Raw(JsonSerializer.Serialize(Model.StatusLabels));
    const statusCountsMonth = @Html.Raw(JsonSerializer.Serialize(Model.StatusCounts));

    new Chart(document.getElementById('statusDonutMonth'), {
        type: 'doughnut',
        data: {
            labels: statusLabelsMonth,
            datasets: [{ data: statusCountsMonth }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { position: 'bottom' } }
        }
    });

    // ✅ YIL DONUT
    const statusLabelsYear = @Html.Raw(JsonSerializer.Serialize(Model.YearStatusLabels));
    const statusCountsYear = @Html.Raw(JsonSerializer.Serialize(Model.YearStatusCounts));

    new Chart(document.getElementById('statusDonutYear'), {
        type: 'doughnut',
        data: {
            labels: statusLabelsYear,
            datasets: [{ data: statusCountsYear }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { position: 'bottom' } }
        }
    });
</script>
