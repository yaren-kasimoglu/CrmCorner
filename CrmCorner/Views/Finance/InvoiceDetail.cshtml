@model CrmCorner.Models.FinanceInvoice

@{
    ViewData["Title"] = "Fatura Detayı";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>@(Model.Contract?.CompanyName ?? "-") – Detay</h4>

    <a href="@Url.Action("Invoices", "Finance", new {
            year = Model.PeriodYear,
            month = Model.PeriodMonth
        })"
       class="btn btn-sm btn-outline-secondary">
        ← Faturalara Dön
    </a>
    <form method="post"
      action="@Url.Action("DeleteContract", "Finance")"
      onsubmit="return confirm('Bu firma/sözleşme ve tüm ay kayıtları + belgeler silinecek. Emin misiniz?');"
      class="mb-0">
    <input type="hidden" name="contractId" value="@Model.ContractId" />
    <input type="hidden" name="returnYear" value="@Model.PeriodYear" />
    <input type="hidden" name="returnMonth" value="@Model.PeriodMonth" />

    <button type="submit" class="btn btn-sm btn-outline-danger">
        <i class="bi bi-trash"></i> Firmayı Sil
    </button>
</form>

</div>

<div class="card">
    <div class="card-body">
        <div class="row g-3">

            <!-- ===================== -->
            <!-- ✅ CONTRACT (MASTER)   -->
            <!-- ===================== -->

            <div class="col-md-4">
                <label class="form-label">Firma</label>
                <input class="form-control inline-edit"
                       data-field="ContractCompanyName"
                       value="@(Model.Contract?.CompanyName ?? "")" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Satış Bedeli ($)</label>
                <input class="form-control inline-edit"
                       data-field="ContractSaleAmountUsd"
                       value="@(Model.Contract?.SaleAmountUsd?.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR")) ?? "")" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Hak Ediş ($)</label>
                <input class="form-control inline-edit"
                       data-field="ContractCommissionUsd"
                       value="@(Model.Contract?.CommissionUsd?.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR")) ?? "")" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Satış Kur (USD)</label>
                <input class="form-control inline-edit"
                       data-field="ContractUsdRateAtSale"
                       value="@(Model.Contract?.UsdRateAtSale?.ToString("N4", System.Globalization.CultureInfo.GetCultureInfo("tr-TR")) ?? "")" />
                <small class="text-muted">Opsiyonel</small>
            </div>

            <div class="col-md-4">
                <label class="form-label">Sözleşme Süresi (Ay)</label>
                <input class="form-control inline-edit"
                       data-field="ContractMonths"
                       value="@(Model.Contract?.ContractMonths?.ToString() ?? "")" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Sözleşme Başlangıç</label>
                <input type="date"
                       class="form-control inline-edit"
                       data-field="ContractStartDate"
                       value="@(Model.Contract?.ContractStartDate?.ToString("yyyy-MM-dd") ?? "")" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Sözleşme Bitiş</label>

                <input type="date"
                       class="form-control"
                       data-field="ContractEndDate"
                       readonly
                       value="@(Model.Contract?.ContractEndDate?.ToString("yyyy-MM-dd") ?? "")" />

                <small class="text-muted d-block" id="contractEndDateText">
                    @(Model.Contract?.ContractEndDate.HasValue == true
                        ? Model.Contract.ContractEndDate.Value.ToString("dd.MM.yyyy")
                        : "")
                </small>
            </div>

            <hr class="mt-3" />

            <!-- ===================== -->
            <!-- ✅ DOCUMENTS           -->
            <!-- ===================== -->

            <!-- ✅ CONTRACT DOCUMENTS -->
            <h6 class="mt-2">Sözleşme / Firma Belgeleri</h6>

            <form method="post"
                  enctype="multipart/form-data"
                  action="@Url.Action("UploadContractDocument", "Finance")"
                  class="mb-3">
                <input type="hidden" name="invoiceId" value="@Model.Id" />
                <input type="hidden" name="contractId" value="@Model.ContractId" />

                <div class="d-flex gap-2">
                    <input type="file" name="file" class="form-control" />
                    <button class="btn btn-sm btn-primary">Yükle</button>
                </div>
                <small class="text-muted d-block mt-1">
                    İpucu: “Abeille.ai &amp; SAAS Corner ... Sözleşmesi” formatındaki dosyalarda firma adı otomatik çekilir.
                </small>
            </form>

            @if (ViewBag.ContractDocuments != null && ((List<CrmCorner.Models.FinanceContractDocument>)ViewBag.ContractDocuments).Any())
            {
                <ul class="list-group mb-4">
                    @foreach (var doc in (List<CrmCorner.Models.FinanceContractDocument>)ViewBag.ContractDocuments)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>
                                <i class="bi bi-paperclip"></i>
                                @doc.FileName
                                <small class="text-muted ms-2">
                                    (@doc.UploadedAt.ToString("dd.MM.yyyy HH:mm"))
                                </small>
                            </span>

                            <div class="d-flex gap-2">
                                <a href="@doc.FilePath"
                                   target="_blank"
                                   class="btn btn-sm btn-outline-secondary">
                                    İndir
                                </a>

                                <form method="post"
                                      action="@Url.Action("DeleteContractDocument", "Finance")"
                                      onsubmit="return confirm('Bu belge silinecek. Emin misiniz?');">
                                    <input type="hidden" name="id" value="@doc.Id" />
                                    <input type="hidden" name="invoiceId" value="@Model.Id" />
                                    <button class="btn btn-sm btn-outline-danger">
                                        Sil
                                    </button>
                                </form>
                            </div>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted mb-4">Henüz sözleşme/firma belgesi eklenmedi.</p>
            }

            <!-- ✅ INVOICE DOCUMENTS -->
            <h6>Fatura / Ay Belgeleri</h6>

            <form method="post"
                  enctype="multipart/form-data"
                  action="@Url.Action("UploadInvoiceDocument", "Finance")"
                  class="mb-3">
                <input type="hidden" name="invoiceId" value="@Model.Id" />

                <div class="d-flex gap-2">
                    <input type="file" name="file" class="form-control" />
                    <button class="btn btn-sm btn-primary">Yükle</button>
                </div>
            </form>

            @if (ViewBag.InvoiceDocuments != null && ((List<CrmCorner.Models.FinanceInvoiceDocument>)ViewBag.InvoiceDocuments).Any())
            {
                <ul class="list-group">
                    @foreach (var doc in (List<CrmCorner.Models.FinanceInvoiceDocument>)ViewBag.InvoiceDocuments)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>
                                <i class="bi bi-paperclip"></i>
                                @doc.FileName
                                <small class="text-muted ms-2">
                                    (@doc.UploadedAt.ToString("dd.MM.yyyy HH:mm"))
                                </small>
                            </span>

                            <div class="d-flex gap-2">
                                <a href="@doc.FilePath"
                                   target="_blank"
                                   class="btn btn-sm btn-outline-secondary">
                                    İndir
                                </a>

                                <form method="post"
                                      action="@Url.Action("DeleteInvoiceDocument", "Finance")"
                                      onsubmit="return confirm('Bu belge silinecek. Emin misiniz?');">
                                    <input type="hidden" name="id" value="@doc.Id" />
                                    <button class="btn btn-sm btn-outline-danger">
                                        Sil
                                    </button>
                                </form>
                            </div>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">Henüz fatura/ay belgesi eklenmedi.</p>
            }

        </div>
    </div>
</div>

@section Scripts {
<script>
    document.querySelectorAll('.inline-edit').forEach(el => {
        if (el.type === 'date' || el.tagName.toLowerCase() === 'select') {
            el.addEventListener('change', saveField);
        } else {
            el.addEventListener('blur', saveField);
            el.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    saveField.call(this);
                }
            });
        }
    });

    function saveField() {
        const el = this;
        const field = el.dataset.field;
        const value = el.value;

        fetch('/Finance/UpdateField', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({
                id: '@Model.Id',
                field: field,
                value: value
            })
        })
        .then(r => r.ok ? r.json() : null)
        .then(data => {
            el.classList.add('border-success');
            setTimeout(() => el.classList.remove('border-success'), 400);

            // ✅ Contract EndDate güncelle (readonly input + text)
            if (data) {
                if (data.contractEndDate !== undefined) {
                    const endInput = document.querySelector('[data-field="ContractEndDate"]');
                    if (endInput) endInput.value = data.contractEndDate || "";

                    const endTextEl = document.getElementById('contractEndDateText');
                    if (endTextEl) endTextEl.innerText = data.contractEndDateText || "";
                }
            }
        })
        .catch(() => {
            el.classList.add('border-danger');
            setTimeout(() => el.classList.remove('border-danger'), 700);
        });
    }
</script>
}
