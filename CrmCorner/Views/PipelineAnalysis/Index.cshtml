@model CrmCorner.Controllers.PipelineAnalysisPageViewModel
@using CrmCorner.Extensions
@using CrmCorner.Models.Enums

@{
    ViewData["Title"] = "Pipeline Analizi";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";

    int usersCount = Model.Rows.Count;
    int totalAll = Model.Rows.Sum(r => r.Total);
    int wonAll = Model.Rows.Sum(r => r.OutcomeCounts.TryGetValue(OutcomeTypeSales.Won, out var w) ? w : 0);
    double winRateAll = totalAll == 0 ? 0 : (wonAll * 100.0 / totalAll);

    var stageTotals = Model.AllStages.ToDictionary(
        s => s,
        s => Model.Rows.Sum(r => r.StageCounts.TryGetValue(s, out var v) ? v : 0)
    );

    var outcomeTotals = Model.AllOutcomes.ToDictionary(
        o => o,
        o => Model.Rows.Sum(r => r.OutcomeCounts.TryGetValue(o, out var v) ? v : 0)
    );
}

<style>
    .sticky-top {
        position: sticky;
        top: 0;
        z-index: 1;
    }

    .table thead th,
    .table tfoot th {
        white-space: nowrap;
    }

    .table tbody td {
        white-space: nowrap;
    }

    .space-y-3 > * + * {
        margin-top: 1rem;
    }
</style>

<div class="space-y-3">

    <!-- === KPI Cards === -->
    <div class="row g-3">
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small">Toplam Görev</div>
                        <div class="h4 mb-0 fw-semibold">@totalAll</div>
                    </div>
                    <i class="fa fa-list text-secondary fs-4"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small">Kullanıcı Sayısı</div>
                        <div class="h4 mb-0 fw-semibold">@usersCount</div>
                    </div>
                    <i class="fa fa-users text-secondary fs-4"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted small">Genel Kazanma Oranı</div>
                            <div class="h4 mb-0 fw-semibold">@winRateAll.ToString("0.0")%</div>
                        </div>
                        <i class="fa fa-trophy text-success fs-4"></i>
                    </div>
                    <div class="progress mt-2" role="progressbar" aria-label="Genel kazanma oranı">
                        <div class="progress-bar bg-success" style="width:@winRateAll.ToString("0.0")%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- === STAGE TABLOSU === -->
    <div class="card border-0 shadow-sm mt-3">
        <div class="card-header bg-white fw-semibold">
            Aşamalar (Stage)
            <span class="text-muted small ms-2">(Her hücre: Adet ve %)</span>
        </div>

        <div class="card-body table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light sticky-top">
                    <tr>
                        <th style="min-width:220px;">Kullanıcı</th>
                        <th class="text-end">Toplam</th>
                        @foreach (var st in Model.AllStages)
                        {
                            <th class="text-end">@st.GetDisplayName()</th>
                        }
                        <th style="min-width:180px;">Dağılım</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var row in Model.Rows)
                    {
                        <tr>
                            <td>
                                <strong>@(string.IsNullOrWhiteSpace(row.NameSurname) ? row.UserName : row.NameSurname)</strong><br />
                                <small class="text-muted">@row.UserName</small>
                            </td>
                            <td class="text-end fw-bold">@row.Total</td>

                            @foreach (var st in Model.AllStages)
                            {
                                var count = row.StageCounts.TryGetValue(st, out var v) ? v : 0;
                                var pct = row.Total == 0 ? 0 : (count * 100.0 / row.Total);
                                <td class="text-end">
                                    @count <span class="text-muted small">(@pct.ToString("0.#")%)</span>
                                </td>
                            }

                            <td>
                                @{
                                    var pieces = new List<string>();
                                    double acc = 0;
                                    var total = row.Total == 0 ? 1 : row.Total;

                                    foreach (var st in Model.AllStages)
                                    {
                                        var count = row.StageCounts.TryGetValue(st, out var v) ? v : 0;
                                        if (count > 0)
                                        {
                                            var percent = (count * 100.0) / total;
                                            var idx = Array.IndexOf(Model.AllStages, st);
                                            var hue = (360.0 / Model.AllStages.Length) * idx;
                                            pieces.Add($"hsl({hue}deg 70% 55%) {acc:0.##}% {(acc + percent):0.##}%");
                                            acc += percent;
                                        }
                                    }

                                    // 🔹 Bar renkleri (5 farklı stage varsa 5 renk görünür)
                                    var bg = pieces.Count == 0 ? "#eee" : $"linear-gradient(to right, {string.Join(", ", pieces)})";
                                }


                                <div class="progress" style="height:10px;">
                                    <div class="progress-bar" style="width:100%;background:@bg"></div>
                                </div>


                                <!-- 🔍 DEBUG GÖSTERİMİ (GEÇİCİ) -->
                                <div class="small text-muted mt-1">
                                    @foreach (var st in Model.AllStages)
                                    {
                                        var count = row.StageCounts.TryGetValue(st, out var v) ? v : 0;
                                        if (count > 0)
                                        {
                                            @($"{st.GetDisplayName()}: {count} ")
                                        }
                                    }
                                </div>


                            </td>

                        </tr>
                    }
                </tbody>

                <tfoot class="table-light">
                    <tr>
                        <th>Genel Toplam</th>
                        <th class="text-end">@totalAll</th>
                        @foreach (var st in Model.AllStages)
                        {
                            var t = stageTotals[st];
                            var p = totalAll == 0 ? 0 : (t * 100.0 / totalAll);
                            <th class="text-end">@t <span class="text-muted small">(@p.ToString("0.#")%)</span></th>
                        }
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <!-- === OUTCOME TABLOSU === -->
    <div class="card border-0 shadow-sm mt-3">
        <div class="card-header bg-white fw-semibold">
            Sonuçlar (Outcome)
            <span class="text-muted small ms-2">(Kazanma oranı ayrıca gösterilir)</span>
        </div>

        <div class="card-body table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light sticky-top">
                    <tr>
                        <th style="min-width:220px;">Kullanıcı</th>
                        <th class="text-end">Toplam</th>
                        @foreach (var oc in Model.AllOutcomes)
                        {
                            <th class="text-end">@oc.GetDisplayName()</th>
                        }
                        <th class="text-end">Kazanma Oranı</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var row in Model.Rows)
                    {
                        var won = row.OutcomeCounts.TryGetValue(OutcomeTypeSales.Won, out var w) ? w : 0;
                        var winRate = row.Total == 0 ? 0 : (w * 100.0 / row.Total);

                        <tr>
                            <td>
                                <strong>@(string.IsNullOrWhiteSpace(row.NameSurname) ? row.UserName : row.NameSurname)</strong><br />
                                <small class="text-muted">@row.UserName</small>
                            </td>
                            <td class="text-end fw-bold">@row.Total</td>

                            @foreach (var oc in Model.AllOutcomes)
                            {
                                var count = row.OutcomeCounts.TryGetValue(oc, out var v) ? v : 0;
                                var pct = row.Total == 0 ? 0 : (count * 100.0 / row.Total);
                                <td class="text-end">
                                    @count <span class="text-muted small">(@pct.ToString("0.#")%)</span>
                                </td>
                            }

                            <td class="text-end">
                                <div class="d-inline-flex align-items-center gap-2" style="min-width:140px;">
                                    <span class="fw-semibold">@winRate.ToString("0.0")%</span>
                                    <div class="progress flex-fill" style="height:8px; background-color:#e9ecef;">
                                        <div class="progress-bar bg-success"
                                             style="width:@($"{winRate:0.##}%"); min-width:5px;">
                                        </div>
                                    </div>
                                </div>
                            </td>

                        </tr>
                    }
                </tbody>

                <tfoot class="table-light">
                    <tr>
                        <th>Genel Toplam</th>
                        <th class="text-end">@totalAll</th>
                        @foreach (var oc in Model.AllOutcomes)
                        {
                            var t = outcomeTotals[oc];
                            var p = totalAll == 0 ? 0 : (t * 100.0 / totalAll);
                            <th class="text-end">@t <span class="text-muted small">(@p.ToString("0.#")%)</span></th>
                        }
                        <th class="text-end">
                            <div class="d-inline-flex align-items-center gap-2" style="min-width:140px;">
                                <span class="fw-semibold">@winRateAll.ToString("0.0")%</span>
                                <div class="progress flex-fill" style="height:8px;">
                                    <div class="progress-bar bg-success" style="width:@winRateAll.ToString("0.0")%"></div>
                                </div>
                            </div>
                        </th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>


