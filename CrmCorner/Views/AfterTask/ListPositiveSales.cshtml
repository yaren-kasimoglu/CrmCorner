@model IEnumerable<CrmCorner.ViewModels.SaleDTO>
@{
    ViewData["Title"] = "ListPositiveSales";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

<div class="row clearfix">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Satış Bilgileri</th>
                                <th>İlk ödeme yapıldı mı?</th>
                                <th>Bir problem var mı, varsa nedir?</th>
                                <th>Devam etmeyi düşünüyorlar mı?</th>
                                <th>Trustpilot yorumu yapıldı mı?</th>
                                <th>Logolarını kullanabilir miyiz?</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sale in Model)
                            {
                                var jsonSale = Json.Serialize(sale);
                                <tr>
                                    <td>@sale.TaskCompTitle</td>
                                    <td>
                                        @if (sale.IsFirstPaymentMade)
                                        {
                                            <i class="fa fa-check"></i>
                                        }
                                        else
                                        {
                                            <i class="fa fa-close text-danger"></i>
                                        }
                                    </td>
                                    <td>
                                        @if (sale.IsThereAProblem)
                                        {
                                            <i class="fa fa-exclamation text-warning" title="@sale.ProblemDescription.Substring(0, 255)"></i>
                                        }
                                        else
                                        {
                                            <i class="fa fa-close text-danger"></i>
                                        }
                                    </td>
                                    <td>
                                        @if (sale.IsContinuationConsidered)
                                        {
                                            <i class="fa fa-check"></i>
                                        }
                                        else
                                        {
                                            <i class="fa fa-close text-danger"></i>
                                        }
                                    </td>
                                    <td>
                                        @if (sale.IsTrustpilotReviewed)
                                        {
                                            <i class="fa fa-check"></i>
                                        }
                                        else
                                        {
                                            <i class="fa fa-close text-danger"></i>
                                        }
                                    </td>
                                    <td>
                                        @if (sale.CanUseLogo)
                                        {
                                            <i class="fa fa-check"></i>
                                        }
                                        else
                                        {
                                            <i class="fa fa-close text-danger"></i>
                                        }
                                    </td>
                                    <td>
                                        <a href="/AfterTask/AfterTaskEdit/@sale.Id" target="_self">
                                            <button type="button" class="btn btn-sm btn-outline-secondary">
                                                <i class="fa fa-edit"></i>
                                            </button>
                                        </a>

                                        <button type="button" class="btn btn-sm btn-outline-secondary" data-toggle="modal" data-target="#detailModal" onclick='showDetails(@Html.Raw(jsonSale))'>
                                            Detay
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="detailModal" tabindex="-1" aria-labelledby="detailModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="detailModalLabel">Satış Detayları</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <!-- Dinamik içerik buraya yüklenecek -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Kapat</button>
            </div>
        </div>
    </div>
</div>

<!-- Bootstrap CSS -->
<link href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css" rel="stylesheet">

<!-- jQuery first, then Popper.js, then Bootstrap JS -->
<script src="https://code.jquery.com/jquery-3.3.1.slim.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.14.7/umd/popper.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/js/bootstrap.min.js"></script>

<!-- JavaScript -->
<script>
    function showDetails(sale) {
        console.log(sale);  // Bu satırı ekleyerek sale objesini konsola yazdırabilirsiniz
        var modalBody = document.querySelector('#detailModal .modal-body');
        modalBody.innerHTML = `
                <p>İlk ödeme yapıldı mı? ${sale.isFirstPaymentMade ? 'Evet' : 'Hayır'}</p>
                <p>Bir problem var mı? ${sale.isThereAProblem ? 'Evet' : 'Hayır'}</p>
                ${sale.isThereAProblem && sale.problemDescription ?
                '<div class="alert alert-warning" role="alert" title="' + sale.problemDescription.substring(0, 255) + '"><strong>Problem Açıklaması:</strong> ' + sale.problemDescription + '</div>' : ''}
                <p>Devam etmeyi düşünüyorlar mı? ${sale.isContinuationConsidered ? 'Evet' : 'Hayır'}</p>
                <p>Trustpilot yorumu yapıldı mı? ${sale.isTrustpilotReviewed ? 'Evet' : 'Hayır'}</p>
                ${sale.isTrustpilotReviewed && sale.trustPilotComment ?
                '<div class="alert alert-info" role="alert"><strong>Trustpilot Yorumu:</strong> ' + sale.trustPilotComment + '</div>' : ''}
                <p>Logolarını kullanabilir miyiz? ${sale.canUseLogo ? 'Evet' : 'Hayır'}</p>
            `;
    }
</script>

<!-- core js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>

<!-- page js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>