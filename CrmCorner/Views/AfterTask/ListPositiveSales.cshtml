@model IEnumerable<CrmCorner.ViewModels.SaleDTO>
@{
    ViewData["Title"] = "ListPositiveSales";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml"; // Tek Layout kullanıyoruz
}

<div class="row clearfix">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Satış Bilgileri</th>
                                <th>İlk ödeme yapıldı mı?</th>
                                <th>Bir problem var mı, varsa nedir?</th>
                                <th>Devam etmeyi düşünüyorlar mı?</th>
                                <th>Trustpilot yorumu yapıldı mı?</th>
                                <th>Logoları kullanabilir miyiz?</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sale in Model)
                            {
                                var jsonSale = Json.Serialize(sale);
                                <tr>
                                    <td>@sale.TaskCompTitle</td>
                                    <td>@Html.Raw(sale.IsFirstPaymentMade ? "<i class='fa fa-check'></i>" : "<i class='fa fa-close text-danger'></i>")</td>

                                    <td>
                                        @if (sale.IsThereAProblem)
                                        {
                                            var tooltipText = sale.ProblemDescription?.Length > 255 ? sale.ProblemDescription.Substring(0, 255) + "..." : sale.ProblemDescription;
                                            <a href="#" onclick='showProblemDescription("@tooltipText", "@sale.ProblemDescription")'>
                                                <i class="fa fa-exclamation text-warning" title="@tooltipText"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <i class="fa fa-close text-danger"></i>
                                        }
                                    </td>
                                    <td>@Html.Raw(sale.IsContinuationConsidered ? "<i class='fa fa-check'></i>" : "<i class='fa fa-close text-danger'></i>")</td>

                                    <td>
                                        @if (sale.IsTrustpilotReviewed)
                                        {
                                            var trustpilotTooltip = sale.TrustPilotComment?.Length > 255 ? sale.TrustPilotComment.Substring(0, 255) + "..." : sale.TrustPilotComment;
                                            <a href="#" onclick='showTrustpilotComment("@trustpilotTooltip", "@sale.TrustPilotComment")'>
                                                <i class="fa fa-check"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <i class="fa fa-close text-danger"></i>
                                        }
                                    </td>
                                    <td>@Html.Raw(sale.CanUseLogo ? "<i class='fa fa-check'></i>" : "<i class='fa fa-close text-danger'></i>")</td>

                                    <td>

                                   
                                            <button type="button" class="btn btn-sm btn-outline-secondary edit-btn"
                                                    data-id="@sale.Id"
                                                    data-firstpayment="@sale.IsFirstPaymentMade"
                                                    data-problem="@sale.IsThereAProblem"
                                                data-problem-description="@sale.ProblemDescription"
                                                    data-continuation="@sale.IsContinuationConsidered"
                                                    data-reviewed="@sale.IsTrustpilotReviewed"
                                                    data-comment="@sale.TrustPilotComment"
                                                    data-logo="@sale.CanUseLogo"
                                                    data-taskid="@sale.TaskCompId"
                                                    data-toggle="modal" data-target="#editModal">
                                                <i class="fa fa-edit"></i>
                                            </button>
                                          


                                        <a asp-controller="PipelineTask" asp-action="PipelineDetails" asp-route-id="@sale.TaskCompId">
                                            <button type="button" class="btn btn-sm btn-outline-secondary">
                                                <i class="fa fa-send"></i>
                                            </button>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-outline-secondary" data-toggle="modal" data-target="#detailModal" onclick='showDetails(@Html.Raw(jsonSale))'>
                                            Takibasyon Detay
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@* Modal Kodları burada kalacak (detail, problem, trustpilot) *@
@* @await Html.PartialAsync("_AfterTaskModalsPartial") *@

@* detay *@
<!-- Takip Detay Modalı -->
<div class="modal fade" id="detailModal" tabindex="-1" role="dialog" aria-labelledby="detailModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="detailModalLabel">Takip Detayı</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <div class="modal-body">
                <!-- JavaScript ile doldurulacak -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
            </div>
        </div>
    </div>
</div>


@* edit *@
<div class="modal fade" id="editModal" tabindex="-1" role="dialog" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form asp-controller="AfterTask" asp-action="AfterTaskEdit" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="editModalLabel">Takip Güncelle</h5>
                    <button type="button" class="btn-close" aria-label="Close" id="editModalClose"></button>
                    </button>
                </div>
                <div class="modal-body">

                    <!-- HIDDEN ID’LER -->
                    <input type="hidden" name="Id" id="editId" />
                    <input type="hidden" name="PipelineTaskId" id="editTaskId" />

                    <!-- ÖDEME -->
                    <div class="form-group">
                        <label>İlk Ödeme Yapıldı mı?</label>
                        <select class="form-control" name="IsFirstPaymentMade" id="editFirstPayment">
                            <option value="true">Evet</option>
                            <option value="false">Hayır</option>
                        </select>
                    </div>

                    <!-- PROBLEM -->
                    <div class="form-group">
                        <label>Bir Sorun Var mı?</label>
                        <select class="form-control" name="IsThereAProblem" id="editProblem">
                            <option value="true">Evet</option>
                            <option value="false">Hayır</option>
                        </select>
                    </div>
                    <div class="form-group" id="problemDescriptionGroup" style="display: none;">
                        <label>Problem Açıklaması</label>
                        <textarea class="form-control" name="ProblemDescription" id="editProblemDescription"></textarea>
                    </div>

                    <!-- DEVAM -->
                    <div class="form-group">
                        <label>Devam Ediyorlar mı?</label>
                        <select class="form-control" name="IsContinuationConsidered" id="editContinuation">
                            <option value="true">Evet</option>
                            <option value="false">Hayır</option>
                        </select>
                    </div>

                    <!-- TRUSTPILOT -->
                    <div class="form-group">
                        <label>Trustpilot Yorumu Yapıldı mı?</label>
                        <select class="form-control" name="IsTrustpilotReviewed" id="editReviewed">
                            <option value="true">Evet</option>
                            <option value="false">Hayır</option>
                        </select>
                    </div>
                    <div class="form-group" id="trustpilotCommentGroup" style="display: none;">
                        <label>Trustpilot Yorumu</label>
                        <textarea class="form-control" name="TrustPilotComment" id="editTrustpilotComment"></textarea>
                    </div>

                    <!-- LOGO -->
                    <div class="form-group">
                        <label>Logo Kullanılabilir mi?</label>
                        <select class="form-control" name="CanUseLogo" id="editLogo">
                            <option value="true">Evet</option>
                            <option value="false">Hayır</option>
                        </select>
                    </div>

                </div>
                @Html.AntiForgeryToken()
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                    <button type="button" class="btn btn-secondary" id="editCancelBtn">İptal</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>


<script>
function showDetails(sale) {
    const modalBody = document.querySelector('#detailModal .modal-body');

    modalBody.innerHTML = `
        <p><strong>İlk ödeme yapıldı mı?:</strong> ${sale.isFirstPaymentMade ? 'Evet' : 'Hayır'}</p>
        <p><strong>Bir problem var mı?:</strong> ${sale.isThereAProblem ? 'Evet' : 'Hayır'}</p>
        ${sale.isThereAProblem && sale.problemDescription ? 
            `<p><strong>Problem Açıklaması:</strong><br/>${sale.problemDescription}</p>` : ''
        }
        <p><strong>Devam etmeyi düşünüyorlar mı?:</strong> ${sale.isContinuationConsidered ? 'Evet' : 'Hayır'}</p>
        <p><strong>Trustpilot yorumu yapıldı mı?:</strong> ${sale.isTrustpilotReviewed ? 'Evet' : 'Hayır'}</p>
        ${sale.isTrustpilotReviewed && sale.trustPilotComment ? 
            `<p><strong>Trustpilot Yorumu:</strong><br/>${sale.trustPilotComment}</p>` : ''
        }
        <p><strong>Logo kullanım izni var mı?:</strong> ${sale.canUseLogo ? 'Evet' : 'Hayır'}</p>
    `;

    $('#detailModal').modal('show'); // Bootstrap 4 ise bu kalır
}


    //EDİT MODALI AYARLARI

    $(document).ready(function () {
        // ❌ Çarpı butonuna tıklanınca modal kapansın
        $('#editModalClose').on('click', function () {
            const modalEl = document.getElementById('editModal');
            const modal = bootstrap.Modal.getInstance(modalEl);
            modal.hide();
        });

        // ⛔ İptal butonuna tıklanınca modal kapansın
        $('#editCancelBtn').on('click', function () {
            const modalEl = document.getElementById('editModal');
            const modal = bootstrap.Modal.getInstance(modalEl);
            modal.hide();
        });
    });

     $(document).on("click", ".edit-btn", function () {
        const id = $(this).data("id");
        const taskId = $(this).data("taskid");
        const firstPayment = $(this).data("firstpayment");
        const problem = $(this).data("problem");
        const problemDescription = $(this).data("problem-description");
        const continuation = $(this).data("continuation");
        const reviewed = $(this).data("reviewed");
        const comment = $(this).data("comment");
        const logo = $(this).data("logo");

        $("#editId").val(id);
        $("#editTaskId").val(taskId);
        $("#editFirstPayment").val(firstPayment);
        $("#editProblem").val(problem);
        $("#editProblemDescription").val(problemDescription);
        $("#editContinuation").val(continuation);
        $("#editReviewed").val(reviewed);
        $("#editTrustpilotComment").val(comment);
        $("#editLogo").val(logo);

        // Problem varsa açıklama alanını göster
        if (problem === true || problem === "True") {
            $("#problemDescriptionGroup").show();
        } else {
            $("#problemDescriptionGroup").hide();
        }

        // Trustpilot yorumu varsa yorum alanını göster
        if (reviewed === true || reviewed === "True") {
            $("#trustpilotCommentGroup").show();
        } else {
            $("#trustpilotCommentGroup").hide();
        }

        // Modalı aç
        $("#editModal").modal("show");
    });

    // Problem seçimi değişince textarea göster/gizle
    $(document).on("change", "#editProblem", function () {
        const selected = $(this).val();
        if (selected === "true") {
            $("#problemDescriptionGroup").show();
        } else {
            $("#problemDescriptionGroup").hide();
        }
    });

    // Trustpilot seçimi değişince textarea göster/gizle
    $(document).on("change", "#editReviewed", function () {
        const selected = $(this).val();
        if (selected === "true") {
            $("#trustpilotCommentGroup").show();
        } else {
            $("#trustpilotCommentGroup").hide();
        }
    });

</script>
