@model IEnumerable<CrmCorner.ViewModels.SaleDTO>
@{
    ViewData["Title"] = "ListPositiveSales";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml"; // Tek Layout kullanıyoruz
}

<div class="row clearfix">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Satış Bilgileri</th>
                                <th>İlk ödeme yapıldı mı?</th>
                                <th>Bir problem var mı, varsa nedir?</th>
                                <th>Devam etmeyi düşünüyorlar mı?</th>
                                <th>Trustpilot yorumu yapıldı mı?</th>
                                <th>Logoları kullanabilir miyiz?</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sale in Model)
                            {
                                var jsonSale = Json.Serialize(sale);
                                <tr>
                                    <td>@sale.TaskCompTitle</td>
                                    <td>@(sale.IsFirstPaymentMade ? "<i class='fa fa-check'></i>" : "<i class='fa fa-close text-danger'></i>")</td>
                                    <td>
                                        @if (sale.IsThereAProblem)
                                        {
                                            var tooltipText = sale.ProblemDescription?.Length > 255 ? sale.ProblemDescription.Substring(0, 255) + "..." : sale.ProblemDescription;
                                            <a href="#" onclick='showProblemDescription("@tooltipText", "@sale.ProblemDescription")'>
                                                <i class="fa fa-exclamation text-warning" title="@tooltipText"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <i class="fa fa-close text-danger"></i>
                                        }
                                    </td>
                                    <td>@(sale.IsContinuationConsidered ? "<i class='fa fa-check'></i>" : "<i class='fa fa-close text-danger'></i>")</td>
                                    <td>
                                        @if (sale.IsTrustpilotReviewed)
                                        {
                                            var trustpilotTooltip = sale.TrustPilotComment?.Length > 255 ? sale.TrustPilotComment.Substring(0, 255) + "..." : sale.TrustPilotComment;
                                            <a href="#" onclick='showTrustpilotComment("@trustpilotTooltip", "@sale.TrustPilotComment")'>
                                                <i class="fa fa-check"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <i class="fa fa-close text-danger"></i>
                                        }
                                    </td>
                                    <td>@(sale.CanUseLogo ? "<i class='fa fa-check'></i>" : "<i class='fa fa-close text-danger'></i>")</td>
                                    <td>
                                        <a asp-controller="AfterTask" asp-action="AfterTaskEdit" asp-route-id="@sale.Id">
                                            <button type="button" class="btn btn-sm btn-outline-secondary">
                                                <i class="fa fa-edit"></i>
                                            </button>
                                        </a>
                                        <a asp-controller="Task" asp-action="TaskDetail" asp-route-id="@sale.TaskCompId">
                                            <button type="button" class="btn btn-sm btn-outline-secondary">
                                                <i class="fa fa-send"></i>
                                            </button>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-outline-secondary" data-toggle="modal" data-target="#detailModal" onclick='showDetails(@Html.Raw(jsonSale))'>
                                            Takibasyon Detay
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@* Modal Kodları burada kalacak (detail, problem, trustpilot) *@
@await Html.PartialAsync("_AfterTaskModalsPartial")

<script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>
<script>
    function showDetails(sale) {
        var modalBody = document.querySelector('#detailModal .modal-body');
        modalBody.innerHTML = `
            <p>İlk ödeme yapıldı mı? ${sale.isFirstPaymentMade ? 'Evet' : 'Hayır'}</p>
            <p>Bir problem var mı? ${sale.isThereAProblem ? 'Evet' : 'Hayır'}</p>
            ${sale.isThereAProblem && sale.problemDescription ?
                `<div class="alert alert-warning" role="alert"><strong>Problem:</strong> ${sale.problemDescription}</div>` : ''}
            <p>Devam etmeyi düşünüyorlar mı? ${sale.isContinuationConsidered ? 'Evet' : 'Hayır'}</p>
            <p>Trustpilot yorumu var mı? ${sale.isTrustpilotReviewed ? 'Evet' : 'Hayır'}</p>
            ${sale.isTrustpilotReviewed && sale.trustPilotComment ?
                `<div class="alert alert-info" role="alert"><strong>Trustpilot:</strong> ${sale.trustPilotComment}</div>` : ''}
            <p>Logo kullanım izni var mı? ${sale.canUseLogo ? 'Evet' : 'Hayır'}</p>
        `;
        $('#detailModal').modal('show');
    }

    function showProblemDescription(tooltip, fullDescription) {
        var modalBody = document.querySelector('#problemDescriptionModal .modal-body');
        modalBody.innerHTML = `<p>${fullDescription}</p>`;
        $('#problemDescriptionModal').modal('show');
    }

    function showTrustpilotComment(tooltip, fullComment) {
        var modalBody = document.querySelector('#trustpilotCommentModal .modal-body');
        modalBody.innerHTML = `<p>${fullComment}</p>`;
        $('#trustpilotCommentModal').modal('show');
    }
</script>
