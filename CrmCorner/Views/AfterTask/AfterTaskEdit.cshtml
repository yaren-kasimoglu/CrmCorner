@model CrmCorner.Models.PostSaleInfo

@{
    ViewData["Title"] = "Satış Sonrası Bilgi Düzenleme";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml"; // Tek bir layout kullanıyoruz ✅
}

<h2>Satış Sonrası Bilgi Düzenleme</h2>

@Html.ValidationSummary(true, "", new { @class = "text-danger" })

<form asp-action="AfterTaskEdit" method="post">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="TaskCompId" />

    <div class="form-group">
        <label asp-for="IsFirstPaymentMade" class="control-label">İlk Ödeme Yapıldı mı?</label>
        <div>
            <label><input type="radio" asp-for="IsFirstPaymentMade" value="true" /> Evet</label>
            <label><input type="radio" asp-for="IsFirstPaymentMade" value="false" /> Hayır</label>
        </div>
    </div>

    <div class="form-group">
        <label asp-for="IsThereAProblem" class="control-label">Bir Sorun Var mı?</label>
        <div>
            <label><input type="radio" asp-for="IsThereAProblem" value="true" /> Evet</label>
            <label><input type="radio" asp-for="IsThereAProblem" value="false" /> Hayır</label>
        </div>
    </div>

    <div class="form-group" id="problemDescriptionSection" style="display:none;">
        <label asp-for="ProblemDescription" class="control-label">Sorun Tanımı</label>
        <textarea asp-for="ProblemDescription" class="form-control"></textarea>
        <span asp-validation-for="ProblemDescription" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="IsContinuationConsidered" class="control-label">Devam Etmeyi Düşünüyorlar mı?</label>
        <div>
            <label><input type="radio" asp-for="IsContinuationConsidered" value="true" /> Evet</label>
            <label><input type="radio" asp-for="IsContinuationConsidered" value="false" /> Hayır</label>
        </div>
    </div>

    <div class="form-group">
        <label asp-for="IsTrustpilotReviewed" class="control-label">Trustpilot Yorumu Yapıldı mı?</label>
        <div>
            <label><input type="radio" asp-for="IsTrustpilotReviewed" value="true" /> Evet</label>
            <label><input type="radio" asp-for="IsTrustpilotReviewed" value="false" /> Hayır</label>
        </div>
    </div>

    <div class="form-group" id="trustPilotCommentSection" style="display:none;">
        <label asp-for="TrustPilotComment" class="control-label">Trustpilot Yorumu</label>
        <textarea asp-for="TrustPilotComment" class="form-control"></textarea>
        <span asp-validation-for="TrustPilotComment" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="CanUseLogo" class="control-label">Logo Kullanılabilir mi?</label>
        <div>
            <label><input type="radio" asp-for="CanUseLogo" value="true" /> Evet</label>
            <label><input type="radio" asp-for="CanUseLogo" value="false" /> Hayır</label>
        </div>
    </div>

    <div class="form-group mt-3">
        <input type="submit" value="Kaydet" class="btn btn-primary" />
        <a asp-action="ListPositiveSales" asp-controller="AfterTask" class="btn btn-secondary">İptal</a>
    </div>
</form>

@section Scripts {
    <script>
        function toggleProblemDescription(isVisible) {
            document.getElementById('problemDescriptionSection').style.display = isVisible ? 'block' : 'none';
        }

        function toggleTrustpilotComment(isVisible) {
            document.getElementById('trustPilotCommentSection').style.display = isVisible ? 'block' : 'none';
        }

        document.addEventListener('DOMContentLoaded', function () {
            toggleProblemDescription(@(Model.IsThereAProblem.ToString().ToLower()));
            toggleTrustpilotComment(@(Model.IsTrustpilotReviewed.ToString().ToLower()));

            document.querySelectorAll('input[name="IsThereAProblem"]').forEach(function (elem) {
                elem.addEventListener('change', function () {
                    toggleProblemDescription(this.value === 'true');
                });
            });

            document.querySelectorAll('input[name="IsTrustpilotReviewed"]').forEach(function (elem) {
                elem.addEventListener('change', function () {
                    toggleTrustpilotComment(this.value === 'true');
                });
            });
        });
    </script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
}

<script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>
