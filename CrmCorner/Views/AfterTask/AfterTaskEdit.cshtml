@model CrmCorner.Models.PostSaleInfo

@{
    ViewData["Title"] = "Satış Sonrası Bilgi Düzenleme";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

<h2>Satış Sonrası Bilgi Düzenleme</h2>
@Html.ValidationSummary(true, "", new { @class = "text-danger" })
<form asp-action="AfterTaskEdit" method="post">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="TaskCompId" />

    <div class="form-group">
        <label asp-for="IsFirstPaymentMade" class="control-label">İlk Ödeme Yapıldı mı?</label>
        <div>
            <label><input type="radio" asp-for="IsFirstPaymentMade" value="true" id="IsFirstPaymentMadeTrue" name="IsFirstPaymentMade" /> Evet</label>
            <label><input type="radio" asp-for="IsFirstPaymentMade" value="false" id="IsFirstPaymentMadeFalse" name="IsFirstPaymentMade" /> Hayır</label>
        </div>
    </div>

    <div class="form-group">
        <label asp-for="IsThereAProblem" class="control-label">Bir Sorun Var mı?</label>
        <div>
            <label><input type="radio" asp-for="IsThereAProblem" value="true" id="IsThereAProblemTrue" name="IsThereAProblem" onclick="toggleProblemDescription(true);" /> Evet</label>
            <label><input type="radio" asp-for="IsThereAProblem" value="false" id="IsThereAProblemFalse" name="IsThereAProblem" onclick="toggleProblemDescription(false);" /> Hayır</label>
        </div>
    </div>

    <div class="form-group" id="problemDescriptionSection" style="display:none;">
        <label asp-for="ProblemDescription" class="control-label">Sorun Tanımı</label>
        <textarea asp-for="ProblemDescription" class="form-control"></textarea>
        <span asp-validation-for="ProblemDescription" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="IsContinuationConsidered" class="control-label">Devam Etmeyi Düşünüyorlar mı?</label>
        <div>
            <label><input type="radio" asp-for="IsContinuationConsidered" value="true" id="IsContinuationConsideredTrue" name="IsContinuationConsidered" /> Evet</label>
            <label><input type="radio" asp-for="IsContinuationConsidered" value="false" id="IsContinuationConsideredFalse" name="IsContinuationConsidered" /> Hayır</label>
        </div>
    </div>

    <div class="form-group">
        <label asp-for="IsTrustpilotReviewed" class="control-label">Trustpilot Yorumu Yapıldı mı?</label>
        <div>
            <label><input type="radio" asp-for="IsTrustpilotReviewed" value="true" id="IsTrustpilotReviewedTrue" name="IsTrustpilotReviewed" onclick="toggleTrustpilotComment(true);" /> Evet</label>
            <label><input type="radio" asp-for="IsTrustpilotReviewed" value="false" id="IsTrustpilotReviewedFalse" name="IsTrustpilotReviewed" onclick="toggleTrustpilotComment(false);" /> Hayır</label>
        </div>
    </div>

    <div class="form-group" id="trustPilotCommentSection" style="display:none;">
        <label asp-for="TrustPilotComment" class="control-label">Trustpilot Yorumu</label>
        <textarea asp-for="TrustPilotComment" class="form-control"></textarea>
        <span asp-validation-for="TrustPilotComment" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="CanUseLogo" class="control-label">Logo Kullanılabilir mi?</label>
        <div>
            <label><input type="radio" asp-for="CanUseLogo" value="true" id="CanUseLogoTrue" name="CanUseLogo" /> Evet</label>
            <label><input type="radio" asp-for="CanUseLogo" value="false" id="CanUseLogoFalse" name="CanUseLogo" /> Hayır</label>
        </div>
    </div>

    <div class="form-group">
        <input type="submit" value="Kaydet" class="btn btn-primary" />
        <a asp-action="ListPositiveSales" asp-controller="AfterTask" class="btn btn-secondary">İptal</a>
    </div>
</form>

@section Scripts {
    <script>
        function toggleProblemDescription(isVisible) {
            var section = document.getElementById('problemDescriptionSection');
            section.style.display = isVisible ? 'block' : 'none';
        }

        function toggleTrustpilotComment(isVisible) {
            var section = document.getElementById('trustPilotCommentSection');
            section.style.display = isVisible ? 'block' : 'none';
        }

        document.addEventListener('DOMContentLoaded', function () {
            var isFirstPaymentMade = @Model.IsFirstPaymentMade.ToString().ToLower() === 'true';
            document.getElementById(isFirstPaymentMade ? 'IsFirstPaymentMadeTrue' : 'IsFirstPaymentMadeFalse').checked = true;

            var isThereAProblem = @Model.IsThereAProblem.ToString().ToLower() === 'true';
            document.getElementById(isThereAProblem ? 'IsThereAProblemTrue' : 'IsThereAProblemFalse').checked = true;
            toggleProblemDescription(isThereAProblem);

            var isContinuationConsidered = @Model.IsContinuationConsidered.ToString().ToLower() === 'true';
            document.getElementById(isContinuationConsidered ? 'IsContinuationConsideredTrue' : 'IsContinuationConsideredFalse').checked = true;

            var isTrustpilotReviewed = @Model.IsTrustpilotReviewed.ToString().ToLower() === 'true';
            document.getElementById(isTrustpilotReviewed ? 'IsTrustpilotReviewedTrue' : 'IsTrustpilotReviewedFalse').checked = true;
            toggleTrustpilotComment(isTrustpilotReviewed);

            var canUseLogo = @Model.CanUseLogo.ToString().ToLower() === 'true';
            document.getElementById(canUseLogo ? 'CanUseLogoTrue' : 'CanUseLogoFalse').checked = true;
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<!-- core js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>

<!-- page js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>
