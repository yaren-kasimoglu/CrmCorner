@{
    ViewData["Title"] = "Ödeme Başarısız";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<style>
    .result-page {
        min-height: 100vh;
        background: linear-gradient(180deg, #fff8f8 0%, #ffffff 100%);
        padding: 80px 0;
    }

    .result-card {
        max-width: 760px;
        margin: 0 auto;
        background: #fff;
        border-radius: 24px;
        border: 1px solid #f3d6d6;
        box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
        padding: 40px;
        text-align: center;
    }

    .result-icon {
        width: 72px;
        height: 72px;
        margin: 0 auto 20px auto;
        border-radius: 50%;
        background: #fee2e2;
        color: #991b1b;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 34px;
        font-weight: 800;
    }

    .result-title {
        font-size: 34px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 12px;
    }

    .result-text {
        font-size: 17px;
        color: #6b7280;
        line-height: 1.8;
        margin-bottom: 20px;
    }

    .error-box {
        background: #fff5f5;
        border: 1px solid #fecaca;
        color: #991b1b;
        border-radius: 14px;
        padding: 14px 18px;
        margin-bottom: 26px;
    }

    .result-actions {
        display: flex;
        gap: 14px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .result-btn {
        display: inline-block;
        padding: 14px 24px;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 700;
        transition: .3s ease;
    }

        .result-btn.primary {
            background: #0d6efd;
            color: #fff;
        }

            .result-btn.primary:hover {
                background: #0b5ed7;
                color: #fff;
            }

        .result-btn.secondary {
            background: #f3f4f6;
            color: #111827;
        }

            .result-btn.secondary:hover {
                background: #e5e7eb;
                color: #111827;
            }
</style>

<div class="result-page">
    <div class="container">
        <div class="result-card">
            <div class="result-icon">!</div>
            <h1 class="result-title">Ödeme Tamamlanamadı</h1>
            <p class="result-text">
                Ödeme işlemi sırasında bir sorun oluştu. Lütfen bilgilerinizi kontrol ederek tekrar deneyin.
            </p>

            @if (TempData["PaymentError"] != null)
            {
                <div class="error-box">
                    @TempData["PaymentError"]
                </div>
            }

            <div class="result-actions">
                <a href="/Home/Pricing" class="result-btn secondary">Paketlere Dön</a>
                <a href="/Home/Contact" class="result-btn primary">Destek Al</a>
            </div>
        </div>
    </div>
</div>