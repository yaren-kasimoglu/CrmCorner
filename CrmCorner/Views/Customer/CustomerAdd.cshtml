@model CrmCorner.Models.Customer
@{
    ViewData["Title"] = "CustomerAdd";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

<form asp-action="CustomerAdd" method="post">
    <div class="form-group">
        <label asp-for="Name" class="control-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Surname" class="control-label"></label>
        <input asp-for="Surname" class="form-control" />
        <span asp-validation-for="Surname" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Email" class="control-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Status" class="control-label"></label>
        <select asp-for="Status" asp-items="new SelectList(ViewBag.StatusList)" class="form-control"></select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>
        <div class="form-group">
        <label asp-for="IdEmployee" class="control-label">Responsible</label>
        @Html.DropDownListFor(m=>m.IdEmployee,(List<SelectListItem>) ViewBag.Employees,"Seçiniz",new {@class="form-select", aria_label="IdEmployee",@id="IdEmployee", @required="required"})
        <span asp-validation-for="IdEmployee" class="text-danger"></span>
    </div>
    <br />
    <div class="form-group">
        <input type="submit" value="Add Customer" class="btn btn-primary" />
    </div>
</form>

