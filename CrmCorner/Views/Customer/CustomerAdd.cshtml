@model CrmCorner.Models.CustomerN
@{
    ViewData["Title"] = "CustomerAdd";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}
<!-- Hataları göstermek için -->
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <ul>
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}


<div class="col-md-6 offset-md-0">
    <form asp-action="CustomerAdd" method="post">
        <div class="form-group">
            <label asp-for="Name" class="control-label">İsim</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Surname" class="control-label">Soyisim</label>
            <input asp-for="Surname" class="form-control" />
            <span asp-validation-for="Surname" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="CustomerEmail" class="control-label">Müşteri Email</label>
            <input asp-for="CustomerEmail" class="form-control" />
            <span asp-validation-for="CustomerEmail" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="CustomerTitle" class="control-label">Pozisyon</label>
            <input asp-for="CustomerTitle" class="form-control" />
            <span asp-validation-for="CustomerTitle" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="PhoneNumber" class="control-label">Telefon Numarası</label>
            <input asp-for="PhoneNumber" id="PhoneNumber" class="form-control" type="tel" placeholder="5__-___-____" />
            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
        </div>


        <div class="form-group">
            <label asp-for="CompanyName" class="control-label">Firma Adı</label>
            <input asp-for="CompanyName" class="form-control" />
            <span asp-validation-for="CompanyName" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="CompanyEmail" class="control-label">Firma Email</label>
            <input asp-for="CompanyEmail" class="form-control" />
            <span asp-validation-for="CompanyEmail" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="AppUserId" class="control-label">Sorumlu</label>
            @Html.DropDownListFor(m=>m.AppUserId,(List<SelectListItem>)  ViewBag.AppUsers,"Seçiniz",new {@class="form-select", aria_label="AppUserId",@id="AppUserId", @required="required"})
            <span asp-validation-for="AppUserId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Industry" class="control-label">Sektör</label>
            @Html.DropDownListFor(model => model.Industry, (IEnumerable<SelectListItem>)ViewBag.IndustryTypes, "Seçiniz", new { @class = "form-control" })
            <span asp-validation-for="Industry" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="EmployeeCount" class="control-label">Çalışan Sayısı</label>
            @Html.DropDownListFor(model => model.EmployeeCount,
            (IEnumerable<SelectListItem>)ViewBag.EmployeeCountSelectList,
            "Seçiniz",
            new { @class = "form-control" })
            <span asp-validation-for="EmployeeCount" class="text-danger"></span>
        </div>



        <br />
        <div class="form-group">
            <input type="submit" value="EKLE" class="btn btn-primary" />
        </div>
    </form>
</div>
<!-- core js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/libscripts.bundle.js"></script>

<!-- page js file -->
<script src="~/CRMTema/bootstrap5/dist/assets/bundles/mainscripts.bundle.js"></script>


<script>
    $(document).ready(function () {
        // Formun submit olayını yakala
        $("form").on("submit", function (e) {
            // Boş bırakılan nullable alanları topla
            var emptyFields = [];

            // Kontrol edilecek alanlar
            var nullableFields = [
                { name: "CustomerEmail", label: "Müşteri Email" },
                { name: "CustomerTitle", label: "Pozisyon" },
                { name: "PhoneNumber", label: "Telefon Numarası" },
                { name: "CompanyName", label: "Firma Adı" },
                { name: "CompanyEmail", label: "Firma Email" }
            ];

            // Boş alanları kontrol et
            nullableFields.forEach(function (field) {
                var value = $("#" + field.name).val(); // Alanın değerini al
                if (!value || value.trim() === "") { // Eğer boşsa listeye ekle
                    emptyFields.push(field.label);
                }
            });

            // Eğer boş alan varsa
            if (emptyFields.length > 0) {
                // Boş alanları kullanıcıya göster
                var message = "Aşağıdaki alanlar boş bırakılmış:\n\n" + emptyFields.join("\n") + "\n\nOnaylıyor musunuz?";

                // Kullanıcıya onay sor
                var confirmed = confirm(message);

                if (!confirmed) {
                    // Eğer kullanıcı onaylamazsa, formun gönderilmesini engelle
                    e.preventDefault();
                }
            }
        });
    });
</script>



@*TELEFON NUMARASI FORMATLAMAK İÇİN AŞAĞIDAKİ 2 CDN VE BİR SCRİPT YAZILMIŞTIR*@
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/inputmask/5.0.7/inputmask.min.js"></script>
<script>
    $(document).ready(function () {
        $("#PhoneNumber").inputmask("5\\99-999-9999", {
            "placeholder": "5__-___-____"
        });
    });
</script>