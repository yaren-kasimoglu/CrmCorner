@using CrmCorner.Extensions;
@model List<CustomerN>

@{
    ViewData["Title"] = "CustomerList";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

<a href="/Customer/CustomerAdd" target="_self">
    <input type="button" class="btn btn-success" value="Müşteri Ekle" />
</a>

<div>&nbsp;</div>

@if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        @ViewBag.ErrorMessage
    </div>
}

<table class="table table-bordered" id="customer_List">
    <thead>
        <tr>
            <th scope="col">Adı</th>
            <th scope="col">Soyadı</th>
            <th scope="col">Müşteri Email</th>
            <th scope="col">Pozisyon</th>
            <th scope="col">Telefon Numarası</th>
            <th scope="col">Firma Adı</th>
            <th scope="col">Firma Email</th>
            <th scope="col">Sektör</th>
            <th scope="col">Çalışan Sayısı</th>
            <th scope="col">Atanmış Kullanıcı</th>
            <th scope="col">İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Surname</td>
                <td>@item.CustomerEmail</td>
                <td>@item.CustomerTitle</td>
                <td>@item.PhoneNumber</td>
                <td>@item.CompanyName</td>
                <td>@item.CompanyEmail</td>
                <td>
                    @if (item.Industry != null)
                    {
                        <span class="badge bg-success">@item.Industry.GetDisplayName()</span>
                    }
                    else
                    {
                        <span class="text-danger">Bilinmiyor</span>
                    }
                </td>
                <td>
                    @if (item.EmployeeCount.HasValue)
                    {
                        @item.EmployeeCount.Value.GetDisplayName()
                    }
                    else
                    {
                        <span class="text-danger">Bilinmiyor</span>
                    }
                </td>
                <td>@(item.AppUser != null ? item.AppUser.UserName : "-")</td>
                <td>
                    <a href="/Customer/CustomerEdit/@item.Id" target="_self">
                        <button type="button" class="btn btn-sm btn-outline-secondary">
                            <i class="fa fa-edit"></i>
                        </button>
                    </a>

                    <button type="button"
                            class="btn btn-sm btn-outline-danger js-sweetalert"
                            data-customerid="@item.Id"
                            onclick="confirmDelete(this)">
                        <i class="fa fa-trash-o"></i>
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script src="~/CRMTema/bootstrap5/dist/assets/bundles/datatables.bundle.js"></script>

    <script>
        function confirmDelete(button) {
            if (confirm('Are you sure you want to delete this customer?')) {
                var customerId = button.getAttribute('data-customerid');
                var form = document.createElement('form');
                form.action = '/Customer/CustomerDelete/' + customerId;
                form.method = 'post';
                document.body.appendChild(form);
                form.submit();
            }
        }

        $(document).ready(function () {
            if ($.fn.DataTable) {
                $('#customer_List').DataTable({
                    responsive: true,
                    columnDefs: [
                        {
                            orderable: false,
                            targets: [10]
                        }
                    ]
                });
            } else {
                console.error('DataTables yüklenemedi.');
            }
        });
    </script>
}